<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="utf-8">
    <meta http-equiv="X-UA-Compatible" content="IE=edge">
    <meta name="viewport" content="width=device-width, initial-scale=1, shrink-to-fit=no">
    <meta name="description" content="Tableau de bord fournisseurs et règlements">
    <meta name="author" content="Confonda">
    <link href="vendor/fontawesome-free/css/all.min.css" rel="stylesheet" type="text/css">
    <link href="https://fonts.googleapis.com/css?family=Nunito:200,300,400,600,700,800,900" rel="stylesheet">
    <link href="css/sb-admin-2.min.css" rel="stylesheet">
    <style>
        :root {
            --primary-color: #3829ab;
            --second-color: #4232b6;
            --sidebar-width: 250px;
        }

        /* Sidebar styling */
        .sidebar {
            background: var(--second-color);
            position: sticky;
            top: 0;
            height: 100vh;
            overflow-y: auto;
            z-index: 1000;
            transition: transform 0.3s ease-in-out;
            width: var(--sidebar-width);
        }

        .navbar-nav .nav-item .nav-link {
            color: white;
            background: var(--primary-color);
            font-size: 15px;
            padding: 15px;
        }

        .nav-item {
            background: var(--second-color);
        }

        /* Main content styling */
        .content-wrapper {
            margin-left: 0;
            padding: 0px;
            transition: margin-left 0.3s ease-in-out;
        }

        /* Mobile sidebar styles */
        @media (max-width: 767.98px) {
            .sidebar {
                transform: translateX(-100%);
                position: fixed;
                top: 0;
                left: 0;
                width: var(--sidebar-width);
                z-index: 1100;
            }

            .sidebar.active {
                transform: translateX(0);
            }

            /* Style for mobile toggle button */
            .sidebar-toggle-btn {
                display: block;
                position: fixed;
                top: 15px;
                left: 15px;
                z-index: 1200;
                background: var(--second-color);
                color: white;
                border: none;
                border-radius: 50%;
                width: 40px;
                height: 40px;
                display: flex;
                align-items: center;
                justify-content: center;
                box-shadow: 0 4px 8px rgba(0, 0, 0, 0.2);
                transition: all 0.3s ease;
            }

            .sidebar-toggle-btn:hover {
                transform: scale(1.1);
                box-shadow: 0 6px 12px rgba(0, 0, 0, 0.3);
            }

            .content-wrapper {
                margin-left: 0;
            }
        }

        /* Desktop sidebar styles */
        @media (min-width: 768px) {
            .sidebar {
                transform: translateX(0);
                position: fixed;
                width: var(--sidebar-width);
                height: 100vh;
            }

            .sidebar-toggle-btn {
                display: none;
            }

            .content-wrapper {
                margin-left: var(--sidebar-width);
            }
        }

        /* Ensure sidebar content stays visible */
        .sidebar-brand, .nav-item {
            width: 100%;
        }
    </style>
</head>
<body id="page-top">
    <!-- Mobile Toggle Button -->
    <button class="sidebar-toggle-btn" id="mobileSidebarToggle">
        <i class="fas fa-bars"></i>
    </button>

    <!-- Sidebar -->
    <ul class="navbar-nav sidebar sidebar-dark accordion" id="accordionSidebar">
        <!-- Sidebar - Brand -->
        <a class="sidebar-brand d-flex align-items-center justify-content-center" href="/dashboard">
            <div class="sidebar-brand-icon rotate-n-15">
                <i class="fas fa-boxes"></i>
            </div>
            <div class="sidebar-brand-text mx-3">Confonda</div>
        </a>

        <!-- Divider -->
        <hr class="sidebar-divider my-0">

        <!-- Nav Item - Dashboard -->
     

        <!-- Divider -->
        <hr class="sidebar-divider">

        <!-- Nav Item - Payment Methods -->
        <% if (user && user.role === 'grandadmin' || user.role === 'admin') { %>
            <li class="nav-item">
                <a class="nav-link py-3" href="/tresorerie">
                    <i class="fas fa-fw fa-credit-card" style="font-size: 17px;"></i>
                    <span>Trésorerie</span>
                </a>
            </li>
            <hr class="sidebar-divider">
    
            <li class="nav-item">
                <a class="nav-link py-3" href="/achats">
                    <i class="fas fa-fw fa-shopping-cart" style="font-size: 17px;"></i>
                    <span>Achats</span>
                </a>
            </li>
    
            <hr class="sidebar-divider">
    
            <li class="nav-item">
                <a class="nav-link py-3" href="/ventes">
                    <i class="fas fa-fw fa-money-bill-alt" style="font-size: 17px;"></i>
                    <span>Ventes</span>
                </a>
            </li>
          <% } else if (user && user.role === 'user') { %>
            <li class="nav-item">
                <a class="nav-link py-3" href="/achats">
                    <i class="fas fa-fw fa-shopping-cart" style="font-size: 17px;"></i>
                    <span>Achats</span>
                </a>
            </li>
          <% } %>
        <hr class="sidebar-divider">

        <% if (user && user.role === 'grandadmin') { %>
        <li class="nav-item">
            <a class="nav-link py-3" href="/users">
                <i class="fas fa-fw fa-users" style="font-size: 17px;"></i>
                <span>Utilisateurs</span>
            </a>
        </li>
        <% } %>
       

        <!-- Divider -->

        <!-- Sidebar Toggler (Desktop) -->
        <!-- <div class="text-center d-none d-md-inline">
            <button class="rounded-circle border-0" id="sidebarToggle"></button>
        </div> -->
    </ul>
    <!-- End of Sidebar -->

    <!-- Main Content -->
    <div class="content-wrapper">
       
    </div>
    <!-- End of Main Content -->

    <!-- Scripts -->
    <script src="/vendor/jquery/jquery.min.js"></script>
    <script src="/vendor/bootstrap/js/bootstrap.bundle.min.js"></script>
    <script src="/vendor/jquery-easing/jquery.easing.min.js"></script>
    <script src="/js/sb-admin-2.min.js"></script>
    <script>
        $(document).ready(function () {
            // Ensure sidebar is closed by default on mobile
            if ($(window).width() < 768) {
                $('#accordionSidebar').removeClass('active');
            }

            // Toggle sidebar on mobile
            $('#mobileSidebarToggle').on('click', function (e) {
                e.preventDefault();
                $('#accordionSidebar').toggleClass('active');
                const icon = $(this).find('i');
                icon.toggleClass('fa-bars fa-times');
            });

            // Close sidebar when clicking outside on mobile
            $(document).on('click', function (e) {
                if ($(window).width() < 768) {
                    if (!$(e.target).closest('#accordionSidebar').length && !$(e.target).closest('#mobileSidebarToggle').length) {
                        $('#accordionSidebar').removeClass('active');
                        $('#mobileSidebarToggle').find('i').removeClass('fa-times').addClass('fa-bars');
                    }
                }
            });

            // Handle window resize to ensure sidebar state
            $(window).on('resize', function () {
                if ($(window).width() >= 768) {
                    $('#accordionSidebar').removeClass('active');
                    $('#mobileSidebarToggle').find('i').removeClass('fa-times').addClass('fa-bars');
                }
            });
        });
    </script>
</body>
</html>