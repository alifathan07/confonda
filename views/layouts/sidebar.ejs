<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="utf-8">
    <meta http-equiv="X-UA-Compatible" content="IE=edge">
    <meta name="viewport" content="width=device-width, initial-scale=1, shrink-to-fit=no">
    <meta name="description" content="Tableau de bord fournisseurs et règlements">
    <meta name="author" content="Confonda">
    <link href="/vendor/fontawesome-free/css/all.min.css" rel="stylesheet" type="text/css">
    <link href="https://fonts.googleapis.com/css?family=Nunito:200,300,400,600,700,800,900" rel="stylesheet">
    <link href="/css/sb-admin-2.min.css" rel="stylesheet">
    <style>
        :root {
            --primary-color: #3829ab;
            --second-color: #4232b6;
            --sidebar-text: rgba(255, 255, 255, 0.92);
            --sidebar-muted: rgba(255, 255, 255, 0.65);
            --sidebar-hover: rgba(255, 255, 255, 0.10);
            --sidebar-active: rgba(255, 255, 255, 0.16);
            --sidebar-width: 250px;
        }

        /* Sidebar styling */
        .sidebar {
            background: linear-gradient(180deg, #4b2fe0 0%, #3526a8 55%, #2a1f86 100%);
            position: sticky;
            top: 0;
            height: 100vh;
            overflow-y: auto;
            z-index: 1000;
            transition: transform 0.3s ease-in-out;
            width: var(--sidebar-width);
        }

        .sidebar {
            box-shadow: 10px 0 30px rgba(0, 0, 0, 0.18);
        }

        .sidebar::-webkit-scrollbar {
            width: 8px;
        }

        .sidebar::-webkit-scrollbar-thumb {
            background: rgba(255, 255, 255, 0.18);
            border-radius: 10px;
        }

        .sidebar::-webkit-scrollbar-thumb:hover {
            background: rgba(255, 255, 255, 0.26);
        }

        .sidebar-brand {
            padding: 18px 12px;
        }

        .sidebar-brand .sidebar-brand-icon {
            width: 44px;
            height: 44px;
            border-radius: 12px;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            background: rgba(255, 255, 255, 0.14);
            box-shadow: 0 8px 18px rgba(0, 0, 0, 0.18);
        }

        .sidebar-brand-text {
            letter-spacing: 0.4px;
            color: var(--sidebar-text);
        }

        .sidebar .sidebar-brand-text {
            font-weight: 800;
            text-transform: uppercase;
            font-size: 0.95rem;
        }

        .navbar-nav .nav-item {
            background: transparent;
        }

        .navbar-nav .nav-item .nav-link {
            color: var(--sidebar-text);
            background: transparent;
            font-size: 0.95rem;
            padding: 12px 14px;
            margin: 4px 10px;
            border-radius: 12px;
            display: flex;
            align-items: center;
            gap: 10px;
            transition: background 0.18s ease, transform 0.18s ease;
        }

        /* Prevent Bootstrap utility classes (ex: py-3) from breaking spacing */
        .navbar-nav .nav-item .nav-link.py-3 {
            padding-top: 12px !important;
            padding-bottom: 12px !important;
        }

        .navbar-nav .nav-item .nav-link i {
            width: 22px;
            text-align: center;
        }

        .navbar-nav .nav-item .nav-link i {
            opacity: 0.95;
        }

        .navbar-nav .nav-item .nav-link span {
            color: var(--sidebar-text);
            font-weight: 600;
        }

        .navbar-nav .nav-item .nav-link:hover {
            background: var(--sidebar-hover);
            transform: translateX(2px);
        }

        .navbar-nav .nav-item.active .nav-link,
        .navbar-nav .nav-item .nav-link[aria-current="page"] {
            background: var(--sidebar-active);
        }

        /* Main content styling */
        .content-wrapper {
            margin-left: 0;
            padding: 0px;
            transition: margin-left 0.3s ease-in-out;
        }

        .sidebar-divider {
            border-top: 1px solid rgba(255, 255, 255, 0.14);
            margin: 10px 14px;
        }

        .sidebar-divider.my-0 {
            margin-top: 6px !important;
            margin-bottom: 6px !important;
        }

        /* Mobile sidebar styles */
        @media (max-width: 767.98px) {
            .sidebar {
                transform: translateX(-100%);
            }

            .sidebar.active {
                transform: translateX(0);
            }

            /* Style for mobile toggle button */
            .sidebar-toggle-btn {
                display: block;
                position: fixed;
                top: 15px;
                left: 15px;
                z-index: 1200;
                background: rgba(26, 18, 86, 0.92);
                color: white;
                border: none;
                border-radius: 50%;
                width: 40px;
                height: 40px;
                display: flex;
                align-items: center;
                justify-content: center;
                box-shadow: 0 4px 8px rgba(0, 0, 0, 0.2);
                transition: all 0.3s ease;
            }

            .sidebar-toggle-btn:hover {
                transform: scale(1.1);
                box-shadow: 0 6px 12px rgba(0, 0, 0, 0.3);
            }

            .content-wrapper {
                margin-left: 0;
            }
        }

        /* Desktop sidebar styles */
        @media (min-width: 768px) {
            .sidebar {
                transform: translateX(0);
                position: fixed;
                width: var(--sidebar-width);
                height: 100vh;
            }

            .sidebar-toggle-btn {
                display: none;
            }

            .content-wrapper {
                margin-left: var(--sidebar-width);
            }
        }

        /* Ensure sidebar content stays visible */
        .sidebar-brand, .nav-item {
            width: 100%;
        }
    </style>
</head>
<body id="page-top">
    <!-- Mobile Toggle Button -->
    <button class="sidebar-toggle-btn" id="mobileSidebarToggle">
        <i class="fas fa-bars"></i>
    </button>

    <!-- Sidebar -->
   <!-- sidebar.ejs -->
<ul class="navbar-nav sidebar sidebar-dark accordion" id="accordionSidebar">

  <!-- Brand -->
  <a class="sidebar-brand d-flex align-items-center justify-content-center" href="/dashboard">
    <div class="sidebar-brand-icon">
      <i class="fas fa-boxes"></i>
    </div>
    <div class="sidebar-brand-text mx-3">Confonda</div>
  </a>

  <hr class="sidebar-divider my-0">

  <% if (user && (user.role === 'grandadmin' || user.role === 'admin' || user.role === 'developer')) { %>

    <!-- Section: Finance -->
    <div class="sidebar-heading">Finance</div>

    <li class="nav-item">
      <a class="nav-link" href="/tresorerie">
        <i class="fas fa-fw fa-credit-card"></i>
        <span>Trésorerie</span>
      </a>
    </li>

    <li class="nav-item">
      <a class="nav-link" href="/achats/caisse">
        <i class="fas fa-fw fa-cash-register"></i>
        <span>Caisse</span>
      </a>
    </li>

    <li class="nav-item">
      <a class="nav-link" href="/virementpay">
        <i class="fas fa-fw fa-hand-holding-usd"></i>
        <span>Virement Des Salaires</span>
      </a>
    </li>

    <hr class="sidebar-divider">

    <!-- Section: Achats -->
    <div class="sidebar-heading">Achats</div>

    <li class="nav-item">
      <a class="nav-link" href="/achats/fourniture">
        <i class="fas fa-fw fa-truck"></i>
        <span>Demande Fournitures</span>
      </a>
    </li>

    <li class="nav-item">
      <a class="nav-link" href="/achats">
        <i class="fas fa-fw fa-shopping-cart"></i>
        <span>Achats</span>
      </a>
    </li>

    <li class="nav-item">
      <a class="nav-link" href="/ventes">
        <i class="fas fa-fw fa-money-bill-alt"></i>
        <span>Ventes</span>
      </a>
    </li>

    <hr class="sidebar-divider">

    <!-- Section: Admin -->
    <div class="sidebar-heading">Administration</div>

    <li class="nav-item">
      <a class="nav-link" href="/settings">
        <i class="fas fa-fw fa-cog"></i>
        <span>Paramètres</span>
      </a>
    </li>

    <% if (user && (user.role === 'grandadmin' || user.role === 'developer')) { %>
    <li class="nav-item">
      <a class="nav-link" href="/users">
        <i class="fas fa-fw fa-users"></i>
        <span>Utilisateurs</span>
      </a>
    </li>
    <% } %>

    <% if (user && user.role === 'developer') { %>
    <li class="nav-item">
      <a class="nav-link" href="/popups">
        <i class="fas fa-fw fa-bullhorn"></i>
        <span>Gestion Popups</span>
      </a>
    </li>
    <% } %>

  <% } else if (user && (user.role === 'user' || user.role === 'granduser')) { %>

    <div class="sidebar-heading">Menu</div>

    <li class="nav-item">
      <a class="nav-link" href="/achats/caisse">
        <i class="fas fa-fw fa-cash-register"></i>
        <span>Caisse</span>
      </a>
    </li>

    <li class="nav-item">
      <a class="nav-link" href="/achats/fourniture">
        <i class="fas fa-fw fa-truck"></i>
        <span>Demande Fournitures</span>
      </a>
    </li>

  <% } %>
  <li class="nav-item">
            <a class="nav-link py-3" href="/bug-reports">
                <i class="fas fa-fw fa-bug" style="font-size: 17px;"></i>
                <span>Signaler un problème</span>
            </a>
        </li>

</ul>
    <!-- End of Sidebar -->

    <!-- Main Content -->
    <div class="content-wrapper">
       
    </div>
    <!-- End of Main Content -->

    <!-- Scripts -->
    <script src="/vendor/jquery/jquery.min.js"></script>
    <script src="/vendor/bootstrap/js/bootstrap.bundle.min.js"></script>
    <script src="/vendor/jquery-easing/jquery.easing.min.js"></script>
    <script src="/js/sb-admin-2.min.js"></script>
    <script>
        $(document).ready(function () {
            // Ensure sidebar is closed by default on mobile
            if ($(window).width() < 768) {
                $('#accordionSidebar').removeClass('active');
            }

            // Toggle sidebar on mobile
            $('#mobileSidebarToggle').on('click', function (e) {
                e.preventDefault();
                $('#accordionSidebar').toggleClass('active');
                const icon = $(this).find('i');
                icon.toggleClass('fa-bars fa-times');
            });

            // Close sidebar when clicking outside on mobile
            $(document).on('click', function (e) {
                if ($(window).width() < 768) {
                    if (!$(e.target).closest('#accordionSidebar').length && !$(e.target).closest('#mobileSidebarToggle').length) {
                        $('#accordionSidebar').removeClass('active');
                        $('#mobileSidebarToggle').find('i').removeClass('fa-times').addClass('fa-bars');
                    }
                }
            });

            // Handle window resize to ensure sidebar state
            $(window).on('resize', function () {
                if ($(window).width() >= 768) {
                    $('#accordionSidebar').removeClass('active');
                    $('#mobileSidebarToggle').find('i').removeClass('fa-times').addClass('fa-bars');
                }
            });
        });
    </script>
</body>
</html>


       