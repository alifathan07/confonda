<title>Dashboard</title>

<div id="wrapper">
  <%- include('../layouts/sidebar') %>

  <div id="content-wrapper" class="d-flex flex-column bg-light min-vh-100">
    <div id="content">
      <%- include('../layouts/topbar') %>

      <div class="container-fluid py-4">

        <!-- Dashboard Cards -->
        <div class="row g-4">
          <!-- Card 1: Achats -->
          <div class="col-xl-6 col-md-12">
            <a href="/achats" class="card dashboard-card shadow-sm border-0 bg-gradient-primary">
              <div class="card-body d-flex justify-content-between align-items-center">
                <div>
                  <h5 class="card-title text-white text-uppercase fw-bold mb-1">Achats</h5>
                  <p class="card-text text-white-50 mb-0">Voir les achats récents</p>
                </div>
                <div class="icon-box bg-white bg-opacity-10 text-white">
                  <i class="fas fa-shopping-cart fa-2x"></i>
                </div>
              </div>
            </a>
          </div>

          <!-- Card 2: Trésorerie -->
          <div class="col-xl-6 col-md-12">
            <a href="/tresorerie" class="card dashboard-card shadow-sm border-0 bg-gradient-success">
              <div class="card-body d-flex justify-content-between align-items-center">
                <div>
                  <h5 class="card-title text-white text-uppercase fw-bold mb-1">Trésorerie</h5>
                  <p class="card-text text-white-50 mb-0">Voir le solde actuel et les mouvements</p>
                </div>
                <div class="icon-box bg-white bg-opacity-10 text-white">
                  <i class="fas fa-coins fa-2x"></i>
                </div>
              </div>
            </a>
          </div>
        </div>

      </div>
    </div>

    <footer class="sticky-footer bg-white mt-auto">
      <div class="container my-auto">
        <div class="copyright text-center my-auto">
          <span>Copyright &copy; Confonda 2025</span>
        </div>
      </div>
    </footer>
  </div>
</div>

<a class="scroll-to-top rounded" href="#page-top">
  <i class="fas fa-angle-up"></i>
</a>

<!-- ================== CSS ================== -->
<style>
  .bg-gradient-primary {
    background: linear-gradient(135deg, #4e73df, #224abe);
  }

  .bg-gradient-success {
    background: linear-gradient(135deg, #1cc88a, #17a673);
  }

  .dashboard-card {
    border-radius: 1.5rem !important;
    transition: all 0.2s ease-in-out;
    min-height: 130px;
  }

  .dashboard-card:hover {
    transform: translateY(-6px) scale(1.02);
    box-shadow: 0 12px 30px rgba(0, 0, 0, 0.15);
  }

  .icon-box {
    width: 60px;
    height: 60px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .bg-opacity-10 {
    background-color: rgba(255, 255, 255, 0.1);
  }
</style>

<!-- ================== JS ================== -->
<script src="vendor/jquery/jquery.min.js"></script>
<script src="vendor/bootstrap/js/bootstrap.bundle.min.js"></script>
<script src="vendor/jquery-easing/jquery.easing.min.js"></script>
<script src="js/sb-admin-2.min.js"></script>
<script src="vendor/chart.js/Chart.min.js"></script>
<script src="js/demo/chart-area-demo.js"></script>
<script src="js/demo/chart-pie-demo.js"></script>
