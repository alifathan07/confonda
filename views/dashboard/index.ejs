<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta name="description" content="Modern financial dashboard">
  <title>Dashboard</title>
  <!-- Tailwind CSS CDN (v2.2.19 for stability) -->
  <link href="https://cdn.jsdelivr.net/npm/tailwindcss@2.2.19/dist/tailwind.min.css" rel="stylesheet">
  <!-- Font Awesome 6.4 for icons -->
  <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet">
  <!-- Google Fonts (Poppins) for modern typography -->
  <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;500;600;700&display=swap" rel="stylesheet">
  <!-- Custom CSS for refined styling and button visibility -->
  <style>
    body { font-family: 'Poppins', sans-serif; }
    .logo { transition: transform 0.2s; }
    .logo:hover { transform: scale(1.05); }
    .card { transition: transform 0.2s, box-shadow 0.2s; }
    .card:hover { transform: translateY(-4px); box-shadow: 0 8px 24px rgba(0, 0, 0, 0.1); }
    .action-btn { 
      display: inline-flex; 
      align-items: center; 
      opacity: 1 !important; 
      transition: background-color 0.2s, opacity 0.2s; 
    }
    .action-btn:hover { opacity: 0.9; }
    .chart-container { position: relative; height: 280px; }
    .table { border-collapse: separate; border-spacing: 0; }
    .table th, .table td { border-bottom: 1px solid #e5e7eb; }
    .table thead th { background: #e5e7eb; }
    /* Ensure text contrast meets WCAG 2.1 */
    .text-green-700, .text-red-700, .text-blue-700, .text-yellow-700 { font-weight: 600; }
  </style>
</head>
<body class="bg-gray-100 text-gray-800">
  <div id="wrapper" class="flex min-h-screen">
    <!-- Sidebar (unchanged to preserve your base layout) -->
    <%- include('../layouts/sidebar') %>

    <div id="content-wrapper" class="flex-1 flex flex-col bg-gray-50">
      <div class="flex flex-col justify-center items-center pt-16">
        <img class="logo h-20 w-20 mb-4" src="/img/logo-4.png" alt="Logo" style="height:300px; width:300px;"/>
        <h1 class="text-3xl font-bold text-center">Confonda</h1>
        <div class="flex justify-center mt-4">
          <a href="/tresorerie" class="mr-4 action-btn bg-green-700 hover:bg-green-800 text-white px-4 py-2 rounded">Tresorerie</a>
          <a href="/achats" class="mr-4 action-btn bg-blue-700 hover:bg-blue-800 text-white px-4 py-2 rounded">Achats</a>
          <a href="/ventes" class="action-btn bg-red-700 hover:bg-red-800 text-white px-4 py-2 rounded">Ventes</a>

        </div>
      </div>
      
    </div>
  </div>

  <!-- Chart.js 4.4.0 -->
  <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>

  <% if (typeof nouveauBugs !== 'undefined' && nouveauBugs && nouveauBugs.length > 0) { %>
    <% nouveauBugs.forEach(function(bug, index) { %>
      <div id="bugPopup<%= bug.id %>" class="fixed inset-0 bg-black bg-opacity-50 flex items-center justify-center z-50" style="display: flex;">
        <div class="bg-white rounded-lg shadow-xl p-6 max-w-lg w-full mx-4 transform transition-all border-l-4 border-red-500">
          <div class="text-center">
            <div class="mx-auto flex items-center justify-center h-12 w-12 rounded-full bg-red-100 mb-4">
              <i class="fas fa-bug text-red-600 text-xl"></i>
            </div>
            <h3 class="text-lg font-semibold text-gray-900 mb-2">🐛 Nouveau Bug Signalé</h3>
            <div class="text-left bg-gray-50 p-4 rounded-lg mb-4">
              <p class="text-sm text-gray-600 mb-2">
                <strong>Titre:</strong> <%= bug.title %>
              </p>
              <p class="text-sm text-gray-600 mb-2">
                <strong>Priorité:</strong> 
                <span class="badge badge-<%= bug.priority === 'critique' ? 'danger' : bug.priority === 'haute' ? 'warning' : 'info' %>">
                  <%= bug.priority %>
                </span>
              </p>
              <p class="text-sm text-gray-600 mb-2">
                <strong>Catégorie:</strong> <%= bug.category %>
              </p>
              <p class="text-sm text-gray-600 mb-2">
                <strong>Signalé par:</strong> <%= bug.userName || 'Anonyme' %>
              </p>
              <p class="text-sm text-gray-600 mb-2">
                <strong>Date:</strong> <%= new Date(bug.createdAt).toLocaleString('fr-FR') %>
              </p>
              <p class="text-sm text-gray-600" style="white-space: pre-wrap;">
                <strong>Description:</strong><br>
                <%= bug.description.substring(0, 200) %><%= bug.description.length > 200 ? '...' : '' %>
              </p>
            </div>
            <div class="flex flex-col space-y-2">
              <a href="/bug-reports/<%= bug.id %>/edit" class="inline-flex justify-center items-center px-4 py-2 border border-transparent text-sm font-medium rounded-md text-white bg-red-600 hover:bg-red-700 focus:outline-none focus:ring-2 focus:ring-offset-2">
                <i class="fas fa-wrench mr-2"></i>Traiter ce bug
              </a>
              <button onclick="dismissBugPopup(<%= bug.id %>)" class="inline-flex justify-center items-center px-4 py-2 border border-gray-300 text-sm font-medium rounded-md text-gray-700 bg-white hover:bg-gray-50 focus:outline-none focus:ring-2 focus:ring-offset-2">
                <i class="fas fa-eye-slash mr-2"></i>Masquer pour l'instant
              </button>
            </div>
          </div>
        </div>
      </div>
    <% }); %>

  <script>
    function dismissBugPopup(bugId) {
      const popup = document.getElementById('bugPopup' + bugId);
      if (popup) {
        popup.style.display = 'none';
      }
      // Notify server that user dismissed this bug notification
      fetch('/api/bug-reports/' + bugId + '/dismiss', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' }
      });
    }
  </script>
  <% } %>
 
</body>
</html>