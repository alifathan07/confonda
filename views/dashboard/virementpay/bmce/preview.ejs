<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8" />
  <meta http-equiv="X-UA-Compatible" content="IE=edge" />
  <meta name="viewport" content="width=device-width, initial-scale=1, shrink-to-fit=no" />
  <meta name="description" content="Virement Pay BMCE Preview" />
  <meta name="author" content="Confonda" />
  <title>Virement Pay - BMCE - Preview</title>
  <link href="/vendor/fontawesome-free/css/all.min.css" rel="stylesheet" type="text/css" />
  <link href="https://fonts.googleapis.com/css?family=Nunito:200,300,400,600,700,800,900" rel="stylesheet" />
  <link href="/css/sb-admin-2.min.css" rel="stylesheet" />
  <script src="https://cdn.tailwindcss.com"></script>
</head>

<body id="page-top">
  <div id="wrapper">
    <%- include('../../../layouts/sidebar') %>

    <div id="content-wrapper" class="d-flex flex-column">
      <div id="content">
        <%- include('../../../layouts/topbar') %>

        <div class="container-fluid">
          <div class="flex items-start justify-between mb-4">
            <div>
              <h1 class="h3 mb-1 text-gray-800">Aperçu du fichier</h1>
              <div class="text-sm text-gray-500">BMCE - 20 lignes par page</div>
            </div>
            <div class="flex gap-2">
              <a href="/virementpay/bmce" class="btn btn-light btn-sm">
                <i class="fas fa-arrow-left mr-1"></i>
                Retour
              </a>
              <a href="/virementpay/bmce/files/<%= file.id %>/download" class="btn btn-success btn-sm">
                <i class="fas fa-file-excel mr-1"></i>
                Télécharger format BMCE
              </a>
            </div>
          </div>

          <div class="bg-white rounded-xl shadow-sm border border-gray-100 p-4 mb-4">
            <div class="grid grid-cols-1 md:grid-cols-4 gap-3">
              <div>
                <div class="text-xs text-gray-500">Fichier</div>
                <div class="font-semibold text-gray-800 break-words"><%= file?.originalName || ('Fichier #' + file?.id) %></div>
              </div>
             
              <div>
                <div class="text-xs text-gray-500">Date Ordre</div>
                <div class="font-semibold text-gray-800"><%= file?.payrollDate || '-' %></div>
              </div>
              
              <div>
                <div class="text-xs text-gray-500">Raison Sociale</div>
                <div class="font-semibold text-gray-800"><%= file?.companyName  %></div>
              </div>
              <div>
                <div class="text-xs text-gray-500">RIB </div>
                <div class="font-semibold text-gray-800"><%= file?.companyRib  %></div>
              </div>
              <div>
                <div class="text-xs text-gray-500"> LIBELLE OPERATIONS  </div>
                <div class="font-semibold text-gray-800"><%= file?.obs  %></div>
              </div>
              <div>
                <div class="text-xs text-gray-500">Montant Total (page)</div>
                <div class="font-semibold text-gray-800"><%= typeof file?.montantTotalPage === 'number' ? file.montantTotalPage.toFixed(2) : (file?.montantTotalPage || '0.00') %></div>
              </div>
              

              
              <div>
                <div class="text-xs text-gray-500">Total Opérations (page)</div>
                <div class="font-semibold text-gray-800"><%= typeof file?.totalOperationsPage === 'number' ? file.totalOperationsPage : '-' %></div>
              </div>

              <div>
                <div class="text-xs text-gray-500">Montant Total (global)</div>
                <div class="font-semibold text-gray-800"><%= typeof file?.montantTotalGlobal === 'number' ? file.montantTotalGlobal.toFixed(2) : (file?.montantTotalGlobal || '0.00') %></div>
              </div>

              <div>
                <div class="text-xs text-gray-500">Total Opérations (global)</div>
                <div class="font-semibold text-gray-800"><%= typeof file?.totalOperationsGlobal === 'number' ? file.totalOperationsGlobal : (typeof file?.totalRows === 'number' ? file.totalRows : '-') %></div>
              </div>
            </div>
          </div>

          <div class="bg-white rounded-xl shadow-sm border border-gray-100 p-4">
            <% const hdrs = (typeof headers !== 'undefined' && Array.isArray(headers)) ? headers : []; %>
            <% const rows = (typeof items !== 'undefined' && Array.isArray(items)) ? items : []; %>
            <% const p = pagination || { page: 1, pageSize: 20, totalItems: rows.length, totalPages: 1 }; %>

            <div class="flex items-center justify-between mb-3">
              <div class="font-semibold text-gray-800">Données importées</div>
              <div class="text-xs text-gray-500">Page <%= p.page %> / <%= p.totalPages %></div>
            </div>

            <% if (rows.length === 0) { %>
              <div class="border border-dashed border-gray-200 rounded-xl p-6 text-center">
                <div class="text-gray-700 font-medium mb-1">Aucune ligne à afficher</div>
                <div class="text-sm text-gray-500">Le fichier est vide ou aucune donnée n’a été détectée.</div>
              </div>
            <% } else { %>
              <div class="table-responsive">
                <table class="table table-bordered mb-0" width="100%" cellspacing="0">
                  <thead class="bg-gray-50">
                    <tr>
                      <th style="width: 70px;">#</th>
                      <% hdrs.forEach((h) => { %>
                        <th><%= h %></th>
                      <% }) %>
                    </tr>
                  </thead>
                  <tbody>
                    <% const startIndex = (p.page - 1) * p.pageSize; %>
                    <% rows.forEach((r, idx) => { %>
                      <tr>
                        <td class="text-gray-600"><%= startIndex + idx + 1 %></td>
                        <% (Array.isArray(r) ? r : []).forEach((cell) => { %>
                          <td class="text-gray-800"><%= cell %></td>
                        <% }) %>
                      </tr>
                    <% }) %>
                  </tbody>
                </table>
              </div>

              <div class="flex flex-col md:flex-row items-center justify-between gap-3 mt-4">
                <div class="text-sm text-gray-600">
                  <span class="font-medium"><%= p.totalItems %></span> lignes
                </div>

                <nav aria-label="Pagination">
                  <ul class="pagination mb-0">
                    <% const prevDisabled = p.page <= 1; %>
                    <% const nextDisabled = p.page >= p.totalPages; %>
                    <li class="page-item <%= prevDisabled ? 'disabled' : '' %>">
                      <a class="page-link" href="/virementpay/bmce/files/<%= file.id %>?page=<%= Math.max(p.page - 1, 1) %>">Précédent</a>
                    </li>

                    <% const windowSize = 2; %>
                    <% const startPage = Math.max(1, p.page - windowSize); %>
                    <% const endPage = Math.min(p.totalPages, p.page + windowSize); %>

                    <% if (startPage > 1) { %>
                      <li class="page-item">
                        <a class="page-link" href="/virementpay/bmce/files/<%= file.id %>?page=1">1</a>
                      </li>
                      <% if (startPage > 2) { %>
                        <li class="page-item disabled"><span class="page-link">...</span></li>
                      <% } %>
                    <% } %>

                    <% for (let i = startPage; i <= endPage; i++) { %>
                      <li class="page-item <%= i === p.page ? 'active' : '' %>">
                        <a class="page-link" href="/virementpay/bmce/files/<%= file.id %>?page=<%= i %>"><%= i %></a>
                      </li>
                    <% } %>

                    <% if (endPage < p.totalPages) { %>
                      <% if (endPage < p.totalPages - 1) { %>
                        <li class="page-item disabled"><span class="page-link">...</span></li>
                      <% } %>
                      <li class="page-item">
                        <a class="page-link" href="/virementpay/bmce/files/<%= file.id %>?page=<%= p.totalPages %>"><%= p.totalPages %></a>
                      </li>
                    <% } %>

                    <li class="page-item <%= nextDisabled ? 'disabled' : '' %>">
                      <a class="page-link" href="/virementpay/bmce/files/<%= file.id %>?page=<%= Math.min(p.page + 1, p.totalPages) %>">Suivant</a>
                    </li>
                  </ul>
                </nav>
              </div>
            <% } %>
          </div>
        </div>
      </div>
    </div>
  </div>

  <script src="/vendor/jquery/jquery.min.js"></script>
  <script src="/vendor/bootstrap/js/bootstrap.bundle.min.js"></script>
  <script src="/vendor/jquery-easing/jquery.easing.m7in.js"></script>
  <script src="/js/sb-admin-2.min.js"></script>
</body>

</html>
