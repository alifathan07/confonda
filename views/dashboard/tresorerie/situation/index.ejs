function downloadPayavenirsPDF() {
  const loadingMsg = document.createElement('div');
  loadingMsg.innerHTML = '<div class="alert alert-info" style="position: fixed; top: 20px; right: 20px; z-index: 1000;">Génération du PDF paiements à venir...</div>';
  document.body.appendChild(loadingMsg);

  const script = document.createElement('script');
  script.src = 'https://cdnjs.cloudflare.com/ajax/libs/jspdf/2.5.1/jspdf.umd.min.js';
  script.onload = function () {
    try {
      const { jsPDF } = window.jspdf;
      const pdf = new jsPDF('p', 'mm', 'a4'); // Portrait

      // Helpers
      function parseFrenchNumber(text) {
        if (!text) return 0;
        return parseFloat(text.replace(/\s/g, '').replace(',', '.')) || 0;
      }
      function formatFrenchNumber(value) {
        if (isNaN(value)) return '0,00';
        return value
          .toFixed(2)
          .replace(/\B(?=(\d{3})+(?!\d))/g, ' ')
          .replace('.', ',');
      }

      // Title
      pdf.setFontSize(16);
      pdf.setTextColor(0, 102, 204);
      pdf.text("Paiements à venir", 15, 20);

      // Date
      pdf.setFontSize(10);
      pdf.setTextColor(0, 0, 0);
      const now = new Date();
      pdf.text("Date: " + now.toLocaleDateString('fr-FR'), 15, 28);

      // Collect data
      const visiblePayavenirs = [];
      let totalAmount = 0;
      document.querySelectorAll('.payavenir-row').forEach(row => {
        if (row.style.display !== 'none') {
          const cells = row.querySelectorAll('td');
          if (cells.length >= 7) {
            const montantValue = parseFrenchNumber(cells[3].textContent.trim());
            totalAmount += montantValue;
            visiblePayavenirs.push([
              cells[0].textContent.trim(), // Désignation
              cells[1].textContent.trim(), // Banque
              cells[2].textContent.trim(), // Bénéficiaire
              formatFrenchNumber(montantValue), // Montant
              cells[4].textContent.trim(), // Date Échéance
              cells[5].textContent.trim()  // Statut
              // Validation is ignored (checkbox)
            ]);
          }
        }
      });

      // Table headers
      const headers = ['Désignation', 'Banque', 'Bénéficiaire', 'Montant', 'Date Échéance', 'Statut'];
      const columnWidths = [35, 30, 40, 25, 30, 25];
      const startX = 15;
      const cellHeight = 8;
      let yPosition = 40;

      // Headers
      pdf.setFontSize(8).setFont(undefined, 'bold').setTextColor(255, 255, 255);
      let currentX = startX;
      headers.forEach((header, i) => {
        pdf.setFillColor(0, 102, 204);
        pdf.rect(currentX, yPosition, columnWidths[i], cellHeight, 'F');
        pdf.text(header, currentX + 1, yPosition + 5);
        currentX += columnWidths[i];
      });
      yPosition += cellHeight;

      // Rows
      pdf.setFontSize(7).setFont(undefined, 'normal').setTextColor(0, 0, 0);
      visiblePayavenirs.forEach(row => {
        if (yPosition > 270) { // page break
          pdf.addPage();
          yPosition = 20;

          // redraw headers
          currentX = startX;
          pdf.setFont(undefined, 'bold').setTextColor(255, 255, 255);
          headers.forEach((header, i) => {
            pdf.setFillColor(0, 102, 204);
            pdf.rect(currentX, yPosition, columnWidths[i], cellHeight, 'F');
            pdf.text(header, currentX + 1, yPosition + 5);
            currentX += columnWidths[i];
          });
          yPosition += cellHeight;
          pdf.setFont(undefined, 'normal').setTextColor(0, 0, 0);
        }

        currentX = startX;
        row.forEach((cell, i) => {
          const text = cell.toString();
          const displayText = text.length > 20 ? text.substring(0, 20) + '...' : text;
          pdf.rect(currentX, yPosition, columnWidths[i], cellHeight);
          pdf.text(displayText, currentX + 1, yPosition + 5);
          currentX += columnWidths[i];
        });
        yPosition += cellHeight;
      });

      // Total
      yPosition += 10;
      pdf.setFont(undefined, 'bold').setFontSize(10);
      pdf.text(`Total: ${formatFrenchNumber(totalAmount)}`, startX, yPosition);

      // Summary
      yPosition += 8;
      pdf.setFont(undefined, 'normal').setFontSize(8);
      pdf.text(`Nombre de paiements à venir: ${visiblePayavenirs.length}`, startX, yPosition);

      pdf.save(`paiements-a-venir-${now.toISOString().split('T')[0]}.pdf`);
      document.body.removeChild(loadingMsg);
    } catch (error) {
      console.error("Erreur PDF:", error);
      document.body.removeChild(loadingMsg);
      alert("Erreur lors de la génération du PDF des paiements à venir");
    }
  };
  document.head.appendChild(script);
}

