<script>

// show / hide tables of validation 
const toggleBtn = document.getElementById("toggleTablesBtn");
  const toggleIcon = document.getElementById("toggleIcon");
  const toggleText = document.getElementById("toggleText");
  const tablesContainer = document.getElementById("tables-container");

  toggleBtn.addEventListener("click", () => {
    const isHidden = tablesContainer.classList.contains("hidden");

    tablesContainer.classList.toggle("hidden");
    toggleIcon.classList.toggle("fa-eye-slash", !isHidden);
    toggleIcon.classList.toggle("fa-eye", isHidden);
    toggleText.textContent = isHidden ? "Afficher" : "Masquer";
  });
  document.addEventListener('DOMContentLoaded', () => {
  const getNumber = id => parseFloat(document.getElementById(id)?.textContent.replace(/\s/g, '').replace(',', '.') || 0);
  const chequetotal = document.querySelector('.chequetotal')
  const effettotal = document.querySelector('.effettotal')
  const paytotal = document.querySelector('.paytotal')
  const grandTotal = parseFloat(chequetotal.textContent.replace(/\s/g, '').replace(',', '.')) + parseFloat(effettotal.textContent.replace(/\s/g, '').replace(',', '.')) + parseFloat(paytotal.textContent.replace(/\s/g, '').replace(',', '.'));
  document.getElementById('grandTotalValide').textContent = grandTotal.toLocaleString('fr-FR', { minimumFractionDigits: 2, maximumFractionDigits: 2 }).replace(/\u202F/g, ' ') + ' dirhams';
});

document.addEventListener('DOMContentLoaded', function() {
  // Get filter elements
  const statutFilter = document.getElementById('statutFilterCheques');
  const fournisseurFilter = document.getElementById('fournisseurFilterCheques');
  const banqueFilter = document.getElementById('banqueFilterCheques');
  const dateFromFilter = document.getElementById('dateFilter');   // start date
  const dateToFilter = document.getElementById('dateToFilter');   // end date
  const resetButton = document.getElementById('resetFilters') || document.getElementById('resetDateBtn');

  // Tables
  const chequesTable = document.getElementById('chequesTable');
  const effetsTable = document.getElementById('effetsTable');
  const payavenirsTable = document.getElementById('payavenirsTable');

  const chequesRows = chequesTable ? chequesTable.querySelectorAll('tbody tr.cheque-row') : [];
  const effetsRows = effetsTable ? effetsTable.querySelectorAll('tbody tr.effet-row') : [];
  const payavenirRows = payavenirsTable ? payavenirsTable.querySelectorAll('tbody tr.payavenir-row') : [];

  // Totals
  const totalMontantCheques = document.getElementById('displayTotalCheques');
const totalMontantEffets = document.getElementById('displayTotalEffets');
const totalMontantGeneral = document.getElementById('displayTotalGeneral');

  // Parse French numbers
  function parseFrenchNumber(value) {
    if (!value) return 0;
    const clean = value.toString().replace(/\s/g, '').replace(',', '.');
    return parseFloat(clean) || 0;
  }
  function formatFrenchNumber(value) {
    return value.toLocaleString('fr-FR', { minimumFractionDigits: 2, maximumFractionDigits: 2 });
  }

  const MIN_DATE = new Date("2020-01-01");

  // Shared filter
  function filterChequesAndEffetsRows() {
    const selectedStatut = statutFilter?.value.toLowerCase() || '';
    const selectedFournisseur = fournisseurFilter?.value.toLowerCase() || '';
    const selectedBanque = banqueFilter?.value.toLowerCase() || '';
    const fromDate = dateFromFilter?.value ? new Date(dateFromFilter.value) : MIN_DATE;
    const toDate = dateToFilter?.value ? new Date(dateToFilter.value) : null;

    // --- Filter cheques ---
    let visibleChequeRows = 0;
    chequesRows.forEach(row => {
      const rowStatut = row.getAttribute('data-statut').toLowerCase();
      const rowFournisseur = row.getAttribute('data-fournisseur').toLowerCase();
      const rowBanque = row.getAttribute('data-banque').toLowerCase();
      const rowDate = new Date(row.getAttribute('data-date'));

      const showStatut = !selectedStatut || rowStatut === selectedStatut;
      const showFournisseur = !selectedFournisseur || rowFournisseur === selectedFournisseur;
      const showBanque = !selectedBanque || rowBanque === selectedBanque;
      const showDate = rowDate >= MIN_DATE && rowDate >= fromDate && (!toDate || rowDate <= toDate);

      if (showStatut && showFournisseur && showBanque && showDate) {
        row.style.display = '';
        visibleChequeRows++;
      } else {
        row.style.display = 'none';
      }
    });

    // Handle "no results"
    let chequeMsg = document.getElementById('noChequeMsg');
    if (visibleChequeRows === 0) {
      if (!chequeMsg) {
        chequeMsg = document.createElement('tr');
        chequeMsg.id = 'noChequeMsg';
        chequeMsg.innerHTML = `<td colspan="7" class="text-muted text-center">Aucun chèque trouvé pour ce filtre.</td>`;
        chequesTable.querySelector('tbody').appendChild(chequeMsg);
      }
    } else if (chequeMsg) {
      chequeMsg.remove();
    }

    // --- Filter effets ---
    let visibleEffetRows = 0;
    effetsRows.forEach(row => {
      const rowStatut = row.getAttribute('data-statut').toLowerCase();
      const rowFournisseur = row.getAttribute('data-fournisseur').toLowerCase();
      const rowBanque = row.getAttribute('data-banque').toLowerCase();
      const rowDate = new Date(row.getAttribute('data-date'));

      const showStatut = !selectedStatut || rowStatut === selectedStatut;
      const showFournisseur = !selectedFournisseur || rowFournisseur === selectedFournisseur;
      const showBanque = !selectedBanque || rowBanque === selectedBanque;
      const showDate = rowDate >= MIN_DATE && rowDate >= fromDate && (!toDate || rowDate <= toDate);

      if (showStatut && showFournisseur && showBanque && showDate) {
        row.style.display = '';
        visibleEffetRows++;
      } else {
        row.style.display = 'none';
      }
    });

    let effetMsg = document.getElementById('noEffetMsg');
    if (visibleEffetRows === 0) {
      if (!effetMsg) {
        effetMsg = document.createElement('tr');
        effetMsg.id = 'noEffetMsg';
        effetMsg.innerHTML = `<td colspan="6" class="text-muted text-center">Aucun effet trouvé pour ce filtre.</td>`;
        effetsTable.querySelector('tbody').appendChild(effetMsg);
      }
    } else if (effetMsg) {
      effetMsg.remove();
    }

    // --- Filter payavenirs ---
    let visiblePayavenirRows = 0;
    payavenirRows.forEach(row => {
      const rowStatut = row.getAttribute('data-statut').toLowerCase();
      const rowFournisseur = row.getAttribute('data-fournisseur').toLowerCase();
      const rowBanque = row.getAttribute('data-banque').toLowerCase();
      const rowDate = new Date(row.getAttribute('data-date'));

      const showStatut = !selectedStatut || rowStatut === selectedStatut;
      const showFournisseur = !selectedFournisseur || rowFournisseur === selectedFournisseur;
      const showBanque = !selectedBanque || rowBanque === selectedBanque;
      const showDate = rowDate >= MIN_DATE && rowDate >= fromDate && (!toDate || rowDate <= toDate);

      if (showStatut && showFournisseur && showBanque && showDate) {
        row.style.display = '';
        visiblePayavenirRows++;
      } else {
        row.style.display = 'none';
      }
    });

    let payavenirMsg = document.getElementById('noPayavenirMsg');
    if (visiblePayavenirRows === 0) {
      if (!payavenirMsg && payavenirsTable) {
        payavenirMsg = document.createElement('tr');
        payavenirMsg.id = 'noPayavenirMsg';
        payavenirMsg.innerHTML = `<td colspan="7" class="text-muted text-center">Aucun paiement trouvé pour ce filtre.</td>`;
        payavenirsTable.querySelector('tbody').appendChild(payavenirMsg);
      }
    } else if (payavenirMsg) {
      payavenirMsg.remove();
    }

    // ✅ One function for all totals
    updateDashboardTotals();
  }

  // --- Totals ---
  function updateDashboardTotals() {
    let totalCheques = 0;
    let totalEffets = 0;
    let totalPayavenirs = 0;

    // Chèques visibles
    chequesRows.forEach(row => {
      if (row.style.display !== 'none') {
        const montantCell = row.querySelector('.montant');
        if (montantCell) totalCheques += parseFrenchNumber(montantCell.textContent);
      }
    });

    // Effets visibles
    effetsRows.forEach(row => {
      if (row.style.display !== 'none') {
        const montantCell = row.querySelector('.montant');
        if (montantCell) totalEffets += parseFrenchNumber(montantCell.textContent);
      }
    });

    // Payavenirs visibles
    payavenirRows.forEach(row => {
      if (row.style.display !== 'none') {
        const montantCell = row.querySelector('.montant');
        if (montantCell) totalPayavenirs += parseFrenchNumber(montantCell.textContent);
      }
    });

    // Update footers
    if (totalMontantCheques) totalMontantCheques.textContent = formatFrenchNumber(totalCheques.toLocaleString('fr-FR', { minimumFractionDigits: 2, maximumFractionDigits: 2 }).replace(/\u202F/g, ' ')) + ' ';
    if (totalMontantEffets) totalMontantEffets.textContent = formatFrenchNumber(totalEffets.toLocaleString('fr-FR', { minimumFractionDigits: 2, maximumFractionDigits: 2 }).replace(/\u202F/g, ' ')) + ' ';

    // Update general
    if (totalMontantGeneral) totalMontantGeneral.textContent = formatFrenchNumber((totalCheques + totalEffets + totalPayavenirs).toLocaleString('fr-FR', { minimumFractionDigits: 2, maximumFractionDigits: 2 }).replace(/\u202F/g, ' ')) + ' ';

    // Update dashboard cards (if you have them)
    const chequesCard = document.getElementById('displayTotalChequesCard');
    const effetsCard = document.getElementById('displayTotalEffetsCard');
    const generalCard = document.getElementById('displayTotalGeneralCard');

    if (chequesCard) chequesCard.textContent = formatFrenchNumber(totalCheques.toLocaleString('fr-FR', { minimumFractionDigits: 2, maximumFractionDigits: 2 }).replace(/\u202F/g, ' ')) + ' ';
    if (effetsCard) effetsCard.textContent = formatFrenchNumber(totalEffets.toLocaleString('fr-FR', { minimumFractionDigits: 2, maximumFractionDigits: 2 }).replace(/\u202F/g, ' ')) + ' ';
    if (generalCard) generalCard.textContent = formatFrenchNumber((totalCheques + totalEffets + totalPayavenirs).toLocaleString('fr-FR', { minimumFractionDigits: 2, maximumFractionDigits: 2 }).replace(/\u202F/g, ' ')) + ' ';
  }

  // Reset
  function resetFilters() {
    statutFilter.value = '';
    fournisseurFilter.value = '';
    banqueFilter.value = '';
    if (dateFromFilter) dateFromFilter.value = '2020-01-01';
    if (dateToFilter) dateToFilter.value = '';
    filterChequesAndEffetsRows();
  }

  // Events
  statutFilter?.addEventListener('change', filterChequesAndEffetsRows);
  fournisseurFilter?.addEventListener('change', filterChequesAndEffetsRows);
  banqueFilter?.addEventListener('change', filterChequesAndEffetsRows);
  dateFromFilter?.addEventListener('change', filterChequesAndEffetsRows);
  dateToFilter?.addEventListener('change', filterChequesAndEffetsRows);
  resetButton?.addEventListener('click', resetFilters);

  // Initial run
  filterChequesAndEffetsRows();
});
// cheques validation 
document.addEventListener('DOMContentLoaded', () => {
  const checkboxes = document.querySelectorAll('input[name="validation"]');

  checkboxes.forEach(checkbox => {
    checkbox.checked = checkbox.dataset.validation === "true"; 

    checkbox.addEventListener('change', async (e) => {
      const id = e.target.dataset.id;
      const validation = e.target.checked;

      try {
        const response = await fetch(`/tresorerie/cheques/${id}/validation`, {
          method: 'PATCH',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ validation }) // ⚡ envoie booléen
        });

        if (!response.ok){
          throw new Error('Erreur lors de la mise à jour');
        }else{
          window.location.reload();
          console.log(`✅ Chèque ${id} updated: ${validation}`);
        }

        
      } catch (err) {
        console.error(err);
        e.target.checked = !validation; // rollback
        alert('Erreur lors de la mise à jour du chèque.');
      }
    });
  });
});

