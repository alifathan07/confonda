      function formatFrenchNumber(value) {
        if (isNaN(value)) return '0,00';
        return value.toFixed(2).replace(/\B(?=(\d{3})+(?!\d))/g, ' ').replace('.', ',');
      }

      // Title
      pdf.setFontSize(16);
      pdf.setFont(undefined, 'bold');
      pdf.setTextColor(106, 90, 231);
      pdf.text("Recettes à venir", 15, 15);
      
      pdf.setFontSize(9);
      pdf.setFont(undefined, 'normal');
      pdf.setTextColor(100, 100, 100);
      pdf.text("Date: " + new Date().toLocaleDateString('fr-FR'), 15, 22);

      // Group by client
      const recettesByClient = {};
      let grandTotal = 0;

      document.querySelectorAll('.recavenir-row').forEach(row => {
        if (row.style.display !== 'none') {
          const cells = row.querySelectorAll('td');
          if (cells.length >= 7) {
            const client = cells[0].textContent.trim();
            const montant = parseFrenchNumber(cells[2].textContent.trim());

            if (!recettesByClient[client]) {
              recettesByClient[client] = { rows: [], total: 0 };
            }

            recettesByClient[client].rows.push({
              designation: cells[1].textContent.trim(),
              montant: montant,
              date: cells[3].textContent.trim(),
              statut: cells[4].textContent.trim(),
              chantier: cells[5].textContent.trim(),
              banque: cells[6].textContent.trim()
            });

            recettesByClient[client].total += montant;
            grandTotal += montant;
          }
        }
      });

      const colWidths = [60, 40, 30, 25, 30, 35];
      const startX = 15;
      let y = 30;
      const totalWidth = colWidths.reduce((a,b) => a+b, 0);
      const headers = ['Désignation', 'Montant', 'Date Échéance', 'Statut', 'Chantier', 'Banque'];

      // For each client
      Object.keys(recettesByClient).sort().forEach(clientName => {
        const clientData = recettesByClient[clientName];

        if (y > 170) {
          pdf.addPage();
          y = 15;
        }

        // Client name row - draw background first, then text
        pdf.setFillColor(106, 90, 231);
        pdf.setDrawColor(106, 90, 231);
        pdf.rect(startX, y, totalWidth, 8, 'F');
        pdf.setFont(undefined, 'bold');
        pdf.setFontSize(10);
        pdf.setTextColor(255, 255, 255);
        pdf.text(clientName, startX + 2, y + 5.5);
        y += 8;

        // Column headers - draw each cell separately
        pdf.setFont(undefined, 'bold');
        pdf.setFontSize(8);
        pdf.setTextColor(0, 0, 0);
        pdf.setDrawColor(200, 200, 200);
        let x = startX;
        headers.forEach((header, i) => {
          pdf.setFillColor(245, 245, 245);
          pdf.rect(x, y, colWidths[i], 6, 'FD');
          pdf.setTextColor(0, 0, 0);
          pdf.text(header, x + 2, y + 4);
          x += colWidths[i];
        });
        y += 6;

        // Data rows
        pdf.setFont(undefined, 'normal');
        pdf.setFontSize(8);
        clientData.rows.forEach(row => {
          if (y > 185) {
            pdf.addPage();
            y = 15;

            // Redraw headers on new page
            pdf.setFont(undefined, 'bold');
            pdf.setDrawColor(200, 200, 200);
            let tempX = startX;
            headers.forEach((header, i) => {
              pdf.setFillColor(245, 245, 245);
              pdf.rect(tempX, y, colWidths[i], 6, 'FD');
              pdf.setTextColor(0, 0, 0);
              pdf.text(header, tempX + 2, y + 4);
              tempX += colWidths[i];
            });
            y += 6;
            pdf.setFont(undefined, 'normal');
          }

          let x = startX;
          const cells = [
            row.designation.length > 40 ? row.designation.substring(0, 37) + '...' : row.designation,
            formatFrenchNumber(row.montant),
            row.date,
            row.statut,
            row.chantier.length > 18 ? row.chantier.substring(0, 15) + '...' : row.chantier,
            row.banque.length > 20 ? row.banque.substring(0, 17) + '...' : row.banque
          ];

          pdf.setDrawColor(200, 200, 200);
          cells.forEach((cellText, i) => {
            // Draw white background for data cells
            pdf.setFillColor(255, 255, 255);
            pdf.rect(x, y, colWidths[i], 6, 'FD');
            pdf.setTextColor(0, 0, 0);
            pdf.text(cellText, x + 2, y + 4);
            x += colWidths[i];
          });

          y += 6;
        });

        // Client subtotal
        pdf.setFillColor(240, 240, 240);
        pdf.setDrawColor(200, 200, 200);
        pdf.rect(startX, y, totalWidth, 7, 'FD');
        pdf.setFont(undefined, 'bold');
        pdf.setTextColor(0, 0, 0);
        pdf.text(`Total ${clientName}:`, startX + 2, y + 4.5);
        pdf.text(formatFrenchNumber(clientData.total) + ' DH', startX + colWidths[0] + colWidths[1] - 2, y + 4.5, { align: 'right' });
        y += 10;
        pdf.setFont(undefined, 'normal');
      });

      // Grand total
      y += 2;
      pdf.setFillColor(106, 90, 231);
      pdf.setDrawColor(106, 90, 231);
      pdf.rect(startX, y, 120, 8, 'F');
      pdf.setFontSize(11);
      pdf.setFont(undefined, 'bold');
      pdf.setTextColor(255, 255, 255);
      pdf.text(`TOTAL GÉNÉRAL: ${formatFrenchNumber(grandTotal)} DH`, startX + 2, y + 5.5);

      pdf.save(`recettes-a-venir-${new Date().toISOString().split('T')[0]}.pdf`);
      document.body.removeChild(loadingMsg);

    } catch (error) {
      console.error("Erreur PDF:", error);
      document.body.removeChild(loadingMsg);
      alert("Erreur lors de la génération du PDF des recettes à venir");
    }
  };
  document.head.appendChild(script);
}
function deleteBanque(id) {
  fetch(`/tresorerie/banques/delete/${id}`, {
    method: 'DELETE',
    body: JSON.stringify({ id }),
    headers: {
      'Content-Type': 'application/json'
    }
  })
  .then(response => {
    if (response.ok) {
      alert('Banque supprimée avec succès');
      location.reload();
    } else {
      alert('Erreur lors de la suppression de la banque');
    }
  })
  .catch(error => {
    console.error('Error:', error);
    alert('Erreur lors de la suppression de la banque');
  });
}
</script>