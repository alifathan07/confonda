                              </div>
                            </td>
                          </tr>
                        <% }) %>
                      </tbody>
                      <tfoot>
                        <tr style="background-color: #2fb415; color: white; font-weight: bold;">
                          <td>Total</td>
                          <td colspan="3"></td>
                          <td class="paytotal text-right" id="displayTotalPayavenirsValides">
                            <%= payavenirs.filter(p => p.validation).reduce((acc, p) => acc + p.montant, 0).toLocaleString('fr-FR', { minimumFractionDigits: 2, maximumFractionDigits: 2 }).replace(/\u202F/g, ' ') %>
                          </td>
                          <td colspan="3"></td>
                        </tr>
                      </tfoot>
                    </table>
                  </div>
                </div>
              </div>
          
              <!-- Total Général -->
              <div class="card mb-4 shadow-sm rounded fade-in">
                <div class="card-header bg-success text-white text-center">
                  <h3>Total Général des Paiements Validés</h3>
                </div>
                <div class="card-body d-flex justify-content-center">
                  <h4 id="grandTotalValide" class="fw-bold text-dark">
                    0,00
                  </h4>
                </div>
              </div>
          
            </div>
          </div>
          
      
          
         
        </div>
      </div>
    </div>
  </div>

  <!-- Scripts -->
  <script src="/vendor/jquery/jquery.min.js"></script>
  <script src="/vendor/bootstrap/js/bootstrap.bundle.min.js"></script>
  <script src="/vendor/jquery-easing/jquery.easing.min.js"></script>
  <script src="/js/sb-admin-2.min.js"></script>
</body>





<!-- <<<<<<<<<<<<< SCRIPT >>>>>>>>>>>>> -->




<script>
  document.addEventListener('DOMContentLoaded', () => {
  // Filter elements
  const statutFilter = document.getElementById('statutFilterCheques');
  const banqueFilter = document.getElementById('banqueFilterCheques');
  const dateFromFilter = document.getElementById('dateFilter');
  const dateToFilter = document.getElementById('dateToFilter');
  const resetButton = document.getElementById('resetDateBtn');
  const supplierList = document.getElementById('supplierList');
  const selectAllEl = document.getElementById('supplierSelectAll');
  const countBadge = document.getElementById('supplierSelectedCount');

  // Table elements
  const chequesTable = document.getElementById('chequesTable');
  const effetsTable = document.getElementById('effetsTable');
  const payavenirsTable = document.getElementById('payavenirsTable');
  const chequesValidesTable = document.querySelector('#tables-container #chequesTable');
  const effetsValidesTable = document.querySelector('#tables-container #effetsTable');
  const payavenirsValidesTable = document.getElementById('payavenirsValidesTable');

  // Row selectors
  const chequesRows = chequesTable?.querySelectorAll('tbody tr.cheque-row') || [];
  const effetsRows = effetsTable?.querySelectorAll('tbody tr.effet-row') || [];
  const payavenirsRows = payavenirsTable?.querySelectorAll('tbody tr.payavenir-row') || [];
  const chequesValidesRows = chequesValidesTable?.querySelectorAll('tbody tr.cheque-row-valid') || [];
  const effetsValidesRows = effetsValidesTable?.querySelectorAll('tbody tr.effet-row-valid') || [];
  const payavenirsValidesRows = payavenirsValidesTable?.querySelectorAll('tbody tr.payavenir-row-valid') || [];

  // Total elements
  const totalMontantCheques = document.getElementById('displayTotalCheques');
  const totalMontantEffets = document.getElementById('displayTotalEffets');
  const totalMontantPayavenirs = document.getElementById('displayTotalPayavenirs');
  const totalMontantChequesValides = chequesValidesTable?.querySelector('.chequetotal');
  const totalMontantEffetsValides = effetsValidesTable?.querySelector('.effettotal');
  const totalMontantPayavenirsValides = payavenirsValidesTable?.querySelector('.paytotal');
  const totalMontantGeneral = document.getElementById('displayTotalGeneralCard');
  const totalMontantGeneralValide = document.getElementById('grandTotalValide');

  // Utility functions
  const parseFrenchNumber = (value) => {
    if (!value) return 0;
    return parseFloat(value.toString().replace(/\s/g, '').replace(',', '.')) || 0;
  };

  const formatFrenchNumber = (value) => {
    return value.toLocaleString('fr-FR', { minimumFractionDigits: 2, maximumFractionDigits: 2 }).replace(/\u202F/g, ' ');
  };

  // Collect unique suppliers
  const suppliers = Array.from(new Set(
    [...chequesRows, ...effetsRows, ...payavenirsRows]
      .map(r => r.getAttribute('data-fournisseur')?.trim())
      .filter(Boolean)
  )).sort((a, b) => a.localeCompare(b, 'fr'));

  // Render supplier checkboxes
  if (supplierList) {
    supplierList.innerHTML = '';
    suppliers.forEach((name, idx) => {
      const id = `supplier-opt-${idx}`;
      const wrap = document.createElement('div');
      wrap.className = 'custom-control custom-checkbox mb-1';
      const input = document.createElement('input');
      input.type = 'checkbox';
      input.className = 'custom-control-input';
      input.id = id;
      input.value = name;
      input.checked = true;
      const label = document.createElement('label');
      label.className = 'custom-control-label';
      label.setAttribute('for', id);
      label.textContent = name;
      wrap.appendChild(input);
      wrap.appendChild(label);
      supplierList.appendChild(wrap);

      input.addEventListener('change', () => {
        applyFilters();
        syncSelectAll();
        updateBadge();
      });
    });
  }

  // Fallback dropdown toggle
  const dropdownBtn = document.getElementById('supplierFilterBtn');
  if (dropdownBtn) {
    const menu = dropdownBtn.nextElementSibling;
    dropdownBtn.addEventListener('click', (e) => {
      e.preventDefault();
      e.stopPropagation();
      dropdownBtn.parentElement.classList.toggle('show');
      if (menu && menu.classList) menu.classList.toggle('show');
    });
    document.addEventListener('click', () => {
      dropdownBtn.parentElement.classList.remove('show');
      if (menu && menu.classList) menu.classList.remove('show');
    });
  }

  // Get selected suppliers
  const getSelectedSuppliers = () => {
    return Array.from(supplierList?.querySelectorAll('input[type="checkbox"]:checked') || [])
      .map(cb => cb.value);
  };

  // Update supplier badge
  const updateBadge = () => {
    if (!countBadge) return;
    const checkedCount = supplierList.querySelectorAll('input[type="checkbox"]:checked').length;
    countBadge.textContent = checkedCount === suppliers.length ? 'Tous' : `${checkedCount}/${suppliers.length}`;
  };

  // Sync "Select All" checkbox
  const syncSelectAll = () => {
    if (!selectAllEl) return;
    const boxes = supplierList.querySelectorAll('input[type="checkbox"]');
    const total = boxes.length;
    const checked = Array.from(boxes).filter(b => b.checked).length;
    selectAllEl.indeterminate = checked > 0 && checked < total;
    selectAllEl.checked = checked === total;
  };

  // Handle "Select All" toggle
  selectAllEl?.addEventListener('change', () => {
    const check = selectAllEl.checked;
    supplierList.querySelectorAll('input[type="checkbox"]').forEach(cb => cb.checked = check);
    selectAllEl.indeterminate = false;
    updateBadge();
    applyFilters();
  });

  // Apply all filters
  const applyFilters = () => {
    const selectedStatut = statutFilter?.value.toLowerCase() || '';
    const selectedBanque = banqueFilter?.value.toLowerCase() || '';
    const selectedSuppliers = new Set(getSelectedSuppliers());
    const allSuppliersSelected = selectedSuppliers.size === suppliers.length;
    const fromDate = dateFromFilter?.value ? new Date(dateFromFilter.value) : new Date('2020-01-01');
    const toDate = dateToFilter?.value ? new Date(dateToFilter.value) : null;

    const filterRow = (row) => {
      const rowStatut = row.getAttribute('data-statut')?.toLowerCase() || '';
      const rowBanque = row.getAttribute('data-banque')?.toLowerCase() || '';
      const rowFournisseur = row.getAttribute('data-fournisseur')?.trim() || '';
      const rowDate = new Date(row.getAttribute('data-date'));
      const isValidated = row.querySelector('input[name="validation"], input[name="validationEffet"], input[name="validationPayavenir"]')?.checked;

      const statutMatch = !selectedStatut || rowStatut === selectedStatut;
      const banqueMatch = !selectedBanque || rowBanque === selectedBanque;
      const supplierMatch = allSuppliersSelected || selectedSuppliers.has(rowFournisseur);
      const dateMatch = rowDate >= fromDate && (!toDate || rowDate <= toDate);

      return statutMatch && banqueMatch && supplierMatch && dateMatch;
    };

    const tables = [
      { rows: chequesRows, table: chequesTable, msgId: 'noChequeMsg', colspan: 9 },
      { rows: effetsRows, table: effetsTable, msgId: 'noEffetMsg', colspan: 9 },
      { rows: payavenirsRows, table: payavenirsTable, msgId: 'noPayavenirMsg', colspan: 7 },
    ];

    tables.forEach(({ rows, table, msgId, colspan }) => {
      let visibleCount = 0;
      rows.forEach(row => {
        row.style.display = filterRow(row) ? '' : 'none';
        if (row.style.display !== 'none') visibleCount++;
      });

      let msg = document.getElementById(msgId);
      if (visibleCount === 0) {
        if (!msg && table) {
          msg = document.createElement('tr');
          msg.id = msgId;
          msg.innerHTML = `<td colspan="${colspan}" class="text-muted text-center">Aucun élément trouvé pour ce filtre.</td>`;
          table.querySelector('tbody').appendChild(msg);
        }
      } else if (msg) {
        msg.remove();
      }
    });

    const validatedTables = [
      { rows: chequesValidesRows, table: chequesValidesTable, msgId: 'noChequeValideMsg', colspan: 9 },
      { rows: effetsValidesRows, table: effetsValidesTable, msgId: 'noEffetValideMsg', colspan: 9 },
      { rows: payavenirsValidesRows, table: payavenirsValidesTable, msgId: 'noPayavenirValideMsg', colspan: 8 },
    ];

    validatedTables.forEach(({ rows, table, msgId, colspan }) => {
      let visibleCount = 0;
      rows.forEach(row => {
        const isValidated = row.querySelector('input[name="validation"], input[name="validationEffet"], input[name="validationPayavenir"]')?.checked;
        row.style.display = filterRow(row) && isValidated ? '' : 'none';
        if (row.style.display !== 'none') visibleCount++;
      });

      let msg = document.getElementById(msgId);
      if (visibleCount === 0) {
        if (!msg && table) {
          msg = document.createElement('tr');
          msg.id = msgId;
          msg.innerHTML = `<td colspan="${colspan}" class="text-muted text-center">Aucun élément validé trouvé pour ce filtre.</td>`;
          table.querySelector('tbody').appendChild(msg);
        }
      } else if (msg) {
        msg.remove();
      }
    });

    updateAllTotals();
  };

  // Update all totals
  const updateAllTotals = () => {
    let totalCheques = 0, totalEffets = 0, totalPayavenirs = 0;
    let totalChequesValides = 0, totalEffetsValides = 0, totalPayavenirsValides = 0;

    chequesRows.forEach(row => {
      if (row.style.display !== 'none') {
        const montant = parseFrenchNumber(row.querySelector('.montant')?.textContent);
        totalCheques += montant;
      }
    });

    effetsRows.forEach(row => {
      if (row.style.display !== 'none') {
        const montant = parseFrenchNumber(row.querySelector('.montant')?.textContent);
        totalEffets += montant;
      }
    });

    payavenirsRows.forEach(row => {
      if (row.style.display !== 'none') {
        const montant = parseFrenchNumber(row.querySelector('.montant')?.textContent);
        totalPayavenirs += montant;
      }
    });

    chequesValidesRows.forEach(row => {
      if (row.style.display !== 'none') {
        const montant = parseFrenchNumber(row.querySelector('.montant')?.textContent);
        totalChequesValides += montant;
      }
    });

    effetsValidesRows.forEach(row => {
      if (row.style.display !== 'none') {
        const montant = parseFrenchNumber(row.querySelector('.montant')?.textContent);
        totalEffetsValides += montant;
      }
    });

    payavenirsValidesRows.forEach(row => {
      if (row.style.display !== 'none') {
        const montant = parseFrenchNumber(row.querySelector('.montant')?.textContent);
        totalPayavenirsValides += montant;
      }
    });

    if (totalMontantCheques) totalMontantCheques.textContent = formatFrenchNumber(totalCheques);
    if (totalMontantEffets) totalMontantEffets.textContent = formatFrenchNumber(totalEffets);
    if (totalMontantPayavenirs) totalMontantPayavenirs.textContent = formatFrenchNumber(totalPayavenirs);

    if (totalMontantChequesValides) totalMontantChequesValides.textContent = formatFrenchNumber(totalChequesValides);
    if (totalMontantEffetsValides) totalMontantEffetsValides.textContent = formatFrenchNumber(totalEffetsValides);
    if (totalMontantPayavenirsValides) totalMontantPayavenirsValides.textContent = formatFrenchNumber(totalPayavenirsValides);

    const chequesCard = document.getElementById('displayTotalChequesCard');
    const effetsCard = document.getElementById('displayTotalEffetsCard');
    if (chequesCard) chequesCard.textContent = formatFrenchNumber(totalCheques);
    if (effetsCard) effetsCard.textContent = formatFrenchNumber(totalEffets);
    if (totalMontantGeneral) totalMontantGeneral.textContent = formatFrenchNumber(totalCheques + totalEffets + totalPayavenirs);

    if (totalMontantGeneralValide) {
      const grandTotalValide = totalChequesValides + totalEffetsValides + totalPayavenirsValides;
      totalMontantGeneralValide.textContent = formatFrenchNumber(grandTotalValide) + ' dirhams';
    }
  };

  // Reset filters
  const resetFilters = () => {
    if (statutFilter) statutFilter.value = '';
    if (banqueFilter) banqueFilter.value = '';
    if (dateFromFilter) dateFromFilter.value = '2020-01-01';
    if (dateToFilter) dateToFilter.value = '';
    if (supplierList) {
      supplierList.querySelectorAll('input[type="checkbox"]').forEach(cb => cb.checked = true);
      syncSelectAll();
      updateBadge();
    }
    applyFilters();
  };

  // Add event listeners
  statutFilter?.addEventListener('change', applyFilters);
  banqueFilter?.addEventListener('change', applyFilters);
  dateFromFilter?.addEventListener('change', applyFilters);
  dateToFilter?.addEventListener('change', applyFilters);
  resetButton?.addEventListener('click', resetFilters);

  // Handle validation checkboxes
  const validationCheckboxes = document.querySelectorAll('input[name="validation"], input[name="validationEffet"], input[name="validationPayavenir"]');
  validationCheckboxes.forEach(checkbox => {
    checkbox.checked = checkbox.dataset.validation === "true" || checkbox.dataset.effetvalidation === "true" || checkbox.dataset.payavenirvalidation === "true";
    checkbox.addEventListener('change', async () => {
      const id = checkbox.getAttribute('data-id');
      const isChecked = checkbox.checked;
      const type = checkbox.name === 'validation' ? 'cheques' :
                   checkbox.name === 'validationEffet' ? 'effets' : 'payavenirs';
      const endpoint = `/tresorerie/${type}/${id}/validation`;
      const bodyKey = type === 'cheques' ? 'validation' :
                      type === 'effets' ? 'validationEffet' : 'validationPayavenir';

      try {
        const response = await fetch(endpoint, {
          method: 'PATCH',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ [bodyKey]: isChecked })
        });

        if (!response.ok) {
          throw new Error('Erreur lors de la mise à jour');
        }
        console.log(`✅ ${type} ${id} updated: ${isChecked}`);
        window.location.reload();
      } catch (err) {
        console.error(err);
        checkbox.checked = !isChecked;
        alert(`Erreur lors de la mise à jour du ${type === 'cheques' ? 'chèque' : type === 'effets' ? 'effet' : 'paiement'}.`);
      }
    });
  });

  // Toggle validated tables
  const toggleTablesBtn = document.getElementById('toggleTablesBtn');
  const toggleIcon = document.getElementById('toggleIcon');
  const toggleText = document.getElementById('toggleText');
  const tablesContainer = document.getElementById('tables-container');

  toggleTablesBtn?.addEventListener('click', () => {
    const isHidden = tablesContainer.classList.contains('hidden');
    tablesContainer.classList.toggle('hidden');
    toggleIcon.className = isHidden ? 'fas fa-eye-slash me-1' : 'fas fa-eye me-1';
    toggleText.textContent = isHidden ? 'Masquer' : 'Afficher';
  });

  // Initial run
  updateBadge();
  applyFilters();

  // New: Recettes à venir multi-select client filter
  const clientList = document.getElementById('clientList');
  const clientSelectAll = document.getElementById('clientSelectAll');
  const clientCountBadge = document.getElementById('clientSelectedCount');
  const clientSearch = document.getElementById('clientSearch');
  const chantierFilter = document.getElementById('chantierFilter');
  const recavenirsTable = document.getElementById('recavenirsTable');
  const recavenirsRows = recavenirsTable?.querySelectorAll('tbody tr.recavenir-row') || [];
  const totalMontantRecettes = document.getElementById('totalMontant');
  const totalRecettesCard = document.getElementById('displayTotalChequesCard'); // Misnamed, but for recettes

  // Collect unique clients
  const clientsUnique = Array.from(new Set(
    [...recavenirsRows]
      .map(r => r.getAttribute('data-client')?.trim())
      .filter(Boolean)
  )).sort((a, b) => a.localeCompare(b, 'fr'));

  // Render client checkboxes
  if (clientList) {
    clientList.innerHTML = '';
    clientsUnique.forEach((name, idx) => {
      const id = `client-opt-${idx}`;
      const wrap = document.createElement('div');
      wrap.className = 'custom-control custom-checkbox mb-1';
      const input = document.createElement('input');
      input.type = 'checkbox';
      input.className = 'custom-control-input';
      input.id = id;
      input.value = name;
      input.checked = true;
      const label = document.createElement('label');
      label.className = 'custom-control-label';
      label.setAttribute('for', id);
      label.textContent = name;
      wrap.appendChild(input);
      wrap.appendChild(label);
      clientList.appendChild(wrap);

      input.addEventListener('change', () => {
        updateRecettesTable();
        syncClientSelectAll();
        updateClientBadge();
      });
    });
  }

  // Fallback dropdown toggle for clients
  const clientDropdownBtn = document.getElementById('clientFilterBtn');
  if (clientDropdownBtn) {
    const clientMenu = clientDropdownBtn.nextElementSibling;
    clientDropdownBtn.addEventListener('click', (e) => {
      e.preventDefault();
      e.stopPropagation();
      clientDropdownBtn.parentElement.classList.toggle('show');
      if (clientMenu && clientMenu.classList) clientMenu.classList.toggle('show');
    });
    document.addEventListener('click', () => {
      clientDropdownBtn.parentElement.classList.remove('show');
      if (clientMenu && clientMenu.classList) clientMenu.classList.remove('show');
    });
  }

  // Get selected clients
  const getSelectedClients = () => {
    return Array.from(clientList?.querySelectorAll('input[type="checkbox"]:checked') || [])
      .map(cb => cb.value);
  };

  // Update client badge
  const updateClientBadge = () => {
    if (!clientCountBadge) return;
    const checkedCount = clientList.querySelectorAll('input[type="checkbox"]:checked').length;
    clientCountBadge.textContent = checkedCount === clientsUnique.length ? 'Tous' : `${checkedCount}/${clientsUnique.length}`;
  };

  // Sync "Select All" checkbox for clients
  const syncClientSelectAll = () => {
    if (!clientSelectAll) return;
    const boxes = clientList.querySelectorAll('input[type="checkbox"]');
    const total = boxes.length;
    const checked = Array.from(boxes).filter(b => b.checked).length;
    clientSelectAll.indeterminate = checked > 0 && checked < total;
    clientSelectAll.checked = checked === total;
  };

  // Handle "Select All" toggle for clients
  clientSelectAll?.addEventListener('change', () => {
    const check = clientSelectAll.checked;
    clientList.querySelectorAll('input[type="checkbox"]').forEach(cb => cb.checked = check);
    clientSelectAll.indeterminate = false;
    updateClientBadge();
    updateRecettesTable();
  });

  // Search functionality for clients
  clientSearch?.addEventListener('keyup', () => {
    const term = clientSearch.value.toLowerCase();
    clientList.querySelectorAll('.custom-control').forEach(wrap => {
      const labelText = wrap.querySelector('label').textContent.toLowerCase();
      wrap.style.display = labelText.includes(term) ? '' : 'none';
    });
  });

  // Update recettes table
 // Update recettes table
 const updateRecettesTable = () => {
    const selectedClients = new Set(getSelectedClients());
    const allClientsSelected = selectedClients.size === clientsUnique.length;
    const selectedChantier = chantierFilter?.value || '';

    let total = 0;
    let visibleCount = 0;

    // First pass: filter data rows and track which clients have visible rows
    const visibleClientsSet = new Set();
    recavenirsRows.forEach(row => {
      const client = row.getAttribute('data-client')?.trim() || '';
      const chantier = row.getAttribute('data-chantier')?.trim() || '';
      const montantText = row.querySelector('td:nth-child(3)')?.textContent.replace(/\s/g, '').replace(',', '.') || '0';
      const montant = parseFloat(montantText) || 0;

      const clientMatch = allClientsSelected || selectedClients.has(client);
      const chantierMatch = !selectedChantier || chantier === selectedChantier;

      if (clientMatch && chantierMatch) {
        row.style.display = '';
        total += montant;
        visibleCount++;
        visibleClientsSet.add(client);
      } else {
        row.style.display = 'none';
      }
    });

    // Second pass: hide/show client headers and subtotal rows
    if (recavenirsTable) {
      const allRows = recavenirsTable.querySelectorAll('tbody tr');
      allRows.forEach(row => {
        // Check if this is a client header or subtotal row
        if (row.classList.contains('table-secondary')) {
          const cellText = row.querySelector('td')?.textContent.trim() || '';
          
          // Extract client name from header (format: "Client : ClientName") or subtotal (format: "Total ClientName")
          let clientName = '';
          if (cellText.startsWith('Client :')) {
            clientName = cellText.replace('Client :', '').trim();
          } else if (cellText.startsWith('Total ')) {
            clientName = cellText.replace('Total ', '').trim();
          }
          
          // Show/hide based on whether this client has visible rows
          if (clientName && visibleClientsSet.has(clientName)) {
            row.style.display = '';
          } else if (clientName) {
            row.style.display = 'none';
          }
        }
      });
    }

    if (totalMontantRecettes) totalMontantRecettes.textContent = formatFrenchNumber(total);
    if (totalRecettesCard) totalRecettesCard.textContent = formatFrenchNumber(total);

    let noRecetteMsg = document.getElementById('noRecetteMsg');
    if (visibleCount === 0) {
      if (!noRecetteMsg && recavenirsTable) {
        noRecetteMsg = document.createElement('tr');
        noRecetteMsg.id = 'noRecetteMsg';
        noRecetteMsg.innerHTML = '<td colspan="7" class="text-muted text-center">Aucun élément trouvé pour ce filtre.</td>';
        recavenirsTable.querySelector('tbody').appendChild(noRecetteMsg);
      }
    } else if (noRecetteMsg) {
      noRecetteMsg.remove();
    }
  };
  // Add event listeners for recettes
  chantierFilter?.addEventListener('change', updateRecettesTable);

  // Initial run for recettes
  updateClientBadge();
  syncClientSelectAll();
  updateRecettesTable();

});

// Restored original PDF download functions
function downloadFullPagePDF() {
  const loadingMsg = createLoadingMessage();
  document.body.appendChild(loadingMsg);

  loadScript('https://cdnjs.cloudflare.com/ajax/libs/jspdf/2.5.1/jspdf.umd.min.js')
    .then(() => loadScript('https://cdnjs.cloudflare.com/ajax/libs/jspdf-autotable/3.5.28/jspdf.plugin.autotable.min.js'))
    .then(() => generatePDF())
    .catch(error => handleError(error, loadingMsg))
    .finally(() => document.body.removeChild(loadingMsg));

  function createLoadingMessage() {
    const div = document.createElement('div');
    div.innerHTML = '<div class="alert alert-info" style="position: fixed; top: 20px; right: 20px; z-index: 1000;">Génération du PDF complet en cours...</div>';
    return div;
  }

  function loadScript(src) {
    return new Promise((resolve, reject) => {
      const script = document.createElement('script');
      script.src = src;
      script.onload = resolve;
      script.onerror = () => reject(new Error(`Failed to load script: ${src}`));
      document.head.appendChild(script);
    });
  }

  function formatFrenchNumber(value) {
    if (isNaN(value)) return '0,00';
    return value
      .toFixed(2)
      .replace(/\B(?=(\d{3})+(?!\d))/g, ' ')
      .replace('.', ',');
  }

  function parseFrenchNumber(text) {
    if (!text) return 0;
    return parseFloat(text.replace(/[\/\s]/g, '').replace(',', '.')) || 0;
  }

  function addSectionTable(pdf, title, headers, data, yPosition, columnStyles, hasTotals = true, customOptions = {}) {
    if (yPosition > 220) {
      pdf.addPage();
      yPosition = 20;
    }

    pdf.setFontSize(16);
    pdf.text(title, 20, yPosition);
    yPosition += 10;

    if (data.length > 0) {
      pdf.autoTable({
        head: [headers],
        body: data,
        startY: yPosition,
        theme: 'striped',
        styles: {
          fontSize: 10,
          cellPadding: 2,
          lineWidth: 0.2,
          lineColor: [0, 0, 0],
        },
        headStyles: {
          fillColor: [52, 144, 220],
          textColor: 255,
          fontStyle: 'bold',
          lineWidth: 0.2,
          lineColor: [0, 0, 0],
        },
        columnStyles,
        ...customOptions,
        didParseCell: (data) => {
          if (hasTotals && data.row.index === data.table.body.length - 1) {
            data.cell.styles.fontStyle = 'bold';
            data.cell.styles.fillColor = [240, 240, 240];
            data.cell.styles.lineWidth = 0.2;
            data.cell.styles.lineColor = [0, 0, 0];
          }
        },
      });
      return pdf.lastAutoTable.finalY + 20;
    } else {
      pdf.setFontSize(10);
      pdf.text(`Aucun élément trouvé pour cette période.`, 20, yPosition);
      return yPosition + 15;
    }
  }

  function generatePDF() {
    const { jsPDF } = window.jspdf;
    const pdf = new jsPDF('p', 'mm', 'a4');

    pdf.setFontSize(20);
    pdf.text('Situation Bancaire Complète', 20, 20);
    pdf.setFontSize(12);
    pdf.text(`Généré le: ${new Date().toLocaleString('fr-FR')}`, 30, 30);

    let yPosition = 50;

    const bankData = [];
    let totalPositive = 0, totalNegative = 0, totalDmlt = 0;

    document.querySelectorAll('#soldeTable tbody tr').forEach((row) => {
      const cells = row.querySelectorAll('td');
      if (cells.length >= 4) {
        const bankName = cells[0].textContent.trim() || cells[0].querySelector('strong')?.textContent.trim();
        const positiveInput = cells[1].querySelector('input')?.value.trim();
        const negativeInput = cells[2].querySelector('input')?.value.trim();
        const dmltInput = cells[3].querySelector('input')?.value.trim();

        const positive = parseFrenchNumber(positiveInput);
        const negative = parseFrenchNumber(negativeInput);
        const dmlt = parseFrenchNumber(dmltInput);

        if (!isNaN(positive)) totalPositive += positive;
        if (!isNaN(negative)) totalNegative += negative;
        if (!isNaN(dmlt)) totalDmlt += dmlt;

        bankData.push([
          bankName,
          formatFrenchNumber(positive),
          formatFrenchNumber(negative),
          formatFrenchNumber(dmlt),
        ]);
      }
    });

    bankData.push([
      'TOTAL',
      totalPositive.toLocaleString('fr-FR', { minimumFractionDigits: 2, maximumFractionDigits: 2 }).replace(/\u202F/g, ' '),
      totalNegative.toLocaleString('fr-FR', { minimumFractionDigits: 2, maximumFractionDigits: 2 }).replace(/\u202F/g, ' '),
      totalDmlt.toLocaleString('fr-FR', { minimumFractionDigits: 2, maximumFractionDigits: 2 }).replace(/\u202F/g, ' '),
    ]);

    yPosition = addSectionTable(
      pdf,
      '1. Soldes Bancaires',
      ['Banque', 'Solde positif', 'Solde négatif', 'Dette à moyen et long terme'],
      bankData,
      yPosition,
      {
        0: { halign: 'left' },
        1: { halign: 'right' },
        2: { halign: 'right' },
        3: { halign: 'right' },
      },
      true,
      { headStyles: { fillColor: [0, 128, 0], textColor: 255, halign: 'center' } }
    );

    const recetteData = [];
    let totalRecette = 0;

    document.querySelectorAll('#recavenirsTable tbody tr').forEach((row) => {
      const cells = row.querySelectorAll('td');
      if (cells.length >= 6) {
        const client = cells[0].textContent.trim();
        const designation = cells[1].textContent.trim();
        const montantInput = cells[2].textContent.trim().replace(/\s/g, '').replace(',', '.');
        const dateEcheance = cells[3].textContent.trim();
        const statut = cells[4].textContent.trim();
        const banque = cells[5].textContent.trim();

        const montant = parseFrenchNumber(montantInput);
        if (!isNaN(montant)) totalRecette += montant;

        recetteData.push([
          client,
          designation,
          formatFrenchNumber(montant),
          dateEcheance,
          statut,
          banque
        ]);
      }
    });

    recetteData.push(['TOTAL', '', formatFrenchNumber(totalRecette), '', '', '']);

    yPosition = addSectionTable(
      pdf,
      '2. Recettes à venir',
      ['Client', 'Désignation', 'Montant', 'Date Échéance', 'Statut', 'Banque'],
      recetteData,
      yPosition,
      {
        0: { halign: 'left' },
        1: { halign: 'left' },
        2: { halign: 'right' },
        3: { halign: 'center' },
        4: { halign: 'center' },
        5: { halign: 'left' }
      },
      true,
      { headStyles: { fillColor: [0, 128, 0], textColor: 255, halign: 'center' } }
    );

    const visibleCheques = [];
    let chequesTotalAmount = 0;

    document.querySelectorAll('.cheque-row').forEach(row => {
      if (row.style.display !== 'none') {
        const cells = row.querySelectorAll('td');
        if (cells.length >= 8) {
          const montantValue = parseFrenchNumber(cells[4].textContent.trim());
          chequesTotalAmount += montantValue;
          visibleCheques.push([
            cells[1].textContent.trim(),
            formatFrenchNumber(montantValue),
            cells[5].textContent.trim(),
            cells[3].textContent.trim(),
            cells[2].textContent.trim(),
            cells[6].textContent.trim(),
            cells[7].querySelector('input')?.value || cells[7].textContent.trim(),
          ]);
        }
      }
    });

    if (visibleCheques.length > 0) {
      visibleCheques.push(['TOTAL', formatFrenchNumber(chequesTotalAmount), '', '', '', '', '']);
    }

    yPosition = addSectionTable(
      pdf,
      '3. Chèques en circulation',
      ['Numéro', 'Montant', 'Date Échéance', 'Bénéficiaire', 'Banque', 'Statut', 'Observation'],
      visibleCheques,
      yPosition,
      {
        0: { halign: 'left', cellWidth: 25 },
        1: { halign: 'right', cellWidth: 25 },
        2: { halign: 'center', cellWidth: 25 },
        3: { halign: 'left', cellWidth: 30 },
        4: { halign: 'left', cellWidth: 30 },
        5: { halign: 'center', cellWidth: 25 },
        6: { halign: 'left', cellWidth: 30 },
      }
    );

    const visibleEffets = [];
    let effetsTotalAmount = 0;

    document.querySelectorAll('.effet-row').forEach(row => {
      if (row.style.display !== 'none') {
        const cells = row.querySelectorAll('td');
        if (cells.length >= 8) {
          const montantValue = parseFrenchNumber(cells[4].textContent.trim());
          effetsTotalAmount += montantValue;
          visibleEffets.push([
            cells[1].textContent.trim(),
            formatFrenchNumber(montantValue),
            cells[5].textContent.trim(),
            cells[3].textContent.trim(),
            cells[2].textContent.trim(),
            cells[6].textContent.trim(),
            cells[7].querySelector('input')?.value || cells[7].textContent.trim(),
          ]);
        }
      }
    });

    if (visibleEffets.length > 0) {
      visibleEffets.push(['TOTAL', formatFrenchNumber(effetsTotalAmount), '', '', '', '', '']);
    }

    yPosition = addSectionTable(
      pdf,
      '4. Effets en circulation',
      ['Numéro', 'Montant', 'Date Échéance', 'Bénéficiaire', 'Banque', 'Statut', 'Observation'],
      visibleEffets,
      yPosition,
      {
        0: { halign: 'left', cellWidth: 25 },
        1: { halign: 'right', cellWidth: 25 },
        2: { halign: 'center', cellWidth: 25 },
        3: { halign: 'left', cellWidth: 30 },
        4: { halign: 'left', cellWidth: 30 },
        5: { halign: 'center', cellWidth: 25 },
        6: { halign: 'left', cellWidth: 30 },
      }
    );

    const visiblePayavenirs = [];
    let payavenirsTotalAmount = 0;

    document.querySelectorAll('.payavenir-row').forEach(row => {
      if (row.style.display !== 'none') {
        const cells = row.querySelectorAll('td');
        if (cells.length >= 6) {
          const montantValue = parseFrenchNumber(cells[3].textContent.trim());
          payavenirsTotalAmount += montantValue;
          visiblePayavenirs.push([
            cells[0].textContent.trim(),
            formatFrenchNumber(montantValue),
            cells[4].textContent.trim(),
            cells[2].textContent.trim(),
            cells[1].textContent.trim(),
            cells[5].textContent.trim(),
          ]);
        }
      }
    });

    if (visiblePayavenirs.length > 0) {
      visiblePayavenirs.push(['TOTAL', formatFrenchNumber(payavenirsTotalAmount), '', '', '', '']);
    }

    yPosition = addSectionTable(
      pdf,
      '5. Paiements à venir',
      ['Désignation', 'Montant', 'Date Échéance', 'Bénéficiaire', 'Banque', 'Statut'],
      visiblePayavenirs,
      yPosition,
      {
        0: { halign: 'left', cellWidth: 35 },
        1: { halign: 'right', cellWidth: 25 },
        2: { halign: 'center', cellWidth: 25 },
        3: { halign: 'left', cellWidth: 30 },
        4: { halign: 'left', cellWidth: 25 },
        5: { halign: 'center', cellWidth: 20 },
      }
    );

    if (yPosition > 220) {
      pdf.addPage();
      yPosition = 20;
    }

    pdf.setFontSize(16);
    pdf.text('Recap. Général', 20, yPosition);
    yPosition += 15;

    const generalTotal = chequesTotalAmount + effetsTotalAmount + payavenirsTotalAmount;
    const summaryData = [
      ['Total Chèques', formatFrenchNumber(chequesTotalAmount)],
      ['Total Effets', formatFrenchNumber(effetsTotalAmount)],
      ['Total Paiements à venir', formatFrenchNumber(payavenirsTotalAmount)],
      ['TOTAL GÉNÉRAL', formatFrenchNumber(generalTotal)],
    ];

    pdf.autoTable({
      head: [['Description', 'Montant']],
      body: summaryData,
      startY: yPosition,
      theme: 'striped',
      styles: {
        fontSize: 12,
        cellPadding: 4,
        lineWidth: 0.2,
        lineColor: [0, 0, 0],
      },
      headStyles: {
        fillColor: [52, 144, 220],
        textColor: 255,
        fontStyle: 'bold',
        lineWidth: 0.2,
        lineColor: [0, 0, 0],
      },
      columnStyles: {
        0: { halign: 'left', cellWidth: 80 },
        1: { halign: 'right', cellWidth: 50 },
      },
      didParseCell: (data) => {
        if (data.row.index === 3) {
          data.cell.styles.fontStyle = 'bold';
          data.cell.styles.fillColor = [76, 175, 80];
          data.cell.styles.textColor = 255;
          data.cell.styles.fontSize = 14;
          data.cell.styles.lineWidth = 0.2;
          data.cell.styles.lineColor = [0, 0, 0];
        }
      },
    });

    const finalY = pdf.lastAutoTable.finalY + 15;
    pdf.setFontSize(10);
    pdf.text(`Nombre de chèques: ${visibleCheques.length > 0 ? visibleCheques.length - 1 : 0}`, 20, finalY);
    pdf.text(`Nombre d'effets: ${visibleEffets.length > 0 ? visibleEffets.length - 1 : 0}`, 20, finalY + 8);
    pdf.text(`Nombre de paiements à venir: ${visiblePayavenirs.length > 0 ? visiblePayavenirs.length - 1 : 0}`, 20, finalY + 16);
    pdf.text(`Généré le: ${new Date().toLocaleString('fr-FR')}`, 20, finalY + 24);

    pdf.save(`situation-bancaire-complete-${new Date().toISOString().split('T')[0]}.pdf`);
  }

  function handleError(error, loadingMsg) {
    console.error('Error generating complete PDF:', error);
    if (loadingMsg && document.body.contains(loadingMsg)) {
      document.body.removeChild(loadingMsg);
    }
    alert(`Erreur lors de la génération du PDF complet: ${error.message}`);
  }
}

function downloadChequesPDF() {
  const loadingMsg = document.createElement('div');
  loadingMsg.innerHTML = '<div class="alert alert-info" style="position: fixed; top: 20px; right: 20px; z-index: 1000;">Génération du PDF chèques...</div>';
  document.body.appendChild(loadingMsg);

  loadScript('https://cdnjs.cloudflare.com/ajax/libs/jspdf/2.5.1/jspdf.umd.min.js')
    .then(() => loadScript('https://cdnjs.cloudflare.com/ajax/libs/jspdf-autotable/3.5.28/jspdf.plugin.autotable.min.js'))
    .then(() => generatePDF())
    .catch(error => {
      console.error('Erreur PDF:', error);
      alert('Erreur lors de la génération du PDF des chèques');
    })
    .finally(() => document.body.removeChild(loadingMsg));

  function loadScript(src) {
    return new Promise((resolve, reject) => {
      const script = document.createElement('script');
      script.src = src;
      script.onload = resolve;
      script.onerror = () => reject(new Error(`Failed to load script: ${src}`));
      document.head.appendChild(script);
    });
  }

  function parseFrenchNumber(text) {
    if (!text) return 0;
    return parseFloat(text.replace(/\s/g, '').replace(',', '.')) || 0;
  }

  function formatFrenchNumber(value) {
    if (isNaN(value)) return '0,00';
    return value
      .toFixed(2)
      .replace(/\B(?=(\d{3})+(?!\d))/g, ' ')
      .replace('.', ',');
  }

  function generatePDF() {
    const { jsPDF } = window.jspdf;
    const pdf = new jsPDF('l', 'mm', 'a4');

    pdf.setFontSize(20);
    pdf.setTextColor(30, 30, 120);
    pdf.text('Chèques à payer', 20, 20);

    const now = new Date();
    const formattedDate = now.toLocaleDateString('fr-FR');
    const formattedTime = now.toLocaleTimeString('fr-FR', { hour: '2-digit', minute: '2-digit' });
    pdf.setFontSize(11);
    pdf.setTextColor(80, 80, 80);
    pdf.text(`Généré le : ${formattedDate} à ${formattedTime}`, 20, 30);

    const chequeRows = document.querySelectorAll('.cheque-row');
    const data = [];
    let totalAmount = 0;

    chequeRows.forEach(row => {
      if (row.style.display !== 'none') {
        const cells = row.querySelectorAll('td');
        if (cells.length >= 8) {
          const montantValue = parseFrenchNumber(cells[4].textContent);
          totalAmount += montantValue;

          data.push([
            cells[1].textContent.trim(),
            formatFrenchNumber(montantValue),
            cells[5].textContent.trim(),
            cells[3].textContent.trim(),
            cells[2].textContent.trim(),
            cells[6].textContent.trim(),
            cells[7].querySelector('input')?.value || cells[7].textContent.trim()
          ]);
        }
      }
    });

    if (data.length > 0) {
      data.push(['TOTAL', formatFrenchNumber(totalAmount), '', '', '', '', '']);
    }

    pdf.autoTable({
      head: [['Numéro', 'Montant', 'Date Échéance', 'Bénéficiaire', 'Banque', 'Statut', 'Observation']],
      body: data,
      startY: 40,
      theme: 'grid',
      headStyles: { fillColor: [52, 152, 219], textColor: 255, fontStyle: 'bold', fontSize: 11 },
      styles: { fontSize: 10, cellPadding: 3, lineColor: [230, 230, 230], lineWidth: 0.1 },
      alternateRowStyles: { fillColor: [245, 245, 245] },
      columnStyles: {
        0: { halign: 'left', cellWidth: 25 },
        1: { halign: 'right', cellWidth: 30 },
        2: { halign: 'center', cellWidth: 30 },
        3: { halign: 'left', cellWidth: 45 },
        4: { halign: 'left', cellWidth: 35 },
        5: { halign: 'center', cellWidth: 30 },
        6: { halign: 'left', cellWidth: 55 },
      },
      didParseCell: (tableData) => {
        if (tableData.row.index === data.length - 1) {
          tableData.cell.styles.fontStyle = 'bold';
          tableData.cell.styles.fillColor = [230, 230, 230];
        }
      },
    });

    pdf.save(`cheques-en-circulation-${now.toISOString().split('T')[0]}.pdf`);
  }
}

