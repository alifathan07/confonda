<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta http-equiv="X-UA-Compatible" content="IE=edge" />
  <meta name="viewport" content="width=device-width, initial-scale=1, shrink-to-fit=no" />
  <meta name="description" content="Cheques" />
  <meta name="author" content="Confonda" />
  <title>Virements</title>
  <link href="/vendor/fontawesome-free/css/all.min.css" rel="stylesheet" type="text/css" />
  <link href="https://fonts.googleapis.com/css?family=Nunito:200,300,400,600,700,800,900" rel="stylesheet" />
  <link href="/css/sb-admin-2.min.css" rel="stylesheet" />
   <!-- Enhanced Status Styles -->
      
      <body>
        
        <body id="page-top">
            <div id="wrapper">
                <%- include('../../../../layouts/sidebar') %>
                <div id="content-wrapper" class="d-flex flex-column">
                    <div id="content">
                        <%- include('../../../../layouts/topbar') %>
                        <div class="container-fluid">
                            <div class="card shadow mb-4">
                                <div class="card-header py-3">
                                    <h4 class="m-0 font-weight-bold text-primary">
                                        <i class="fas fa-exchange-alt"></i> Virement
                                    </h4>
                                </div>
                                <div class="card-body">
                                    <form id="virementForm">
                                        <div class="form-row">
                                            <div class="form-group col-12 d-flex justify-content-center">
                                                <div class="col-md-6">
                                                    <label for="date">Date de saisie</label>
                                                    <input type="date" class="form-control" id="date" name="date" value="<%= virement.date ? virement.date.toISOString().slice(0,10) : '' %>">
                                                </div>
                                                <div class="col-md-6">
                                                    <label for="objet">Objet</label>
                                                    <input type="text" class="form-control" id="objet" name="objet" value="<%= virement.objet %>">
                                                </div>
                                            </div>
                                        </div>
                                        <div class="form-row">
                                            <div class="form-group col-12 col-md-6">
                                                <label for="beneficiaire">Bénéficiaire</label>
                                                <input type="text" class="form-control" id="beneficiaire" name="beneficiaire" placeholder="Nom du bénéficiaire" value="<%= virement.beneficiaire %>">
                                            </div>
                                            <div class="form-group col-12 col-md-6">
                                                <label for="montant">Montant</label>
                                                <div class="input-group">
                                                    <input type="number" step="0.01" class="form-control" id="montant" name="montant" placeholder="Montant" value="<%= virement.montant %>">
                                                    <div class="input-group-append"></div>
                                                </div> 
                                            </div>
                                          
                                            <div class="form-group col-12 col-md-6 d-flex align-items-center">
                                                <div class="custom-control custom-switch">
                                                    <input type="checkbox" class="custom-control-input" id="rtgs" name="rtgs" value="RTGS" <%= virement.rtgs ? 'checked' : '' %>>
                                                    <label class="custom-control-label" for="rtgs">RTGS</label>
                                                </div>
                                            </div>
                                        </div>
                                        <div class="form-row">
                                            <div class="form-group col-12 col-md-6">
                                                <label for="dateReglement">Date de règlement</label>
                                                <input type="date" class="form-control" id="dateReglement" name="dateReglement" value="<%= virement.dateReglement ? virement.dateReglement.toISOString().slice(0,10) : '' %>">
                                            </div>
                                            <div class="form-group col-12 col-md-6">
                                                <label for="obs">Observations</label>
                                                <textarea class="form-control" id="obs" name="obs" rows="2" placeholder="Notes ou remarques"><%= virement.obs %></textarea>
                                            </div>
                                        </div>
                                        <div class="form-group col-12 col-md-6">
                                            <label for="montantLettre">Montant en lettres</label>
                                            <input type="text" class="form-control" id="montantLettre" name="montantLettre" readonly placeholder="Montant en lettres" value="<%= virement.montantLettre %>">
                                        </div>
                                        
                                        <script>
                                        const montantWordsCache = new Map();
                                        
                                        function numberToFrenchWords(n) {
                                            if (montantWordsCache.has(n)) return montantWordsCache.get(n);
                                            if (typeof n === "string") n = n.replace(/\s/g,''); 
                                            n = BigInt(n); 
                                        
                                            if (n === 0n) return "ZÉRO";
                                        
                                            const ones = ["","UN","DEUX","TROIS","QUATRE","CINQ","SIX","SEPT","HUIT","NEUF"];
                                            const teens = ["DIX","ONZE","DOUZE","TREIZE","QUATORZE","QUINZE","SEIZE","DIX-SEPT","DIX-HUIT","DIX-NEUF"];
                                            const tens = ["","DIX","VINGT","TRENTE","QUARANTE","CINQUANTE","SOIXANTE","SOIXANTE","QUATRE-VINGT","QUATRE-VINGT"];
                                            const scales = ["","MILLE","MILLION","MILLIARD","BILLION","BILLIARD","TRILLION"];
                                        
                                            function chunkNumber(num) {
                                                let chunks = [];
                                                while (num > 0) {
                                                    chunks.push(num % 1000n);
                                                    num = num / 1000n;
                                                }
                                                return chunks;
                                            }
                                        
                                            function chunkToWords(chunk) {
                                                let h = chunk / 100n;
                                                let t = (chunk % 100n) / 10n;
                                                let o = chunk % 10n;
                                                let str = "";
                                        
                                                // Hundreds
                                                if (h > 0n) {
                                                    str += (h === 1n ? "CENT" : ones[Number(h)] + " CENT");
                                                    if (t !== 0n || o !== 0n) str += " ";
                                                }
                                        
                                                // Tens & Ones
                                                let num2 = Number(t * 10n + o);
                                                if (num2 > 0) {
                                                    if (num2 < 10) {
                                                        str += ones[num2];
                                                    } else if (num2 < 20) {
                                                        str += teens[num2 - 10];
                                                    } else {
                                                        let tenVal = Number(t);
                                                        let oneVal = Number(o);
                                        
                                                        if (tenVal === 7 || tenVal === 9) {
                                                            str += tens[tenVal] + "-" + teens[oneVal];
                                                        } else if (tenVal === 8) {
                                                            str += "QUATRE-VINGT" + (oneVal === 0 ? "S" : "-" + ones[oneVal]);
                                                        } else if (oneVal === 1 && tenVal !== 8) {
                                                            str += tens[tenVal] + "-ET-UN";
                                                        } else if (oneVal > 0) {
                                                            str += tens[tenVal] + "-" + ones[oneVal];
                                                        } else {
                                                            str += tens[tenVal];
                                                        }
                                                    }
                                                }
                                        
                                                return str.trim();
                                            }
                                        
                                            let chunks = chunkNumber(n);
                                            let words = [];
                                        
                                            for (let i = chunks.length - 1; i >= 0; i--) {
                                                let chunk = chunks[i];
                                                if (chunk === 0n) continue;
                                                let chunkWord = chunkToWords(chunk);
                                                if (i > 0) {
                                                    if (i === 1 && chunk === 1n) chunkWord = scales[i]; 
                                                    else chunkWord += " " + scales[i];
                                                    if (chunk > 1n && i > 1) chunkWord += "S"; 
                                                }
                                                words.push(chunkWord);
                                            }
                                        
                                            let result = words.join(" ").replace(/\s+/g,' ').trim();
                                            montantWordsCache.set(n, result);
                                            return result;
                                        }
                                        
                                        // Debounce function
                                        function debounce(fn, delay) {
                                            let timer = null;
                                            return function(...args) {
                                                clearTimeout(timer);
                                                timer = setTimeout(() => fn.apply(this, args), delay);
                                            };
                                        }
                                        
                                        document.getElementById('montant').addEventListener('input', debounce(function() {
                                            const val = this.value;
                                            if (!val) {
                                                document.getElementById('montantLettre').value = "";
                                                return;
                                            }
                                        
                                            let parts = val.split(".");
                                            let integerPart = parts[0];
                                            let decimalPart = parts[1] || "";
                                        
                                            let text = numberToFrenchWords(integerPart) + " DIRHAMS";
                                            if (decimalPart && parseInt(decimalPart, 10) > 0) {
                                                // normalize centimes to 2 digits
                                                decimalPart = decimalPart.padEnd(2, "0").slice(0,2);
                                                text += " " + numberToFrenchWords(decimalPart) + " CENTIMES";
                                            }
                                        
                                            document.getElementById('montantLettre').value = text;
                                        }, 150));
                                        </script>
                                    
                                        <div class="form-group col-12 col-md-6">
                                            <label for="rib">RIB</label>
                                            <input type="hidden" id="fournisseurId" name="fournisseurId" value="<%= virement.fournisseurId %>">
                                            <input type="text" class="form-control" id="rib" name="rib" value="<%= fournisseur.rib %>">
                                        </div>
                                        <div class="form-group col-12 col-md-6">
                                            <label for="rib">Banque</label>
                                            <input type="hidden" id="fournisseurId" name="fournisseurId" value="<%= virement.fournisseurId %>">
                                            <input type="text" class="form-control" id="banque" name="banque" value="<%= fournisseur.banque %>">
                                        </div>
                                        <div class="form-group col-12 col-md-6">
                                            <label for="rib">Agence</label>
                                            <input type="hidden" id="fournisseurId" name="fournisseurId" value="<%= virement.fournisseurId %>">
                                            <input type="text" class="form-control" id="agence" name="agence" value="<%= fournisseur.agence %>">
                                        </div>
                                        <div class="d-flex flex-column flex-md-row">
                                            <button type="submit" class="btn btn-success custom-btn mb-2 mb-md-0">
                                                <i class="fas fa-save"></i> Enregistrer
                                            </button>
                                            <button type="button" class="btn btn-primary" onclick="downloadPDF(<%= virement.id %>)">
                                                <i class="fas fa-download"></i> Télécharger PDF
                                            </button>
                                            <a href="/tresorerie" class="btn btn-secondary custom-btn ml-md-2">
                                                <i class="fas fa-arrow-left"></i> Annuler
                                            </a>
                                        </div>
                                    </form>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        
            <!-- Include Axios -->
            <script src="https://cdn.jsdelivr.net/npm/axios/dist/axios.min.js"></script>
            <script src="/vendor/jquery/jquery.min.js"></script>
            <script src="/vendor/bootstrap/js/bootstrap.bundle.min.js"></script>
            <script src="/vendor/jquery-easing/jquery.easing.min.js"></script>
            <script src="/js/sb-admin-2.min.js"></script>
            <script src="/vendor/datatables/jquery.dataTables.min.js"></script>
            <script src="/vendor/datatables/dataTables.bootstrap4.min.js"></script>
            <script src="https://cdnjs.cloudflare.com/ajax/libs/xlsx/0.18.5/xlsx.full.min.js"></script>
            <script src="/js/demo/datatables-demo.js"></script>
        
            <script>
         
                // Debounce function to limit conversion calls
                function debounce(fn, delay) {
                    let timer = null;
                    return function (...args) {
                        clearTimeout(timer);
                        timer = setTimeout(() => fn.apply(this, args), delay);
                    };
                }
        
                document.getElementById('montant').addEventListener('input', debounce(function () {
                    const val = this.value;
                    if (!val) {
                        document.getElementById('montantLettre').value = "";
                        return;
                    }
                    const num = parseInt(val, 10);
                    let text = "";
                    if (!isNaN(num) && num >= 0) {
                        text = numberToFrenchWords(num);
                        if (val.includes('.')) {
                            const decimals = val.split('.')[1];
                            if (decimals && parseInt(decimals, 10) > 0) {
                                text += " virgule " + numberToFrenchWords(parseInt(decimals, 10));
                            }
                        }
                    }
                    document.getElementById('montantLettre').value = text;
                }, 150));
        
                $(document).ready(function () {
                    let fournisseurs = [];
        
                    // Load suppliers from API
                    $.ajax({
                        url: '/api/fournisseurs',
                        method: 'GET',
                        success: function (data) {
                            fournisseurs = data;
                            console.log("Fournisseurs chargés :", fournisseurs);
                        },
                        error: function (xhr, status, error) {
                            console.error('Erreur lors de la récupération des fournisseurs:', error);
                        }
                    });
        
                    // Auto-complete RIB based on beneficiary input
                    $('#beneficiaire').on('input', function () {
                        const inputName = $(this).val().trim().toLowerCase();
                        if (inputName.length > 1) {
                            const found = fournisseurs.find(f => f.name.toLowerCase().startsWith(inputName));
                            if (found) {
                                $('#rib').val(found.rib);
                                $('#fournisseurId').val(found.id);
                            } else {
                                $('#rib').val("");
                                $('#fournisseurId').val("");
                            }
                        } else {
                            $('#rib').val("");
                            $('#fournisseurId').val("");
                        }
                    });
        
                    // Handle form submission with Axios
                    $('#virementForm').on('submit', function (e) {
                        e.preventDefault(); // Prevent default form submission
        
                        // Collect form data
                        const formData = {
                            date: $('#date').val(),
                            objet: $('#objet').val(),
                            beneficiaire: $('#beneficiaire').val(),
                            montant: parseFloat($('#montant').val()) || 0,
                            cause: $('#cause').val(),
                            rtgs: $('#rtgs').is(':checked'),
                            dateReglement: $('#dateReglement').val(),
                            obs: $('#obs').val(),
                            montantLettre: $('#montantLettre').val(),
                            fournisseurId: $('#fournisseurId').val(),
                            rib: $('#rib').val()
                        };
        
                        // Send data via Axios
                        axios.patch(`/tresorerie/virements/banque/<%= banqueId %>/update/<%= virement.id %>`, formData)
                            .then(response => {
                                alert('Virement mis à jour avec succès !');
                                window.location.href = '/tresorerie/virements/banque/' + '<%= banqueId %>';
                            })
                            .catch(error => {
                                console.error('Erreur lors de la mise à jour du virement:', error);
                                alert('Erreur lors de la mise à jour du virement. Veuillez réessayer.');
                            });
                    });
                });
        
                async function downloadPDF(id) {
                    try {
                        const res = await fetch(`/tresorerie/virements/banque/${id}/pdf`);
                        if (!res.ok) throw new Error('Erreur lors du téléchargement');
                        const blob = await res.blob();
                        const url = URL.createObjectURL(blob);
                        const link = document.createElement('a');
                        link.href = url;
                        link.download = `virement_${id}.pdf`;
                        document.body.appendChild(link);
                        link.click();
                        link.remove();
                        URL.revokeObjectURL(url);
                    } catch (err) {
                        console.error(err);
                        alert('Erreur lors du téléchargement du PDF');
                    }
                }
            </script>
        </body>