<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8" />
  <meta http-equiv="X-UA-Compatible" content="IE=edge" />
  <meta name="viewport" content="width=device-width, initial-scale=1, shrink-to-fit=no" />
  <meta name="description" content="Virements" />
  <meta name="author" content="Confonda" />
  <title>Virements</title>
  <link href="/vendor/fontawesome-free/css/all.min.css" rel="stylesheet" type="text/css" />
  <link href="https://fonts.googleapis.com/css?family=Nunito:200,300,400,600,700,800,900" rel="stylesheet" />
  <link href="/css/sb-admin-2.min.css" rel="stylesheet" />
  <style>
    .virement-table td,
    .virement-table th {
      vertical-align: middle;
    }

    .virement-table.table-bordered td,
    .virement-table.table-bordered th {
      border-color: #e6e8f0;
    }

    .allocations {
      display: grid;
      gap: 6px;
    }

    .alloc-line {
      display: flex;
      justify-content: space-between;
      gap: 10px;
      padding: 6px 10px;
      border: 1px solid #e9ecef;
      border-radius: 10px;
      background: #fff;
    }

    .alloc-name {
      min-width: 0;
      overflow: hidden;
      text-overflow: ellipsis;
      white-space: nowrap;
    }

    .alloc-amount {
      white-space: nowrap;
      font-weight: 700;
    }

    .table-actions {
      display: flex;
      gap: 6px;
      justify-content: flex-end;
    }

    .cell-edit {
      min-width: 120px;
    }

    .cell-edit[contenteditable="true"] {
      outline: none;
    }

    .cell-edit[contenteditable="true"]:focus {
      box-shadow: inset 0 0 0 2px rgba(78, 115, 223, .25);
      border-radius: 6px;
    }

    .obs-cell {
      min-width: 260px;
      max-width: 420px;
      white-space: normal;
      line-height: 1.25;
    }

    .obs-cell[contenteditable="true"] {
      padding: 8px 10px;
    }

    #filterTypeDropdown .dropdown-menu {
      z-index: 2000;
    }

    body {
      padding-bottom: 26px;
    }

    .bottom-hscroll {
      position: fixed;
      left: 0;
      right: 0;
      bottom: 0;
      height: 18px;
      overflow-x: scroll;
      overflow-y: hidden;
      background: rgba(255, 255, 255, .95);
      border-top: 1px solid rgba(0, 0, 0, .08);
      z-index: 4000;
      display: block;
    }

    .bottom-hscroll::-webkit-scrollbar {
      height: 12px;
    }

    .bottom-hscroll::-webkit-scrollbar-thumb {
      background: rgba(108, 117, 125, .6);
      border-radius: 10px;
    }

    .bottom-hscroll::-webkit-scrollbar-track {
      background: rgba(108, 117, 125, .12);
    }

    .bottom-hscroll-inner {
      height: 1px;
    }
  </style>
</head>

<body id="page-top">
  <div id="wrapper">
    <%- include('../../../../layouts/sidebar') %>
      <div id="content-wrapper" class="d-flex flex-column">
        <div id="content">
          <%- include('../../../../layouts/topbar') %>

            <div class="container-fluid">
              <!-- Page header -->
              <div class="d-flex align-items-center justify-content-between mb-3">
                <div>
                  <h1 class="h3 mb-0 text-gray-800">Virements</h1>
                  <div class="small text-muted" id="virementCount">
                    <% if (typeof virements !=='undefined' ) { %>
                      <%= virements.length %> résultat(s)<% } %>
                  </div>
                </div>
                <div class="d-flex" style="gap: 10px;">
                  <button id="btnExportPdf" type="button" class="btn btn-outline-danger">
                    <i class="fas fa-file-pdf mr-2"></i>PDF
                  </button>
                  <button id="btnExportExcel" type="button" class="btn btn-outline-success">
                    <i class="fas fa-file-excel mr-2"></i>Excel
                  </button>
                  <a href="/tresorerie/virements/banques" class="btn btn-primary">
                    <i class="fas fa-plus mr-2"></i>Nouveau
                  </a>
                </div>
              </div>

              <div class="card shadow mb-4">
                <div class="card-body">
                  <!-- Filters row -->
                  <div class="row mb-3">
                    <div class="col-md-3 mb-2">
                      <label class="small text-muted mb-1">Filtre</label>
                      <div class="dropdown" id="filterTypeDropdown">
                        <button class="btn btn-success dropdown-toggle w-100" type="button" id="filterTypeBtn"
                          data-toggle="dropdown" aria-haspopup="true" aria-expanded="false">
                          Filtrer Par
                        </button>
                        <div class="dropdown-menu w-100" id="filterTypeMenu" aria-labelledby="filterTypeBtn">
                          <button class="dropdown-item" type="button"
                            data-filter-type="beneficiaire">Bénéficiaire</button>
                          <button class="dropdown-item" type="button" data-filter-type="chantier">Chantier</button>
                          <button class="dropdown-item" type="button" data-filter-type="banque">Banque</button>
                          <button class="dropdown-item" type="button" data-filter-type="montant">Montant</button>
                        </div>
                      </div>

                      <div id="filterDynamicContainer" class="mt-2">
                        <div id="filterBoxBeneficiaire" style="display:none;">
                          <input id="filterBeneficiaire" class="form-control" placeholder="Bénéficiaire..." />
                        </div>
                        <div id="filterBoxChantier" style="display:none;">
                          <select id="filterChantier" class="form-control">
                            <option value="">Tous</option>
                            <% (chantiers || []).forEach(c=> { %>
                              <option value="<%= c.id %>">
                                <%= c.nom %>
                              </option>
                              <% }) %>
                          </select>
                        </div>
                        <div id="filterBoxBanque" style="display:none;">
                          <input id="filterBanque" class="form-control" placeholder="Banque..." />
                        </div>
                        <div id="filterBoxMontant" style="display:none;">
                          <input id="filterMontant" class="form-control" placeholder="ex: 1200" />
                        </div>
                      </div>
                    </div>

                    <div class="col-md-2 mb-2 d-flex align-items-end">
                      <button id="btnClearFilters" type="button" class="btn btn-danger w-100" style="display:none;">
                        <i class="fas fa-times mr-1"></i>Annuler filtre
                      </button>
                    </div>

                    <div class="col-md-2 mb-2">
                      <label class="small text-muted mb-1">Date saisie du</label>
                      <input id="filterDateFrom" type="date" class="form-control" />
                    </div>
                    <div class="col-md-2 mb-2">
                      <label class="small text-muted mb-1">Date saisie au</label>
                      <input id="filterDateTo" type="date" class="form-control" />
                    </div>
                  </div>

                  <!-- Table -->
                  <div class="table-responsive" id="virementsTableResponsive">
                    <% function fmtDate(d) { if (!d) return '' ; const dt=new Date(d); if (isNaN(dt)) return '' ; return
                      String(dt.getDate()).padStart(2,'0') + '/' + String(dt.getMonth()+1).padStart(2,'0') + '/' +
                      dt.getFullYear(); } %>
                      <table class="table table-sm table-hover table-bordered virement-table"
                        style="min-width: 1000px;">
                        <thead class="thead-light">
                          <tr>
                            <th>Bénéficiaire</th>
                            <th>Banque</th>
                            <th class="text-right">Montant</th>
                            <th>Date Saisie</th>
                            <th>Observation</th>
                            <th>Date Règlement</th>
                            <th>Chantier</th>
                            <th>Montant chantier</th>
                            <th class="text-right">Actions</th>
                          </tr>
                        </thead>
                        <tbody id="virementTbody">
                          <% if (typeof virements==='undefined' || !virements.length) { %>
                            <tr>
                              <td colspan="8" class="text-center text-muted">Aucun virement disponible.</td>
                            </tr>
                            <% } else { %>
                              <% virements.forEach(v=> { %>
                                <tr data-id="<%= v.id %>">
                                  <td class="cell-edit" contenteditable="true" data-name="beneficiaire">
                                    <%= v.beneficiaire || '' %>
                                  </td>
                                  <td class="cell-edit" contenteditable="true" data-name="banque">
                                    <%= v.banque?.name || '' %>
                                  </td>
                                  <td class="text-right cell-edit" contenteditable="true" data-name="montant">
                                    <%= Number(v.montant || 0).toLocaleString('fr-FR', { minimumFractionDigits: 2,
                                      maximumFractionDigits: 2 }) %>
                                  </td>
                                  <td class="cell-edit" contenteditable="true" data-name="dateSaisie">
                                    <%= fmtDate(v.date) %>
                                  </td>
                                  <td class="cell-edit obs-cell" contenteditable="true" data-name="obs">
                                    <%= v.obs || '' %>
                                  </td>
                                  <td class="cell-edit" contenteditable="true" data-name="dateReglement">
                                    <%= fmtDate(v.dateReglement) %>
                                  </td>
                                  <td>
                                    <div class="allocations">
                                      <% const _displayAllocs=(v.allocations && v.allocations.length) ? v.allocations :
                                        []; %>
                                        <% if (_displayAllocs.length> 0) { %>
                                          <% _displayAllocs.forEach(a=> { %>
                                            <div class="alloc-line"
                                              data-chantier-id="<%= (a.chantierId != null ? a.chantierId : (a.chantier ? a.chantier.id : '')) %>">
                                              <div class="alloc-name">
                                                <%= a.chantier ? a.chantier.nom : '' %>
                                              </div>
                                            </div>
                                            <% }) %>
                                              <% } else if (v.chantier) { %>
                                                <div class="alloc-line" data-chantier-id="<%= v.chantier.id %>">
                                                  <div class="alloc-name">
                                                    <%= v.chantier.nom %>
                                                  </div>
                                                </div>
                                                <% } %>
                                    </div>
                                  </td>
                                  <td>
                                    <div class="allocations">
                                      <% if (_displayAllocs.length> 0) { %>
                                        <% _displayAllocs.forEach(a=> { %>
                                          <div class="alloc-line">
                                            <div class="alloc-name">&nbsp;</div>
                                            <div class="alloc-amount">
                                              <%= (a.montant || 0).toLocaleString('fr-FR', { minimumFractionDigits: 2,
                                                maximumFractionDigits: 2 }) %>
                                            </div>
                                          </div>
                                          <% }) %>
                                            <% } else if (v.chantier) { %>
                                              <div class="alloc-line">
                                                <div class="alloc-name">&nbsp;</div>
                                                <div class="alloc-amount">
                                                  <%= (v.montant || 0).toLocaleString('fr-FR', { minimumFractionDigits:
                                                    2, maximumFractionDigits: 2 }) %>
                                                </div>
                                              </div>
                                              <% } %>
                                    </div>
                                  </td>
                                  <td class="text-right">
                                    <div class="table-actions">
                                      <button class="btn btn-sm btn-outline-secondary btn-alloc" title="Chantiers"
                                        data-id="<%= v.id %>"
                                        data-allocs="<%= escape(JSON.stringify((v.allocations || []).map(a => ({ chantierId: a.chantierId, montant: a.montant })))) %>">
                                        <i class="fas fa-project-diagram"></i>
                                      </button>
                                      <button class="btn btn-sm btn-outline-danger btn-download-pdf"
                                        title="Télécharger PDF" data-id="<%= v.id %>">
                                        <i class="fas fa-download"></i>
                                      </button>
                                      <button class="btn btn-sm btn-outline-danger btn-delete" title="Supprimer"
                                        data-id="<%= v.id %>">
                                        <i class="fas fa-trash"></i>
                                      </button>
                                    </div>
                                  </td>
                                </tr>
                                <% }) %>
                                  <% } %>
                        </tbody>
                        <tfoot>
                          <tr>
                            <th colspan="2" class="text-right">Total</th>
                            <th class="text-right" id="totalMontantCell">0,00</th>
                            <th colspan="6"></th>
                          </tr>
                          <tr id="totalChantierRow" style="display:none;">
                            <th colspan="7" class="text-right">Total chantier</th>
                            <th class="text-right" id="totalMontantChantierCell">0,00</th>
                            <th colspan="1"></th>
                          </tr>
                        </tfoot>
                      </table>
                  </div>

                  <!-- Fixed bottom scrollbar -->
                  <div id="virementsBottomHScroll" class="bottom-hscroll" aria-hidden="true">
                    <div id="virementsBottomHScrollInner" class="bottom-hscroll-inner"></div>
                  </div>

                  <!-- Results info -->
                  <div class="d-flex align-items-center justify-content-between mt-3">
                    <div class="small text-muted" id="virementInfo">
                      <% if (typeof virements !=='undefined' ) { %>
                        <%= virements.length %> résultat(s)<% } %>
                    </div>
                  </div>
                </div>
              </div>
            </div>
        </div>
        <div class="modal fade" id="allocModal" tabindex="-1" role="dialog" aria-hidden="true">
          <div class="modal-dialog modal-lg" role="document">
            <div class="modal-content">
              <div class="modal-header">
                <h5 class="modal-title">Chantiers & montants</h5>
                <button type="button" class="close" data-dismiss="modal" aria-label="Close">
                  <span aria-hidden="true">&times;</span>
                </button>
              </div>
              <div class="modal-body">
                <div class="small text-muted" id="allocTotals"></div>
                <div id="allocList" class="d-grid" style="gap: 10px;"></div>
                <button id="btnAddAllocLine" class="btn btn-sm btn-outline-primary mt-3"><i
                    class="fas fa-plus mr-2"></i>Ajouter chantier</button>
              </div>
              <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-dismiss="modal">Fermer</button>
                <button type="button" class="btn btn-primary" id="btnSaveAlloc">Enregistrer</button>
              </div>
            </div>
          </div>
        </div>

      </div>
  </div>

  <script src="/vendor/jquery/jquery.min.js"></script>
  <script src="/vendor/bootstrap/js/bootstrap.bundle.min.js"></script>
  <script src="/vendor/jquery-easing/jquery.easing.min.js"></script>
  <script src="/js/sb-admin-2.min.js"></script>
  <script src="https://cdnjs.cloudflare.com/ajax/libs/jspdf/2.5.1/jspdf.umd.min.js"></script>
  <script src="https://cdnjs.cloudflare.com/ajax/libs/jspdf-autotable/3.8.3/jspdf.plugin.autotable.min.js"></script>
  <script src="https://cdnjs.cloudflare.com/ajax/libs/xlsx/0.18.5/xlsx.full.min.js"></script>

  <script type="application/json" id="virementsPageData">
    <%- JSON.stringify({
      chantiers: (typeof chantiers !== 'undefined' ? chantiers : []).map(c => ({ id: c.id, nom: c.nom }))
    }) %>
  </script>

  <script>
    const virementsPageData = JSON.parse(document.getElementById('virementsPageData').textContent);
    (function () {
      /* ── helpers ── */
      function fmtFr(d) {
        if (!d) return '';
        const s = String(d).trim();
        const iso = s.match(/^(\d{4})-(\d{2})-(\d{2})/);
        if (iso) return `${iso[3]}/${iso[2]}/${iso[1]}`;
        if (/^\d{2}\/\d{2}\/\d{4}$/.test(s)) return s;
        const dt = new Date(s);
        return isNaN(dt) ? '' : dt.toLocaleDateString('fr-FR');
      }

      function moneyFr(v) {
        return Number(v || 0).toLocaleString('fr-FR', { minimumFractionDigits: 2, maximumFractionDigits: 2 });
      }

      function parseMoney(v) {
        const s = String(v || '').trim();
        if (!s) return null;
        const n = Number(s.replace(/\s/g, '').replace(/[^0-9,.-]/g, '').replace(',', '.'));
        return isNaN(n) ? null : n;
      }

      function dateToISO(str) {
        if (!str) return null;
        const parts = str.trim().split('/');
        if (parts.length !== 3) return null;
        const [dd, mm, yyyy] = parts.map(p => p.trim());
        if (!dd || !mm || !yyyy) return null;
        const val = `${yyyy.padStart(4, '0')}-${mm.padStart(2, '0')}-${dd.padStart(2, '0')}`;
        return isNaN(new Date(val)) ? null : val;
      }

      /* ── DOM refs ── */
      const $tbody = document.getElementById('virementTbody');
      const $totalCell = document.getElementById('totalMontantCell');
      const $filterTypeBtn = document.getElementById('filterTypeBtn');
      const $filterTypeDropdown = document.getElementById('filterTypeDropdown');
      const $filterTypeMenu = document.getElementById('filterTypeMenu');
      const $btnClearFilters = document.getElementById('btnClearFilters');
      const $filterBoxBeneficiaire = document.getElementById('filterBoxBeneficiaire');
      const $filterBoxChantier = document.getElementById('filterBoxChantier');
      const $filterBoxBanque = document.getElementById('filterBoxBanque');
      const $filterBoxMontant = document.getElementById('filterBoxMontant');
      const $filterBeneficiaire = document.getElementById('filterBeneficiaire');
      const $filterChantier = document.getElementById('filterChantier');
      const $filterBanque = document.getElementById('filterBanque');
      const $filterMontant = document.getElementById('filterMontant');
      const $filterDateFrom = document.getElementById('filterDateFrom');
      const $filterDateTo = document.getElementById('filterDateTo');
      const $btnExportPdf = document.getElementById('btnExportPdf');
      const $btnExportExcel = document.getElementById('btnExportExcel');

      let activeFilterType = '';

      /* ── filter visibility ── */
      function setFilterType(type) {
        const t = String(type || '').trim();
        activeFilterType = t;
        if ($filterBoxBeneficiaire) $filterBoxBeneficiaire.style.display = (t === 'beneficiaire') ? '' : 'none';
        if ($filterBoxChantier) $filterBoxChantier.style.display = (t === 'chantier') ? '' : 'none';
        if ($filterBoxBanque) $filterBoxBanque.style.display = (t === 'banque') ? '' : 'none';
        if ($filterBoxMontant) $filterBoxMontant.style.display = (t === 'montant') ? '' : 'none';

        if ($filterTypeBtn) {
          $filterTypeBtn.textContent = t === 'beneficiaire' ? 'Bénéficiaire'
            : t === 'chantier' ? 'Chantier'
              : t === 'banque' ? 'Banque'
                : t === 'montant' ? 'Montant'
                  : 'Filtrer Par';
        }
        updateClearBtn();
        applyFilters();
      }

      function updateClearBtn() {
        if (!$btnClearFilters) return;
        const active = !!(activeFilterType ||
          ($filterBeneficiaire && $filterBeneficiaire.value) ||
          ($filterChantier && $filterChantier.value) ||
          ($filterBanque && $filterBanque.value) ||
          ($filterMontant && $filterMontant.value) ||
          ($filterDateFrom && $filterDateFrom.value) ||
          ($filterDateTo && $filterDateTo.value));
        $btnClearFilters.style.display = active ? '' : 'none';
      }

      function clearFilters() {
        activeFilterType = '';
        if ($filterBeneficiaire) $filterBeneficiaire.value = '';
        if ($filterChantier) $filterChantier.value = '';
        if ($filterBanque) $filterBanque.value = '';
        if ($filterMontant) $filterMontant.value = '';
        if ($filterDateFrom) $filterDateFrom.value = '';
        if ($filterDateTo) $filterDateTo.value = '';
        setFilterType('');
      }

      /* ── dropdown toggle ── */
      function toggleMenu(forceOpen) {
        if (!$filterTypeDropdown || !$filterTypeMenu) return;
        const open = typeof forceOpen === 'boolean' ? forceOpen : !$filterTypeMenu.classList.contains('show');
        $filterTypeDropdown.classList.toggle('show', open);
        $filterTypeMenu.classList.toggle('show', open);
        if ($filterTypeBtn) $filterTypeBtn.setAttribute('aria-expanded', String(open));
      }

      if ($filterTypeBtn) $filterTypeBtn.addEventListener('click', e => { e.preventDefault(); toggleMenu(); });
      document.addEventListener('click', e => {
        if ($filterTypeDropdown && !$filterTypeDropdown.contains(e.target)) toggleMenu(false);
      });
      if ($filterTypeDropdown) {
        $filterTypeDropdown.addEventListener('click', e => {
          const btn = e.target && e.target.closest ? e.target.closest('[data-filter-type]') : null;
          if (!btn) return;
          setFilterType(btn.getAttribute('data-filter-type'));
          toggleMenu(false);
        });
      }

      if ($btnClearFilters) $btnClearFilters.addEventListener('click', clearFilters);

      /* ── filtering ── */
      function applyFilters() {
        const benVal = ($filterBeneficiaire && $filterBeneficiaire.value || '').toLowerCase().trim();
        const chVal = $filterChantier && $filterChantier.value || '';
        const banVal = ($filterBanque && $filterBanque.value || '').toLowerCase().trim();
        const mtVal = parseMoney($filterMontant && $filterMontant.value);
        const dateFrom = $filterDateFrom && $filterDateFrom.value;
        const dateTo = $filterDateTo && $filterDateTo.value;

        const rows = $tbody ? $tbody.querySelectorAll('tr[data-id]') : [];
        let total = 0;
        let totalChantier = 0;
        let shown = 0;

        rows.forEach(tr => {
          let show = true;

          if (benVal) {
            const cell = tr.querySelector('td[data-name="beneficiaire"]');
            show = show && cell && cell.textContent.toLowerCase().includes(benVal);
          }

          const allocTds = tr.querySelectorAll('td .allocations');
          const hasAllocs = allocTds.length === 2;
          let rowHasChantier = false;
          let rowChantierAmt = 0;

          if (hasAllocs) {
            const nameLines = allocTds[0].querySelectorAll('.alloc-line');
            const amtLines = allocTds[1].querySelectorAll('.alloc-line');

            nameLines.forEach((nLine, i) => {
              const aLine = amtLines[i];
              const cId = nLine.getAttribute('data-chantier-id');

              let lineMatch = true;
              if (chVal) {
                lineMatch = cId === chVal;
                if (lineMatch) {
                  rowHasChantier = true;
                  if (aLine) {
                    const amtText = aLine.querySelector('.alloc-amount');
                    const amt = parseMoney(amtText ? amtText.textContent : '');
                    if (amt !== null) rowChantierAmt += amt;
                  }
                }
              }

              nLine.style.display = lineMatch ? '' : 'none';
              if (aLine) aLine.style.display = lineMatch ? '' : 'none';
            });
          }

          if (chVal) {
            show = show && rowHasChantier;
          }

          if (banVal) {
            const cell = tr.querySelector('td[data-name="banque"]');
            show = show && cell && cell.textContent.toLowerCase().includes(banVal);
          }
          if (mtVal !== null) {
            const cell = tr.querySelector('td[data-name="montant"]');
            const v = parseMoney(cell ? cell.textContent : '');
            show = show && v !== null && Math.abs(v - mtVal) < 0.01;
          }
          if (dateFrom || dateTo) {
            const cell = tr.querySelector('td[data-name="dateSaisie"]');
            const iso = dateToISO(cell ? cell.textContent.trim() : '');
            if (iso) {
              const d = new Date(iso);
              if (dateFrom && d < new Date(dateFrom)) show = false;
              if (dateTo && d > new Date(dateTo)) show = false;
            } else {
              show = false;
            }
          }

          tr.style.display = show ? '' : 'none';
          if (show) {
            const mc = tr.querySelector('td[data-name="montant"]');
            const v = parseMoney(mc ? mc.textContent : '');
            if (v !== null) total += v;
            if (chVal) totalChantier += rowChantierAmt;
            shown++;
          }
        });

        if ($totalCell) $totalCell.textContent = moneyFr(total);
        const tcRow = document.getElementById('totalChantierRow');
        const tcCell = document.getElementById('totalMontantChantierCell');

        if (chVal) {
          if (tcRow) tcRow.style.display = '';
          if (tcCell) tcCell.textContent = moneyFr(totalChantier);
        } else {
          if (tcRow) tcRow.style.display = 'none';
          if (tcCell) tcCell.textContent = '0,00';
        }

        const info = document.getElementById('virementInfo');
        if (info) info.textContent = `${shown} résultat(s)`;
      }

      /* filter inputs */
      [$filterBeneficiaire, $filterBanque, $filterMontant].forEach(el => {
        if (el) el.addEventListener('input', () => { updateClearBtn(); applyFilters(); });
      });
      if ($filterChantier) $filterChantier.addEventListener('change', () => { updateClearBtn(); applyFilters(); });
      if ($filterDateFrom) $filterDateFrom.addEventListener('change', () => { updateClearBtn(); applyFilters(); });
      if ($filterDateTo) $filterDateTo.addEventListener('change', () => { updateClearBtn(); applyFilters(); });

      /* ── total compute on load ── */
      applyFilters();

      /* ── bottom scrollbar sync ── */
      function updateBottomHScroll() {
        const sc = document.getElementById('virementsTableResponsive');
        const bar = document.getElementById('virementsBottomHScroll');
        const inner = document.getElementById('virementsBottomHScrollInner');
        if (!sc || !bar || !inner) return;
        inner.style.width = sc.scrollWidth + 'px';
        bar.scrollLeft = sc.scrollLeft;
      }

      (function initHScroll() {
        const sc = document.getElementById('virementsTableResponsive');
        const bar = document.getElementById('virementsBottomHScroll');
        if (!sc || !bar) return;
        let lock = false;
        sc.addEventListener('scroll', () => { if (lock) return; lock = true; bar.scrollLeft = sc.scrollLeft; lock = false; }, { passive: true });
        bar.addEventListener('scroll', () => { if (lock) return; lock = true; sc.scrollLeft = bar.scrollLeft; lock = false; }, { passive: true });
        window.addEventListener('resize', updateBottomHScroll);
        setTimeout(updateBottomHScroll, 0);
        window.addEventListener('load', () => { updateBottomHScroll(); setTimeout(updateBottomHScroll, 200); });
      })();

      /* ── inline edit (blur → PATCH) ── */
      function sanitize(s) {
        const d = document.createElement('div');
        d.textContent = s;
        return d.innerHTML;
      }

      let dirtyRows = new Set();

      if ($tbody) {
        $tbody.addEventListener('input', e => {
          const td = e.target.closest('td[data-name]');
          if (!td) return;
          const tr = td.closest('tr[data-id]');
          if (tr) dirtyRows.add(tr);
        });

        $tbody.addEventListener('change', e => {
          const sel = e.target.closest('select[data-name="chantier"]');
          if (!sel) return;
          const tr = sel.closest('tr[data-id]');
          if (tr) { dirtyRows.add(tr); saveRow(tr); }
        });

        $tbody.addEventListener('focusout', async e => {
          const td = e.target.closest('td[data-name]');
          if (!td) return;
          const tr = td.closest('tr[data-id]');
          if (!tr || !dirtyRows.has(tr)) return;
          await saveRow(tr);
        }, true);
      }

      async function saveRow(tr) {
        const id = tr.dataset.id;
        if (!id) return;
        const data = {};
        tr.querySelectorAll('[data-name]').forEach(el => {
          const key = el.getAttribute('data-name');
          if (el.tagName === 'SELECT') {
            data[key] = el.value || null;
          } else {
            let val = el.textContent.trim();
            if (key === 'montant') {
              const n = parseMoney(val);
              if (n === null) return;
              data[key] = n;
              data.montantLettre = null; // backend will compute if needed
            } else if (key === 'dateSaisie' || key === 'dateReglement') {
              data[key] = dateToISO(val);
            } else {
              data[key] = val;
            }
          }
        });

        try {
          const res = await fetch(`/tresorerie/virements/update/${id}`, {
            method: 'PATCH',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(data)
          });
          const json = await res.json().catch(() => ({}));
          if (res.ok) {
            dirtyRows.delete(tr);
            applyFilters();
          } else {
            alert(json.message || 'Erreur mise à jour');
          }
        } catch (err) {
          alert(err.message || 'Erreur réseau');
        }
      }

      /* ── delete & pdf per-row ── */
      if ($tbody) {
        $tbody.addEventListener('click', async e => {
          const btnDel = e.target.closest('.btn-delete');
          const btnPdf = e.target.closest('.btn-download-pdf');
          const tr = e.target.closest('tr[data-id]');
          const id = tr && tr.dataset.id;
          if (!id) return;

          if (btnDel) {
            if (!confirm('Supprimer ce virement ?')) return;
            const res = await fetch(`/tresorerie/virements/delete/${id}`, { method: 'DELETE' });
            if (res.ok) { tr.remove(); applyFilters(); }
            else alert('Erreur suppression');
            return;
          }

          if (btnPdf) {
            try {
              const res = await fetch(`/tresorerie/virements/banque/${id}/pdf`);
              if (!res.ok) throw new Error('Erreur téléchargement');
              const blob = await res.blob();
              const url = URL.createObjectURL(blob);
              const a = document.createElement('a');
              a.href = url; a.download = `virement_${id}.pdf`;
              document.body.appendChild(a); a.click(); a.remove();
              URL.revokeObjectURL(url);
            } catch (err) { alert(err.message); }
          }
        });
      }

      /* ── bulk PDF export ── */
      if ($btnExportPdf) {
        $btnExportPdf.addEventListener('click', () => {
          const { jsPDF } = window.jspdf;
          const table = document.getElementById('virementsTableResponsive').querySelector('table');
          const headers = Array.from(table.querySelectorAll('thead th')).slice(0, -1).map(th => th.innerText);
          const rows = [];
          document.querySelectorAll('#virementTbody tr[data-id]').forEach(tr => {
            if (tr.style.display === 'none') return;
            const row = [];
            tr.querySelectorAll('td').forEach((td, i) => {
              if (i === tr.cells.length - 1) return;
              let val = td.textContent.trim();
              if (td.querySelector('.allocations')) {
                const lines = td.querySelectorAll('.alloc-line > div');
                val = Array.from(lines).map(l => l.innerText || l.textContent).map(t => t.replace(/\u00A0/g, '').trim()).filter(t => t).join(', ');
              }
              row.push(val);
            });
            rows.push(row);
          });
          if (!rows.length) return alert('Aucune donnée à exporter.');
          const doc = new jsPDF({ unit: 'mm', format: 'a4' });
          doc.text('Liste des Virements', 10, 15);
          doc.autoTable({ head: [headers], body: rows, startY: 22, theme: 'grid' });
          doc.save('virements.pdf');
        });
      }

      /* ── bulk Excel export ── */
      if ($btnExportExcel) {
        $btnExportExcel.addEventListener('click', () => {
          const table = document.getElementById('virementsTableResponsive').querySelector('table');
          const headers = Array.from(table.querySelectorAll('thead th')).slice(0, -1).map(th => th.innerText);
          const rows = [];
          document.querySelectorAll('#virementTbody tr[data-id]').forEach(tr => {
            if (tr.style.display === 'none') return;
            const row = [];
            tr.querySelectorAll('td').forEach((td, i) => {
              if (i === tr.cells.length - 1) return;

              let val = td.textContent.trim();
              if (td.querySelector('.allocations')) {
                const lines = td.querySelectorAll('.alloc-line > div');
                val = Array.from(lines).map(l => l.innerText || l.textContent).map(t => t.replace(/\u00A0/g, '').trim()).filter(t => t).join(', ');
              }

              if (td.dataset.name === 'montant') {
                const n = parseMoney(val);
                if (n !== null) val = n;
              }
              row.push(val);
            });
            rows.push(row);
          });
          if (!rows.length) return alert('Aucune donnée à exporter.');
          const wb = XLSX.utils.book_new();
          const ws = XLSX.utils.aoa_to_sheet([headers, ...rows]);
          XLSX.utils.book_append_sheet(wb, ws, 'Virements');
          XLSX.writeFile(wb, 'virements.xlsx');
        });
      }

      /* ── multi-chantier allocation logic ── */
      const chantiers = virementsPageData.chantiers;
      const $allocModal = $('#allocModal');
      const $allocList = document.getElementById('allocList');
      const $btnAddAllocLine = document.getElementById('btnAddAllocLine');
      const $btnSaveAlloc = document.getElementById('btnSaveAlloc');

      let editingAllocVirementId = null;
      let editingAllocations = [];
      let editingAllocVirementMontant = null;

      if ($tbody) {
        $tbody.addEventListener('click', async e => {
          const btnAlloc = e.target.closest('.btn-alloc');
          if (btnAlloc) {
            e.preventDefault();
            const id = btnAlloc.getAttribute('data-id');
            const tr = btnAlloc.closest('tr');
            if (!tr || !id) return;

            editingAllocVirementId = id;
            const mc = tr.querySelector('td[data-name="montant"]');
            editingAllocVirementMontant = mc ? parseMoney(mc.textContent) : 0;

            const baseAllocsRaw = btnAlloc.getAttribute('data-allocs');
            let baseAllocs = [];
            try {
              if (baseAllocsRaw) baseAllocs = JSON.parse(unescape(baseAllocsRaw));
            } catch (e) { }

            editingAllocations = baseAllocs.map(a => ({ chantierId: a.chantierId, montant: a.montant }));
            if (!editingAllocations.length) editingAllocations = [{ chantierId: '', montant: '' }];
            renderAllocEditor();
            $allocModal.modal('show');
          }
        });
      }

      function updateAllocTotals() {
        const el = document.getElementById('allocTotals');
        if (!el) return;

        const amounts = editingAllocations
          .map(a => parseMoney(a.montant))
          .filter(v => v !== null);

        const sum = amounts.reduce((acc, v) => acc + Number(v || 0), 0);
        const virementM = Number(editingAllocVirementMontant || 0);
        const eps = 0.01;
        if (!virementM) {
          el.textContent = `Total affectations: ${moneyFr(sum)}`;
          el.className = 'small text-muted';
          return;
        }

        const diff = sum - virementM;
        const isOver = diff > eps;
        const isEqual = Math.abs(diff) <= eps;

        el.textContent = `Total affectations: ${moneyFr(sum)} / Montant virement: ${moneyFr(virementM)}`;
        el.className = `small ${isEqual ? 'text-success' : (isOver ? 'text-danger' : 'text-warning')}`;
      }

      function renderAllocEditor() {
        if (!$allocList) return;
        $allocList.innerHTML = '';
        for (let i = 0; i < editingAllocations.length; i++) {
          const line = editingAllocations[i];

          const wrap = document.createElement('div');
          wrap.className = 'd-flex align-items-center';
          wrap.style.gap = '10px';

          const sel = document.createElement('select');
          sel.className = 'form-control';
          sel.style.flex = '1';
          const optEmpty = document.createElement('option');
          optEmpty.value = '';
          optEmpty.textContent = '-- Chantier --';
          sel.appendChild(optEmpty);
          for (const c of chantiers) {
            const o = document.createElement('option');
            o.value = String(c.id);
            o.textContent = c.nom;
            if (String(line.chantierId || '') === String(c.id)) o.selected = true;
            sel.appendChild(o);
          }

          const input = document.createElement('input');
          input.className = 'form-control';
          input.placeholder = 'Montant';
          input.style.width = '200px';
          input.value = line.montant !== undefined && line.montant !== null ? String(line.montant) : '';

          const btnRemove = document.createElement('button');
          btnRemove.className = 'btn btn-outline-danger';
          btnRemove.innerHTML = '<i class="fas fa-times"></i>';

          sel.addEventListener('change', () => { editingAllocations[i].chantierId = sel.value; });
          input.addEventListener('input', () => { editingAllocations[i].montant = input.value; updateAllocTotals(); });
          btnRemove.addEventListener('click', () => {
            editingAllocations.splice(i, 1);
            if (!editingAllocations.length) editingAllocations.push({ chantierId: '', montant: '' });
            renderAllocEditor();
          });

          wrap.appendChild(sel);
          wrap.appendChild(input);
          wrap.appendChild(btnRemove);
          $allocList.appendChild(wrap);
        }

        updateAllocTotals();
      }

      if ($btnAddAllocLine) {
        $btnAddAllocLine.addEventListener('click', () => {
          editingAllocations.push({ chantierId: '', montant: '' });
          renderAllocEditor();
        });
      }

      if ($btnSaveAlloc) {
        $btnSaveAlloc.addEventListener('click', async () => {
          if (!editingAllocVirementId) return;

          const payload = editingAllocations
            .map(a => ({ chantierId: a.chantierId, montant: parseMoney(a.montant) }))
            .filter(a => a.chantierId && a.montant !== null);

          const sum = payload.reduce((acc, a) => acc + Number(a.montant || 0), 0);
          const virementM = Number(editingAllocVirementMontant || 0);
          const eps = 0.01;
          if (virementM && (sum - virementM) > eps) {
            return alert(`Tu as dépassé le montant du virement. Total affectations: ${moneyFr(sum)} / Montant virement: ${moneyFr(virementM)}`);
          }
          if (virementM && Math.abs(sum - virementM) > eps) {
            return alert(`Le total des montants chantier doit être égal au montant du virement. Total affectations: ${moneyFr(sum)} / Montant virement: ${moneyFr(virementM)}`);
          }

          try {
            const res = await fetch(`/tresorerie/virements/${editingAllocVirementId}/allocations`, {
              method: 'PATCH',
              headers: { 'Content-Type': 'application/json' },
              body: JSON.stringify({ allocations: payload })
            });
            const json = await res.json().catch(() => ({}));
            if (!res.ok || json.success === false) return alert(json.error || 'Erreur');
            $allocModal.modal('hide');
            alert('Enregistré avec succès !');
            window.location.reload();
          } catch (err) {
            alert(err.message || 'Erreur');
          }
        });
      }

    })();
  </script>
</body>

</html>