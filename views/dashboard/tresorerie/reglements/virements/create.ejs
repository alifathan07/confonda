      <body>
        
     <body id="page-top">
    <div id="wrapper">
        <%- include('../../../../layouts/sidebar') %>
        <div id="content-wrapper" class="d-flex flex-column">
            <div id="content">
                <%- include('../../../../layouts/topbar') %>
                <div class="container-fluid">
                    <div class="card shadow mb-4">
                        <div class="card-header py-3">
                            <h4 class="m-0 font-weight-bold text-primary">
                                <i class="fas fa-exchange-alt"></i> Nouveau Virement
                            </h4>
                        </div>
                        <div class="card-body">
                            <form action="/tresorerie/virements/banque/<%=banqueId %>/create" method="POST" class="needs-validation" novalidate>
                                <div class="form-row">
                                    <div class="form-group col-12 d-flex justify-content-center">
                                        <div class="col-md-6">
                                            <label for="date" hidden>Date de saisie</label>
                                            <input type="date" class="form-control" id="date" name="date" value="<%= new Date().toISOString().split('T')[0] %>" hidden >
                                        </div>
                                        <div class="col-md-6">
                                            <label for="date" hidden>Objet</label>
                                            <input type="text" class="form-control" id="objet" name="objet" value="Orde de virement" hidden>
                                        </div>
                                    </div>
                                   
                                </div>
                                <div class="form-row">
                                    <div class="form-group col-12 col-md-6">
                                        <label for="beneficiaire">Bénéficiaire</label>
                                        <input type="text" class="form-control" id="beneficiaire" name="beneficiaire" required placeholder="Nom du bénéficiaire">
                                        <div id="beneficiaire-list"></div>
                                    </div>
                                    <div class="form-group col-12 col-md-6">
                                        <label for="montant">Montant</label>
                                        <div class="input-group">
                                            <input type="number" step="0.01" class="form-control" id="montant" name="montant" required placeholder="Montant">
                                            <div class="input-group-append">
                                            </div>
                                        </div> 
                                    </div>
                                    
                                    <div class="form-group col-12 col-md-6 d-flex align-items-center">
                                        <div class="custom-control custom-switch">
                                        <input type="hidden" name="rtgs" value="0">
                                        <input type="checkbox" class="custom-control-input" id="rtgs" name="rtgs" value="1" <%= rtgs ? 'checked' : '' %>>

                                            <label class="custom-control-label" for="rtgs">RTGS</label>
                                        </div>
                                    </div>
                                </div>
                                  
                                <div class="form-row">
                                    <div class="form-group col-12 col-md-6">
                                        <label for="dateReglement">Date de règlement</label>
                                        <input type="date" class="form-control" id="dateReglement" name="dateReglement" required>
                                    </div>
                                    <div class="form-group col-12 col-md-6">
                                        <label for="obs">Observations</label>
                                        <textarea class="form-control" id="obs" name="obs" rows="2" placeholder="Notes ou remarques"></textarea>
                                    </div>
                                </div>
                                <div class="form-group col-12 col-md-6">
                                    <label for="montantLettre">Montant en lettres</label>
                                    <input type="text" class="form-control" id="montantLettre" name="montantLettre" readonly placeholder="Montant en lettres">
                                </div>
                                
                                <script>
                                const montantWordsCache = new Map();
                                
                                function numberToFrenchWords(n) {
                                    if (montantWordsCache.has(n)) return montantWordsCache.get(n);
                                    if (typeof n === "string") n = n.replace(/\s/g,''); 
                                    n = BigInt(n); 
                                
                                    if (n === 0n) return "ZÉRO";
                                
                                    const ones = ["","UN","DEUX","TROIS","QUATRE","CINQ","SIX","SEPT","HUIT","NEUF"];
                                    const teens = ["DIX","ONZE","DOUZE","TREIZE","QUATORZE","QUINZE","SEIZE","DIX-SEPT","DIX-HUIT","DIX-NEUF"];
                                    const tens = ["","DIX","VINGT","TRENTE","QUARANTE","CINQUANTE","SOIXANTE","SOIXANTE","QUATRE-VINGT","QUATRE-VINGT"];
                                    const scales = ["","MILLE","MILLION","MILLIARD","BILLION","BILLIARD","TRILLION"];
                                
                                    function chunkNumber(num) {
                                        let chunks = [];
                                        while (num > 0) {
                                            chunks.push(num % 1000n);
                                            num = num / 1000n;
                                        }
                                        return chunks;
                                    }
                                
                                    function chunkToWords(chunk) {
                                        let h = chunk / 100n;
                                        let t = (chunk % 100n) / 10n;
                                        let o = chunk % 10n;
                                        let str = "";
                                
                                        // Hundreds
                                        if (h > 0n) {
                                            str += (h === 1n ? "CENT" : ones[Number(h)] + " CENT");
                                            if (t !== 0n || o !== 0n) str += " ";
                                        }
                                
                                        // Tens & Ones
                                        let num2 = Number(t * 10n + o);
                                        if (num2 > 0) {
                                            if (num2 < 10) {
                                                str += ones[num2];
                                            } else if (num2 < 20) {
                                                str += teens[num2 - 10];
                                            } else {
                                                let tenVal = Number(t);
                                                let oneVal = Number(o);
                                
                                                if (tenVal === 7 || tenVal === 9) {
                                                    str += tens[tenVal] + "-" + teens[oneVal];
                                                } else if (tenVal === 8) {
                                                    str += "QUATRE-VINGT" + (oneVal === 0 ? "S" : "-" + ones[oneVal]);
                                                } else if (oneVal === 1 && tenVal !== 8) {
                                                    str += tens[tenVal] + "-ET-UN";
                                                } else if (oneVal > 0) {
                                                    str += tens[tenVal] + "-" + ones[oneVal];
                                                } else {
                                                    str += tens[tenVal];
                                                }
                                            }
                                        }
                                
                                        return str.trim();
                                    }
                                
                                    let chunks = chunkNumber(n);
                                    let words = [];
                                
                                    for (let i = chunks.length - 1; i >= 0; i--) {
                                        let chunk = chunks[i];
                                        if (chunk === 0n) continue;
                                        let chunkWord = chunkToWords(chunk);
                                        if (i > 0) {
                                            if (i === 1 && chunk === 1n) chunkWord = scales[i]; 
                                            else chunkWord += " " + scales[i];
                                            if (chunk > 1n && i > 1) chunkWord += "S"; 
                                        }
                                        words.push(chunkWord);
                                    }
                                
                                    let result = words.join(" ").replace(/\s+/g,' ').trim();
                                    montantWordsCache.set(n, result);
                                    return result;
                                }
                                
                                // Debounce function
                                function debounce(fn, delay) {
                                    let timer = null;
                                    return function(...args) {
                                        clearTimeout(timer);
                                        timer = setTimeout(() => fn.apply(this, args), delay);
                                    };
                                }
                                
                                document.getElementById('montant').addEventListener('input', debounce(function() {
                                    const val = this.value;
                                    if (!val) {
                                        document.getElementById('montantLettre').value = "";
                                        return;
                                    }
                                
                                    let parts = val.split(".");
                                    let integerPart = parts[0];
                                    let decimalPart = parts[1] || "";
                                
                                    let text = numberToFrenchWords(integerPart) + " DIRHAMS";
                                    if (decimalPart && parseInt(decimalPart, 10) > 0) {
                                        // normalize centimes to 2 digits
                                        decimalPart = decimalPart.padEnd(2, "0").slice(0,2);
                                        text += " " + numberToFrenchWords(decimalPart) + " CENTIMES";
                                    }
                                
                                    document.getElementById('montantLettre').value = text;
                                }, 150));
                                </script>
                                
                                

                                <div class="form-group col-12 col-md-6">
                                    <label for="rib">RIB</label>
                                    <input type="text" class="form-control" id="rib" name="rib" required placeholder="RIB du bénéficiaire">
                                </div>
                                 <div class="form-group col-12 col-md-6">
                                    <label for="rib">Banque</label>
                                    <input type="text" class="form-control" id="banque" name="banque" required placeholder="Banque du bénéficiaire">
                                </div>
                                 <div class="form-group col-12 col-md-6">
                                    <label for="rib">Agence</label>
                                    <input type="text" class="form-control" id="agence" name="agence" required placeholder="Agence du bénéficiaire">
                                </div>
              <script src="/vendor/jquery/jquery.min.js"></script>
<script>
$(document).ready(function () {
    let fournisseurs = [];

    // Charger la liste des fournisseurs depuis l'API
    $.ajax({
        url: '/api/fournisseurs',
        method: 'GET',
        success: function (data) {
            fournisseurs = data;
            console.log("Fournisseurs chargés :", fournisseurs);
        },
        error: function (xhr, status, error) {
            console.error('Erreur lors de la récupération des fournisseurs:', error);
        }
    });

    const $input = $('#beneficiaire');
    const $list = $('#beneficiaire-list');

    $input.on('input', function () {
        const val = $(this).val().trim().toLowerCase();
        $list.empty();

        if (val.length > 0) {
            const matches = fournisseurs.filter(f => f.name.toLowerCase().includes(val));
            matches.forEach(f => {
                const $item = $('<div>').text(f.name);
                $item.on('click', function () {
                    $input.val(f.name);
                    $('#rib').val(f.rib || "");
                    $('#banque').val(f.banque || "");
                    $('#agence').val(f.agence || "");
                    $list.empty();
                });
                $list.append($item);
            });
        }
    });

    // Hide list if click outside
    $(document).on('click', function(e) {
        if (!$(e.target).closest('#beneficiaire').length) {
            $list.empty();
        }
    });
});
</script>


                             
                                <div class="d-flex flex-column flex-md-row">
                                    <button type="submit" class="btn btn-success custom-btn mb-2 mb-md-0">
                                        <i class="fas fa-save"></i> Enregistrer
                                    </button>
                                    <a href="/tresorerie" class="btn btn-secondary custom-btn ml-md-2">
                                        <i class="fas fa-arrow-left"></i> Annuler
                                    </a>
                                </div>
                            </form>
                        </div>
                    </div>
                </div>
            </div>
        </div>
