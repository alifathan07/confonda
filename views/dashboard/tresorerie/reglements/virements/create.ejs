<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta http-equiv="X-UA-Compatible" content="IE=edge" />
  <meta name="viewport" content="width=device-width, initial-scale=1, shrink-to-fit=no" />
  <meta name="description" content="Cheques" />
  <meta name="author" content="Confonda" />
  <title>Virements</title>
  <link href="/vendor/fontawesome-free/css/all.min.css" rel="stylesheet" type="text/css" />
  <link href="https://fonts.googleapis.com/css?family=Nunito:200,300,400,600,700,800,900" rel="stylesheet" />
  <link href="/css/sb-admin-2.min.css" rel="stylesheet" />
   <!-- Enhanced Status Styles -->
      <style>
/* Simple dropdown styling */
#beneficiaire-list {
    position: absolute;
    background: #fff;
    border: 1px solid #ccc;
    max-height: 150px;
    overflow-y: auto;
    z-index: 3002;
    width: 100%;
    left: 0;
}

#beneficiaire-list div {
    padding: 8px;
    cursor: pointer;
}

#beneficiaire-list div:hover {
    background-color: #f0f0f0;
}

/* Ensure Choices.js dropdown (Répartition par Chantier) stays above other content */
.choices {
    position: relative;
    z-index: 3000;
}

.choices__list--dropdown,
.choices__list[aria-expanded] {
    z-index: 3001;
}

.popup-notif {
    position: fixed;
    top: 16px;
    right: 16px;
    z-index: 9999;
    min-width: 280px;
    max-width: 420px;
    padding: 12px 14px;
    border-radius: 10px;
    box-shadow: 0 12px 30px rgba(0,0,0,.18);
    background: #fff;
    border-left: 6px solid #dc3545;
    color: #1f2937;
    font-size: 0.95rem;
}

.popup-notif.success { border-left-color: #28a745; }
.popup-notif.info { border-left-color: #17a2b8; }
.popup-notif.warning { border-left-color: #ffc107; }

.popup-notif .title {
    font-weight: 700;
    margin-bottom: 2px;
}

.popup-notif .msg {
    line-height: 1.25rem;
}

.popup-notif .close-btn {
    position: absolute;
    top: 8px;
    right: 10px;
    background: transparent;
    border: 0;
    font-size: 18px;
    line-height: 18px;
    cursor: pointer;
    color: #6b7280;
}
</style>
      <body>
        
     <body id="page-top">
    <div id="wrapper">
        <%- include('../../../../layouts/sidebar') %>
        <div id="content-wrapper" class="d-flex flex-column">
            <div id="content">
                <%- include('../../../../layouts/topbar') %>
                <div class="container-fluid">
                    <div class="card shadow mb-4">
                        <div class="card-header py-3">
                            <h4 class="m-0 font-weight-bold text-primary">
                                <i class="fas fa-exchange-alt"></i> Nouveau Virement
                            </h4>
                        </div>
                        <div class="card-body">
                            <form action="/tresorerie/virements/banque/<%=banqueId %>/create" method="POST" class="needs-validation" novalidate>
                                <div class="form-row">
                                    <div class="form-group col-12 d-flex justify-content-center">
                                        <div class="col-md-6">
                                            <label for="date" hidden>Date de saisie</label>
                                            <input type="date" class="form-control" id="date" name="date" value="<%= new Date().toISOString().split('T')[0] %>" hidden >
                                        </div>
                                        <div class="col-md-6">
                                            <label for="date" hidden>Objet</label>
                                            <input type="text" class="form-control" id="objet" name="objet" value="Orde de virement" hidden>
                                        </div>
                                    </div>
                                   
                                </div>
                                <div class="form-row">
                                    <div class="form-group col-12 col-md-6" style="position: relative;">
                                        <label for="beneficiaire">Bénéficiaire</label>
                                        <input type="text" class="form-control" id="beneficiaire" name="beneficiaire" required placeholder="Nom du bénéficiaire">
                                        <div id="beneficiaire-list"></div>
                                    </div>
                                    <div class="form-group col-12 col-md-6">
                                        <label for="montant">Montant</label>
                                        <div class="input-group">
                                            <input type="number" step="0.01" class="form-control" id="montant" name="montant" required placeholder="Montant">
                                        </div> 
                                    </div>
                                </div>
                                
                                <div class="form-group" style="flex: 2;">
                                    <label>Répartition par Chantier:</label>
                                    <div style="display: flex; gap: 10px; margin-bottom: 10px;">
                                        <div style="flex-grow: 5;">
                                            <select id="allocChantierSelect" class="form-control custom-select">
                                                <option value="" >Sélectionnez un chantier</option>
                                                <% chantiers.forEach(chant=> { %>
                                                <option value="<%= chant.id %>" data-name="<%= chant.nom %>">
                                                    <%= chant.nom %>
                                                </option>
                                                <% }) %>
                                            </select>
                                        </div>
                                        <div style="flex-grow: 2;">
                                            <input type="number" id="allocAmountInput" class="form-control" placeholder="Montant">
                                        </div>
                                        <div style="flex-grow: 1;">
                                            <button type="button" class="btn btn-info" onclick="addAllocation()">+</button>
                                        </div>
                                    </div>

                                    <table class="table table-sm table-bordered" style="font-size: 12px;">
                                        <thead>
                                            <tr>
                                                <th>Chantier</th>
                                                <th>Montant</th>
                                                <th>Action</th>
                                            </tr>
                                        </thead>
                                        <tbody id="allocationTableBody"></tbody>
                                    </table>
                                    <div style="font-size: 12px; font-weight: bold;">
                                        Reste à allouer: <span id="remainingAmountDisplay" class="text-danger">0.00</span> DH
                                    </div>
                                    <input type="hidden" name="allocations" id="allocationsInput">
                                </div>

                                <script src="https://cdn.jsdelivr.net/npm/choices.js/public/assets/scripts/choices.min.js"></script>
                                <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/choices.js/public/assets/styles/choices.min.css" />
                                <script>
                                    let allocations = [];

                                    function showPopup(message, type = 'error', title = 'Erreur') {
                                        const existing = document.getElementById('popup-notif');
                                        if (existing) existing.remove();
                                        const el = document.createElement('div');
                                        el.id = 'popup-notif';
                                        el.className = `popup-notif ${type === 'error' ? '' : type}`.trim();
                                        el.innerHTML = `
                                            <button type="button" class="close-btn" aria-label="Close">&times;</button>
                                            <div class="title">${title}</div>
                                            <div class="msg">${message}</div>
                                        `;
                                        document.body.appendChild(el);
                                        const close = () => { if (el && el.parentNode) el.remove(); };
                                        el.querySelector('.close-btn')?.addEventListener('click', close);
                                        window.setTimeout(close, 3500);
                                    }

                                    (function initChantierChoices() {
                                        const select = document.getElementById('allocChantierSelect');
                                        if (!select || typeof Choices === 'undefined') return;
                                        new Choices(select, {
                                            searchEnabled: true,
                                            shouldSort: false,
                                            itemSelectText: '',
                                            searchPlaceholderValue: 'Rechercher...'
                                        });
                                    })();

                                    function updateAllocationUI() {
                                        const tbody = document.getElementById('allocationTableBody');
                                        tbody.innerHTML = '';

                                        let totalAllocated = 0;

                                        allocations.forEach((alloc, index) => {
                                            totalAllocated += parseFloat(alloc.amount);
                                            const row = `
                                            <tr>
                                                <td>${alloc.chantierName}</td>
                                                <td>${parseFloat(alloc.amount).toFixed(2)}</td>
                                                <td><button type="button" class="btn btn-danger btn-sm" onclick="removeAllocation(${index})">X</button></td>
                                            </tr>
                                        `;
                                            tbody.innerHTML += row;
                                        });
                                        const amountInput = document.getElementById('montant').value;
                                        const totalVirement = parseFloat(amountInput.replace(',', '.') || 0);

                                        const remaining = totalVirement - totalAllocated;

                                        const remainingDisplay = document.getElementById('remainingAmountDisplay');
                                        remainingDisplay.textContent = remaining.toFixed(2);

                                        if (Math.abs(remaining) < 0.01) {
                                            remainingDisplay.className = 'text-success';
                                            remainingDisplay.textContent = "0.00"; 
                                        } else {
                                            remainingDisplay.className = 'text-danger';
                                        }
                                        document.getElementById('allocationsInput').value = JSON.stringify(allocations);
                                    }

                                    function addAllocation() {
                                        const select = document.getElementById('allocChantierSelect');
                                        const amountInput = document.getElementById('allocAmountInput');

                                        const chantierId = select.value;
                                        const selectedOption = select.options[select.selectedIndex];
                                        const chantierName = selectedOption ? selectedOption.dataset.name : '';

                                        const amount = parseFloat(amountInput.value);
                                        if (!chantierId || !amount || amount <= 0) {
                                            showPopup('Veuillez sélectionner un chantier et entrer un montant valide.', 'warning', 'Attention');
                                            return;
                                        }

                                        const montantEl = document.getElementById('montant');
                                        const totalVirement = parseFloat((montantEl?.value || '0').toString().replace(',', '.')) || 0;
                                        const totalAllocated = allocations.reduce((acc, a) => acc + (parseFloat(a.amount) || 0), 0);
                                        const remaining = totalVirement - totalAllocated;

                                        if (totalVirement <= 0) {
                                            showPopup('Veuillez saisir le montant du virement avant de faire la répartition.', 'info', 'Info');
                                            return;
                                        }

                                        if (amount > remaining + 0.000001) {
                                            showPopup(`Le montant saisi (${amount.toFixed(2)} DH) dépasse le reste à allouer (${Math.max(remaining, 0).toFixed(2)} DH).`, 'error', 'Montant invalide');
                                            return;
                                        }

                                        allocations.push({ chantierId, chantierName, amount });
                                        updateAllocationUI();

                                        select.value = '';
                                        amountInput.value = '';
                                    }
                                    function removeAllocation(index) {
                                        allocations.splice(index, 1);
                                        updateAllocationUI();
                                    }
                                    
                                    document.addEventListener('DOMContentLoaded', () => {
                                        const montantEl = document.getElementById('montant');
                                        if(montantEl) montantEl.addEventListener('input', updateAllocationUI);
                                    });
                                </script>

                                <div class="form-row">
                                    <div class="form-group col-12 d-flex justify-content-start align-items-center gap-3" style="gap: 1rem;">
                                        <div class="custom-control custom-switch">
                                          <input type="hidden" name="rtgs" value="0">
                                          <input type="checkbox" class="custom-control-input" id="rtgs" name="rtgs" value="1" <%= rtgs ? 'checked' : '' %>>
                                          <label class="custom-control-label" for="rtgs">RTGS</label>
                                        </div>
                                        <div class="custom-control custom-switch">
                                          <input type="hidden" name="srbm" value="0">
                                          <input type="checkbox" class="custom-control-input" id="srbm" name="srbm" value="1" <%= srbm ? 'checked' : '' %>>
                                          <label class="custom-control-label" for="srbm">SRBM</label>
                                        </div>
                                        <div class="custom-control custom-switch">
                                          <input type="hidden" name="instantane" value="0">
                                          <input type="checkbox" class="custom-control-input" id="instantane" name="instantane" value="1" <%= instantane ? 'checked' : '' %>>
                                          <label class="custom-control-label" for="instantane">Instantané</label>
                                        </div>
                                    </div>
                                </div>
                                    <!-- <div class="form-group col-12 col-md-6">
                                        <label for="dateReglement">Date de règlement</label>
                                        <input type="date" class="form-control" id="dateReglement" name="dateReglement" required>
                                    </div> -->
                                    <div class="form-group col-12 col-md-6">
                                        <label for="obs">Observations</label>
                                        <textarea class="form-control" id="obs" name="obs" rows="2" placeholder="Notes ou remarques"></textarea>
                                    </div>
                                </div>
                                    <div class="form-group col-12 col-md-6">
                                        <label for="montantLettre">Montant en lettres</label>
                                        <input type="text" class="form-control" id="montantLettre" name="montantLettre" readonly placeholder="Montant en lettres">
                                    </div>
                                    
                                    <script>
                                    const montantWordsCache = new Map();
                                    
                                    function numberToFrenchWords(n) {
                                        if (montantWordsCache.has(n)) return montantWordsCache.get(n);
                                        if (typeof n === "string") n = n.replace(/\s/g,''); 
                                        n = BigInt(n); 
                                    
                                        if (n === 0n) return "ZÉRO";
                                    
                                        const ones = ["","UN","DEUX","TROIS","QUATRE","CINQ","SIX","SEPT","HUIT","NEUF"];
                                        const teens = ["DIX","ONZE","DOUZE","TREIZE","QUATORZE","QUINZE","SEIZE","DIX-SEPT","DIX-HUIT","DIX-NEUF"];
                                        const tens = ["","DIX","VINGT","TRENTE","QUARANTE","CINQUANTE","SOIXANTE","SOIXANTE","QUATRE-VINGT","QUATRE-VINGT"];
                                        const scales = ["","MILLE","MILLION","MILLIARD","BILLION","BILLIARD","TRILLION"];
                                    
                                        function chunkNumber(num) {
                                            let chunks = [];
                                            while (num > 0) {
                                                chunks.push(num % 1000n);
                                                num = num / 1000n;
                                            }
                                            return chunks;
                                        }
                                    
                                        function chunkToWords(chunk) {
                                            let h = chunk / 100n;
                                            let t = (chunk % 100n) / 10n;
                                            let o = chunk % 10n;
                                            let str = "";
                                    
                                            // Hundreds
                                            if (h > 0n) {
                                                str += (h === 1n ? "CENT" : ones[Number(h)] + " CENT");
                                                if (t !== 0n || o !== 0n) str += " ";
                                            }
                                    
                                            // Tens & Ones
                                            let num2 = Number(t * 10n + o);
                                            if (num2 > 0) {
                                                if (num2 < 10) {
                                                    str += ones[num2];
                                                } else if (num2 < 20) {
                                                    str += teens[num2 - 10];
                                                } else {
                                                    let tenVal = Number(t);
                                                    let oneVal = Number(o);
                                    
                                                    if (tenVal === 7 || tenVal === 9) {
                                                        str += tens[tenVal] + "-" + teens[oneVal];
                                                    } else if (tenVal === 8) {
                                                        str += "QUATRE-VINGT" + (oneVal === 0 ? "S" : "-" + ones[oneVal]);
                                                    } else if (oneVal === 1 && tenVal !== 8) {
                                                        str += tens[tenVal] + "-ET-UN";
                                                    } else if (oneVal > 0) {
                                                        str += tens[tenVal] + "-" + ones[oneVal];
                                                    } else {
                                                        str += tens[tenVal];
                                                    }
                                                }
                                            }
                                    
                                            return str.trim();
                                        }
                                    
                                        let chunks = chunkNumber(n);
                                        let words = [];
                                    
                                        for (let i = chunks.length - 1; i >= 0; i--) {
                                            let chunk = chunks[i];
                                            if (chunk === 0n) continue;
                                            let chunkWord = chunkToWords(chunk);
                                            if (i > 0) {
                                                if (i === 1 && chunk === 1n) chunkWord = scales[i]; 
                                                else chunkWord += " " + scales[i];
                                                if (chunk > 1n && i > 1) chunkWord += "S"; 
                                            }
                                            words.push(chunkWord);
                                        }
                                    
                                        let result = words.join(" ").replace(/\s+/g,' ').trim();
                                        montantWordsCache.set(n, result);
                                        return result;
                                    }
                                    
                                    // Debounce function
                                    function debounce(fn, delay) {
                                        let timer = null;
                                        return function(...args) {
                                            clearTimeout(timer);
                                            timer = setTimeout(() => fn.apply(this, args), delay);
                                        };
                                    }
                                    
                                    document.getElementById('montant').addEventListener('input', debounce(function() {
                                        const val = this.value;
                                        if (!val) {
                                            document.getElementById('montantLettre').value = "";
                                            return;
                                        }
                                    
                                        let parts = val.split(".");
                                        let integerPart = parts[0];
                                        let decimalPart = parts[1] || "";
                                    
                                        let text = numberToFrenchWords(integerPart) + " DIRHAMS";
                                        if (decimalPart && parseInt(decimalPart, 10) > 0) {
                                            // normalize centimes to 2 digits
                                            decimalPart = decimalPart.padEnd(2, "0").slice(0,2);
                                            text += " " + numberToFrenchWords(decimalPart) + " CENTIMES";
                                        }
                                    
                                        document.getElementById('montantLettre').value = text;
                                    }, 150));
                                    </script>
                                
                                

                                <div class="form-group col-12 col-md-6">
                                    <label for="rib">RIB</label>
                                    <input type="text" class="form-control" id="rib" name="rib" required placeholder="RIB du bénéficiaire">
                                </div>
                                 <div class="form-group col-12 col-md-6">
                                    <label for="rib">Banque</label>
                                    <input type="text" class="form-control" id="banque" name="banque" required placeholder="Banque du bénéficiaire">
                                </div>
                                 <div class="form-group col-12 col-md-6">
                                    <label for="rib">Agence</label>
                                    <input type="text" class="form-control" id="agence" name="agence" required placeholder="Agence du bénéficiaire">
                                </div>
                         <script src="/vendor/jquery/jquery.min.js"></script>
<script>
$(document).ready(function () {
    let fournisseurs = [];

    // Charger la liste des fournisseurs depuis l'API
    $.ajax({
        url: '/api/fournisseurs',
        method: 'GET',
        success: function (data) {
            fournisseurs = data;
            console.log("Fournisseurs chargés :", fournisseurs);
        },
        error: function (xhr, status, error) {
            console.error('Erreur lors de la récupération des fournisseurs:', error);
        }
    });

    const $input = $('#beneficiaire');
    const $list = $('#beneficiaire-list');

    $input.on('input', function () {
        const val = $(this).val().trim().toLowerCase();
        $list.empty();

        if (val.length > 0) {
            const matches = fournisseurs.filter(f => f.name.toLowerCase().includes(val));
            matches.forEach(f => {
                const $item = $('<div>').text(f.name);
                $item.on('click', function () {
                    $input.val(f.name);
                    $('#rib').val(f.rib || "");
                    $('#banque').val(f.banque || "");
                    $('#agence').val(f.agence || "");
                    $list.empty();
                });
                $list.append($item);
            });
        }
    });

    // Hide list if click outside
    $(document).on('click', function(e) {
        if (!$(e.target).closest('#beneficiaire').length) {
            $list.empty();
        }
    });
});
</script>


                             
                                <div class="d-flex flex-column flex-md-row">
                                    <button type="submit" class="btn btn-success custom-btn mb-2 mb-md-0">
                                        <i class="fas fa-save"></i> Enregistrer
                                    </button>
                                    <a href="/tresorerie" class="btn btn-secondary custom-btn ml-md-2">
                                        <i class="fas fa-arrow-left"></i> Annuler
                                    </a>
                                </div>
                            </form>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>



