<div id="wrapper">
  <%- include('../../../../layouts/sidebar') %>
  <div id="content-wrapper" class="d-flex flex-column">
    <div id="content">
      <%- include('../../../../layouts/topbar') %>
      <div class="container-fluid">
        <div class="card shadow mb-4">
          <div class="card-header py-3">
            <h6 class="m-0 font-weight-bold text-primary">Liste des recettes à venir</h6>
          </div>
          <div class="card-body">
            <div class="mb-4" style="display: flex; align-items: center; gap: 20px;">
              <form id="excelUploadForm" enctype="multipart/form-data" method="POST" action="/" style="margin: 0;">
                <input type="file" id="excelFile" name="excelFile" accept=".xlsx,.xls" style="display:none;" hidden>
              </form>
              <button id="downloadExcelBtn" class="btn btn-outline-success custom-btn d-flex align-items-center" type="button">
                <i class="fas fa-file-download mr-2"></i> Télécharger Excel
              </button>
              <button id="addRowBtn" class="btn btn-secondary custom-btn d-flex align-items-center" type="button">
                <i class="fas fa-plus mr-2"></i> Ajouter
              </button>
              <button id="saveTableBtn" class="btn btn-primary custom-btn d-flex align-items-center" type="button">
                <i class="fas fa-save mr-2"></i> Enregistrer
              </button>
              <span id="excelUploadMsg" style="font-size:15px; margin-left:10px;"></span>
            </div>
            <div class="mb-3" style="max-width: 350px;">
              <input type="text" id="supplierSearch" class="form-control" placeholder="Rechercher une recette..." style="font-size: 15px;" />
            </div>
            <div class="mb-3 d-flex align-items-center" style="max-width: 600px;">
              <select id="banqueFilter" class="form-control mr-2" style="font-size: 15px; width: 300px;">
                <option value="">-- Filtrer par banque --</option>
                <% banques.forEach(banque => { %>
                  <option value="<%= banque.name %>"><%= banque.name %></option>
                <% }); %>
              </select>
              <select id="supplierFilter" class="form-control mr-2" style="font-size: 15px; width: 250px;">
                <option value="">-- Filtrer par client --</option>
                <% clients.forEach(client => { %>
                  <option value="<%= client.name %>"><%= client.name %></option>
                <% }); %>
              </select>
              <select id="chantierFilter" class="form-control" style="font-size: 15px; width: 250px;">
                <option value="">-- Filtrer par chantier --</option>
                <% chantiers.forEach(chantier => { %>
                  <option value="<%= chantier.nom %>"><%= chantier.nom %></option>
                <% }); %>
              </select>
            </div>
            <%
              function formatDateToDDMMYYYY(dateInput) {
                if (!dateInput) return '';
                const date = new Date(dateInput);
                if (isNaN(date)) return dateInput;
                const day = String(date.getDate()).padStart(2, '0');
                const month = String(date.getMonth() + 1).padStart(2, '0');
                const year = date.getFullYear();
                return `${day}/${month}/${year}`;
              }
            %>
            <div class="table-responsive">
              <table id="editableTable" class="excel-table">
                <thead>
                  <tr style="position: sticky; top: 0; background-color: white; z-index: 1;">
                    <th draggable="true">Client</th>
                    <th draggable="true">Designation</th>
                    <th draggable="true">Montant</th>
                    <th draggable="true">Date d'échéance</th>
                    <th draggable="true">Statut</th>
                    <th draggable="true">Banque</th>
                    <th draggable="true">Chantier</th>
                    <th draggable="true">Date de règlement</th>
                    <th draggable="true">Observation</th>
                    <th style="width:70px;">Actions</th>
                  </tr>
                </thead>
                <tbody>
                  <% if (typeof recavenirs !== 'undefined' && recavenirs.length) { %>
                    <% recavenirs.forEach(recave => { %>
                      <tr data-id="<%= recave.id %>">
                        <td data-name="beneficiaire" class="client-cell" style="position: relative;">
                          <span class="client-display" style="display: inline-block; width: 100%; cursor: pointer;">
                            <%= recave.client.name %>
                          </span>
                          <select class="client-select" style="font-size: 15px; display: none; width: 100%;">
                            <option value="">-- Sélectionner un client --</option>
                            <% clients.forEach(client => { %>
                              <option value="<%= client.name %>" data-client-id="<%= client.id %>" <%= recave.client.name === client.name ? 'selected' : '' %>><%= client.name %></option>
                            <% }); %>
                          </select>
                        </td>
                        
                        <script>
                          document.querySelectorAll('.client-cell').forEach(cell => {
                            const span = cell.querySelector('.client-display');
                            const select = cell.querySelector('.client-select');
                        
                            span.addEventListener('click', () => {
                              span.style.display = 'none';
                              select.style.display = 'inline-block';
                              select.focus();
                            });
                        
                            select.addEventListener('blur', () => {
                              select.style.display = 'none';
                              span.textContent = select.value || '-- Sélectionner un client --';
                              span.style.display = 'inline-block';
                            });
                          });
                        </script>
                        
                        <td contenteditable="true" data-name="designation"><%= recave.designation %></td>
                        <td contenteditable="true" data-name="montant"><%= Number(recave.montant).toLocaleString('fr-FR', { minimumFractionDigits: 2, maximumFractionDigits: 2 }) %></td>
                        <td contenteditable="true" data-name="dateEcheance"><%= formatDateToDDMMYYYY(recave.dateEcheance) %></td>
                        <td data-name="statut" class="statut-cell">
                          <% 
                            let bgColor = '';
                            switch (recave.statut) {
                              case 'payé': bgColor = '#28a745'; break;       // green
                              case 'impayé': bgColor = '#dc3545'; break;     // red
                              case 'non échu': bgColor = '#ffc107'; break;   // yellow
                              case 'échu': bgColor = '#17a2b8'; break;       // blue
                              default: bgColor = '#6c757d';                  // gray
                            }
                          %>
                          <select class="statut-select" style="font-size: 15px; background-color: <%= bgColor %>; color: <%= recave.statut === 'non échu' ? '#000' : '#fff' %>;" data-id="<%= recave.id %>">
                            <% ['non échu', 'impayé', 'échu', 'payé'].forEach(option => { %>
                              <option value="<%= option %>" <%= recave.statut === option ? 'selected' : '' %>><%= option %></option>
                            <% }) %>
                          </select>
                        </td>
                        
                        <td contenteditable="true" data-name="banque"><%= recave.banque.name %></td>
                        <td data-name="chantier" class="chantier-cell" style="position: relative;">
                          <span class="chantier-display" style="display: inline-block; width: 100%; cursor: pointer;">
                            <%= recave.chantier.nom %>
                          </span>
                          <select class="chantier-select" style="font-size: 15px; display: none; width: 100%;">
                            <option value="">-- Sélectionner un chantier --</option>
                            <% chantiers
                                 .filter(chantier => chantier.clientId === recave.client.id)
                                 .forEach(chantier => { %>
                              <option value="<%= chantier.nom %>" data-chantier-id="<%= chantier.id %>" <%= recave.chantier.nom === chantier.nom ? 'selected' : '' %>><%= chantier.nom %></option>
                            <% }); %>
                          </select>
                        </td>
                        
                        <script>
                          document.querySelectorAll('.chantier-cell').forEach(cell => {
                            const span = cell.querySelector('.chantier-display');
                            const select = cell.querySelector('.chantier-select');
                        
                            span.addEventListener('click', () => {
                              span.style.display = 'none';
                              select.style.display = 'inline-block';
                              select.focus();
                            });
                        
                            select.addEventListener('blur', () => {
                              select.style.display = 'none';
                              span.textContent = select.value || '-- Sélectionner un chantier --';
                              span.style.display = 'inline-block';
                            });
                          });
                        </script>
                        
                        <td contenteditable="true" data-name="dateReglement"><%= formatDateToDDMMYYYY(recave.dateReglement) %></td>
                        <td contenteditable="true" data-name="obs"><%= recave.obs %></td>
                        <td>
                          <button class="delete-row excel-delete-btn" title="Supprimer" aria-label="Supprimer"><i class="fas fa-trash"></i></button>
                          <button class="update-row excel-save-btn btn btn-sm btn-warning" title="Mettre à jour" aria-label="Mettre à jour" style="margin-left:5px;"><i class="fas fa-edit"></i></button>
                        </td>
                      </tr>
                    <% }) %>
                  <% } %>
                  <tr>
                    <td colspan="4">Total</td>
                    <td id="total">
                      <%= Number(recavenirs.reduce((total, recave) => total + Number(recave.montant), 0)).toLocaleString('fr-FR', { minimumFractionDigits: 2, maximumFractionDigits: 2 }) %>
                    </td>
                    <td colspan="5"></td>
                  </tr>
                </tbody>
              </table>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

<script>
  const clients = <%- JSON.stringify(clients) %>;
  const chantiers = <%- JSON.stringify(chantiers) %>;
</script>

<script>
  document.addEventListener("DOMContentLoaded", function () {
  // Configuration
  const API_BASE_URL = '/tresorerie/recettes_a_venir';
  const table = document.getElementById("editableTable");
  const uploadForm = document.getElementById('excelUploadForm');
  const fileInput = document.getElementById('excelFile');
  const msg = document.getElementById('excelUploadMsg');

  // Utility Functions
  const convertDateToISO = (dateStr) => {
    if (!dateStr || dateStr.trim() === '') return null;
    const parts = dateStr.split('/');
    if (parts.length !== 3) return null;
    const [day, month, year] = parts;
    const isoDate = `${year.padStart(4, '0')}-${month.padStart(2, '0')}-${day.padStart(2, '0')}`;
    return isNaN(new Date(isoDate)) ? null : isoDate;
  };

  const updateTotal = () => {
    const rows = document.querySelectorAll("#editableTable tbody tr:not(:last-child)");
    let total = 0;
    rows.forEach(row => {
      if (row.style.display !== "none") {
        const montantCell = row.querySelector("td[data-name='montant']");
        if (montantCell) {
          const value = parseFloat(montantCell.innerText.replace(/,/g, '.').replace(/[^\d.-]/g, ''));
          if (!isNaN(value)) total += value;
        }
      }
    });
    const totalCell = document.getElementById("total");
    if (totalCell) {
      totalCell.textContent = total.toLocaleString('fr-FR', { minimumFractionDigits: 2, maximumFractionDigits: 2 });
    }
  };

  const updateChantierDropdown = (clientSelect, chantierSelect) => {
  const selectedClientName = clientSelect.value;
  const selectedClient = clients.find(client => client.name === selectedClientName);
  const clientId = selectedClient ? selectedClient.id : null;
  const currentChantier = chantierSelect.value;

  // Clear the chantier dropdown
  chantierSelect.innerHTML = '<option value="">-- Sélectionner un chantier --</option>';

  if (clientId) {
    const filteredChantiers = chantiers.filter(chantier => chantier.clientId === clientId);
    filteredChantiers.forEach(chantier => {
      const option = document.createElement('option');
      option.value = chantier.nom;
      option.setAttribute('data-chantier-id', chantier.id);
      option.textContent = chantier.nom;
      // Retain the current chantier if it matches and is valid
      if (chantier.nom === currentChantier && chantier.clientId === clientId) {
        option.selected = true;
      }
      chantierSelect.appendChild(option);
    });

    if (!filteredChantiers.length) {
      const option = document.createElement('option');
      option.value = '';
      option.textContent = 'Aucun chantier disponible';
      option.disabled = true;
      chantierSelect.appendChild(option);
    }
  } else {
    // If no client is selected, clear the chantier selection
    chantierSelect.value = '';
  }
};
  const getStatusClass = (statut) => {
    const normalized = statut.toLowerCase().normalize('NFD').replace(/[\u0300-\u036f]/g, '').replace(/\s+/g, '-').trim();
    return ['en-circulation', 'paye', 'impaye', 'annule'].includes(normalized) ? normalized : 'en-circulation';
  };

  // API Handlers
  const apiRequest = async (url, method, data = null) => {
    try {
      const response = await fetch(url, {
        method,
        headers: { 'Content-Type': 'application/json' },
        body: data ? JSON.stringify(data) : null
      });
      if (!response.ok) throw new Error(`HTTP error! status: ${response.status}`);
      return response.json ? await response.json() : await response.text();
    } catch (err) {
      console.error(`API error at ${url}:`, err);
      throw err;
    }
  };

  const createRow = async (data) => {
    try {
      const result = await apiRequest(`${API_BASE_URL}/create`, 'POST', data);
      return result;
    } catch (err) {
      throw new Error('Erreur lors de la création de la ligne');
    }
  };

  const updateRow = async (id, data) => {
    try {
      await apiRequest(`${API_BASE_URL}/${id}`, 'PATCH', data);
    } catch (err) {
      throw new Error('Erreur lors de la mise à jour de la ligne');
    }
  };

  const updateStatus = async (id, statut) => {
    try {
      await apiRequest(`${API_BASE_URL}/${id}/update-statut`, 'PUT', { statut });
    } catch (err) {
      window.location.reload();
      
    }
  };

  const deleteRow = async (id) => {
    try {
      await apiRequest(`${API_BASE_URL}/${id}`, 'DELETE');
    } catch (err) {
      throw new Error('Erreur lors de la suppression de la ligne');
    }
  };

  // Row Data Handler
  const getRowData = (row) => {
  const data = {};
  let selectedClientId = null;

  row.querySelectorAll("td[data-name]").forEach(cell => {
    const key = cell.getAttribute("data-name");
    let value = cell.querySelector("select") ? cell.querySelector("select").value : cell.innerText.trim();

    if (key === 'beneficiaire') {
      const selectedClient = clients.find(client => client.name === value);
      if (selectedClient) {
        data[key] = selectedClient.id;
        selectedClientId = selectedClient.id; // Store client ID for chantier validation
      } else if (value) {
        throw new Error(`Client "${value}" not found.`);
      }
    } else if (key === 'chantier') {
      const selectedChantier = chantiers.find(chantier => chantier.nom === value);
      if (selectedChantier && selectedClientId) {
        // Validate that the chantier belongs to the selected client
        if (selectedChantier.clientId === selectedClientId) {
          data[key] = selectedChantier.id;
        } else {
          throw new Error(`Chantier "${value}" is not associated with the selected client.`);
        }
      } else if (value && selectedClientId) {
        throw new Error(`Chantier "${value}" not found.`);
      }
    } else if (['dateEcheance', 'dateReglement'].includes(key)) {
      value = convertDateToISO(value);
      if (value) data[key] = value;
    } else if (key === 'montant' && cell.getAttribute("data-edited") === "true") {
      value = parseFloat(value.replace(/,/g, '.').replace(/[^\d.-]/g, '')) || 0;
      data[key] = value;
    } else if (value && key !== 'statut') {
      data[key] = value;
    }
  });

  if (!data.beneficiaire && data.chantier) {
    throw new Error('Cannot select a chantier without a client.');
  }

  return Object.keys(data).length ? data : null;
};
// Event Handlers
  const handleRowUpdate = async (row) => {
    if (!row.getAttribute("data-dirty")) return;
    const id = row.getAttribute("data-id");
    const data = getRowData(row);

    if (!data) return;

    try {
      if (id) {
        await updateRow(id, data);
      } else {
        const result = await createRow(data);
        if (result?.id) row.setAttribute("data-id", result.id);
      }
      row.removeAttribute("data-dirty");
      row.classList.remove("excel-dirty-row");
      row.querySelectorAll("td[data-name]").forEach(cell => cell.removeAttribute("data-edited"));
      updateTotal();
    } catch (err) {
      alert(err.message);
    }
  };

  const handleAddRow = () => {
    
  const tbody = table.querySelector("tbody");
  const colCount = table.querySelectorAll("thead th").length;
  const tr = document.createElement("tr");
  let clientSelect, chantierSelect;

  for (let i = 0; i < colCount - 1; i++) {
    const td = document.createElement("td");
    const header = table.querySelectorAll("thead th")[i]?.innerText.trim();
    let dataName = '';

    switch (header) {
      case 'Client':
        dataName = 'beneficiaire';
        td.classList.add('client-cell');
        clientSelect = document.createElement('select');
        clientSelect.className = 'client-select';
        clientSelect.style.fontSize = '15px';
        clientSelect.innerHTML = '<option value="">-- Sélectionner un client --</option>';
        clients.forEach(client => {
          clientSelect.innerHTML += `<option value="${client.name}" data-client-id="${client.id}">${client.name}</option>`;
        });
        td.appendChild(clientSelect);
        break;

      case 'Chantier':
        dataName = 'chantier';
        td.classList.add('chantier-cell');
        chantierSelect = document.createElement('select');
        chantierSelect.className = 'chantier-select';
        chantierSelect.style.fontSize = '15px';
        // initially empty, will be populated when client changes
        chantierSelect.innerHTML = '<option value="">-- Sélectionner un chantier --</option>';
        td.appendChild(chantierSelect);
        break;

      case 'Designation':
        dataName = 'designation';
        td.contentEditable = "true";
        break;

      case 'Montant':
        dataName = 'montant';
        td.contentEditable = "true";
        td.innerText = '0,00';
        break;

      case "Date d'échéance":
        dataName = 'dateEcheance';
        td.contentEditable = "true";
        break;

      case 'Statut':
        dataName = 'statut';
        td.classList.add('statut-cell');
        const statutSelect = document.createElement('select');
        statutSelect.className = 'statut-select';
        ['non échu', 'impayé', 'échu', 'payé'].forEach(option => {
          statutSelect.innerHTML += `<option value="${option}">${option}</option>`;
        });
        td.appendChild(statutSelect);
        break;

      case 'Banque':
        dataName = 'banque';
        td.contentEditable = "true";
        break;

      case 'Date de règlement':
        dataName = 'dateReglement';
        td.contentEditable = "true";
        break;

      case 'Observation':
        dataName = 'obs';
        td.contentEditable = "true";
        break;
    }

    if (dataName) td.setAttribute('data-name', dataName);
    tr.appendChild(td);
  }

  // Add action buttons
  tr.innerHTML += '<td><button class="delete-row excel-delete-btn" title="Supprimer"><i class="fas fa-trash"></i></button><button class="update-row excel-save-btn btn btn-sm btn-warning" title="Mettre à jour" style="margin-left:5px;"><i class="fas fa-edit"></i></button></td>';

  tr.setAttribute("data-dirty", "true");
  tr.classList.add("excel-dirty-row");
  tbody.insertBefore(tr, tbody.firstChild);

  // Link client -> chantier dynamically
  if (clientSelect && chantierSelect) {
    const populateChantiers = () => {
      const selectedClient = clients.find(c => c.name === clientSelect.value);
      chantierSelect.innerHTML = '<option value="">-- Sélectionner un chantier --</option>';
      if (selectedClient) {
        const filteredChantiers = chantiers.filter(ch => ch.clientId === selectedClient.id);
        filteredChantiers.forEach(ch => {
          const option = document.createElement('option');
          option.value = ch.nom;
          option.textContent = ch.nom;
          chantierSelect.appendChild(option);
        });
      }
    };

    clientSelect.addEventListener('change', () => {
      populateChantiers();
      tr.setAttribute('data-dirty', 'true');
      tr.classList.add('excel-dirty-row');
    });

    // populate initial (in case client is pre-selected)
    populateChantiers();
  }

  updateTotal();
};

  // Event Listeners
  table.querySelectorAll('.statut-select').forEach(select => {
    select.addEventListener('change', async function() {
      const newStatut = select.value;
      const recaveId = select.closest('tr').getAttribute('data-id');
      if (!recaveId) return;

      select.disabled = true;
      try {
        await updateStatus(recaveId, newStatut);
        select.classList.add('status-updating');
        setTimeout(() => select.classList.remove('status-updating'), 300);
      } catch (err) {
        alert(err.message);
        window.location.reload();
      } finally {
        select.disabled = false;
      }
    });
  });

  uploadForm?.addEventListener('submit', async (e) => {
    e.preventDefault();
    if (!fileInput.files.length) {
      msg.textContent = 'Veuillez sélectionner un fichier Excel.';
      msg.style.color = 'red';
      return;
    }
    const formData = new FormData(uploadForm);
    msg.textContent = 'Importation en cours...';
    msg.style.color = '#1976d2';
    try {
      const text = await apiRequest('/tresorerie/effets/import', 'POST', formData);
      msg.textContent = text;
      msg.style.color = 'green';
      setTimeout(() => window.location.reload(), 1200);
    } catch {
      msg.textContent = "Erreur lors de l'importation du fichier.";
      msg.style.color = 'red';
    }
  });

  fileInput?.addEventListener('change', () => {
    if (fileInput.files.length) uploadForm.requestSubmit();
  });

  table.querySelector("tbody").addEventListener("click", async (e) => {
    const row = e.target.closest("tr");
    if (e.target.closest(".delete-row")) {
      if (confirm("Êtes-vous sûr de vouloir supprimer ce chèque ?")) {
        const id = row.getAttribute("data-id");
        if (id) {
          try {
            await deleteRow(id);
            row.remove();
            alert("Recette supprimée avec succès.");
            updateTotal();
          } catch (err) {
            alert(err.message);
          }
        } else {
          row.remove();
          updateTotal();
        }
      }
    } else if (e.target.closest(".update-row")) {
      await handleRowUpdate(row);
    }
  });

  table.addEventListener("blur", async (e) => {
  const cell = e.target.closest("td[data-name='montant']");
  if (cell && cell.isContentEditable) {
    const row = cell.parentElement;

    let value = cell.innerText.trim();

    // Remove spaces (normal and non-breaking) but keep commas
    value = value.replace(/[\s\u202F]/g, '');

    // Replace comma with dot only if it exists
    if (value.includes(',')) value = value.replace(',', '.');

    // Convert to number safely
    const numValue = Number(value);

    // Keep exact number if valid, otherwise 0
    const displayValue = isNaN(numValue) ? '0,00' : numValue.toLocaleString('fr-FR', { 
      minimumFractionDigits: 2, 
      maximumFractionDigits: 2 
    });

    cell.innerText = displayValue;
    cell.setAttribute("data-edited", "true");
    updateTotal();

    row.setAttribute("data-dirty", "true");
    row.classList.add("excel-dirty-row");
    if (row.getAttribute("data-id")) {
      await handleRowUpdate(row);
    }
  }
}, true);

  table.addEventListener("change", async (e) => {
    const select = e.target.closest("td[data-name='beneficiaire'] select, td[data-name='chantier'] select");
    if (select) {
      const row = select.closest("tr");
      row.setAttribute("data-dirty", "true");
      row.classList.add("excel-dirty-row");
      if (row.getAttribute("data-id")) {
        await handleRowUpdate(row);
      }
    }
  });

  document.getElementById("addRowBtn")?.addEventListener("click", handleAddRow);

  document.getElementById("saveTableBtn")?.addEventListener("click", async () => {
    const dirtyRows = table.querySelectorAll("tbody tr[data-dirty='true']");
    if (!dirtyRows.length) {
      alert("Aucune modification à enregistrer.");
      return;
    }

    let successCount = 0, failCount = 0;
    for (const row of dirtyRows) {
      try {
        await handleRowUpdate(row);
        successCount++;
      } catch {
        failCount++;
      }
    }

    if (successCount) alert(`${successCount} recettes enregistrées/modifiées avec succès !`);
    if (failCount) alert(`${failCount} recettes n'ont pas pu être enregistrées.`);
    updateTotal();
  });

  // Initialize existing rows
  table.querySelectorAll('tbody tr:not(:last-child)').forEach(row => {
    const clientSelect = row.querySelector('td[data-name="beneficiaire"] select');
    const chantierSelect = row.querySelector('td[data-name="chantier"] select');
    if (clientSelect && chantierSelect) {
      updateChantierDropdown(clientSelect, chantierSelect);
      clientSelect.addEventListener('change', () => {
        updateChantierDropdown(clientSelect, chantierSelect);
        row.setAttribute('data-dirty', 'true');
        row.classList.add('excel-dirty-row');
      });
    }
  });

  // Search and Filter Handlers
  const handleFilter = (selector, dataName, value) => {
    const rows = table.querySelectorAll("tbody tr:not(:last-child)");
    rows.forEach(row => {
      const cell = row.querySelector(`td[data-name='${dataName}']${dataName === 'beneficiaire' || dataName === 'chantier' ? ' select' : ''}`);
      const cellValue = cell ? (cell.querySelector('select') ? cell.querySelector('select').value : cell.innerText).toLowerCase() : '';
      row.style.display = (value === "" || cellValue === value) ? "" : "none";
    });
    updateTotal();
  };

  document.getElementById("supplierSearch")?.addEventListener("input", function () {
    const filter = this.value.toLowerCase();
    const rows = table.querySelectorAll("tbody tr:not(:last-child)");
    rows.forEach(row => {
      const rowText = Array.from(row.querySelectorAll("td[data-name]")).map(cell => 
        cell.querySelector('select') ? cell.querySelector('select').value : cell.innerText
      ).join(' ').toLowerCase();
      row.style.display = rowText.includes(filter) ? "" : "none";
    });
    updateTotal();
  });

  document.getElementById("banqueFilter")?.addEventListener("change", function () {
    handleFilter("#banqueFilter", "banque", this.value.toLowerCase());
  });

  document.getElementById("supplierFilter")?.addEventListener("change", function () {
    handleFilter("#supplierFilter", "beneficiaire", this.value.toLowerCase());
  });

  document.getElementById("chantierFilter")?.addEventListener("change", function () {
    handleFilter("#chantierFilter", "chantier", this.value.toLowerCase());
  });

  // Column Drag and Drop (unchanged from original)
  let dragSrcIdx = null;
  const swapColumns = (table, fromIdx, toIdx) => {
    if (fromIdx === toIdx) return;
    const headerRow = table.tHead.rows[0];
    headerRow.insertBefore(headerRow.children[fromIdx], headerRow.children[toIdx + (fromIdx < toIdx ? 1 : 0)]);
    Array.from(table.tBodies[0].rows).forEach(row => {
      row.insertBefore(row.children[fromIdx], row.children[toIdx + (fromIdx < toIdx ? 1 : 0)]);
    });
  };

  Array.from(table.tHead.rows[0].cells).forEach((th, idx) => {
    th.draggable = true;
    th.addEventListener('dragstart', (e) => {
      dragSrcIdx = idx;
      e.dataTransfer.effectAllowed = 'move';
      th.classList.add('dragging');
    });
    th.addEventListener('dragend', () => {
      dragSrcIdx = null;
      th.classList.remove('dragging');
      Array.from(table.tHead.rows[0].cells).forEach(cell => cell.classList.remove('drag-over'));
    });
    th.addEventListener('dragover', (e) => {
      e.preventDefault();
      th.classList.add('drag-over');
    });
    th.addEventListener('dragleave', () => th.classList.remove('drag-over'));
    th.addEventListener('drop', (e) => {
      e.preventDefault();
      th.classList.remove('drag-over');
      if (dragSrcIdx !== null && dragSrcIdx !== idx) {
        swapColumns(table, dragSrcIdx, idx);
      }
    });
  });

  // Excel Download
  document.getElementById("downloadExcelBtn")?.addEventListener("click", () => {
    const wb = XLSX.utils.book_new();
    const ws = XLSX.utils.table_to_sheet(table, { raw: true, cellDates: true });
    XLSX.utils.book_append_sheet(wb, ws, "Cheques");
    XLSX.writeFile(wb, "liste_cheques.xlsx");
  });

  // Initialize
  updateTotal();
});
</script>

<style>
.client-select, .chantier-select, .statut-select {
  width: 100%;
  padding: 5px;
  border: none;
  background: transparent;
  font-size: 15px;
  color: #333;
}
.client-select:focus, .chantier-select:focus, .statut-select:focus {
  outline: none;
  border: 1px solid #007bff;
  border-radius: 4px;
}
.client-cell, .chantier-cell, .statut-cell {
  padding: 5px;
}
</style>

  
