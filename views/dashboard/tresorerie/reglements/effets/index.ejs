<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8" />
  <meta http-equiv="X-UA-Compatible" content="IE=edge" />
  <meta name="viewport" content="width=device-width, initial-scale=1, shrink-to-fit=no" />
  <meta name="description" content="effets" />
  <meta name="author" content="Confonda" />
  <title>Effets</title>
  <link href="/vendor/fontawesome-free/css/all.min.css" rel="stylesheet" type="text/css" />
  <link href="https://fonts.googleapis.com/css?family=Nunito:200,300,400,600,700,800,900" rel="stylesheet" />
  <link href="/css/sb-admin-2.min.css" rel="stylesheet" />
  <style>
    .effet-table td,
    .effet-table th {
      vertical-align: middle;
    }

    .effet-table.table-bordered td,
    .effet-table.table-bordered th {
      border-color: #e6e8f0;
    }

    .badge-statut {
      display: inline-block;
      padding: 4px 10px;
      font-weight: 700;
      font-size: 11px;
      text-transform: uppercase;
      letter-spacing: .3px;
      border-radius: 12px;
      cursor: pointer;
      transition: box-shadow .2s;
    }

    .badge-statut:hover {
      box-shadow: 0 2px 8px rgba(0,0,0,.18);
    }

    .badge-statut.en-circulation {
      background: #fff3cd;
      color: #856404;
    }

    .badge-statut.paye {
      background: #d4edda;
      color: #155724;
    }

    .badge-statut.impaye {
      background: #f8d7da;
      color: #721c24;
    }

    .badge-statut.annule {
      background: #e2e3e5;
      color: #383d41;
    }

    .badge-statut.treso {
      background: #d1ecf1;
      color: #0c5460;
    }

    .statut-select {
      min-width: 140px;
      font-weight: 700;
    }

    .table-actions {
      display: flex;
      gap: 6px;
      justify-content: flex-end;
    }

    .cell-edit {
      min-width: 100px;
    }

    .cell-edit[contenteditable="true"] {
      outline: none;
    }

    .cell-edit[contenteditable="true"]:focus {
      box-shadow: inset 0 0 0 2px rgba(78, 115, 223, .25);
      border-radius: 4px;
    }

    .obs-cell {
      min-width: 220px;
      max-width: 380px;
      white-space: normal;
      line-height: 1.25;
    }

    #filterTypeDropdown .dropdown-menu {
      z-index: 2000;
    }

    body {
      padding-bottom: 26px;
    }

    .bottom-hscroll {
      position: fixed;
      left: 0;
      right: 0;
      bottom: 0;
      height: 18px;
      overflow-x: scroll;
      overflow-y: hidden;
      background: rgba(255, 255, 255, .95);
      border-top: 1px solid rgba(0, 0, 0, .08);
      z-index: 4000;
      display: block;
    }

    .bottom-hscroll::-webkit-scrollbar {
      height: 12px;
    }

    .bottom-hscroll::-webkit-scrollbar-thumb {
      background: rgba(108, 117, 125, .6);
      border-radius: 10px;
    }

    .bottom-hscroll::-webkit-scrollbar-track {
      background: rgba(108, 117, 125, .12);
    }

    .bottom-hscroll-inner {
      height: 1px;
    }
  </style>
</head>

<body id="page-top">
  <div id="wrapper">
    <%- include('../../../../layouts/sidebar') %>
    <div id="content-wrapper" class="d-flex flex-column">
      <div id="content">
        <%- include('../../../../layouts/topbar') %>

        <div class="container-fluid">
          <!-- Page header -->
          <div class="d-flex align-items-center justify-content-between mb-3">
            <div>
              <h1 class="h3 mb-0 text-gray-800">
                <% if (typeof id !== 'undefined' && id && typeof banqueName !== 'undefined' && banqueName) { %>
                  Effets — <%= banqueName.name %>
                <% } else { %>
                  Liste des Effets
                <% } %>
              </h1>
              <div class="small text-muted" id="effetCount">
                <% if (typeof effets !== 'undefined') { %><%= effets.length %> résultat(s)<% } %>
              </div>
            </div>
            <div class="d-flex" style="gap: 10px;">
              <button id="btnExportPdf" type="button" class="btn btn-outline-danger">
                <i class="fas fa-file-pdf mr-2"></i>PDF
              </button>
              <button id="btnExportExcel" type="button" class="btn btn-outline-success">
                <i class="fas fa-file-excel mr-2"></i>Excel
              </button>
              <button id="addRowBtn" type="button" class="btn btn-secondary">
                <i class="fas fa-plus mr-2"></i>Ajouter
              </button>
              <button id="saveTableBtn" type="button" class="btn btn-warning">
                <i class="fas fa-save mr-2"></i>Enregistrer
              </button>
              <% if (typeof id !== 'undefined' && id && typeof banqueName !== 'undefined' && banqueName) {
                const supportedBanks = (banques || []).map(b => b.name.toLowerCase());
                const bankKey = banqueName.name.toLowerCase();
                const bankRoute = bankKey === 'credit agricole' ? 'credit_agricole' : bankKey;
                if (supportedBanks.includes(bankKey)) { %>
                  <a href="/tresorerie/effets/create/format/<%= bankRoute %>/<%= id %>" class="btn btn-primary">
                    <i class="fas fa-file-invoice-dollar mr-2"></i>Établir effet
                  </a>
              <% } } %>
            </div>
          </div>

          <div class="card shadow mb-4">
            <div class="card-body">
              <!-- Filters row -->
              <div class="row mb-3">
                <div class="col-md-3 mb-2">
                  <label class="small text-muted mb-1">Filtre</label>
                  <div class="dropdown" id="filterTypeDropdown">
                    <button class="btn btn-success dropdown-toggle w-100" type="button" id="filterTypeBtn"
                      data-toggle="dropdown" aria-haspopup="true" aria-expanded="false">
                      Filtrer Par
                    </button>
                    <div class="dropdown-menu w-100" id="filterTypeMenu" aria-labelledby="filterTypeBtn">
                      <button class="dropdown-item" type="button" data-filter-type="beneficiaire">Bénéficiaire</button>
                      <button class="dropdown-item" type="button" data-filter-type="banque">Banque</button>
                      <button class="dropdown-item" type="button" data-filter-type="statut">Statut</button>
                      <button class="dropdown-item" type="button" data-filter-type="chantier">Chantier</button>
                      <button class="dropdown-item" type="button" data-filter-type="montant">Montant</button>
                      <button class="dropdown-item" type="button" data-filter-type="numero">N° Effet</button>
                    </div>
                  </div>

                  <div id="filterDynamicContainer" class="mt-2">
                    <div id="filterBoxBeneficiaire" style="display:none;">
                      <input id="filterBeneficiaire" class="form-control" placeholder="Bénéficiaire..." />
                    </div>
                    <div id="filterBoxBanque" style="display:none;">
                      <select id="filterBanque" class="form-control">
                        <option value="">Tous</option>
                        <% (banques || []).forEach(b => { %>
                          <option value="<%= b.name %>"><%= b.name %></option>
                        <% }) %>
                      </select>
                    </div>
                    <div id="filterBoxStatut" style="display:none;">
                      <select id="filterStatut" class="form-control">
                        <option value="">Tous</option>
                        <option value="En Circulation">En Circulation</option>
                        <option value="PAYÉ">Payé</option>
                        <option value="Impayé">Impayé</option>
                        <option value="Annulé">Annulé</option>
                        <option value="Treso">Treso</option>
                      </select>
                    </div>
                    <div id="filterBoxChantier" style="display:none;">
                      <select id="filterChantier" class="form-control">
                        <option value="">Tous</option>
                        <% (chantiers || []).forEach(c => { %>
                          <option value="<%= c.nom %>"><%= c.nom %></option>
                        <% }) %>
                      </select>
                    </div>
                    <div id="filterBoxMontant" style="display:none;">
                      <input id="filterMontant" class="form-control" placeholder="ex: 1200" />
                    </div>
                    <div id="filterBoxNumero" style="display:none;">
                      <input id="filterNumero" class="form-control" placeholder="N° effet..." />
                    </div>
                  </div>
                </div>

                <div class="col-md-2 mb-2 d-flex align-items-end">
                  <button id="btnClearFilters" type="button" class="btn btn-danger w-100" style="display:none;">
                    <i class="fas fa-times mr-1"></i>Annuler filtre
                  </button>
                </div>

                <div class="col-md-2 mb-2">
                  <label class="small text-muted mb-1">Échéance du</label>
                  <input id="filterDateFrom" type="date" class="form-control" />
                </div>
                <div class="col-md-2 mb-2">
                  <label class="small text-muted mb-1">Échéance au</label>
                  <input id="filterDateTo" type="date" class="form-control" />
                </div>
              </div>

              <!-- Table -->
              <div class="table-responsive" id="effetsTableResponsive">
                <%
                  function fmtDate(d) {
                    if (!d) return '';
                    const dt = new Date(d);
                    if (isNaN(dt)) return '';
                    return String(dt.getDate()).padStart(2,'0') + '/' + String(dt.getMonth()+1).padStart(2,'0') + '/' + dt.getFullYear();
                  }
                  function statutClass(s) {
                    return String(s||'').toLowerCase().normalize('NFD').replace(/[\u0300-\u036f]/g,'').replace(/\s+/g,'-');
                  }
                %>
                <table class="table table-sm table-hover table-bordered effet-table" style="min-width: 1200px;" id="editableTable">
                  <thead class="thead-light">
                    <tr>
                      <th>Date</th>
                      <th>N° Effet</th>
                      <th>Banque</th>
                      <th>Bénéficiaire</th>
                      <th class="text-right">Montant</th>
                      <th>Échéance</th>
                      <th>Statut</th>
                      <th>Date Règlement</th>
                      <th>Chantier</th>
                      <th>Observation</th>
                      <th class="text-right">Actions</th>
                    </tr>
                  </thead>
                  <tbody id="effetTbody">
                    <% if (typeof effets === 'undefined' || !effets.length) { %>
                      <tr><td colspan="11" class="text-center text-muted">Aucun effet disponible.</td></tr>
                    <% } else { %>
                      <% effets.forEach(e => { %>
                        <tr data-id="<%= e.id %>">
                          <td class="cell-edit" contenteditable="true" data-name="dateEtablissement"><%= fmtDate(e.dateEtablissement) %></td>
                          <td class="cell-edit" contenteditable="true" data-name="numero"><%= e.numero || '' %></td>
                          <td class="cell-edit" contenteditable="true" data-name="banque"><%= e.banque ? e.banque.name : '' %></td>
                          <td class="cell-edit" contenteditable="true" data-name="beneficiaire"><%= e.beneficiaire || '' %></td>
                          <td class="text-right cell-edit" contenteditable="true" data-name="montant"><%= e.montant ? Number(e.montant).toLocaleString('fr-FR', { minimumFractionDigits: 2, maximumFractionDigits: 2 }) : '' %></td>
                          <td class="cell-edit" contenteditable="true" data-name="dateEcheance"><%= e.dateEcheance ? fmtDate(e.dateEcheance) : '' %></td>
                          <td data-name="statut" class="text-center">
                            <span class="badge-statut <%= statutClass(e.statut) %>" onclick="toggleStatutSelect(this)">
                              <%= e.statut %>
                            </span>
                          </td>
                          <td class="cell-edit" contenteditable="true" data-name="dateReglement"><%= fmtDate(e.dateReglement) %></td>
                          <td data-name="chantier">
                            <select class="form-control form-control-sm chantier-select">
                              <option value="">-- Aucun --</option>
                              <% (chantiers || []).forEach(c => { %>
                                <option value="<%= c.nom %>" <%= (e.chantier && e.chantier.nom === c.nom) ? 'selected' : '' %>><%= c.nom %></option>
                              <% }) %>
                            </select>
                          </td>
                          <td class="cell-edit obs-cell" contenteditable="true" data-name="obs"><%= e.obs || '' %></td>
                          <td class="text-right">
                            <div class="table-actions">
                              <button class="btn btn-sm btn-outline-danger btn-delete-effet" title="Supprimer" data-id="<%= e.id %>">
                                <i class="fas fa-trash"></i>
                              </button>
                            </div>
                          </td>
                        </tr>
                      <% }) %>
                    <% } %>
                  </tbody>
                  <tfoot>
                    <tr>
                      <th colspan="4" class="text-right">Total</th>
                      <th class="text-right" id="totalMontantCell">
                        <%= (typeof effets !== 'undefined' && effets.length) ? effets.reduce((s, e2) => s + Number(e2.montant || 0), 0).toLocaleString('fr-FR', { minimumFractionDigits: 2, maximumFractionDigits: 2 }) : '0,00' %>
                      </th>
                      <th colspan="6"></th>
                    </tr>
                  </tfoot>
                </table>
              </div>

              <!-- Fixed bottom scrollbar -->
              <div id="effetsBottomHScroll" class="bottom-hscroll" aria-hidden="true">
                <div id="effetsBottomHScrollInner" class="bottom-hscroll-inner"></div>
              </div>

              <!-- Results info -->
              <div class="mt-3">
                <div class="small text-muted" id="effetInfo">
                  <% if (typeof effets !== 'undefined') { %><%= effets.length %> résultat(s)<% } %>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <script src="/vendor/jquery/jquery.min.js"></script>
  <script src="/vendor/bootstrap/js/bootstrap.bundle.min.js"></script>
  <script src="/vendor/jquery-easing/jquery.easing.min.js"></script>
  <script src="/js/sb-admin-2.min.js"></script>
  <script src="https://cdnjs.cloudflare.com/ajax/libs/jspdf/2.5.1/jspdf.umd.min.js"></script>
  <script src="https://cdnjs.cloudflare.com/ajax/libs/jspdf-autotable/3.8.3/jspdf.plugin.autotable.min.js"></script>
  <script src="https://cdnjs.cloudflare.com/ajax/libs/xlsx/0.18.5/xlsx.full.min.js"></script>

  <script>
    /* ── chantier data for add-row ── */
    const CHANTIERS_DATA = <%- JSON.stringify((chantiers || []).map(c => ({ nom: c.nom }))) %>;

    /* ── helpers ── */
    function fmtFr(d) {
      if (!d) return '';
      const s = String(d).trim();
      const iso = s.match(/^(\d{4})-(\d{2})-(\d{2})/);
      if (iso) return `${iso[3]}/${iso[2]}/${iso[1]}`;
      if (/^\d{2}\/\d{2}\/\d{4}$/.test(s)) return s;
      const dt = new Date(s);
      return isNaN(dt) ? '' : dt.toLocaleDateString('fr-FR');
    }

    function moneyFr(v) {
      return Number(v || 0).toLocaleString('fr-FR', { minimumFractionDigits: 2, maximumFractionDigits: 2 });
    }

    function parseMoney(v) {
      const s = String(v || '').trim().replace(/\s/g, '').replace(/[^\d,.-]/g, '').replace(',', '.');
      const n = Number(s);
      return isNaN(n) ? null : n;
    }

    function dateToISO(str) {
      if (!str) return null;
      const parts = String(str).trim().split('/');
      if (parts.length !== 3) return null;
      const [dd, mm, yyyy] = parts.map(p => p.trim());
      if (!dd || !mm || !yyyy) return null;
      const val = `${yyyy.padStart(4, '0')}-${mm.padStart(2, '0')}-${dd.padStart(2, '0')}`;
      return isNaN(new Date(val)) ? null : val;
    }

    function statutClass(s) {
      return String(s || '').toLowerCase().normalize('NFD').replace(/[\u0300-\u036f]/g, '').replace(/\s+/g, '-');
    }

    /* ── DOM refs ── */
    const $tbody = document.getElementById('effetTbody');
    const $totalCell = document.getElementById('totalMontantCell');
    const $filterTypeBtn = document.getElementById('filterTypeBtn');
    const $filterTypeDropdown = document.getElementById('filterTypeDropdown');
    const $filterTypeMenu = document.getElementById('filterTypeMenu');
    const $btnClearFilters = document.getElementById('btnClearFilters');
    const $filterBeneficiaire = document.getElementById('filterBeneficiaire');
    const $filterBanque = document.getElementById('filterBanque');
    const $filterStatut = document.getElementById('filterStatut');
    const $filterChantier = document.getElementById('filterChantier');
    const $filterMontant = document.getElementById('filterMontant');
    const $filterNumero = document.getElementById('filterNumero');
    const $filterDateFrom = document.getElementById('filterDateFrom');
    const $filterDateTo = document.getElementById('filterDateTo');

    let activeFilterType = '';

    /* ── filter dropdown ── */
    function setFilterType(type) {
      const t = String(type || '').trim();
      activeFilterType = t;
      document.getElementById('filterBoxBeneficiaire').style.display = t === 'beneficiaire' ? '' : 'none';
      document.getElementById('filterBoxBanque').style.display = t === 'banque' ? '' : 'none';
      document.getElementById('filterBoxStatut').style.display = t === 'statut' ? '' : 'none';
      document.getElementById('filterBoxChantier').style.display = t === 'chantier' ? '' : 'none';
      document.getElementById('filterBoxMontant').style.display = t === 'montant' ? '' : 'none';
      document.getElementById('filterBoxNumero').style.display = t === 'numero' ? '' : 'none';

      $filterTypeBtn.textContent =
        t === 'beneficiaire' ? 'Bénéficiaire' :
        t === 'banque' ? 'Banque' :
        t === 'statut' ? 'Statut' :
        t === 'chantier' ? 'Chantier' :
        t === 'montant' ? 'Montant' :
        t === 'numero' ? 'N° Effet' :
        'Filtrer Par';

      updateClearBtn();
      applyFilters();
    }

    function updateClearBtn() {
      const active = !!(activeFilterType ||
        ($filterBeneficiaire && $filterBeneficiaire.value) ||
        ($filterBanque && $filterBanque.value) ||
        ($filterStatut && $filterStatut.value) ||
        ($filterChantier && $filterChantier.value) ||
        ($filterMontant && $filterMontant.value) ||
        ($filterNumero && $filterNumero.value) ||
        ($filterDateFrom && $filterDateFrom.value) ||
        ($filterDateTo && $filterDateTo.value));
      $btnClearFilters.style.display = active ? '' : 'none';
    }

    function clearFilters() {
      activeFilterType = '';
      [$filterBeneficiaire, $filterBanque, $filterStatut, $filterChantier, $filterMontant, $filterNumero, $filterDateFrom, $filterDateTo].forEach(el => { if (el) el.value = ''; });
      setFilterType('');
    }

    function toggleMenu(forceOpen) {
      const open = typeof forceOpen === 'boolean' ? forceOpen : !$filterTypeMenu.classList.contains('show');
      $filterTypeDropdown.classList.toggle('show', open);
      $filterTypeMenu.classList.toggle('show', open);
      $filterTypeBtn.setAttribute('aria-expanded', String(open));
    }

    $filterTypeBtn.addEventListener('click', e => { e.preventDefault(); toggleMenu(); });
    document.addEventListener('click', e => { if (!$filterTypeDropdown.contains(e.target)) toggleMenu(false); });
    $filterTypeDropdown.addEventListener('click', e => {
      const btn = e.target && e.target.closest ? e.target.closest('[data-filter-type]') : null;
      if (!btn) return;
      setFilterType(btn.getAttribute('data-filter-type'));
      toggleMenu(false);
    });
    $btnClearFilters.addEventListener('click', clearFilters);

    /* ── filtering ── */
    function applyFilters() {
      const benVal = ($filterBeneficiaire && $filterBeneficiaire.value || '').toLowerCase().trim();
      const banVal = $filterBanque && $filterBanque.value || '';
      const stVal = ($filterStatut && $filterStatut.value || '').toLowerCase().normalize('NFD').replace(/[\u0300-\u036f]/g, '').trim();
      const chVal = $filterChantier && $filterChantier.value || '';
      const mtVal = parseMoney($filterMontant && $filterMontant.value);
      const numVal = ($filterNumero && $filterNumero.value || '').toLowerCase().trim();
      const dateFrom = $filterDateFrom && $filterDateFrom.value;
      const dateTo = $filterDateTo && $filterDateTo.value;

      const rows = $tbody ? $tbody.querySelectorAll('tr[data-id]') : [];
      let total = 0;
      let shown = 0;

      rows.forEach(tr => {
        let show = true;

        if (benVal) {
          const c = tr.querySelector('td[data-name="beneficiaire"]');
          show = show && c && c.textContent.toLowerCase().includes(benVal);
        }
        if (banVal) {
          const c = tr.querySelector('td[data-name="banque"]');
          show = show && c && c.textContent.trim() === banVal;
        }
        if (stVal) {
          const span = tr.querySelector('td[data-name="statut"] .badge-statut');
          const sel = tr.querySelector('td[data-name="statut"] select');
          const raw = (sel ? sel.value : (span ? span.textContent : '')).toLowerCase().normalize('NFD').replace(/[\u0300-\u036f]/g, '').trim();
          show = show && raw === stVal;
        }
        if (chVal) {
          const sel = tr.querySelector('select.chantier-select');
          show = show && sel && sel.value === chVal;
        }
        if (mtVal !== null) {
          const c = tr.querySelector('td[data-name="montant"]');
          const v = parseMoney(c ? c.textContent : '');
          show = show && v !== null && Math.abs(v - mtVal) < 0.01;
        }
        if (numVal) {
          const c = tr.querySelector('td[data-name="numero"]');
          show = show && c && c.textContent.toLowerCase().includes(numVal);
        }
        if (dateFrom || dateTo) {
          const c = tr.querySelector('td[data-name="dateEcheance"]');
          const iso = dateToISO(c ? c.textContent.trim() : '');
          if (iso) {
            const d = new Date(iso);
            if (dateFrom && d < new Date(dateFrom)) show = false;
            if (dateTo && d > new Date(dateTo)) show = false;
          } else {
            show = false;
          }
        }

        tr.style.display = show ? '' : 'none';
        if (show) {
          const mc = tr.querySelector('td[data-name="montant"]');
          const v = parseMoney(mc ? mc.textContent : '');
          if (v !== null) total += v;
          shown++;
        }
      });

      if ($totalCell) $totalCell.textContent = moneyFr(total);
      const info = document.getElementById('effetInfo');
      if (info) info.textContent = `${shown} résultat(s)`;
    }

    [$filterBeneficiaire, $filterMontant, $filterNumero].forEach(el => {
      if (el) el.addEventListener('input', () => { updateClearBtn(); applyFilters(); });
    });
    [$filterBanque, $filterStatut, $filterChantier, $filterDateFrom, $filterDateTo].forEach(el => {
      if (el) el.addEventListener('change', () => { updateClearBtn(); applyFilters(); });
    });

    applyFilters();

    /* ── bottom scrollbar sync ── */
    function updateBottomHScroll() {
      const sc = document.getElementById('effetsTableResponsive');
      const bar = document.getElementById('effetsBottomHScroll');
      const inner = document.getElementById('effetsBottomHScrollInner');
      if (!sc || !bar || !inner) return;
      inner.style.width = sc.scrollWidth + 'px';
      bar.scrollLeft = sc.scrollLeft;
    }

    (function () {
      const sc = document.getElementById('effetsTableResponsive');
      const bar = document.getElementById('effetsBottomHScroll');
      if (!sc || !bar) return;
      let lock = false;
      sc.addEventListener('scroll', () => { if (lock) return; lock = true; bar.scrollLeft = sc.scrollLeft; lock = false; }, { passive: true });
      bar.addEventListener('scroll', () => { if (lock) return; lock = true; sc.scrollLeft = bar.scrollLeft; lock = false; }, { passive: true });
      window.addEventListener('resize', updateBottomHScroll);
      setTimeout(updateBottomHScroll, 0);
      window.addEventListener('load', () => { updateBottomHScroll(); setTimeout(updateBottomHScroll, 200); });
    })();

    /* ── statut badge → select toggle ── */
    function toggleStatutSelect(span) {
      const td = span.closest('td[data-name="statut"]');
      if (!td) return;
      span.style.display = 'none';
      const sel = document.createElement('select');
      sel.className = 'form-control form-control-sm statut-select';
      ['En Circulation', 'PAYÉ', 'Impayé', 'Annulé', 'Treso'].forEach(opt => {
        const o = document.createElement('option');
        o.value = opt;
        o.textContent = opt;
        if (span.textContent.trim() === opt) o.selected = true;
        sel.appendChild(o);
      });
      sel.addEventListener('change', async () => {
        const tr = td.closest('tr[data-id]');
        const id = tr && tr.dataset.id;
        const val = sel.value;
        if (id) {
          try {
            await fetch(`/tresorerie/effets/${id}/`, {
              method: 'PATCH',
              headers: { 'Content-Type': 'application/json' },
              body: JSON.stringify({ statut: val })
            });
          } catch (e) { console.error(e); }
        }
        span.textContent = val;
        span.className = `badge-statut ${statutClass(val)}`;
        span.style.display = '';
        sel.remove();
        applyFilters();
      });
      sel.addEventListener('blur', () => {
        span.style.display = '';
        sel.remove();
      });
      td.appendChild(sel);
      sel.focus();
    }

    /* ── inline edit (blur → PATCH) ── */
    let dirtyRows = new Set();

    if ($tbody) {
      $tbody.addEventListener('input', e => {
        const td = e.target.closest('td[data-name]');
        if (!td) return;
        const tr = td.closest('tr[data-id]');
        if (tr) dirtyRows.add(tr);
      });

      $tbody.addEventListener('change', e => {
        const sel = e.target.closest('select.chantier-select');
        if (!sel) return;
        const tr = sel.closest('tr[data-id]');
        if (tr) { dirtyRows.add(tr); saveRow(tr); }
      });

      $tbody.addEventListener('focusout', async e => {
        const td = e.target.closest('td[data-name]');
        if (!td) return;
        const tr = td.closest('tr[data-id]');
        if (!tr || !dirtyRows.has(tr)) return;
        await saveRow(tr);
      }, true);
    }

    async function saveRow(tr) {
      const id = tr.dataset.id;
      if (!id) return;
      const data = {};
      tr.querySelectorAll('[data-name]').forEach(el => {
        const key = el.getAttribute('data-name');
        if (el.tagName === 'SELECT' && el.classList.contains('chantier-select')) {
          data[key] = el.value || null;
        } else if (el.tagName === 'TD' && el.contentEditable === 'true') {
          let val = el.textContent.trim();
          if (key === 'montant') {
            const n = parseMoney(val); if (n !== null) data[key] = n;
          } else if (['dateEtablissement', 'dateEcheance', 'dateReglement'].includes(key)) {
            data[key] = dateToISO(val);
          } else {
            data[key] = val;
          }
        }
      });

      try {
        const res = await fetch(`/tresorerie/effets/${id}/`, {
          method: 'PATCH',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(data)
        });
        if (res.ok) {
          dirtyRows.delete(tr);
          applyFilters();
        } else {
          const j = await res.json().catch(() => ({}));
          alert(j.message || 'Erreur mise à jour');
        }
      } catch (err) { alert(err.message || 'Erreur réseau'); }
    }

    /* ── "Enregistrer" saves all dirty rows ── */
    document.getElementById('saveTableBtn').addEventListener('click', async () => {
      const rows = [...dirtyRows];
      if (!rows.length) return alert('Aucune modification à enregistrer.');
      for (const tr of rows) await saveRow(tr);
      alert('Modifications enregistrées.');
    });

    /* ── delete ── */
    if ($tbody) {
      $tbody.addEventListener('click', async e => {
        const btn = e.target.closest('.btn-delete-effet');
        if (!btn) return;
        const tr = btn.closest('tr[data-id]');
        const id = tr && tr.dataset.id;
        if (!id || !confirm('Supprimer cet effet ?')) return;
        const res = await fetch(`/tresorerie/effets/${id}`, { method: 'DELETE' });
        if (res.ok) { tr.remove(); applyFilters(); }
        else alert('Erreur suppression');
      });
    }

    /* ── add row ── */
    document.getElementById('addRowBtn').addEventListener('click', () => {
      const tr = document.createElement('tr');
      tr.setAttribute('data-dirty', 'true');

      const dateFields = ['dateEtablissement', 'numero', 'banque', 'beneficiaire'];
      [
        { key: 'dateEtablissement', label: 'Date', editable: true },
        { key: 'numero', label: 'N° Effet', editable: true },
        { key: 'banque', label: 'Banque', editable: true },
        { key: 'beneficiaire', label: 'Bénéficiaire', editable: true },
        { key: 'montant', label: 'Montant', editable: true, cls: 'text-right' },
        { key: 'dateEcheance', label: 'Échéance', editable: true },
        { key: 'statut', label: 'Statut', editable: false },
        { key: 'dateReglement', label: 'Date Règlement', editable: true },
        { key: 'chantier', label: 'Chantier', editable: false },
        { key: 'obs', label: 'Observation', editable: true, cls: 'obs-cell' },
      ].forEach(col => {
        const td = document.createElement('td');
        td.setAttribute('data-name', col.key);
        if (col.cls) td.className = col.cls;

        if (col.key === 'statut') {
          const sel = document.createElement('select');
          sel.className = 'form-control form-control-sm statut-select';
          ['En Circulation', 'PAYÉ', 'Impayé', 'Annulé', 'Treso'].forEach(o => {
            const opt = document.createElement('option');
            opt.value = o; opt.textContent = o;
            sel.appendChild(opt);
          });
          td.appendChild(sel);
        } else if (col.key === 'chantier') {
          const sel = document.createElement('select');
          sel.className = 'form-control form-control-sm chantier-select';
          const defOpt = document.createElement('option');
          defOpt.value = ''; defOpt.textContent = '-- Aucun --';
          sel.appendChild(defOpt);
          CHANTIERS_DATA.forEach(c => {
            const opt = document.createElement('option');
            opt.value = c.nom; opt.textContent = c.nom;
            sel.appendChild(opt);
          });
          td.appendChild(sel);
        } else {
          td.contentEditable = 'true';
          td.className = (td.className ? td.className + ' ' : '') + 'cell-edit';
        }

        tr.appendChild(td);
      });

      const tdAct = document.createElement('td');
      tdAct.className = 'text-right';
      tdAct.innerHTML = `<div class="table-actions"><button class="btn btn-sm btn-success btn-save-new" title="Enregistrer"><i class="fas fa-save"></i></button></div>`;
      tr.appendChild(tdAct);

      $tbody.prepend(tr);

      /* save new row */
      tdAct.querySelector('.btn-save-new').addEventListener('click', async () => {
        const data = {};
        tr.querySelectorAll('[data-name]').forEach(el => {
          const key = el.getAttribute('data-name');
          if (el.tagName === 'SELECT') {
            data[key] = el.value || null;
          } else {
            let val = el.textContent.trim();
            if (['dateEtablissement', 'dateEcheance', 'dateReglement'].includes(key)) val = dateToISO(val);
            else if (key === 'montant') { const n = parseMoney(val); val = n; }
            data[key] = val;
          }
        });
        try {
          const res = await fetch('/tresorerie/effets/', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(data)
          });
          const json = await res.json().catch(() => ({}));
          if (res.ok && json.id) {
            tr.setAttribute('data-id', json.id);
            tr.removeAttribute('data-dirty');
            tdAct.innerHTML = `<div class="table-actions"><button class="btn btn-sm btn-outline-danger btn-delete-effet" data-id="${json.id}" title="Supprimer"><i class="fas fa-trash"></i></button></div>`;
            applyFilters();
          } else {
            alert(json.message || 'Erreur création effet');
          }
        } catch (err) { alert(err.message || 'Erreur réseau'); }
      });
    });

    /* ── bulk PDF export ── */
    document.getElementById('btnExportPdf').addEventListener('click', () => {
      const { jsPDF } = window.jspdf;
      const headers = Array.from(document.querySelectorAll('#editableTable thead th')).slice(0, -1).map(th => th.innerText);
      const rows = [];
      document.querySelectorAll('#effetTbody tr[data-id]').forEach(tr => {
        if (tr.style.display === 'none') return;
        const row = [];
        tr.querySelectorAll('td:not(:last-child)').forEach(td => {
          const sel = td.querySelector('select:not(.statut-select)');
          const badge = td.querySelector('.badge-statut');
          const statSel = td.querySelector('.statut-select');
          if (sel) row.push(sel.options[sel.selectedIndex].text);
          else if (statSel) row.push(statSel.value);
          else if (badge) row.push(badge.textContent.trim());
          else row.push(td.textContent.trim());
        });
        rows.push(row);
      });
      if (!rows.length) return alert('Aucune donnée à exporter.');
      const doc = new jsPDF({ unit: 'mm', format: 'a4', orientation: 'landscape' });
      doc.text('Liste des Effets', 10, 15);
      doc.autoTable({ head: [headers], body: rows, startY: 22, theme: 'grid' });
      doc.save('effets.pdf');
    });

    /* ── bulk Excel export ── */
    document.getElementById('btnExportExcel').addEventListener('click', () => {
      const headers = Array.from(document.querySelectorAll('#editableTable thead th')).slice(0, -1).map(th => th.innerText);
      const rows = [];
      document.querySelectorAll('#effetTbody tr[data-id]').forEach(tr => {
        if (tr.style.display === 'none') return;
        const row = [];
        tr.querySelectorAll('td:not(:last-child)').forEach(td => {
          const sel = td.querySelector('select:not(.statut-select)');
          const badge = td.querySelector('.badge-statut');
          const statSel = td.querySelector('.statut-select');
          let val;
          if (sel) val = sel.options[sel.selectedIndex].text;
          else if (statSel) val = statSel.value;
          else if (badge) val = badge.textContent.trim();
          else val = td.textContent.trim();
          if (td.dataset.name === 'montant') { const n = parseMoney(val); if (n !== null) val = n; }
          row.push(val);
        });
        rows.push(row);
      });
      if (!rows.length) return alert('Aucune donnée à exporter.');
      const wb = XLSX.utils.book_new();
      const ws = XLSX.utils.aoa_to_sheet([headers, ...rows]);
      XLSX.utils.book_append_sheet(wb, ws, 'Effets');
      XLSX.writeFile(wb, 'effets.xlsx');
    });
  </script>
</body>

</html>