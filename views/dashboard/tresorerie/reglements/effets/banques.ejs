<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta http-equiv="X-UA-Compatible" content="IE=edge" />
  <meta name="viewport" content="width=device-width, initial-scale=1, shrink-to-fit=no" />
  <meta name="description" content="effets" />
  <meta name="author" content="Confonda" />
  <title>effets</title>
  <link href="/vendor/fontawesome-free/css/all.min.css" rel="stylesheet" type="text/css" />
  <link href="https://fonts.googleapis.com/css?family=Nunito:200,300,400,600,700,800,900" rel="stylesheet" />
  <link href="/css/sb-admin-2.min.css" rel="stylesheet" />
  <script src="https://cdn.tailwindcss.com"></script>
  <style>
    .action-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(250px, 1fr));
      gap: 1.5rem;
      padding: 1rem;
    }
    .achat-card {
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      background: white;
      border-radius: 0.75rem;
      box-shadow: 0 4px 6px rgba(0, 0, 0, 0.1);
      padding: 1.5rem;
      transition: transform 0.3s ease, box-shadow 0.3s ease, background 0.3s ease;
      position: relative;
      overflow: hidden;
      text-decoration: none;
      color: inherit;
      height: 180px;
    }
    .achat-card:hover {
      transform: translateY(-5px);
      box-shadow: 0 8px 16px rgba(0, 0, 0, 0.2);
      background: linear-gradient(135deg, #3b82f6, #6366f1);
      color: white;
    }
    .achat-card:hover .card-icon-wrapper i,
    .achat-card:hover .card-title {
      color: white;
    }
    .card-icon-wrapper {
      font-size: 2.5rem;
      margin-bottom: 1rem;
      color: #3b82f6;
      transition: color 0.3s ease;
    }
    .card-title {
      font-size: 1.125rem;
      font-weight: 600;
      text-align: center;
      color: #1f2937;
      transition: color 0.3s ease;
    }
  </style>
</head>
<body id="page-top">
  <div id="wrapper">
    <%- include('../../../../layouts/sidebar') %>
    <div id="content-wrapper" class="d-flex flex-column">
      <div id="content">
        <%- include('../../../../layouts/topbar') %>
        <div class="container-fluid">
            <div class="section-spacing">
              <div class="action-grid" id="cards">
                <a id="card-effets-etablir" href="/tresorerie/effets/create/format/bmce/1" class="achat-card">
                  <div class="card-icon-wrapper">
                    <img src="https://upload.wikimedia.org/wikipedia/commons/thumb/6/67/Bank_of_Africa_Logo.png/420px-Bank_of_Africa_Logo.png" alt="BMCE Bank Logo" class="bank-logo" style="width: 800px; height: 800px;">
                  </div>
                  <span class="card-title">BMCE</span>
                </a>
                <a id="card-effets-etablir" href="/tresorerie/effets/create/format/bmci/3" class="achat-card">
                  <div class="card-icon-wrapper">
                    <img src="../../img/bmci.png" alt="BMCI Bank Logo" class="bank-logo">
                  </div>
                  <span class="card-title">BMCI</span>
                </a>
                <a id="card-virement" href="/tresorerie/effets/create/format/awb/2" class="achat-card">
                  <div class="card-icon-wrapper">
                    <img src="../../img/awb.png" alt="AWB Bank Logo" class="bank-logo" style="width: 800px; height: 800px;">
                  </div>
                  <span class="card-title">AWB</span>
                </a>
                <a id="card-mise" href="/tresorerie/effets/create/format/bp/5" class="achat-card">
                  <div class="card-icon-wrapper">
                    <img src="https://media.licdn.com/dms/image/v2/C560BAQEIddSTtHJb-w/company-logo_200_200/company-logo_200_200/0/1631395045660/banque_populaire_du_maroc_groupe_inc_logo?e=2147483647&v=beta&t=hxsmOagjFYwwZKtxxEvRxHcNHR3pJz91alOcUVw-Dds" alt="Banque Populaire Logo" class="bank-logo" style="width: 800px; height: 800px;">
                  </div>
                  <span class="card-title">Banque Populaire</span>
                </a>
                <a id="card-effets" href="/tresorerie/effets/create/format/credit_agricole/7" class="achat-card">
                  <div class="card-icon-wrapper">
                    <img src="../../img/cag.png" alt="Crédit Agricole Logo" class="bank-logo" style="width: 800px; height: 800px;">
                  </div>
                  <span class="card-title">CREDIT AGRICOLE</span>
                </a>
                <a id="card-effets" href="/tresorerie/effets/create/format/cdm/4" class="achat-card">
                  <div class="card-icon-wrapper">
                    <img src="https://lbanka.com/assets/banks/CDM.png" alt="CDM Bank Logo" class="bank-logo" style="width: 1800px; height: 800px;">
                  </div>
                  <span class="card-title">CDM</span>
                </a>
              </div>
            </div>
          </div>
          
          <style>
            .bank-logo {
              max-width: 100%;
              height: auto;
              max-height: 50px; /* Adjust based on your design */
              object-fit: contain;
            }
          </style>
      </div>
