// Enhanced toggleSelect function with professional styling
function toggleSelect(spanElem) {
const currentStatut = spanElem.textContent.trim();
const statutOptions = ['non échu' , 'impayé' , 'échu' , 'payé'];
let hasChanged = false;

const select = document.createElement('select');
select.className = 'statut-select';

statutOptions.forEach(option => {
  const opt = document.createElement('option');
  opt.value = option;
  opt.textContent = option;
  if (option.toLowerCase() === currentStatut.toLowerCase()) {
    opt.selected = true;
  }
  select.appendChild(opt);
});

spanElem.parentNode.replaceChild(select, spanElem);
select.focus();

select.addEventListener('change', async function () {
  const newStatut = select.value;
  const row = select.closest('tr');
  const payId = row.getAttribute('data-id');

  if (!payId) {
    alert("Impossible de modifier un effet non enregistré.");
    select.blur();
    return;
  }

  // Add loading animation
  select.classList.add('status-updating');

  try {
    const res = await fetch(`/tresorerie/payavenir/${payId}/update-statut`, {
      method: 'PUT',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ statut: newStatut }),
    });

    if (res.ok) {
      hasChanged = true;
      
      const statusClass = getStatusClass(newStatut);
      
      const newSpan = document.createElement('span');
      newSpan.className = `statut-badge ${statusClass}`;
      newSpan.textContent = newStatut;
      newSpan.onclick = () => toggleSelect(newSpan);

      if (select.parentNode) {
        select.parentNode.replaceChild(newSpan, select);
      }
      
      // Add success animation
      newSpan.classList.add('status-updating');
      setTimeout(() => newSpan.classList.remove('status-updating'), 300);
      
    } else {
      
      window.location.href = `/tresorerie/payavenir/banque/${banqueId}`;

      select.classList.remove('status-updating');
      select.blur();
    }
  } catch (err) {
    console.error("Erreur lors de la mise à jour du statut:", err);
      
    

    window.location.href = `/tresorerie/payavenir/banque/${banqueId}`;


    console.log("Erreur réseau lors de la mise à jour du statut. " + err.message);
    select.classList.remove('status-updating');
    select.blur();
  }
});

select.addEventListener('blur', () => {
  if (hasChanged) return;

  const statusClass = getStatusClass(currentStatut);
  const span = document.createElement('span');
  span.className = `statut-badge ${statusClass}`;
  span.textContent = currentStatut;
  span.onclick = () => toggleSelect(span);

  if (select.parentNode) {
    select.parentNode.replaceChild(span, select);
  }
});
}

