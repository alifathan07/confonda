<script>

document.addEventListener("DOMContentLoaded", function () {
const uploadForm = document.getElementById('excelUploadForm');
const fileInput = document.getElementById('excelFile');
const msg = document.getElementById('excelUploadMsg');
const table = document.getElementById("editableTable");

// Convert dd/mm/yyyy → yyyy-mm-dd ISO format or null if empty
function convertDateToISO(dateStr) {
if (!dateStr || dateStr.trim() === '') return null;
const parts = dateStr.split('/');
if (parts.length !== 3) return dateStr.trim(); // fallback: send raw text
const [day, month, year] = parts;
return `${year.padStart(4, '0')}-${month.padStart(2, '0')}-${day.padStart(2, '0')}`;
}

// Function to update total - calculates only visible rows
function updateTotal() {
const rows = document.querySelectorAll("#editableTable tbody tr:not(:last-child)"); // Exclude the total row
let total = 0;

rows.forEach(row => {
  if (row.style.display !== "none") {
  const montantCell = row.querySelector("td[data-name='montant']");
  if (montantCell) {
    const value = parseFloat(montantCell.innerText.replace(/,/g, '.').replace(/[^\d.-]/g, ''));
    if (!isNaN(value)) total += value;
  }
  }
});

const totalCell = document.getElementById("total");
if (totalCell) {
  totalCell.textContent = total.toLocaleString('fr-FR', { minimumFractionDigits: 2, maximumFractionDigits: 2 });
}
}

// Auto-submit Excel upload form on file select
fileInput.addEventListener('change', function () {
if (fileInput.files.length) {
  uploadForm.requestSubmit();
}
});

uploadForm.addEventListener('submit', function(e) {
e.preventDefault();
if (!fileInput.files.length) {
  msg.textContent = 'Veuillez sélectionner un fichier Excel.';
  msg.style.color = 'red';
  return;
}
const formData = new FormData(uploadForm);
msg.textContent = 'Importation en cours...';
msg.style.color = '#1976d2';
fetch('/tresorerie/effets/import', {
  method: 'POST',
  body: formData
})
.then(res => res.text())
.then(text => {
  msg.textContent = text;
  msg.style.color = 'green';
  setTimeout(() => window.location.reload(), 1200);
})
.catch(() => {
  msg.textContent = 'Erreur lors de l\'importation du fichier.';
  msg.style.color = 'red';
});
});
// Drag and drop columns
let dragSrcIdx = null;
function swapColumns(table, fromIdx, toIdx) {
const headerRow = table.tHead.rows[0];
if (fromIdx === toIdx) return;
headerRow.insertBefore(headerRow.children[fromIdx], headerRow.children[toIdx + (fromIdx < toIdx ? 1 : 0)]);
Array.from(table.tBodies[0].rows).forEach(row => {
  row.insertBefore(row.children[fromIdx], row.children[toIdx + (fromIdx < toIdx ? 1 : 0)]);
});
}

Array.from(table.tHead.rows[0].cells).forEach((th, idx) => {
th.addEventListener('dragstart', function (e) {
  dragSrcIdx = idx;
  e.dataTransfer.effectAllowed = 'move';
  th.classList.add('dragging');
});
th.addEventListener('dragend', function () {
  dragSrcIdx = null;
  th.classList.remove('dragging');
  Array.from(table.tHead.rows[0].cells).forEach(cell => cell.classList.remove('drag-over'));
});
th.addEventListener('dragover', function (e) {
  e.preventDefault();
  th.classList.add('drag-over');
});
th.addEventListener('dragleave', function () {
  th.classList.remove('drag-over');
});
th.addEventListener('drop', function (e) {
  e.preventDefault();
  th.classList.remove('drag-over');
  if (dragSrcIdx !== null && dragSrcIdx !== idx) {
  swapColumns(table, dragSrcIdx, idx);
  }
});
});

// Enhanced function to get status class
function getStatusClass(statut) {
  const normalized = statut.toLowerCase()
    .normalize('NFD')
    .replace(/[\u0300-\u036f]/g, '') // Remove accents
    .replace(/\s+/g, '-')
    .trim();
  
  switch(normalized) {
    case 'en-circulation': return 'en-circulation';
    case 'paye': return 'paye';
    case 'impaye': return 'impaye';
    case 'annule': return 'annule';
    default: return 'en-circulation';
  }
}

// Add Row functionality
document.getElementById("addRowBtn").addEventListener("click", function () {
const tbody = table.querySelector("tbody");
const colCount = table.querySelectorAll("thead th").length;
const tr = document.createElement("tr");

for (let i = 0; i < colCount - 1; i++) { // -1 for delete column
  const td = document.createElement("td");
  const header = table.querySelectorAll("thead th")[i];

  if (header && header.innerText) {
  let dataName = '';
  switch (header.innerText.trim()) {
    case 'Designation':
      dataName = 'designation';
      td.contentEditable = "true";
      break;
    case 'Banque':
      dataName = 'banque';
      td.contentEditable = "true";
      break;
    case 'Bénéficiaire':
      dataName = 'beneficiaire';
      td.contentEditable = "true";
      break;
    case 'Montant':
      dataName = 'montant';
      td.contentEditable = "true";
      break;
    case "Date d'échéance": // Updated to match your table header
      dataName = 'dateEcheance';
      td.contentEditable = "true";
      break;
    case 'Statut':
      dataName = 'statut';
      td.classList.add('statut-cell');
      // Create enhanced select for statut
      const select = document.createElement('select');
      select.className = 'statut-select';
      
      const statutOptions = [ 'non échu', 'impayé', 'échu', 'payé'];
      statutOptions.forEach(option => {
        const opt = document.createElement('option');
        opt.value = option;
        opt.textContent = option;
        select.appendChild(opt);
      });
      td.appendChild(select);
      break;
    case 'Date de règlement': // Updated to match your table header
      dataName = 'dateReglement';
      td.contentEditable = "true";
      break;
    case 'Observation':
      dataName = 'obs';
      td.contentEditable = "true";
      break;
    case 'Actions': // Handle the Actions column
      dataName = 'actions';
      // Don't make it contentEditable since it contains buttons
      // You might want to add action buttons here programmatically
      const deleteBtn = document.createElement('button');
      deleteBtn.className = 'delete-row excel-delete-btn';
      deleteBtn.title = 'Supprimer';
      deleteBtn.innerHTML = '<i class="fas fa-trash"></i>';
      
      const updateBtn = document.createElement('button');
      updateBtn.className = 'update-row excel-save-btn btn btn-sm btn-warning';
      updateBtn.title = 'Mettre à jour';
      updateBtn.style.marginLeft = '5px';
      updateBtn.innerHTML = '<i class="fas fa-edit"></i>';
      
      td.appendChild(deleteBtn);
      td.appendChild(updateBtn);
      break;
  }
  
  if (dataName) td.setAttribute('data-name', dataName);
}
tr.appendChild(td);
}

const tdDelete = document.createElement("td");
tdDelete.innerHTML = '<button class="delete-row excel-delete-btn" title="Supprimer" aria-label="Supprimer"><i class="fas fa-trash"></i></button><button class="update-row excel-save-btn btn btn-sm btn-warning" title="Mettre à jour" aria-label="Mettre à jour" style="margin-left:5px;"><i class="fas fa-edit"></i></button>';
tr.appendChild(tdDelete);
tr.setAttribute("data-dirty", "true");
tr.classList.add("excel-dirty-row");
tbody.insertBefore(tr, tbody.firstChild); // Insert at top

updateTotal();
});


// Delete row functionality (event delegation)
table.querySelector("tbody").addEventListener("click", async function (e) {
if (e.target.closest(".delete-row")) {
  const row = e.target.closest("tr");
  const id = row.getAttribute("data-id");
  console.log(id);
  if (confirm("Êtes-vous sûr de vouloir supprimer ce chèque ?")) {
  if (id) {
    try {
    const response = await fetch(`/tresorerie/payavenir/${id}`, {
      method: "DELETE"
    });
    if (response.ok) {
      row.parentNode.removeChild(row);
      alert("Payavenir supprimé avec succès.");
      // Update total after deletion
      updateTotal();
    } else {
      alert("Erreur lors de la suppression du payavenir.");
    }
    } catch (err) {
    alert("Erreur réseau lors de la suppression.");
    }
  } else {
    row.parentNode.removeChild(row);
    // Update total after deletion
    updateTotal();
  }
  }
}

// Update row functionality
if (e.target.closest(".update-row")) {
  // Keep button for manual update, but auto-update is handled below
  const row = e.target.closest("tr");
  await autoUpdateRow(row);
}

// Auto-update row after editing any cell
table.addEventListener("blur", async function (e) {
  const cell = e.target.closest("td[data-name]");
  if (cell && cell.isContentEditable) {
    const row = cell.parentElement;
    if (row.getAttribute("data-id")) {
      await autoUpdateRow(row);
    }
  }
}, true);

// Helper function for updating a row
async function autoUpdateRow(row) {
  if (!row.getAttribute("data-dirty")) return;
  const cells = Array.from(row.querySelectorAll("td[data-name]"));
  const data = {};
  let id = row.getAttribute("data-id");

  cells.forEach(cell => {
    const key = cell.getAttribute("data-name");
    let value;
    if (cell.querySelector("select")) {
      value = cell.querySelector("select").value;
    } else {
      value = cell.innerText.trim();
    }
    if (['dateEtablissement', 'dateEcheance', 'dateReglement'].includes(key)) {
      value = convertDateToISO(value);
    }
    data[key] = value;
  });

  if (!id) {
    // Only update if row is already saved
    return;
  }

  try {
    const response = await fetch(`/tresorerie/payavenir/${id}/`, {
      method: "PATCH",
      headers: { "Content-Type": "application/json" },
      body: JSON.stringify(data)
    }); 
    if (response.ok) {
      row.removeAttribute("data-dirty");
      row.classList.remove("excel-dirty-row");
      updateTotal();
    }
  } catch(err) {
    console.log("Error : "  + err.message
    );
    
  }
}
});

// Mark row as dirty on cell edit and update total if montant changed
table.addEventListener("input", function (e) {
const cell = e.target.closest("td[data-name]");
if (cell) {
  const row = cell.parentElement;
  row.setAttribute("data-dirty", "true");
  row.classList.add("excel-dirty-row");
  
  // If the montant field was edited, update the total
  if (cell.getAttribute("data-name") === "montant") {
  updateTotal();
  }
}
});

// Save functionality (send all dirty rows to backend)
// Save functionality (send all dirty rows to backend)
document.getElementById("saveTableBtn").addEventListener("click", async function () {
const dirtyRows = Array.from(table.querySelectorAll("tbody tr[data-dirty='true']"));
if (dirtyRows.length === 0) {
alert("Aucune modification à enregistrer.");
return;
}

let successCount = 0, failCount = 0;

for (const row of dirtyRows) {
const cells = Array.from(row.querySelectorAll("td[data-name]"));
const data = {};
let id = row.getAttribute("data-id");

cells.forEach(cell => {
  const key = cell.getAttribute("data-name");
  let value;
  if (cell.querySelector("select")) {
  value = cell.querySelector("select").value;
  } else {
  value = cell.innerText.trim();
  }

  if (['dateEtablissement', 'dateEcheance', 'dateReglement'].includes(key)) {
  value = convertDateToISO(value);
  }

  data[key] = value;
});

let url = '';
let method = '';

if (id) {
  url = `/tresorerie/payavenir/${id}/`;
  method = "PUT";
  window.location.reload();
  return;
 
} else {
  const banqueCell = row.querySelector("td[data-name='banque']");
  const banqueId = (banqueCell?.innerText || "").trim().split("/").pop();
  url = `/tresorerie/payavenir/create`;
  method = "POST";
}

try {
  const response = await fetch(url, {
  method,
  headers: { "Content-Type": "application/json" },
  body: JSON.stringify(data)
  });

  if (response.ok) {
  if (!id) {
    const result = await response.json();
    if (result && result.id) {
    row.setAttribute("data-id", result.id);
    }
  }
  row.removeAttribute("data-dirty");
  row.classList.remove("excel-dirty-row");
  successCount++;
  } else {
  failCount++;
  }
} catch {
  failCount++;
}
}

if (successCount > 0) alert(successCount + " payavenir(s) enregistré(s)/modifié(s) avec succès !");
if (failCount > 0) alert(failCount + " payavenir(s) n'ont pas pu être enregistrés.");

// Update total after saving
updateTotal();
});


