<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta http-equiv="X-UA-Compatible" content="IE=edge">
  <meta name="viewport" content="width=device-width, initial-scale=1, shrink-to-fit=no">
  <meta name="description" content="Mises à Disposition">
  <meta name="author" content="Confonda">
  <title>Mise à Disposition</title>
  <link href="/vendor/fontawesome-free/css/all.min.css" rel="stylesheet" type="text/css">
  <link href="https://fonts.googleapis.com/css?family=Nunito:200,300,400,600,700,800,900" rel="stylesheet">
  <link href="/css/sb-admin-2.min.css" rel="stylesheet">
  <style>
    .miseadis-table td,
    .miseadis-table th {
      vertical-align: middle;
    }

    .miseadis-table.table-bordered td,
    .miseadis-table.table-bordered th {
      border-color: #e6e8f0;
    }

    .allocations {
      display: grid;
      gap: 6px;
    }

    .alloc-line {
      display: flex;
      justify-content: space-between;
      gap: 10px;
      padding: 6px 10px;
      border: 1px solid #e9ecef;
      border-radius: 10px;
      background: #fff;
    }

    .alloc-name {
      min-width: 0;
      overflow: hidden;
      text-overflow: ellipsis;
      white-space: nowrap;
    }

    .alloc-amount {
      white-space: nowrap;
      font-weight: 700;
    }

    .table-actions {
      display: flex;
      gap: 6px;
      justify-content: flex-end;
    }

    .cell-edit {
      min-width: 120px;
    }

    .cell-edit[contenteditable="true"] {
      outline: none;
    }

    .cell-edit[contenteditable="true"]:focus {
      box-shadow: inset 0 0 0 2px rgba(78, 115, 223, .25);
      border-radius: 6px;
    }

    .obs-cell {
      min-width: 320px;
      max-width: 520px;
      white-space: normal;
      line-height: 1.25;
    }

    .obs-cell[contenteditable="true"] {
      padding: 8px 10px;
    }

    #filterTypeDropdown .dropdown-menu {
      z-index: 2000;
    }
  
    .statut-cell {
      text-align: center !important;
      vertical-align: middle !important;
      padding: 8px !important;
    }
    .statut-badge {
      display: inline-block;
      padding: 6px 12px;
      font-weight: bold;
    }

    .btn {
      border-radius: 4px;
      padding: 0.5rem 1rem;
      font-size: 0.875rem;
      font-weight: 400;
      border: none;
      cursor: pointer;
    }

    .btn-clear-filters {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      gap: 0.35rem;
      white-space: nowrap !important;
      overflow: visible !important;
      min-width: max-content;
      flex-shrink: 0;
      width: auto !important;
      height: auto !important;
      padding: 0.5rem 1rem !important;
      border-radius: 4px !important;
      line-height: 1.2;
    }
  </style>
</head>
<body id="page-top">
  <div id="wrapper">
    <%- include('../../../../layouts/sidebar') %>
    <div id="content-wrapper" class="d-flex flex-column">
      <div id="content">
        <%- include('../../../../layouts/topbar') %>
        <div class="container-fluid">
          <div class="d-flex align-items-center justify-content-between mb-3">
            <div>
              <h1 class="h3 mb-0 text-gray-800">Mises à disposition</h1>
              <div class="small text-muted" id="miseadisInfo"><%= (miseadis || []).length %> résultat(s)</div>
            </div>
            <div class="d-flex" style="gap: 10px;">
              <button id="downloadPdfBtn" type="button" class="btn btn-outline-danger">
                <i class="fas fa-file-pdf mr-2"></i>PDF
              </button>
              <button id="downloadExcelBtn" type="button" class="btn btn-outline-success">
                <i class="fas fa-file-excel mr-2"></i>Excel
              </button>
              <button id="saveAllChanges" type="button" class="btn btn-warning">
                <i class="fas fa-save mr-2"></i>Enregistrer
              </button>
              <a href="<%= (typeof banqueId !== 'undefined' && banqueId) ? ('/tresorerie/miseadis/banque/' + banqueId + '/create') : '/tresorerie/miseadis/banques' %>" class="btn btn-primary">
                <i class="fas fa-plus mr-2"></i>Nouveau
              </a>
            </div>
          </div>

          <div class="card shadow mb-4">
            <div class="card-body">
              <div class="row mb-3">
                <div class="col-md-3 mb-2">
                  <label class="small text-muted mb-1">Filtre</label>
                  <div class="dropdown" id="filterTypeDropdown">
                    <button class="btn btn-success dropdown-toggle w-100" type="button" id="filterTypeBtn"
                      data-toggle="dropdown" aria-haspopup="true" aria-expanded="false">
                      Filtrer Par
                    </button>
                    <div class="dropdown-menu w-100" id="filterTypeMenu" aria-labelledby="filterTypeBtn">
                      <button class="dropdown-item" type="button" data-filter-type="beneficiaire">Bénéficiaire</button>
                      <button class="dropdown-item" type="button" data-filter-type="banque">Banque</button>
                      <button class="dropdown-item" type="button" data-filter-type="chantier">Chantier</button>
                      <button class="dropdown-item" type="button" data-filter-type="montant">Montant</button>
                    </div>
                  </div>

                  <div id="filterDynamicContainer" class="mt-2">
                    <div id="filterBoxBeneficiaire" style="display:none;">
                      <% const _benefList = Array.from(new Set((miseadis || []).map(m => (m && m.beneficiaire) ? String(m.beneficiaire).trim() : '').filter(Boolean))); %>
                      <select id="filterBeneficiaire" class="form-control">
                        <option value="">Tous</option>
                        <% _benefList.forEach(n => { %>
                          <option value="<%= n %>"><%= n %></option>
                        <% }) %>
                      </select>
                    </div>
                    <div id="filterBoxBanque" style="display:none;">
                      <select id="filterBanque" class="form-control">
                        <option value="">Tous</option>
                        <% (banques || []).forEach(b => { %>
                          <option value="<%= b.name %>"><%= b.name %></option>
                        <% }) %>
                      </select>
                    </div>
                    <div id="filterBoxChantier" style="display:none;">
                      <select id="filterChantier" class="form-control">
                        <option value="">Tous</option>
                        <% (chantiers || []).forEach(c => { %>
                          <option value="<%= c.id %>"><%= c.nom %></option>
                        <% }) %>
                      </select>
                    </div>
                    <div id="filterBoxMontant" style="display:none;">
                      <input id="filterMontant" class="form-control" placeholder="ex: 1200" />
                    </div>
                  </div>
                </div>

                <div class="col-md-2 mb-2 d-flex align-items-end">
                  <button id="btnClearFilters" type="button" class="btn btn-danger w-100 btn-clear-filters" style="display:none;">
                    <i class="fas fa-times mr-1"></i>Annuler filtre
                  </button>
                </div>

                <div class="col-md-2 mb-2">
                  <label class="small text-muted mb-1">Date du</label>
                  <input id="filterDateFrom" type="date" class="form-control" />
                </div>
                <div class="col-md-2 mb-2">
                  <label class="small text-muted mb-1">Date au</label>
                  <input id="filterDateTo" type="date" class="form-control" />
                </div>
              </div>

              <div class="table-responsive" id="miseadisTableResponsive">
                <% 
                  function formatDateToDDMMYYYY(dateInput) {
                    if (!dateInput) return '';
                    const date = new Date(dateInput);
                    if (isNaN(date)) return dateInput;

                    const day = String(date.getDate()).padStart(2, '0');
                    const month = String(date.getMonth() + 1).padStart(2, '0');
                    const year = date.getFullYear();
                    return `${day}/${month}/${year}`;
                  }
                %>

                <table class="table table-sm table-hover table-bordered miseadis-table" style="min-width: 1200px;" id="editableTable">
                  <thead class="thead-light">
                    <tr>
                      <th>Bénéficiaire</th>
                      <th>Banque</th>
                      <th class="text-right">Montant</th>
                      <th>Date</th>
                      <th>Observation</th>
                      <th>Chantier</th>
                      <th>Montant chantier</th>
                      <th class="text-right">Actions</th>
                    </tr>
                  </thead>
                  <tbody id="miseadisTbody">
                    <% if (typeof miseadis === 'undefined' || !miseadis.length) { %>
                      <tr>
                        <td colspan="8" style="text-align: center;">Aucune mise à disposition disponible.</td>
                      </tr>
                    <% } else { %>
                      <% miseadis.forEach(miseadispo => { %>
                        <tr data-id="<%= miseadispo.id %>" data-chantier-ids="<%= (miseadispo.chantierLines && miseadispo.chantierLines.length) ? miseadispo.chantierLines.map(l => l.chantierId).filter(Boolean).join('|') : (miseadispo.chantier ? miseadispo.chantier.id : '') %>">
                          <td class="cell-edit" contenteditable="true" data-name="beneficiaire"><%= miseadispo.beneficiaire || '' %></td>
                          <td class="cell-edit" contenteditable="true" data-name="banque"><%= miseadispo.banque?.name || '' %></td>
                          <td class="text-right cell-edit" contenteditable="true" data-name="montant"><%= Number(miseadispo.montant).toLocaleString('fr-FR', { minimumFractionDigits: 2, maximumFractionDigits: 2 }) %></td>
                          <td class="cell-edit" contenteditable="true" data-name="dateEcheance"><%= formatDateToDDMMYYYY(miseadispo.date) %></td>
                          <td class="cell-edit obs-cell" contenteditable="true" data-name="obs"><%= miseadispo.obs || '' %></td>
                          <td data-name="chantier">
                            <% if (miseadispo.chantierLines && miseadispo.chantierLines.length) { %>
                              <div class="allocations">
                                <% miseadispo.chantierLines.forEach(l=> { %>
                                  <div class="alloc-line" data-chantier-id="<%= l.chantierId %>">
                                    <div class="alloc-name"><%= l.nom %></div>
                                  </div>
                                <% }) %>
                              </div>
                            <% } else { %>
                              <%= miseadispo.chantier ? miseadispo.chantier.nom : "-- Aucun --" %>
                            <% } %>
                          </td>
                          <td data-name="montantChantier">
                            <% if (miseadispo.chantierLines && miseadispo.chantierLines.length) { %>
                              <div class="allocations">
                                <% miseadispo.chantierLines.forEach(l=> { %>
                                  <div class="alloc-line" data-chantier-id="<%= l.chantierId %>">
                                    <div class="alloc-amount"><%= Number(l.montant || 0).toLocaleString('fr-FR', { minimumFractionDigits: 2, maximumFractionDigits: 2 }) %></div>
                                  </div>
                                <% }) %>
                              </div>
                            <% } else { %>
                              <%= Number(miseadispo.montant || 0).toLocaleString('fr-FR', { minimumFractionDigits: 2, maximumFractionDigits: 2 }) %>
                            <% } %>
                          </td>
                          <td class="text-right">
                            <div class="table-actions">
                              <button class="btn btn-danger btn-sm" title="Supprimer" onclick="supprimerMiseadispo(<%= miseadispo.id %>)">
                                <i class="fas fa-trash-alt"></i>
                              </button>
                              <button type="button" class="btn btn-secondary btn-sm" onclick="downloadPDF(<%= miseadispo.id %>)">
                                <i class="fas fa-download"></i>
                              </button>
                            </div>
                          </td>
                        </tr>
                      <% }) %>
                    <% } %>
                  </tbody>
                  <tfoot>
                    <tr>
                      <th colspan="2" class="text-right">Total</th>
                      <th class="text-right" id="totalMontantCell">0,00</th>
                      <th colspan="5"></th>
                    </tr>
                    <tr id="totalChantierRow" style="display:none;">
                      <th colspan="6" class="text-right">Total chantier</th>
                      <th class="text-right" id="totalMontantChantierCell">0,00</th>
                      <th></th>
                    </tr>
                  </tfoot>
                </table>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>

    <script src="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/5.15.4/js/all.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jspdf/2.5.1/jspdf.umd.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jspdf-autotable/3.8.3/jspdf.plugin.autotable.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/xlsx/0.18.5/xlsx.full.min.js"></script>
    <script>
      const { jsPDF } = window.jspdf;
    
      async function supprimerMiseadispo(id) {
        try {
          if (confirm('Êtes-vous sûr de vouloir supprimer cette mise à disposition ?')) {
            const res = await fetch(`/tresorerie/miseadis/delete/${id}`, {
              method: 'DELETE'
            });
            if (res.ok) {
              alert('Mise à disposition supprimée avec succès.');
              location.reload();
            } else {
              const error = await res.json();
              alert(error.error || 'Erreur lors de la suppression de la mise à disposition.');
            }
          }
        } catch (error) {
          console.error('Erreur réseau:', error);
          alert('Erreur réseau lors de la suppression.');
        }
      }
    
      async function downloadPDF(id) {
        try {
          const res = await fetch(`/tresorerie/miseadis/banque/${id}/pdf`);
          if (!res.ok) throw new Error('Erreur lors du téléchargement');
          const blob = await res.blob();
          const url = URL.createObjectURL(blob);
          const link = document.createElement('a');
          link.href = url;
          link.download = `miseadispo_${id}.pdf`;
          document.body.appendChild(link);
          link.click();
          link.remove();
          URL.revokeObjectURL(url);
        } catch (err) {
          console.error('Erreur téléchargement PDF:', err);
          alert('Erreur lors du téléchargement du PDF');
        }
      }
    
      document.addEventListener("DOMContentLoaded", function () {
        const table = document.getElementById("editableTable");
        const saveAllButton = document.getElementById('saveAllChanges');

        const $tbody = document.getElementById('miseadisTbody');
        const $totalCell = document.getElementById('totalMontantCell');
        const $totalChantierCell = document.getElementById('totalMontantChantierCell');
        const $totalChantierRow = document.getElementById('totalChantierRow');
        const $filterTypeBtn = document.getElementById('filterTypeBtn');
        const $filterTypeDropdown = document.getElementById('filterTypeDropdown');
        const $filterTypeMenu = document.getElementById('filterTypeMenu');
        const $btnClearFilters = document.getElementById('btnClearFilters');
        const $filterBeneficiaire = document.getElementById('filterBeneficiaire');
        const $filterBanque = document.getElementById('filterBanque');
        const $filterChantier = document.getElementById('filterChantier');
        const $filterMontant = document.getElementById('filterMontant');
        const $filterDateFrom = document.getElementById('filterDateFrom');
        const $filterDateTo = document.getElementById('filterDateTo');

        let activeFilterType = '';

        function formatDateToDDMMYYYY(dateInput) {
          if (!dateInput) return '';
          const date = new Date(dateInput);
          if (isNaN(date)) return dateInput;

          const day = String(date.getDate()).padStart(2, '0');
          const month = String(date.getMonth() + 1).padStart(2, '0');
          const year = date.getFullYear();
          return `${day}/${month}/${year}`;
        }

        function moneyFr(v) {
          return Number(v || 0).toLocaleString('fr-FR', { minimumFractionDigits: 2, maximumFractionDigits: 2 });
        }

        function parseMoney(v) {
          const raw = String(v ?? '').trim();
          if (!raw) return null;
          const s = raw.replace(/\s/g, '').replace(/[^\d,.-]/g, '').replace(',', '.');
          if (!s) return null;
          const n = Number(s);
          return isNaN(n) ? null : n;
        }

        function dateToISO(str) {
          if (!str) return null;
          const parts = String(str).trim().split('/');
          if (parts.length !== 3) return null;
          const [dd, mm, yyyy] = parts.map(p => p.trim());
          if (!dd || !mm || !yyyy) return null;
          const val = `${yyyy.padStart(4, '0')}-${mm.padStart(2, '0')}-${dd.padStart(2, '0')}`;
          return isNaN(new Date(val)) ? null : val;
        }

        function setFilterType(type) {
          const t = String(type || '').trim();
          activeFilterType = t;
          document.getElementById('filterBoxBeneficiaire').style.display = t === 'beneficiaire' ? '' : 'none';
          document.getElementById('filterBoxBanque').style.display = t === 'banque' ? '' : 'none';
          document.getElementById('filterBoxChantier').style.display = t === 'chantier' ? '' : 'none';
          document.getElementById('filterBoxMontant').style.display = t === 'montant' ? '' : 'none';

          $filterTypeBtn.textContent =
            t === 'beneficiaire' ? 'Bénéficiaire' :
              t === 'banque' ? 'Banque' :
                t === 'chantier' ? 'Chantier' :
                  t === 'montant' ? 'Montant' :
                    'Filtrer Par';

          updateClearBtn();
          applyFilters();
        }

        function updateClearBtn() {
          const active = !!(activeFilterType ||
            ($filterBeneficiaire && $filterBeneficiaire.value) ||
            ($filterBanque && $filterBanque.value) ||
            ($filterChantier && $filterChantier.value) ||
            ($filterMontant && $filterMontant.value) ||
            ($filterDateFrom && $filterDateFrom.value) ||
            ($filterDateTo && $filterDateTo.value));
          if ($btnClearFilters) $btnClearFilters.style.display = active ? '' : 'none';
        }

        function clearFilters() {
          activeFilterType = '';
          [$filterBeneficiaire, $filterBanque, $filterChantier, $filterMontant, $filterDateFrom, $filterDateTo].forEach(el => { if (el) el.value = ''; });
          setFilterType('');
        }

        function toggleMenu(forceOpen) {
          const open = typeof forceOpen === 'boolean' ? forceOpen : !$filterTypeMenu.classList.contains('show');
          $filterTypeDropdown.classList.toggle('show', open);
          $filterTypeMenu.classList.toggle('show', open);
          $filterTypeBtn.setAttribute('aria-expanded', String(open));
        }

        if ($filterTypeBtn) {
          $filterTypeBtn.addEventListener('click', e => { e.preventDefault(); toggleMenu(); });
        }
        document.addEventListener('click', e => { if ($filterTypeDropdown && !$filterTypeDropdown.contains(e.target)) toggleMenu(false); });
        if ($filterTypeDropdown) {
          $filterTypeDropdown.addEventListener('click', e => {
            const btn = e.target && e.target.closest ? e.target.closest('[data-filter-type]') : null;
            if (!btn) return;
            setFilterType(btn.getAttribute('data-filter-type'));
            toggleMenu(false);
          });
        }
        if ($btnClearFilters) $btnClearFilters.addEventListener('click', clearFilters);

        function applyFilters() {
          const benVal = ($filterBeneficiaire && $filterBeneficiaire.value || '').toLowerCase().trim();
          const banVal = $filterBanque && $filterBanque.value || '';
          const chVal = String($filterChantier && $filterChantier.value || '').trim();
          const mtVal = parseMoney($filterMontant && $filterMontant.value);

          const dateFrom = $filterDateFrom && $filterDateFrom.value;
          const dateTo = $filterDateTo && $filterDateTo.value;

          const hasAnyFilter = !!(benVal || banVal || chVal || (mtVal !== null) || dateFrom || dateTo);
          const rows = $tbody ? $tbody.querySelectorAll('tr[data-id]') : [];
          let total = 0;
          let totalChantier = 0;
          let shown = 0;

          rows.forEach(tr => {
            let show = true;

            if (benVal) {
              const c = tr.querySelector('td[data-name="beneficiaire"]');
              show = show && c && c.textContent.toLowerCase().includes(benVal);
            }
            if (banVal) {
              const c = tr.querySelector('td[data-name="banque"]');
              show = show && c && c.textContent.trim() === banVal;
            }
            const chantierFilterActive = Boolean(chVal);
            const selectedChantierId = chantierFilterActive ? chVal : '';

            if (chantierFilterActive) {
              const allLines = Array.from(tr.querySelectorAll('.alloc-line'));
              if (allLines.length) {
                const hasMatch = allLines.some((l) => String(l.getAttribute('data-chantier-id') || '') === selectedChantierId);
                show = show && hasMatch;
              } else {
                const rowIdsRaw = String(tr.getAttribute('data-chantier-ids') || '');
                const rowIds = rowIdsRaw.split('|').map(s => s.trim()).filter(Boolean);
                show = show && rowIds.includes(selectedChantierId);
              }
            }

            if (mtVal !== null) {
              const c = tr.querySelector('td[data-name="montant"]');
              const v = parseMoney(c ? c.textContent : '');
              show = show && v !== null && Math.abs(v - mtVal) < 0.01;
            }
            if (dateFrom || dateTo) {
              const c = tr.querySelector('td[data-name="dateEcheance"]');
              const iso = dateToISO(c ? c.textContent.trim() : '');
              if (iso) {
                const d = new Date(iso);
                if (dateFrom && d < new Date(dateFrom)) show = false;
                if (dateTo && d > new Date(dateTo)) show = false;
              } else {
                show = false;
              }
            }

            tr.style.display = (!hasAnyFilter || show) ? '' : 'none';

            const lines = tr.querySelectorAll('.alloc-line');
            if (lines && lines.length) {
              lines.forEach((l) => {
                if (!selectedChantierId) {
                  l.style.display = '';
                  return;
                }
                const n = String(l.getAttribute('data-chantier-id') || '').trim();
                l.style.display = (n === selectedChantierId) ? '' : 'none';
              });
            }

            if (tr.style.display !== 'none') {
              const mc = tr.querySelector('td[data-name="montant"]');
              const v = parseMoney(mc ? mc.textContent : '');
              if (v !== null) total += v;
              shown++;

              if (chantierFilterActive) {
                const visibleAllocLines = Array.from(tr.querySelectorAll("td[data-name='montantChantier'] .alloc-line")).filter((l) => {
                  const style = window.getComputedStyle(l);
                  return style.display !== 'none' && style.visibility !== 'hidden';
                });
                totalChantier += visibleAllocLines.reduce((acc, l) => {
                  const amountEl = l.querySelector('.alloc-amount');
                  const amountText = (amountEl && amountEl.textContent) ? amountEl.textContent : '';
                  const val = parseMoney(amountText);
                  return acc + (val === null ? 0 : val);
                }, 0);
              }
            }
          });

          if ($totalCell) $totalCell.textContent = moneyFr(total);

          if ($totalChantierRow) {
            $totalChantierRow.style.display = chVal ? '' : 'none';
          }
          if ($totalChantierCell) {
            $totalChantierCell.textContent = chVal ? moneyFr(totalChantier) : '0,00';
          }

          const info = document.getElementById('miseadisInfo');
          if (info) info.textContent = `${shown} résultat(s)`;

          updateClearBtn();
        }

        // Wire filters to applyFilters (same behavior as cheques/effets pages)
        [$filterBeneficiaire, $filterBanque, $filterChantier, $filterDateFrom, $filterDateTo].forEach((el) => {
          if (!el) return;
          el.addEventListener('change', () => {
            updateClearBtn();
            applyFilters();
          });
        });
        if ($filterMontant) {
          $filterMontant.addEventListener('input', () => {
            updateClearBtn();
            applyFilters();
          });
        }

        document.getElementById("downloadPdfBtn").addEventListener("click", function () {
          const table = document.getElementById("editableTable");
          const rows = table.querySelectorAll("tbody tr");
          if (!rows || rows.length === 0) {
            alert("Aucune donnée à exporter en PDF.");
            return;
          }

          try {
            const doc = new jsPDF({ unit: 'mm', format: 'a4', orientation: 'portrait' });
            const headers = Array.from(table.querySelectorAll("thead th")).slice(0, -1).map(th => th.innerText);
            const h1 = document.querySelector('h1.h3');
            const title = (h1 && h1.innerText) ? h1.innerText : (document.title || 'Mises à disposition');

            doc.setFont("helvetica", "bold");
            doc.setFontSize(18);
            doc.setTextColor(40, 40, 40);
            doc.text(title, 10, 20);

            const tableData = [];
            Array.from(rows).forEach(row => {
              if (row.style.display === 'none') return;
              const rowData = Array.from(row.querySelectorAll("td:not(:last-child)")).map(cell => {
                let value = '';
                if (cell.dataset.name === 'chantier' || cell.dataset.name === 'montantChantier') {
                  const lines = Array.from(cell.querySelectorAll('.alloc-line')).filter((l) => {
                    const style = window.getComputedStyle(l);
                    return style.display !== 'none' && style.visibility !== 'hidden';
                  });

                  if (lines.length) {
                    if (cell.dataset.name === 'chantier') {
                      value = lines.map(l => {
                        const n = l.querySelector('.alloc-name');
                        return (n && n.textContent) ? n.textContent.trim() : '';
                      }).filter(Boolean).join('\n');
                    } else {
                      value = lines.map(l => {
                        const a = l.querySelector('.alloc-amount');
                        return (a && a.textContent) ? a.textContent.trim() : '';
                      }).filter(Boolean).join('\n');
                    }
                  } else {
                    value = cell.innerText ? cell.innerText.trim() : '';
                  }
                } else {
                  value = cell.innerText ? cell.innerText.trim() : '';
                }

                if (cell.dataset.name === "dateEcheance" && value) {
                  if (value.match(/^\d{4}-\d{2}-\d{2}$/)) {
                    const parts = value.split('-');
                    value = `${parts[2]}/${parts[1]}/${parts[0]}`;
                  } else if (!value.match(/^\d{2}\/\d{2}\/\d{4}$/)) {
                    const d = new Date(value);
                    if (!isNaN(d)) {
                      const day = String(d.getDate()).padStart(2, '0');
                      const month = String(d.getMonth() + 1).padStart(2, '0');
                      const year = d.getFullYear();
                      value = `${day}/${month}/${year}`;
                    }
                  }
                }

                return value || '';
              });
              tableData.push(rowData);
            });

            doc.autoTable({
              head: [headers],
              body: tableData,
              startY: 30,
              theme: 'grid',
              styles: {
                font: 'helvetica',
                fontSize: 8,
                textColor: [40, 40, 40],
                cellPadding: 2,
                lineColor: [200, 200, 200],
                lineWidth: 0.1,
                overflow: 'linebreak'
              },
              headStyles: {
                fillColor: [22, 160, 133],
                textColor: [255, 255, 255],
                fontSize: 7,
                fontStyle: 'bold',
                halign: 'center',
                cellPadding: 2
              },
              alternateRowStyles: { fillColor: [245, 245, 245] },
              margin: { top: 30, left: 10, right: 10 },
              tableWidth: 'wrap'
            });

            const totalEl = document.getElementById("totalMontantCell");
            let total = (totalEl && totalEl.innerText) ? totalEl.innerText : '0';
            total = total.replace(/[^\d.,-]/g, '').replace(/\s/g, '').replace(',', '.');
            const totalNumber = parseFloat(total);
            if (!isNaN(totalNumber)) {
              const parts = totalNumber.toFixed(2).split('.');
              const integerPart = parts[0].replace(/\B(?=(\d{3})+(?!\d))/g, ' ');
              total = `${integerPart},${parts[1]}`;
            }

            const finalY = (doc.lastAutoTable && doc.lastAutoTable.finalY) ? doc.lastAutoTable.finalY : 30;
            doc.setFont("helvetica", "bold");
            doc.setFontSize(12);
            doc.setTextColor(22, 160, 133);
            doc.text(`Total: ${total} MAD`, 10, finalY + 15);

            const chantierTotalRow = document.getElementById('totalChantierRow');
            const totalChantierEl = document.getElementById('totalMontantChantierCell');
            const totalChantier = (totalChantierEl && totalChantierEl.innerText) ? totalChantierEl.innerText : '';
            if (chantierTotalRow && chantierTotalRow.style.display !== 'none' && totalChantier) {
              doc.text(`Total chantier: ${totalChantier.replace(/[^\d.,-]/g, '').replace(/\s/g, '').replace(',', '.')} MAD`, 10, finalY + 22);
            }

            doc.save("liste_mises_a_disposition.pdf");
          } catch (err) {
            console.error("Erreur génération PDF:", err);
            alert("Erreur lors de la génération du PDF. Veuillez vérifier la console.");
          }
        });

        document.getElementById("downloadExcelBtn").addEventListener("click", function () {
          const table = document.getElementById("editableTable");
          const rows = table.querySelectorAll("tbody tr");
          const visibleRows = Array.from(rows).filter(row => row.style.display !== "none");

          if (visibleRows.length === 0) {
            alert("Aucune donnée visible à exporter en Excel. Veuillez vérifier les filtres.");
            return;
          }

          try {
            const headers = Array.from(table.querySelectorAll("thead th")).slice(0, -1).map(th => th.innerText);
            const tableData = [];
            let invalidData = null;

            visibleRows.forEach((row, rowIndex) => {
              const rowData = Array.from(row.querySelectorAll("td:not(:last-child)")).map((cell) => {
                let value = "";
                if (cell.dataset.name === 'chantier' || cell.dataset.name === 'montantChantier') {
                  const lines = Array.from(cell.querySelectorAll('.alloc-line')).filter((l) => {
                    const style = window.getComputedStyle(l);
                    return style.display !== 'none' && style.visibility !== 'hidden';
                  });

                  if (lines.length) {
                    if (cell.dataset.name === 'chantier') {
                      value = lines.map(l => {
                        const n = l.querySelector('.alloc-name');
                        return (n && n.textContent) ? n.textContent.trim() : '';
                      }).filter(Boolean).join('\n');
                    } else {
                      value = lines.map(l => {
                        const a = l.querySelector('.alloc-amount');
                        return (a && a.textContent) ? a.textContent.trim() : '';
                      }).filter(Boolean).join('\n');
                    }
                  } else {
                    value = cell.innerText ? cell.innerText.trim() : '';
                  }
                } else {
                  value = cell.innerText ? cell.innerText.trim() : '';
                }

                if (cell.dataset.name === "montant" && value) {
                  const cleaned = value.replace(/[^\d.,-]/g, '').replace(/\s/g, '').replace(',', '.');
                  const number = parseFloat(cleaned);
                  if (!isNaN(number)) {
                    value = number;
                  } else {
                    invalidData = `Montant non numérique à la ligne ${rowIndex + 1}: "${value}"`;
                  }
                }

                if (cell.dataset.name === "dateEcheance" && value) {
                  if (!/^\d{2}\/\d{2}\/\d{4}$/.test(value)) {
                    invalidData = `Format de date invalide à la ligne ${rowIndex + 1}, colonne ${cell.dataset.name}: "${value}"`;
                  }
                }

                return value || "";
              });

              while (rowData.length < headers.length) rowData.push("");
              tableData.push(rowData);
            });

            if (invalidData) throw new Error(invalidData);

            const totalEl = document.getElementById("totalMontantCell");
            let total = (totalEl && totalEl.innerText) ? totalEl.innerText : "0";
            total = total.replace(/[^\d.,-]/g, '').replace(/\s/g, '').replace(',', '.');
            const totalNumber = parseFloat(total);
            tableData.push(["Total", "", !isNaN(totalNumber) ? totalNumber : 0, "", "", "", ""]);

            const chantierTotalRowEl = document.getElementById('totalChantierRow');
            const chantierTotalCell = document.getElementById('totalMontantChantierCell');
            let totalChantierStr = (chantierTotalRowEl && chantierTotalRowEl.style.display !== 'none' && chantierTotalCell && chantierTotalCell.innerText)
              ? chantierTotalCell.innerText
              : "";
            if (totalChantierStr) {
              totalChantierStr = totalChantierStr.replace(/[^\d.,-]/g, '').replace(/\s/g, '').replace(',', '.');
              const totalChantierNumber = parseFloat(totalChantierStr);
              tableData.push(["", "", "", "", "", "Total chantier", !isNaN(totalChantierNumber) ? totalChantierNumber : 0]);
            }

            const wb = XLSX.utils.book_new();
            const ws = XLSX.utils.aoa_to_sheet([headers, ...tableData], { skipHeader: false });

            ws['!cols'] = [
              { wch: 18 },
              { wch: 18 },
              { wch: 15 },
              { wch: 25 },
              { wch: 25 },
              { wch: 23 },
              { wch: 18 }
            ];

            headers.forEach((_, i) => {
              const cellRef = XLSX.utils.encode_cell({ r: 0, c: i });
              if (!ws[cellRef]) ws[cellRef] = { v: headers[i], t: 's' };
              ws[cellRef].s = {
                font: { bold: true },
                fill: { fgColor: { rgb: "16A085" } },
                alignment: { horizontal: i === 2 ? 'right' : i === 3 ? 'center' : 'left' },
                border: {
                  top: { style: 'thin' },
                  bottom: { style: 'thin' },
                  left: { style: 'thin' },
                  right: { style: 'thin' }
                }
              };
            });

            tableData.forEach((row, rowIndex) => {
              row.forEach((value, colIndex) => {
                const cellRef = XLSX.utils.encode_cell({ r: rowIndex + 1, c: colIndex });
                const isMontantColumn = colIndex === 2;

                if (!ws[cellRef]) {
                  ws[cellRef] = {
                    v: value || "",
                    t: isMontantColumn && typeof value === 'number' ? 'n' : 's'
                  };
                }

                ws[cellRef].s = {
                  fill: { fgColor: { rgb: rowIndex % 2 === 0 ? "FFFFFF" : "F5F5F5" } },
                  alignment: { horizontal: isMontantColumn ? 'right' : colIndex === 3 ? 'center' : 'left' },
                  border: {
                    top: { style: 'thin' },
                    bottom: { style: 'thin' },
                    left: { style: 'thin' },
                    right: { style: 'thin' }
                  }
                };

                if (rowIndex === tableData.length - 1 && (colIndex === 0 || isMontantColumn)) {
                  ws[cellRef].s.font = { bold: true };
                }
              });
            });

            XLSX.utils.book_append_sheet(wb, ws, "MisesADisposition");
            XLSX.writeFile(wb, "liste_mises_a_disposition.xlsx");
          } catch (err) {
            console.error("Erreur génération Excel:", err);
            alert(`Erreur lors de la génération du fichier Excel : ${err.message}`);
          }
        });

        applyFilters();
      });
    </script>

