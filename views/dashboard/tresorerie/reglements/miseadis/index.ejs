// Fonction pour formater les dates en jj/mm/aaaa
function formatDateToDDMMYYYY(dateInput) {
    if (!dateInput) return '';
    const date = new Date(dateInput);
    if (isNaN(date)) return dateInput; 
    const day = String(date.getDate()).padStart(2, '0');
    const month = String(date.getMonth() + 1).padStart(2, '0');
    const year = date.getFullYear();
    return `${day}/${month}/${year}`;
}
%>

<table id="editableTable" class="excel-table">
    <thead>
        <tr style="position: sticky; top: 0; background-color: white; z-index: 1;">
            <th draggable="true">Bénéficiaire</th>
            <th draggable="true">Banque</th>
            <th draggable="true">Montant</th>
            <th draggable="true">Date Saisie</th>
            <th draggable="true">Observation</th>
            <th draggable="true">Chantier</th>
            <th style="width: 180px;">Actions</th>
        </tr>
    </thead>
    <tbody>
        <% if (typeof miseadis !== 'undefined' && miseadis.length) { %>
            <% miseadis.forEach(miseadispo => { %>
            <tr data-id="<%= miseadispo.id %>">
                <td contenteditable="true" data-name="beneficiaire"><%= miseadispo.beneficiaire || '' %></td>
                <td contenteditable="true" data-name="banque"><%= miseadispo.banque?.name || '' %></td>
                <td contenteditable="true" data-name="montant"><%= Number(miseadispo.montant).toLocaleString('fr-FR', { minimumFractionDigits: 2, maximumFractionDigits: 2 }) %></td>
                <td contenteditable="true" data-name="dateEcheance"><%= formatDateToDDMMYYYY(miseadispo.date) %></td>
                <td contenteditable="true" data-name="obs"><%= miseadispo.obs || '' %></td>
                <td data-name="chantier">
                  <select data-name="chantier" class="form-control">
                    <% if (miseadispo.chantier) { %>
                      <option value="<%= miseadispo.chantier.id %>"><%= miseadispo.chantier.nom %></option>
                    <% } else { %>
                      <option value="">Choisir un chantier</option>
                    <% } %>
                    <% chantiers.forEach(chantier => { %>
                      <% if (!miseadispo.chantier || miseadispo.chantier.id !== chantier.id) { %>
                        <option value="<%= chantier.id %>"><%= chantier.nom %></option>
                      <% } %>
                    <% }) %>
                  </select>
                </td>
                <td>
                    <div class="btn-group" role="group">
