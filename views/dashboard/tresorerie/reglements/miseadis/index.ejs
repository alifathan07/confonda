                            <i class="fas fa-edit"></i>
                        </a>
                        <button class="btn btn-danger btn-sm" title="Supprimer" onclick="supprimerVirement(<%= miseadispo.id %>)">
                            <i class="fas fa-trash-alt"></i>
                        </button>
                        <button type="button" class="btn btn-secondary btn-sm" onclick="downloadPDF(<%= miseadispo.id %>)">
                            <i class="fas fa-download"></i>
                        </button>
                    </div>
                </td>
            </tr>
            <% }) %>
        <% } %>
    </tbody>
</table>

<script>
async function supprimerVirement(id) {
    try {
        if (confirm('Êtes-vous sûr de vouloir supprimer ce miseadispo ?')) {
            const res = await fetch(`/tresorerie/miseadis/banque/<%= banqueId %>/delete/${id}`, {
                method: 'DELETE'
            });
            if (res.ok) {
                alert('Virement supprimé avec succès.');
                location.reload();
            } else {
                alert('Erreur lors de la suppression du miseadispo.');
            }
        }
    } catch (error) {
        console.error(error);
    }
    
}
async function downloadPDF(id) {
    try {
        const res = await fetch(`/tresorerie/miseadis/banque/${id}/pdf`);
        if (!res.ok) throw new Error('Erreur lors du téléchargement');

        const blob = await res.blob();
        const url = URL.createObjectURL(blob);

        const link = document.createElement('a');
        link.href = url;
        link.download = `miseadispo_${id}.pdf`;
        document.body.appendChild(link);
        link.click();
        link.remove();
        URL.revokeObjectURL(url);
    } catch (err) {
        console.error(err);
        alert('Erreur lors du téléchargement du PDF');
    }
}
</script>

