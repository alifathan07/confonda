<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta http-equiv="X-UA-Compatible" content="IE=edge" />
  <meta name="viewport" content="width=device-width, initial-scale=1, shrink-to-fit=no" />
  <meta name="description" content="Cheques" />
  <meta name="author" content="Confonda" />
  <title>Mise A Disposition</title>
  <link href="/vendor/fontawesome-free/css/all.min.css" rel="stylesheet" type="text/css" />
  <link href="https://fonts.googleapis.com/css?family=Nunito:200,300,400,600,700,800,900" rel="stylesheet" />
  <link href="/css/sb-admin-2.min.css" rel="stylesheet" />
   <!-- Enhanced Status Styles -->
      <style>
/* Dropdown styling */
#beneficiaire-list {
    position: absolute;
    background: #fff;
    border: 1px solid #ccc;
    max-height: 150px;
    overflow-y: auto;
    z-index: 1000;
    width: 100%;
}

#beneficiaire-list div {
    padding: 8px;
    cursor: pointer;
}

#beneficiaire-list div:hover {
    background-color: #f0f0f0;
}
</style>
      <body>
        
     <body id="page-top">
    <div id="wrapper">
        <%- include('../../../../layouts/sidebar') %>
        <div id="content-wrapper" class="d-flex flex-column">
            <div id="content">
                <%- include('../../../../layouts/topbar') %>
                <div class="container-fluid">
                    <div class="card shadow mb-4">
                        <div class="card-header py-3">
                            <h4 class="m-0 font-weight-bold text-primary">
                                <i class="fas fa-exchange-alt"></i> Nouveau Mise a Disposition
                            </h4>
                        </div>
                        <div class="card-body">
                            <form action="/tresorerie/miseadis/banque/<%=banqueId %>/create" method="POST" class="needs-validation" novalidate>
                                <div class="form-row">
                                    <div class="form-group col-12 d-flex justify-content-center">
                                        <%
  const today = new Date();
  const offset = today.getTimezoneOffset();
  const localDate = new Date(today.getTime() - (offset * 60 * 1000));
  const formatted = localDate.toISOString().split("T")[0];
%>

<div class="col-md-6">
  <label for="date">Date</label>
  <input 
    type="date" 
    class="form-control" 
    id="date" 
    name="date" 
    value="<%= formatted %>" 
    required
  >
</div>

                                        <div class="col-md-6">
                                            <label for="date">Objet</label>
                                            <input type="text" class="form-control" id="objet" name="objet" value="MISE A DISPOSITION" required>
                                        </div>
                                    </div>
                                   
                                </div>
                                <div class="form-row">
                                    <div class="form-group col-12 col-md-6">
                                        <label for="beneficiaire">Bénéficiaire</label>
                                        <input type="text" class="form-control" id="beneficiaire" name="beneficiaire" required placeholder="Nom du bénéficiaire">
                                    
                                    </div>
                                    <div class="form-group col-12 col-md-6">
                                        <label for="beneficiaire">CIN</label>
                                        <input type="text" class="form-control" id="cin" name="cin" required>
                                    </div>
                                    <div class="form-group col-12 col-md-6">
                                        <label for="montant">Montant</label>
                                        <div class="input-group">
                                            <input type="number" step="0.01" class="form-control" id="montant" name="montant" required placeholder="Montant">
                                            <div class="input-group-append">
                                            </div>
                                        </div> 
                                    </div>
                                 
                                   
                                </div>
                                  
                                <div class="form-row">
                                    <div class="form-group col-12 col-md-6">
                                        <label for="dateReglement">Date débit</label>
                                        <input type="date" class="form-control" id="dateReglement" name="dateReglement" value="<%= new Date() %>" required>
                                    </div>
                                    <div class="form-group col-12 col-md-6">
                                        <label for="obs">Observations</label>
                                        <textarea class="form-control" id="obs" name="obs" rows="2" placeholder="Notes ou remarques"></textarea>
                                    </div>
                                </div>
                                <div class="form-group col-12 col-md-6">
                                    <label for="montantLettre">Montant en lettres</label>
                                    <input type="text" class="form-control" id="montantLettre" name="montantLettre" readonly placeholder="Montant en lettres">
                                </div>
                                
                                <script>
                                const montantWordsCache = new Map();
                                
                                function numberToFrenchWords(n) {
                                    if (montantWordsCache.has(n)) return montantWordsCache.get(n);
                                    if (typeof n === "string") n = n.replace(/\s/g,''); 
                                    n = BigInt(n); 
                                
                                    if (n === 0n) return "ZÉRO";
                                
                                    const ones = ["","UN","DEUX","TROIS","QUATRE","CINQ","SIX","SEPT","HUIT","NEUF"];
                                    const teens = ["DIX","ONZE","DOUZE","TREIZE","QUATORZE","QUINZE","SEIZE","DIX-SEPT","DIX-HUIT","DIX-NEUF"];
                                    const tens = ["","DIX","VINGT","TRENTE","QUARANTE","CINQUANTE","SOIXANTE","SOIXANTE","QUATRE-VINGT","QUATRE-VINGT"];
                                    const scales = ["","MILLE","MILLION","MILLIARD","BILLION","BILLIARD","TRILLION"];
                                
                                    function chunkNumber(num) {
                                        let chunks = [];
                                        while (num > 0) {
                                            chunks.push(num % 1000n);
                                            num = num / 1000n;
                                        }
                                        return chunks;
                                    }
                                
                                    function chunkToWords(chunk) {
                                        let h = chunk / 100n;
                                        let t = (chunk % 100n) / 10n;
                                        let o = chunk % 10n;
                                        let str = "";
                                
                                        // Hundreds
                                        if (h > 0n) {
                                            str += (h === 1n ? "CENT" : ones[Number(h)] + " CENT");
                                            if (t !== 0n || o !== 0n) str += " ";
                                        }
                                
                                        let num2 = Number(t * 10n + o);
                                        if (num2 > 0) {
                                            if (num2 < 10) {
                                                str += ones[num2];
                                            } else if (num2 < 20) {
                                                str += teens[num2 - 10];
                                            } else {
                                                let tenVal = Number(t);
                                                let oneVal = Number(o);
                                
                                                if (tenVal === 7) {
                                                    str += "SOIXANTE-" + teens[oneVal];
                                                } else if (tenVal === 9) {
                                                    str += "QUATRE-VINGT-" + teens[oneVal];
                                                } else if (tenVal === 8) {
                                                    str += "QUATRE-VINGT" + (oneVal === 0 ? "S" : "-" + ones[oneVal]);
                                                } else if (oneVal === 1 && tenVal !== 8) {
                                                    str += tens[tenVal] + "-ET-UN";
                                                } else if (oneVal > 0) {
                                                    str += tens[tenVal] + "-" + ones[oneVal];
                                                } else {
                                                    str += tens[tenVal];
                                                }
                                            }
                                        }
                                
                                        return str.trim();
                                    }
                                
                                    let chunks = chunkNumber(n);
                                    let words = [];
                                
                                    for (let i = chunks.length - 1; i >= 0; i--) {
                                        let chunk = chunks[i];
                                        if (chunk === 0n) continue;
                                        let chunkWord = chunkToWords(chunk);
                                        if (i > 0) {
                                            if (i === 1 && chunk === 1n) chunkWord = scales[i]; // "mille" singular
                                            else chunkWord += " " + scales[i];
                                            if (chunk > 1n && i > 1) chunkWord += "S"; 
                                        }
                                        words.push(chunkWord);
                                    }
                                
                                    let result = words.join(" ").replace(/\s+/g,' ').trim();
                                    montantWordsCache.set(n, result);
                                    return result;
                                }
                                
                                // Debounce input
                                function debounce(fn, delay) {
                                    let timer = null;
                                    return function(...args) {
                                        clearTimeout(timer);
                                        timer = setTimeout(() => fn.apply(this, args), delay);
                                    };
                                }
                                
                                document.getElementById('montant').addEventListener('input', debounce(function() {
                                    const val = this.value;
                                    if (!val) {
                                        document.getElementById('montantLettre').value = "";
                                        return;
                                    }
                                
                                    let parts = val.split(".");
                                    let integerPart = parts[0];
                                    let decimalPart = parts[1] || "";
                                
                                    let text = numberToFrenchWords(integerPart);
                                    if (decimalPart && parseInt(decimalPart, 10) > 0) {
                                        text += " VIRGULE " + numberToFrenchWords(decimalPart);
                                    }
                                
                                    document.getElementById('montantLettre').value = text;
                                }, 150));
                                </script>
                                

                                <script src="/vendor/jquery/jquery.min.js"></script>


                             
                                <div class="d-flex flex-column flex-md-row">
                                    <button type="submit" class="btn btn-success custom-btn mb-2 mb-md-0">
                                        <i class="fas fa-save"></i> Enregistrer
                                    </button>
                                    <a href="/dashboard/tresorerie/reglements/virements" class="btn btn-secondary custom-btn ml-md-2">
                                        <i class="fas fa-arrow-left"></i> Annuler
                                    </a>
                                </div>
                            </form>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>



<script src="/vendor/jquery/jquery.min.js"></script>
<script src="/vendor/bootstrap/js/bootstrap.bundle.min.js"></script>
<script src="/vendor/jquery-easing/jquery.easing.min.js"></script>
<script src="/js/sb-admin-2.min.js"></script>
<script src="/vendor/datatables/jquery.dataTables.min.js"></script>
<script src="/vendor/datatables/dataTables.bootstrap4.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/xlsx/0.18.5/xlsx.full.min.js"></script>

<script src="/js/demo/datatables-demo.js"></script>
</body>