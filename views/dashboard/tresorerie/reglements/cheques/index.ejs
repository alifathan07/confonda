<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta http-equiv="X-UA-Compatible" content="IE=edge" />
  <meta name="viewport" content="width=device-width, initial-scale=1, shrink-to-fit=no" />
  <meta name="description" content="cheques" />
  <meta name="author" content="Confonda" />
  <title>cheques</title>
  <link href="/vendor/fontawesome-free/css/all.min.css" rel="stylesheet" type="text/css" />
  <link href="https://fonts.googleapis.com/css?family=Nunito:200,300,400,600,700,800,900" rel="stylesheet" />
  <link href="/css/sb-admin-2.min.css" rel="stylesheet" />
  <link href="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/css/select2.min.css" rel="stylesheet" />
   <!-- Enhanced Status Styles -->
  <style>
    .cheque-table td, .cheque-table th { vertical-align: middle; }
    .cheque-table.table-bordered td, .cheque-table.table-bordered th { border-color: #e6e8f0; }
    .badge-statut { font-weight: 700; letter-spacing: .2px; }
    .badge-statut.en-circulation { background: #fff3cd; color: #856404; }
    .badge-statut.paye { background: #d4edda; color: #155724; }
    .badge-statut.impaye { background: #f8d7da; color: #721c24; }
    .badge-statut.annule { background: #e2e3e5; color: #383d41; }
    .badge-statut.treso { background: #d1ecf1; color: #0c5460; }
    .allocations { display: grid; gap: 6px; }
    .alloc-line { display: flex; justify-content: space-between; gap: 10px; padding: 6px 10px; border: 1px solid #e9ecef; border-radius: 10px; background: #fff; }
    .alloc-name { min-width: 0; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
    .alloc-amount { white-space: nowrap; font-weight: 700; }
    .table-actions { display: flex; gap: 6px; justify-content: flex-end; }
    .cell-edit { min-width: 120px; }
    .cell-edit[contenteditable="true"] { outline: none; }
    .cell-edit[contenteditable="true"]:focus { box-shadow: inset 0 0 0 2px rgba(78,115,223,.25); border-radius: 6px; }
    .obs-cell { min-width: 320px; max-width: 520px; white-space: normal; line-height: 1.25; }
    .obs-cell[contenteditable="true"] { padding: 8px 10px; }
    .statut-select { min-width: 170px; font-weight: 700; }
    .statut-cell { cursor: pointer; }
  </style>
</head>

<body id="page-top">
  <div id="wrapper">
    <%- include('../../../../layouts/sidebar') %>
    <div id="content-wrapper" class="d-flex flex-column">
      <div id="content">
        <%- include('../../../../layouts/topbar') %>

        <div class="container-fluid">
          <div class="d-flex align-items-center justify-content-between mb-3">
            <div>
              <% if (typeof banqueName !== 'undefined' && banqueName && banqueName.name) { %>
                <h1 class="h3 mb-0 text-gray-800">Chèques - <%= banqueName.name %></h1>
              <% } else { %>
                <h1 class="h3 mb-0 text-gray-800">Chèques</h1>
              <% } %>
              <div class="small text-muted">
                <% if (typeof pagination !== 'undefined' && pagination) { %>
                  <%= pagination.total %> résultat(s)
                <% } %>
              </div>
            </div>

            <div class="d-flex" style="gap: 10px;">
              <button id="btnExportPdf" type="button" class="btn btn-outline-danger">
                <i class="fas fa-file-pdf mr-2"></i>PDF
              </button>
              <button id="btnExportExcel" type="button" class="btn btn-outline-success">
                <i class="fas fa-file-excel mr-2"></i>Excel
              </button>
              <button id="btnAddCheque" type="button" class="btn btn-primary">
                <i class="fas fa-plus mr-2"></i>Nouveau
              </button>
            </div>
          </div>

          <div class="card shadow mb-4">
            <div class="card-body">
              <div class="row mb-3">
                <div class="col-md-3 mb-2">
                  <label class="small text-muted mb-1">Fournisseur</label>
                  <select id="filterFournisseur" class="form-control">
                    <option value="">Tous</option>
                    <% (fournisseurs || []).forEach(f => { %>
                      <option value="<%= f.id %>" <%= (filters && String(filters.fournisseurId) === String(f.id)) ? 'selected' : '' %>><%= f.name %></option>
                    <% }) %>
                  </select>
                </div>
                <div class="col-md-3 mb-2">
                  <label class="small text-muted mb-1">Banque</label>
                  <select id="filterBanque" class="form-control" <%= (filters && filters.banqueId) ? 'disabled' : '' %>>
                    <option value="">Toutes</option>
                    <% (banques || []).forEach(b => { %>
                      <option value="<%= b.id %>" <%= (filters && String(filters.banqueId) === String(b.id)) ? 'selected' : '' %>><%= b.name %></option>
                    <% }) %>
                  </select>
                </div>
                <div class="col-md-2 mb-2">
                  <label class="small text-muted mb-1">Statut</label>
                  <select id="filterStatut" class="form-control">
                    <option value="">Tous</option>
                    <option value="En Circulation" <%= (filters && filters.statut === 'En Circulation') ? 'selected' : '' %>>En Circulation</option>
                    <option value="Payé" <%= (filters && filters.statut === 'Payé') ? 'selected' : '' %>>Payé</option>
                    <option value="Impayé" <%= (filters && filters.statut === 'Impayé') ? 'selected' : '' %>>Impayé</option>
                    <option value="Annulé" <%= (filters && filters.statut === 'Annulé') ? 'selected' : '' %>>Annulé</option>
                    <option value="Treso" <%= (filters && filters.statut === 'Treso') ? 'selected' : '' %>>Treso</option>
                  </select>
                </div>
                <div class="col-md-2 mb-2">
                  <label class="small text-muted mb-1">Montant</label>
                  <input id="filterMontant" class="form-control" value="<%= (filters && filters.montant) ? filters.montant : '' %>" placeholder="ex: 1200" />
                </div>
                <div class="col-md-3 mb-2">
                  <label class="small text-muted mb-1">Chantier</label>
                  <select id="filterChantier" class="form-control">
                    <option value="">Tous</option>
                    <% (chantiers || []).forEach(c => { %>
                      <option value="<%= c.id %>" <%= (filters && String(filters.chantierId) === String(c.id)) ? 'selected' : '' %>><%= c.nom %></option>
                    <% }) %>
                  </select>
                </div>
                <div class="col-md-2 mb-2">
                  <label class="small text-muted mb-1">Échéance du</label>
                  <input id="filterEcheanceFrom" type="date" class="form-control" value="<%= (filters && filters.dateEcheanceFrom) ? filters.dateEcheanceFrom : '' %>" />
                </div>
                <div class="col-md-2 mb-2">
                  <label class="small text-muted mb-1">Échéance au</label>
                  <input id="filterEcheanceTo" type="date" class="form-control" value="<%= (filters && filters.dateEcheanceTo) ? filters.dateEcheanceTo : '' %>" />
                </div>
                <div class="col-md-2 mb-2">
                  <label class="small text-muted mb-1">Recherche</label>
                  <input id="filterSearch" class="form-control" value="<%= (filters && filters.search) ? filters.search : '' %>" placeholder="N°, bénéficiaire..." />
                </div>
              </div>

              <div class="table-responsive">
                <table class="table table-sm table-hover table-bordered cheque-table" style="min-width: 1250px;">
                  <thead class="thead-light">
                    <tr>
                      <th>Date</th>
                      <th>N° chèque</th>
                      <th>Bénéficiaire</th>
                      <th>Banque</th>
                      <th>Échéance</th>
                      <th>Statut</th>
                      <th>Date règlement</th>
                      <th>Chantier</th>
                      <th>Montant chantier</th>
                      <th>Observation</th>
                      <th class="text-right">Montant</th>
                      <th class="text-right">Actions</th>
                    </tr>
                  </thead>
                  <tbody id="chequeTbody">
                    <% (cheques || []).forEach(c => { %>
                      <tr data-id="<%= c.id %>" data-banque-name="<%= (c.banque && c.banque.name) ? c.banque.name : '' %>">
                        <td class="cell-edit" contenteditable="true" data-field="dateEtablissement"><%= c.dateEtablissement ? new Date(c.dateEtablissement).toLocaleDateString('fr-FR') : '' %></td>
                        <td class="cell-edit" contenteditable="true" data-field="numero"><%= c.numero || '' %></td>
                        <td class="cell-edit" contenteditable="true" data-field="beneficiaire"><%= c.beneficiaire || '' %></td>
                        <td><%= (c.banque && c.banque.name) ? c.banque.name : '' %></td>
                        <td class="cell-edit" contenteditable="true" data-field="dateEcheance"><%= c.dateEcheance ? new Date(c.dateEcheance).toLocaleDateString('fr-FR') : '' %></td>
                        <td data-field="statut" class="statut-cell">
                          <span class="badge badge-statut <%= (c.statut || '').toLowerCase().normalize('NFD').replace(/[\u0300-\u036f]/g,'').replace(/\s+/g,'-') %>" data-value="<%= c.statut || '' %>"><%= c.statut || '' %></span>
                        </td>
                        <td class="cell-edit" contenteditable="true" data-field="dateReglement"><%= c.dateReglement ? new Date(c.dateReglement).toLocaleDateString('fr-FR') : '' %></td>
                        <td>
                          <div class="allocations">
                            <% 
                              const _chantierFilterId = (filters && filters.chantierId) ? String(filters.chantierId) : '';
                              const _displayAllocs = (c.allocations && c.allocations.length)
                                ? (_chantierFilterId ? c.allocations.filter(a => String(a.chantierId) === _chantierFilterId) : c.allocations)
                                : [];
                              const _shouldUseAlloc = _displayAllocs.length > 0;
                            %>

                            <% if (_shouldUseAlloc) { %>
                              <% _displayAllocs.forEach(a => { %>
                                <div class="alloc-line">
                                  <div class="alloc-name"><%= a.chantier ? a.chantier.nom : '' %></div>
                                </div>
                              <% }) %>
                            <% } else if (!_chantierFilterId && c.chantier) { %>
                              <div class="alloc-line">
                                <div class="alloc-name"><%= c.chantier.nom %></div>
                              </div>
                            <% } %>
                          </div>
                        </td>

                        <td>
                          <div class="allocations">
                            <% if (_shouldUseAlloc) { %>
                              <% _displayAllocs.forEach(a => { %>
                                <div class="alloc-line">
                                  <div class="alloc-name">&nbsp;</div>
                                  <div class="alloc-amount"><%= (a.montant || 0).toLocaleString('fr-FR', { minimumFractionDigits: 2, maximumFractionDigits: 2 }) %></div>
                                </div>
                              <% }) %>
                            <% } else if (!_chantierFilterId && c.chantier) { %>
                              <div class="alloc-line">
                                <div class="alloc-name">&nbsp;</div>
                                <div class="alloc-amount"><%= (c.montant || 0).toLocaleString('fr-FR', { minimumFractionDigits: 2, maximumFractionDigits: 2 }) %></div>
                              </div>
                            <% } %>
                          </div>
                        </td>

                        <td class="cell-edit obs-cell" contenteditable="true" data-field="obs"><%= c.obs || '' %></td>

                        <td class="text-right cell-edit" contenteditable="true" data-field="montant"><%= (c.montant || 0).toLocaleString('fr-FR', { minimumFractionDigits: 2, maximumFractionDigits: 2 }) %></td>
                        <td class="text-right">
                          <div class="table-actions">
                            <button class="btn btn-sm btn-outline-secondary btn-alloc" title="Chantiers">
                              <i class="fas fa-project-diagram"></i>
                            </button>
                            <button class="btn btn-sm btn-outline-danger btn-delete" title="Supprimer">
                              <i class="fas fa-trash"></i>
                            </button>
                          </div>
                        </td>
                      </tr>
                    <% }) %>
                  </tbody>
                  <tfoot>
                    <tr>
                      <th colspan="10" class="text-right">Total</th>
                      <th class="text-right" id="totalMontantCell">0,00</th>
                      <th></th>
                    </tr>
                  </tfoot>
                </table>
              </div>

              <div class="d-flex align-items-center justify-content-between mt-3">
                <div class="small text-muted" id="paginationInfo">
                  <% if (pagination) { %>
                    Page <%= pagination.page %> / <%= pagination.totalPages %> (<%= pagination.total %> résultat(s))
                  <% } %>
                </div>
                <nav aria-label="Pagination">
                  <ul class="pagination pagination-sm mb-0" id="paginationControls">
                    <% if (pagination) { %>
                      <% const p = pagination.page; const totalPages = pagination.totalPages; %>
                      <% const mkLink = (page) => {
                        const params = new URLSearchParams();
                        if (filters && filters.banqueId) params.set('banqueId', filters.banqueId);
                        if (filters && filters.fournisseurId) params.set('fournisseurId', filters.fournisseurId);
                        if (filters && filters.statut) params.set('statut', filters.statut);
                        if (filters && filters.search) params.set('search', filters.search);
                        if (filters && filters.montant) params.set('montant', filters.montant);
                        if (filters && filters.chantierId) params.set('chantierId', filters.chantierId);
                        if (filters && filters.dateEcheanceFrom) params.set('dateEcheanceFrom', filters.dateEcheanceFrom);
                        if (filters && filters.dateEcheanceTo) params.set('dateEcheanceTo', filters.dateEcheanceTo);
                        params.set('page', String(page));
                        params.set('pageSize', String(pagination.pageSize));
                        return '?' + params.toString();
                      }; %>
                      <li class="page-item <%= p <= 1 ? 'disabled' : '' %>"><a class="page-link" href="<%= mkLink(Math.max(p - 1, 1)) %>">Préc.</a></li>
                      <% const start = Math.max(1, p - 2); const end = Math.min(totalPages, p + 2); %>
                      <% for (let i = start; i <= end; i++) { %>
                        <li class="page-item <%= i === p ? 'active' : '' %>"><a class="page-link" href="<%= mkLink(i) %>"><%= i %></a></li>
                      <% } %>
                      <li class="page-item <%= p >= totalPages ? 'disabled' : '' %>"><a class="page-link" href="<%= mkLink(Math.min(p + 1, totalPages)) %>">Suiv.</a></li>
                    <% } %>
                  </ul>
                </nav>
              </div>
            </div>
          </div>
        </div>
      </div>

      <div class="modal fade" id="createChequeModal" tabindex="-1" role="dialog" aria-hidden="true">
        <div class="modal-dialog modal-lg" role="document">
          <div class="modal-content">
            <div class="modal-header">
              <h5 class="modal-title">Créer un chèque</h5>
              <button type="button" class="close" data-dismiss="modal" aria-label="Close">
                <span aria-hidden="true">&times;</span>
              </button>
            </div>
            <div class="modal-body">
              <div class="row">
                <div class="col-md-6 mb-3">
                  <label class="small text-muted mb-1">Bénéficiaire (Fournisseur)</label>
                  <select id="createFournisseur" class="form-control"></select>
                </div>
                <div class="col-md-6 mb-3">
                  <label class="small text-muted mb-1">Banque</label>
                  <select id="createBanque" class="form-control"></select>
                </div>
                <div class="col-md-6 mb-3">
                  <label class="small text-muted mb-1">Date d'échéance</label>
                  <input id="createDateEcheance" type="date" class="form-control" />
                </div>
                <div class="col-md-6 mb-3">
                  <label class="small text-muted mb-1">Montant (auto)</label>
                  <input id="createMontant" class="form-control" readonly />
                </div>
                <div class="col-12 mb-2">
                  <label class="small text-muted mb-1">Observation</label>
                  <input id="createObs" class="form-control" />
                </div>
              </div>

              <div class="d-flex align-items-center justify-content-between mt-2 mb-2">
                <div class="small text-muted">Affectations chantiers</div>
                <button id="btnCreateAddAlloc" class="btn btn-sm btn-outline-primary" type="button">
                  <i class="fas fa-plus mr-2"></i>Ajouter chantier
                </button>
              </div>

              <div id="createAllocList" class="d-grid" style="gap: 10px;"></div>
              <div class="small text-muted mt-2" id="createAllocTotals"></div>
            </div>
            <div class="modal-footer">
              <button type="button" class="btn btn-secondary" data-dismiss="modal">Annuler</button>
              <button type="button" class="btn btn-primary" id="btnCreateChequeConfirm">Créer</button>
            </div>
          </div>
        </div>
      </div>

      <div class="modal fade" id="allocModal" tabindex="-1" role="dialog" aria-hidden="true">
        <div class="modal-dialog modal-lg" role="document">
          <div class="modal-content">
            <div class="modal-header">
              <h5 class="modal-title">Chantiers & montants</h5>
              <button type="button" class="close" data-dismiss="modal" aria-label="Close">
                <span aria-hidden="true">&times;</span>
              </button>
            </div>
            <div class="modal-body">
              <div class="small text-muted" id="allocTotals"></div>
              <div id="allocList" class="d-grid" style="gap: 10px;"></div>
              <button id="btnAddAllocLine" class="btn btn-sm btn-outline-primary mt-3"><i class="fas fa-plus mr-2"></i>Ajouter chantier</button>
            </div>
            <div class="modal-footer">
              <button type="button" class="btn btn-secondary" data-dismiss="modal">Fermer</button>
              <button type="button" class="btn btn-primary" id="btnSaveAlloc">Enregistrer</button>
            </div>
          </div>
        </div>
      </div>

      <script src="/vendor/jquery/jquery.min.js"></script>
      <script src="/vendor/bootstrap/js/bootstrap.bundle.min.js"></script>
      <script src="/vendor/jquery-easing/jquery.easing.min.js"></script>
      <script src="/js/sb-admin-2.min.js"></script>
      <script src="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/js/select2.min.js"></script>

      <script type="application/json" id="chequesPageData">
        <%- JSON.stringify({
          fournisseurs: (fournisseurs || []).map(f => ({ id: f.id, name: f.name })),
          chantiers: (chantiers || []).map(c => ({ id: c.id, nom: c.nom })),
          banques: (banques || []).map(b => ({ id: b.id, name: b.name })),
          banqueName: (typeof banqueName !== 'undefined' && banqueName && banqueName.name) ? banqueName.name : '',
          pagination: {
            page: (pagination && pagination.page) ? pagination.page : 1,
            pageSize: (pagination && pagination.pageSize) ? pagination.pageSize : 25
          },
          filters: {
            banqueId: (filters && filters.banqueId) ? String(filters.banqueId) : '',
            fournisseurId: (filters && filters.fournisseurId) ? String(filters.fournisseurId) : '',
            statut: (filters && filters.statut) ? String(filters.statut) : '',
            montant: (filters && filters.montant) ? String(filters.montant) : '',
            chantierId: (filters && filters.chantierId) ? String(filters.chantierId) : '',
            dateEcheanceFrom: (filters && filters.dateEcheanceFrom) ? String(filters.dateEcheanceFrom) : '',
            dateEcheanceTo: (filters && filters.dateEcheanceTo) ? String(filters.dateEcheanceTo) : '',
            search: (filters && filters.search) ? String(filters.search) : ''
          }
        }) %>
      </script>

      <script>
        (function () {
          const apiUrl = '/api/cheques';
          const $tbody = document.getElementById('chequeTbody');
          const $paginationInfo = document.getElementById('paginationInfo');
          const $totalMontantCell = document.getElementById('totalMontantCell');

          const $paginationControls = document.getElementById('paginationControls');

          const $filterFournisseur = document.getElementById('filterFournisseur');
          const $filterBanque = document.getElementById('filterBanque');
          const $filterStatut = document.getElementById('filterStatut');
          const $filterMontant = document.getElementById('filterMontant');
          const $filterChantier = document.getElementById('filterChantier');
          const $filterEcheanceFrom = document.getElementById('filterEcheanceFrom');
          const $filterEcheanceTo = document.getElementById('filterEcheanceTo');
          const $filterSearch = document.getElementById('filterSearch');

          const $btnExportPdf = document.getElementById('btnExportPdf');
          const $btnExportExcel = document.getElementById('btnExportExcel');
          const $btnAddCheque = document.getElementById('btnAddCheque');
          const $allocModal = $('#allocModal');
          const $createChequeModal = $('#createChequeModal');
          const $allocList = document.getElementById('allocList');
          const $btnAddAllocLine = document.getElementById('btnAddAllocLine');
          const $btnSaveAlloc = document.getElementById('btnSaveAlloc');

          const $createFournisseur = document.getElementById('createFournisseur');
          const $createBanque = document.getElementById('createBanque');
          const $createDateEcheance = document.getElementById('createDateEcheance');
          const $createMontant = document.getElementById('createMontant');
          const $createObs = document.getElementById('createObs');
          const $createAllocList = document.getElementById('createAllocList');
          const $createAllocTotals = document.getElementById('createAllocTotals');
          const $btnCreateAddAlloc = document.getElementById('btnCreateAddAlloc');
          const $btnCreateChequeConfirm = document.getElementById('btnCreateChequeConfirm');

          const pageData = JSON.parse(document.getElementById('chequesPageData').textContent);
          const fournisseurs = pageData.fournisseurs || [];
          const chantiers = pageData.chantiers || [];
          const banques = pageData.banques || [];
          const fixedBanqueName = pageData.banqueName || '';

          let state = {
            page: (pageData.pagination && pageData.pagination.page) ? pageData.pagination.page : 1,
            pageSize: (pageData.pagination && pageData.pagination.pageSize) ? pageData.pagination.pageSize : 25,
            banqueId: (pageData.filters && pageData.filters.banqueId) ? pageData.filters.banqueId : '',
            fournisseurId: (pageData.filters && pageData.filters.fournisseurId) ? pageData.filters.fournisseurId : '',
            statut: (pageData.filters && pageData.filters.statut) ? pageData.filters.statut : '',
            montant: (pageData.filters && pageData.filters.montant) ? pageData.filters.montant : '',
            chantierId: (pageData.filters && pageData.filters.chantierId) ? pageData.filters.chantierId : '',
            dateEcheanceFrom: (pageData.filters && pageData.filters.dateEcheanceFrom) ? pageData.filters.dateEcheanceFrom : '',
            dateEcheanceTo: (pageData.filters && pageData.filters.dateEcheanceTo) ? pageData.filters.dateEcheanceTo : '',
            search: (pageData.filters && pageData.filters.search) ? pageData.filters.search : ''
          };

          let editingAllocChequeId = null;
          let editingAllocations = [];
          let editingAllocChequeMontant = null;

          let createAllocations = [];

          function normalizeStatutClass(statut) {
            return String(statut || '').toLowerCase().normalize('NFD').replace(/[\u0300-\u036f]/g,'').replace(/\s+/g,'-');
          }

          const statutOptions = ['En Circulation', 'Payé', 'Impayé', 'Annulé', 'Treso'];

          function statutBadgeHtml(statut) {
            const cls = normalizeStatutClass(statut);
            const label = String(statut || '').trim();
            return `<span class="badge badge-statut ${cls}" data-value="${label}">${label}</span>`;
          }

          function moneyFr(v) {
            const n = Number(v || 0);
            return n.toLocaleString('fr-FR', { minimumFractionDigits: 2, maximumFractionDigits: 2 });
          }

          function parseMoney(v) {
            const s = String(v || '').trim();
            if (!s) return null;
            const cleaned = s.replace(/\s/g, '').replace(/[^0-9,.-]/g, '').replace(',', '.');
            const n = Number(cleaned);
            return Number.isNaN(n) ? null : n;
          }

          function buildQuery(page) {
            const p = new URLSearchParams();
            p.set('page', String(page || state.page || 1));
            p.set('pageSize', String(state.pageSize || 25));
            if (state.banqueId) p.set('banqueId', state.banqueId);

            if (state.fournisseurId) p.set('fournisseurId', state.fournisseurId);
            if (state.statut) p.set('statut', state.statut);
            if (state.search) p.set('search', state.search);
            if (state.montant) p.set('montant', state.montant);
            if (state.chantierId) p.set('chantierId', state.chantierId);
            if (state.dateEcheanceFrom) p.set('dateEcheanceFrom', state.dateEcheanceFrom);
            if (state.dateEcheanceTo) p.set('dateEcheanceTo', state.dateEcheanceTo);
            return p;
          }

          function buildExportParams() {
            const p = new URLSearchParams();
            if (state.banqueId) p.set('banqueId', state.banqueId);
            if (state.fournisseurId) p.set('fournisseurId', state.fournisseurId);
            if (state.statut) p.set('statut', state.statut);
            if (state.search) p.set('search', state.search);
            if (state.montant) p.set('montant', state.montant);
            if (state.chantierId) p.set('chantierId', state.chantierId);
            if (state.dateEcheanceFrom) p.set('dateEcheanceFrom', state.dateEcheanceFrom);
            if (state.dateEcheanceTo) p.set('dateEcheanceTo', state.dateEcheanceTo);
            return p;
          }

          async function fetchPage(page) {
            const params = buildQuery(page);
            const res = await fetch(apiUrl + '?' + params.toString(), { headers: { 'Accept': 'application/json' } });
            const json = await res.json().catch(() => ({}));
            if (!res.ok || !json || json.success === false) {
              throw new Error(json && json.error ? json.error : 'Erreur chargement');
            }
            return json;
          }

          function setTotalMontant(v) {
            if (!$totalMontantCell) return;
            const n = Number(v || 0);
            $totalMontantCell.textContent = n.toLocaleString('fr-FR', { minimumFractionDigits: 2, maximumFractionDigits: 2 });
          }

          function renderPagination(pagination, totalMontant) {
            const page = pagination.page;
            const totalPages = pagination.totalPages;
            const n = Number(totalMontant || 0);
            $paginationInfo.textContent = `Page ${page} / ${totalPages} (${pagination.total} résultat(s)) - Total : ${n.toLocaleString('fr-FR', { minimumFractionDigits: 2, maximumFractionDigits: 2 })}`;

            const start = Math.max(1, page - 2);
            const end = Math.min(totalPages, page + 2);

            $paginationControls.innerHTML = '';

            function addItem(label, targetPage, disabled, active) {
              const li = document.createElement('li');
              li.className = `page-item${disabled ? ' disabled' : ''}${active ? ' active' : ''}`;
              const a = document.createElement('a');
              a.className = 'page-link';
              a.href = '#';
              a.textContent = label;
              a.addEventListener('click', async (e) => {
                e.preventDefault();
                if (disabled) return;
                await refresh(targetPage);
              });
              li.appendChild(a);
              $paginationControls.appendChild(li);
            }

            addItem('Préc.', Math.max(1, page - 1), page <= 1, false);
            for (let i = start; i <= end; i++) addItem(String(i), i, false, i === page);
            addItem('Suiv.', Math.min(totalPages, page + 1), page >= totalPages, false);
          }

