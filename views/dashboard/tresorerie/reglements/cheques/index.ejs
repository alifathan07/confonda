          $tbody.addEventListener('blur', async (e) => {
            const td = e.target.closest('td[data-field]');
            if (!td || td.getAttribute('contenteditable') !== 'true') return;
            const tr = td.closest('tr');
            const id = tr && tr.dataset.id;
            if (!id) return;

            const field = td.dataset.field;
            let value = td.textContent.trim();

            if (field === 'montant') {
              const n = parseMoney(value);
              if (n === null) return;
              value = String(n);
            }

            try {
              const payload = {};
              if (field === 'dateReglement') {
                if (value === '') {
                  payload[field] = '';
                } else {
                  const iso = parseInputDateToIso(value);
                  if (!iso) {
                    alert('Format date règlement invalide. Utilisez JJ/MM/AAAA.');
                    return;
                  }
                  payload[field] = iso;
                }
              } else if (field === 'dateEcheance' || field === 'dateEtablissement') {
                if (value) {
                  const iso = parseInputDateToIso(value);
                  if (!iso) {
                    alert('Format date invalide. Utilisez JJ/MM/AAAA.');
                    return;
                  }
                  payload[field] = iso;
                } else {
                  payload[field] = value;
                }
              } else {
                payload[field] = value;
              }

              if (!payload.beneficiaire) {
                const cell = tr.querySelector('td[data-field="beneficiaire"]');
                payload.beneficiaire = cell ? cell.textContent.trim() : '';
              }
              // Use the cheque's actual bank from the row (never the filter placeholder like "Toutes")
              payload.banque = (tr && tr.dataset && tr.dataset.banqueName) ? tr.dataset.banqueName : currentBanqueName();

              if (!payload.banque || !payload.beneficiaire) {
                return;
              }

              await enqueuePatchCheque(id, payload);
            } catch (err) {
              alert(err.message || 'Erreur');
            }
          }, true);

          $tbody.addEventListener('click', (e) => {
