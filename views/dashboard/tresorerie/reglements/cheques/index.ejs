          let debounceT = null;
          function debounceRefresh() {
            if (debounceT) clearTimeout(debounceT);
            debounceT = setTimeout(() => refresh(1).catch(() => {}), 250);
          }

          function currentBanqueName() {
            if (fixedBanqueName) return fixedBanqueName;
            if (state.banqueId) {
              const b = banques.find(x => String(x.id) === String(state.banqueId));
              if (b && b.name) return b.name;
            }
            const selected = document.querySelector('#filterBanque option:checked');
            if (selected && selected.textContent) return selected.textContent.trim();
            return '';
          }

          const patchQueues = new Map();
          function enqueuePatchCheque(id, data) {
            const key = String(id);
            const prev = patchQueues.get(key) || Promise.resolve();
            const next = prev
              .catch(() => {})
              .then(() => patchCheque(id, data));
            patchQueues.set(key, next);
            next.finally(() => {
              if (patchQueues.get(key) === next) patchQueues.delete(key);
            });
            return next;
          }

          async function patchCheque(id, data) {
            const res = await fetch(`/tresorerie/cheques/${id}`, {
              method: 'PATCH',
              headers: { 'Content-Type': 'application/json' },
              body: JSON.stringify(data)
            });
            const json = await res.json().catch(() => ({}));
            if (!res.ok) throw new Error(json && json.error ? json.error : 'Erreur mise à jour');
            return json;
          }

          function parseInputDateToIso(value) {
            const s = String(value || '').trim();
            if (!s) return null;

            if (/^\d{4}-\d{2}-\d{2}$/.test(s)) {
              if (!isValidIsoDate(s)) return null;
              return s;
            }

            const m = s.match(/^(\d{2})\/(\d{2})\/(\d{4})$/);
            if (!m) return null;

            const dd = Number(m[1]);
            const mm = Number(m[2]);
            const yyyy = Number(m[3]);
            if (Number.isNaN(dd) || Number.isNaN(mm) || Number.isNaN(yyyy)) return null;
            if (mm < 1 || mm > 12) return null;
            if (dd < 1 || dd > 31) return null;

            const iso = String(yyyy).padStart(4, '0') + '-' + String(mm).padStart(2, '0') + '-' + String(dd).padStart(2, '0');
            if (!isValidIsoDate(iso)) return null;
            return iso;
          }

          function formatFrDateFromAny(d) {
            if (!d) return '';
            const s = String(d).trim();
            if (!s) return '';

            // If backend sends ISO date (YYYY-MM-DD or YYYY-MM-DDTHH:mm:ss...)
            const iso = s.match(/^(\d{4})-(\d{2})-(\d{2})/);
            if (iso) {
              return `${iso[3]}/${iso[2]}/${iso[1]}`;
            }

            // If already in FR format
            if (/^\d{2}\/\d{2}\/\d{4}$/.test(s)) {
              return s;
            }

            const dd = new Date(s);
            if (Number.isNaN(dd.getTime())) return '';
            return dd.toLocaleDateString('fr-FR');
          }

          function isValidIsoDate(yyyyMMdd) {
            const s = String(yyyyMMdd || '').trim();
            if (!/^\d{4}-\d{2}-\d{2}$/.test(s)) return false;

            const d = new Date(s + 'T00:00:00.000Z');
            return !Number.isNaN(d.getTime());
          }

