          function setCreateMontantFromAllocs() {
            const amounts = (Array.isArray(createAllocations) ? createAllocations : [])
              .map(a => parseMoney(a.montant))
              .filter(v => v !== null);
            const sum = amounts.reduce((acc, v) => acc + Number(v || 0), 0);
            if ($createMontant) $createMontant.value = moneyFr(sum);
            if ($createAllocTotals) $createAllocTotals.textContent = `Total affectations: ${moneyFr(sum)}`;
          }

          function renderCreateAllocEditor() {
            if (!$createAllocList) return;
            $createAllocList.innerHTML = '';


            for (let i = 0; i < createAllocations.length; i++) {
              const line = createAllocations[i];

              const wrap = document.createElement('div');
              wrap.className = 'd-flex align-items-center';
              wrap.style.gap = '10px';

              const sel = document.createElement('select');
              sel.className = 'form-control';
              sel.style.flex = '1';
              const optEmpty = document.createElement('option');
              optEmpty.value = '';
              optEmpty.textContent = '-- Chantier --';
              sel.appendChild(optEmpty);
              for (const c of chantiers) {
                const o = document.createElement('option');
                o.value = String(c.id);
                o.textContent = c.nom;
                if (String(line.chantierId || '') === String(c.id)) o.selected = true;
                sel.appendChild(o);
              }

              const input = document.createElement('input');
              input.className = 'form-control';
              input.placeholder = 'Montant';
              input.style.width = '200px';
              input.value = line.montant !== undefined && line.montant !== null ? String(line.montant) : '';


              const btnRemove = document.createElement('button');
              btnRemove.type = 'button';
              btnRemove.className = 'btn btn-outline-danger';
              btnRemove.innerHTML = '<i class="fas fa-times"></i>';


              sel.addEventListener('change', () => { createAllocations[i].chantierId = sel.value; });
              input.addEventListener('input', () => { createAllocations[i].montant = input.value; setCreateMontantFromAllocs(); });
              btnRemove.addEventListener('click', () => {
                createAllocations.splice(i, 1);
                if (!createAllocations.length) createAllocations.push({ chantierId: '', montant: '' });
                renderCreateAllocEditor();
              });

              wrap.appendChild(sel);
              wrap.appendChild(input);
              wrap.appendChild(btnRemove);
              $createAllocList.appendChild(wrap);
            }

            setCreateMontantFromAllocs();
          }

          // Initial load: ensure totals are not stuck at 0 and data is in sync with API
          refresh(state.page).catch(() => {});

        })();
      </script>
    </div>
  </div>
</body>
</html>