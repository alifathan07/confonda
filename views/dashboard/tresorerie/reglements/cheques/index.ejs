              .map(a => ({ chantierId: a.chantierId, montant: parseMoney(a.montant) }))
              .filter(a => a.chantierId && a.montant !== null);

            const sum = payload.reduce((acc, a) => acc + Number(a.montant || 0), 0);
            const chequeM = Number(editingAllocChequeMontant || 0);
            const eps = 0.01;
            if (chequeM && (sum - chequeM) > eps) {
              return alert(`Tu as dépassé le montant du chèque. Total allocations: ${moneyFr(sum)} / Montant chèque: ${moneyFr(chequeM)}`);
