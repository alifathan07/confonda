<!DOCTYPE html>
<html lang="fr">

<head>
  <meta charset="UTF-8">
  <title>Signaler un Bug</title>
  <link href="/vendor/bootstrap/css/bootstrap.min.css" rel="stylesheet">
  <link href="/vendor/fontawesome-free/css/all.min.css" rel="stylesheet">
  <link href="/css/sb-admin-2.min.css" rel="stylesheet">

  <style>
    .bug-form-card {
      max-width: 820px;
      margin: 0 auto;
    }

    /* ── Category cards ── */
    .category-option {
      cursor: pointer;
      padding: 1.1rem 0.75rem;
      border: 2px solid #e3e6f0;
      border-radius: 0.6rem;
      text-align: center;
      transition: all 0.18s;
      background: #fff;
      user-select: none;
    }
    .category-option:hover { border-color: #4e73df; background: #f8f9fc; transform: translateY(-2px); box-shadow: 0 4px 12px rgba(78,115,223,.12); }
    .category-option.selected { border-color: #4e73df; background: #eaedff; box-shadow: 0 4px 14px rgba(78,115,223,.18); }
    .category-icon { font-size: 1.8rem; margin-bottom: 0.4rem; }

    /* ── Priority cards ── */
    .priority-option {
      cursor: pointer;
      padding: 0.8rem 0.6rem;
      border: 2px solid #e3e6f0;
      border-radius: 0.6rem;
      text-align: center;
      transition: all 0.18s;
      background: #fff;
      user-select: none;
    }
    .priority-option:hover { transform: translateY(-2px); box-shadow: 0 4px 12px rgba(0,0,0,.1); }
    .priority-basse.selected   { border-color: #6c757d; background: #f8f9fa; }
    .priority-moyenne.selected { border-color: #ffc107; background: #fff8e1; }
    .priority-haute.selected   { border-color: #fd7e14; background: #fff3e0; }
    .priority-critique.selected{ border-color: #dc3545; background: #ffe5e5; }

    /* ── Drag & drop upload zone ── */
    .upload-zone {
      border: 2.5px dashed #c4cbe8;
      border-radius: 0.75rem;
      padding: 2rem 1rem;
      text-align: center;
      cursor: pointer;
      transition: all 0.2s;
      background: #fafbff;
      position: relative;
    }
    .upload-zone:hover, .upload-zone.drag-over {
      border-color: #4e73df;
      background: #eef0ff;
    }
    .upload-zone input[type="file"] {
      position: absolute;
      inset: 0;
      opacity: 0;
      cursor: pointer;
      width: 100%;
      height: 100%;
    }
    .upload-zone .upload-icon { font-size: 2.2rem; color: #b0bbd6; margin-bottom: 0.5rem; transition: color 0.2s; }
    .upload-zone:hover .upload-icon { color: #4e73df; }

    /* ── Image preview ── */
    #previewWrapper {
      display: none;
      margin-top: 0.75rem;
      position: relative;
      text-align: center;
    }
    #previewImg {
      max-height: 160px;
      max-width: 100%;
      border-radius: 0.6rem;
      border: 2px solid #e3e6f0;
      box-shadow: 0 4px 14px rgba(0,0,0,.1);
      object-fit: cover;
    }
    #removeImg {
      position: absolute;
      top: -8px;
      right: calc(50% - 85px);
      background: #dc3545;
      color: #fff;
      border: none;
      border-radius: 50%;
      width: 26px;
      height: 26px;
      font-size: 12px;
      cursor: pointer;
      line-height: 26px;
      text-align: center;
      box-shadow: 0 2px 6px rgba(0,0,0,.2);
    }

    /* ── Char counter ── */
    .char-counter { font-size: 0.78rem; }
    .char-counter.warn { color: #fd7e14; }
    .char-counter.danger { color: #dc3545; font-weight: 600; }

    /* ── Submit button loader ── */
    #submitBtn .spinner { display: none; }
    #submitBtn.loading .spinner { display: inline-block; }
    #submitBtn.loading .btn-text { display: none; }

    /* ── Toast ── */
    #toast {
      position: fixed;
      bottom: 1.5rem;
      right: 1.5rem;
      z-index: 9999;
      min-width: 280px;
      display: none;
      animation: slideUp 0.25s ease;
    }
    @keyframes slideUp {
      from { opacity: 0; transform: translateY(12px); }
      to   { opacity: 1; transform: translateY(0); }
    }

    /* ── Step badge ── */
    .step-badge {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      width: 24px; height: 24px;
      border-radius: 50%;
      background: #4e73df;
      color: #fff;
      font-size: 0.72rem;
      font-weight: 700;
      margin-right: 0.4rem;
      flex-shrink: 0;
    }
  </style>
</head>

<body id="page-top">
  <div id="wrapper">
    <%- include('../../layouts/sidebar') %>
    <div id="content-wrapper" class="d-flex flex-column">
      <div id="content">
        <%- include('../../layouts/topbar') %>
        <div class="container-fluid">

          <div class="d-flex justify-content-between align-items-center mb-4">
            <h1 class="h3 mb-0 text-gray-800">
              <i class="fas fa-bug mr-2 text-danger"></i>Signaler un Bug
            </h1>
            <a href="/bug-reports" class="btn btn-secondary btn-sm">
              <i class="fas fa-arrow-left mr-1"></i>Retour
            </a>
          </div>

          <div class="card shadow bug-form-card">
            <div class="card-header py-3 d-flex align-items-center justify-content-between">
              <h6 class="m-0 font-weight-bold text-primary"><i class="fas fa-clipboard-list mr-2"></i>Nouveau rapport de bug</h6>
              <small class="text-muted"><span class="text-danger">*</span> champs obligatoires</small>
            </div>
            <div class="card-body">
              <form id="bugForm" enctype="multipart/form-data" novalidate>
                <input type="hidden" name="url" value="<%= currentUrl %>">

                <!-- ── STEP 1 : Title ── -->
                <div class="form-group">
                  <label for="title" class="font-weight-bold">
                    <span class="step-badge">1</span>Titre du bug <span class="text-danger">*</span>
                  </label>
                  <input type="text" class="form-control form-control-lg" id="title" name="title"
                    placeholder="Ex : Erreur lors de la création d'un bon de commande…" required maxlength="120">
                  <small class="form-text text-muted">Court et précis — une phrase suffit.</small>
                </div>

                <!-- ── STEP 2 : Category ── -->
                <div class="form-group">
                  <label class="font-weight-bold d-block">
                    <span class="step-badge">2</span>Catégorie <span class="text-danger">*</span>
                  </label>
                  <div class="row">
                    <div class="col-6 col-md-3 mb-3">
                      <div class="category-option" data-category="ui" onclick="selectCategory('ui')">
                        <div class="category-icon text-primary"><i class="fas fa-desktop"></i></div>
                        <div class="font-weight-bold">Interface</div>
                        <small class="text-muted">Affichage, design</small>
                      </div>
                    </div>
                    <div class="col-6 col-md-3 mb-3">
                      <div class="category-option" data-category="fonctionnalite" onclick="selectCategory('fonctionnalite')">
                        <div class="category-icon text-success"><i class="fas fa-cogs"></i></div>
                        <div class="font-weight-bold">Fonctionnalité</div>
                        <small class="text-muted">Fonction cassée</small>
                      </div>
                    </div>
                    <div class="col-6 col-md-3 mb-3">
                      <div class="category-option" data-category="performance" onclick="selectCategory('performance')">
                        <div class="category-icon text-warning"><i class="fas fa-tachometer-alt"></i></div>
                        <div class="font-weight-bold">Performance</div>
                        <small class="text-muted">Lent ou bloqué</small>
                      </div>
                    </div>
                    <div class="col-6 col-md-3 mb-3">
                      <div class="category-option" data-category="autre" onclick="selectCategory('autre')">
                        <div class="category-icon text-secondary"><i class="fas fa-question-circle"></i></div>
                        <div class="font-weight-bold">Autre</div>
                        <small class="text-muted">Autre problème</small>
                      </div>
                    </div>
                  </div>
                  <input type="hidden" name="category" id="category" value="autre" required>
                </div>

                <!-- ── STEP 3 : Priority ── -->
                <div class="form-group">
                  <label class="font-weight-bold d-block">
                    <span class="step-badge">3</span>Priorité <span class="text-danger">*</span>
                  </label>
                  <div class="row">
                    <div class="col-6 col-md-3 mb-3">
                      <div class="priority-option priority-basse" data-priority="basse" onclick="selectPriority('basse')">
                        <div><i class="fas fa-arrow-down text-secondary"></i> <span class="font-weight-bold">Basse</span></div>
                        <small class="text-muted">Problème mineur</small>
                      </div>
                    </div>
                    <div class="col-6 col-md-3 mb-3">
                      <div class="priority-option priority-moyenne selected" data-priority="moyenne" onclick="selectPriority('moyenne')">
                        <div><i class="fas fa-minus text-warning"></i> <span class="font-weight-bold">Moyenne</span></div>
                        <small class="text-muted">Problème modéré</small>
                      </div>
                    </div>
                    <div class="col-6 col-md-3 mb-3">
                      <div class="priority-option priority-haute" data-priority="haute" onclick="selectPriority('haute')">
                        <div><i class="fas fa-arrow-up" style="color:#fd7e14;"></i> <span class="font-weight-bold">Haute</span></div>
                        <small class="text-muted">Problème important</small>
                      </div>
                    </div>
                    <div class="col-6 col-md-3 mb-3">
                      <div class="priority-option priority-critique" data-priority="critique" onclick="selectPriority('critique')">
                        <div><i class="fas fa-exclamation-triangle text-danger"></i> <span class="font-weight-bold">Critique</span></div>
                        <small class="text-muted">Bloque le travail</small>
                      </div>
                    </div>
                  </div>
                  <input type="hidden" name="priority" id="priority" value="moyenne" required>
                </div>

                <!-- ── STEP 4 : Description ── -->
                <div class="form-group">
                  <label for="description" class="font-weight-bold">
                    <span class="step-badge">4</span>Description <span class="text-danger">*</span>
                  </label>
                  <textarea class="form-control" id="description" name="description" rows="5"
                    placeholder="• Que faisiez-vous quand le bug est apparu ?&#10;• Comportement attendu vs comportement réel ?&#10;• Message d'erreur (si applicable) ?"
                    required maxlength="2000"></textarea>
                  <div class="d-flex justify-content-between mt-1">
                    <small class="form-text text-muted">Soyez précis, ça aide à corriger plus vite.</small>
                    <small class="char-counter" id="descCounter">0 / 2000</small>
                  </div>
                </div>

                <!-- ── STEP 5 : Screenshot ── -->
             
                <!-- ── Current URL ── -->
                <% if (currentUrl) { %>
                <div class="form-group">
                  <label class="font-weight-bold"><i class="fas fa-link mr-1 text-info"></i>Page concernée</label>
                  <div class="alert alert-info py-2 mb-0" style="font-size:0.875rem;word-break:break-all;">
                    <%= currentUrl %>
                  </div>
                </div>
                <% } %>

                <hr>

                <div class="d-flex justify-content-between align-items-center">
                  <a href="/bug-reports" class="btn btn-outline-secondary">
                    <i class="fas fa-times mr-1"></i>Annuler
                  </a>
                  <button type="submit" class="btn btn-primary px-4" id="submitBtn">
                    <span class="btn-text"><i class="fas fa-paper-plane mr-2"></i>Envoyer le rapport</span>
                    <span class="spinner spinner-border spinner-border-sm mr-2" role="status"></span>
                    <span class="loading-text" style="display:none;">Envoi en cours…</span>
                  </button>
                </div>
              </form>
            </div>
          </div>

        </div>
      </div>
    </div>
  </div>

  <!-- ── Toast notification ── -->
  <div id="toast">
    <div class="alert mb-0 shadow-lg d-flex align-items-center" id="toastInner" style="border-radius:0.75rem;">
      <i id="toastIcon" class="mr-3" style="font-size:1.3rem;"></i>
      <span id="toastMsg"></span>
    </div>
  </div>

  <script src="/vendor/jquery/jquery.min.js"></script>
  <script src="/vendor/bootstrap/js/bootstrap.bundle.min.js"></script>
  <script src="/vendor/jquery-easing/jquery.easing.min.js"></script>
  <script src="/js/sb-admin-2.min.js"></script>

  <script>
    /* ── Selectors ── */
    function selectCategory(cat) {
      $('.category-option').removeClass('selected');
      $(`.category-option[data-category="${cat}"]`).addClass('selected');
      $('#category').val(cat);
    }
    function selectPriority(p) {
      $('.priority-option').removeClass('selected');
      $(`.priority-option[data-priority="${p}"]`).addClass('selected');
      $('#priority').val(p);
    }

    /* ── Char counter ── */
    $('#description').on('input', function () {
      var len = $(this).val().length;
      var $c = $('#descCounter');
      $c.text(len + ' / 2000');
      $c.removeClass('warn danger');
      if (len > 1800) $c.addClass('danger');
      else if (len > 1400) $c.addClass('warn');
    });

    /* ── Upload preview ── */
    function handleFile(file) {
      if (!file) return;
      if (file.size > 5 * 1024 * 1024) { showToast('error', 'Fichier trop lourd (max 5 Mo)'); return; }
      var reader = new FileReader();
      reader.onload = function (e) {
        $('#previewImg').attr('src', e.target.result);
        $('#previewName').text(file.name + ' (' + (file.size / 1024).toFixed(0) + ' Ko)');
        $('#previewWrapper').show();
        $('#uploadZone').hide();
      };
      reader.readAsDataURL(file);
    }

    $('#screenshot').on('change', function () { handleFile(this.files[0]); });

    // Drag & drop
    var zone = document.getElementById('uploadZone');
    zone.addEventListener('dragover', function (e) { e.preventDefault(); $(this).addClass('drag-over'); });
    zone.addEventListener('dragleave', function () { $(this).removeClass('drag-over'); });
    zone.addEventListener('drop', function (e) {
      e.preventDefault();
      $(this).removeClass('drag-over');
      var file = e.dataTransfer.files[0];
      // Assign to input
      var dt = new DataTransfer();
      dt.items.add(file);
      document.getElementById('screenshot').files = dt.files;
      handleFile(file);
    });

    // Remove image
    $('#removeImg').on('click', function () {
      $('#screenshot').val('');
      $('#previewWrapper').hide();
      $('#uploadZone').show();
    });

    /* ── Toast helper ── */
    var toastTimer;
    function showToast(type, msg) {
      clearTimeout(toastTimer);
      var isOk = type === 'success';
      $('#toastInner')
        .removeClass('alert-success alert-danger')
        .addClass(isOk ? 'alert-success' : 'alert-danger');
      $('#toastIcon')
        .removeClass()
        .addClass('fas ' + (isOk ? 'fa-check-circle text-success' : 'fa-times-circle text-danger'));
      $('#toastMsg').text(msg);
      $('#toast').show();
      toastTimer = setTimeout(function () { $('#toast').fadeOut(); }, 4000);
    }

    /* ── Form submit ── */
    $('#bugForm').on('submit', function (e) {
      e.preventDefault();

      var $btn = $('#submitBtn');
      $btn.prop('disabled', true).addClass('loading');
      $btn.find('.loading-text').show();

      var formData = new FormData(this);

      $.ajax({
        url: '/api/bug-reports',
        method: 'POST',
        data: formData,
        processData: false,
        contentType: false,
        success: function (data) {
          if (data.success) {
            showToast('success', 'Rapport envoyé ! Redirection…');
            setTimeout(function () { window.location.href = '/bug-reports'; }, 1200);
          } else {
            showToast('error', data.error || 'Erreur lors de l\'envoi');
            $btn.prop('disabled', false).removeClass('loading');
            $btn.find('.loading-text').hide();
          }
        },
        error: function (xhr) {
          var err = xhr.responseJSON?.error || 'Erreur lors de l\'envoi du rapport';
          showToast('error', err);
          $btn.prop('disabled', false).removeClass('loading');
          $btn.find('.loading-text').hide();
        }
      });
    });
  </script>
</body>
</html>
