<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8" />
  <meta http-equiv="X-UA-Compatible" content="IE=edge" />
  <meta name="viewport" content="width=device-width, initial-scale=1, shrink-to-fit=no" />
  <meta name="description" content="Justification Caisse Dashboard" />
  <title><%= user.name || 'Utilisateur' %> - Justification Caisse</title>

  <!-- Fonts & Icons -->
  <link href="/vendor/fontawesome-free/css/all.min.css" rel="stylesheet" />
  <link href="https://fonts.googleapis.com/css?family=Nunito:400,600,700,900" rel="stylesheet" />

  <!-- Theme CSS -->
  <link href="/css/sb-admin-2.min.css" rel="stylesheet" />

  <style>
    .card-header { font-weight: 600; font-size: 1.1rem; }
    .demande-info p { margin-bottom: 0.4rem; }
    .badge { font-size: 0.85rem; padding: 0.4em 0.7em; }
    .table th { background: #f8f9fc; }
    .page-title { font-weight: 700; color: #4e73df; }
    .summary-card { background: #f8f9fc; padding: 15px; border-radius: 5px; }
    .summary-card p { margin: 0.5rem 0; }
    .save-all-btn { margin-bottom: 20px; }
    .error-text { color: red; font-size: 0.9rem; }
    
    /* Toggle Buttons for Table Visibility */
    .table-toggle-container {
      display: flex;
      gap: 15px;
      margin-bottom: 20px;
      justify-content: center;
    }
    .table-toggle-btn {
      padding: 15px 40px;
      font-size: 16px;
      font-weight: 600;
      border: 2px solid #e3e6f0;
      border-radius: 10px;
      background: #fff;
      color: #6c757d;
      cursor: pointer;
      transition: all 0.3s ease;
      display: flex;
      align-items: center;
      gap: 10px;
      box-shadow: 0 2px 5px rgba(0,0,0,0.08);
    }
    .table-toggle-btn:hover {
      border-color: #4e73df;
      color: #4e73df;
      transform: translateY(-2px);
      box-shadow: 0 4px 12px rgba(78,115,223,0.15);
    }
    .table-toggle-btn.active {
      background: #4e73df;
      border-color: #4e73df;
      color: #fff;
      box-shadow: 0 4px 15px rgba(78,115,223,0.3);
    }
    #showRecettesBtn {
      border-color: #e74a3b;
      color: #e74a3b;
    }
    #showRecettesBtn:hover {
      border-color: #e74a3b;
      color: #e74a3b;
      box-shadow: 0 4px 12px rgba(231,74,59,0.18);
    }
    #showRecettesBtn.active {
      background: #e74a3b;
      border-color: #e74a3b;
      color: #fff;
      box-shadow: 0 4px 15px rgba(231,74,59,0.32);
    }
    #showDepensesBtn {
      border-color: #1cc88a;
      color: #1cc88a;
    }
    #showDepensesBtn:hover {
      border-color: #1cc88a;
      color: #1cc88a;
      box-shadow: 0 4px 12px rgba(28,200,138,0.18);
    }
    #showDepensesBtn.active {
      background: #1cc88a;
      border-color: #1cc88a;
      color: #fff;
      box-shadow: 0 4px 15px rgba(28,200,138,0.32);
    }
    .table-toggle-btn i {
      font-size: 18px;
    }
    .table-section {
      display: none !important;
    }
    .table-section.visible {
      display: block !important;
      animation: fadeIn 0.3s ease;
    }
    @keyframes fadeIn {
      from { opacity: 0; transform: translateY(-10px); }
      to { opacity: 1; transform: translateY(0); }
    }

    @media (max-width: 576px) {
      .table-toggle-container {
        flex-direction: column;
        gap: 10px;
        margin-bottom: 15px;
      }
      .table-toggle-btn {
        width: 100%;
        justify-content: center;
        padding: 12px 18px;
        font-size: 15px;
      }

      #recettes .card-header,
      #depenses .card-header {
        flex-direction: column;
        align-items: stretch !important;
        gap: 10px;
      }
      #recettes .card-header > div,
      #depenses .card-header > div {
        width: 100%;
      }

      #recettes .card-body,
      #depenses .card-body {
        overflow-x: auto;
        -webkit-overflow-scrolling: touch;
      }

      #recettes table,
      #depenses table {
        min-width: 720px;
      }

      #recettes .btn,
      #depenses .btn {
        width: 100%;
      }

      #recettes .card-header .btn,
      #depenses .card-header .btn {
        margin-bottom: 6px;
      }

      #recettes .card-header .btn:last-child,
      #depenses .card-header .btn:last-child {
        margin-bottom: 0;
      }
    }
  </style>
</head>
<body id="page-top">
  <div id="wrapper">
    <!-- Sidebar -->
    <%- include('../../../../layouts/sidebar') %>

    <!-- Content Wrapper -->
    <div id="content-wrapper" class="d-flex flex-column">
      <div id="content">
        <!-- Topbar -->
        <%- include('../../../../layouts/topbar') %>

        <div class="container-fluid">
          <!-- Page Header -->
          <div class="d-flex justify-content-between align-items-center mb-4">
            <h1 class="h3 page-title"><i class="fas fa-cash-register"></i> Justification Caisse</h1>
            <div>
               <% if (justifCaisse && justifCaisse.id) { %>
                <a href="/achats/caisse/justification/recettes/<%= justifCaisse.id %>/pdf" class="btn btn-danger btn-sm">
                  <i class="fas fa-file-pdf"></i> PDF
                </a>
              <% } %>
             
              <a href="/achats/caisse/justifecaisse" class="btn btn-primary btn-sm">
                <i class="fas fa-list"></i> Retour
              </a>
              
            </div>
          </div>

          <!-- Justification Info -->
          <div class="row">
            <div class="col-lg-12">
              <div class="card shadow mb-4">
                <div class="card-body demande-info" style="display: flex; align-items: center; gap: 20px; padding: 20px;">
                  <p style="margin: 0;"><strong>RESPONSABLE CAISSE :</strong> <%= user.name || 'Non défini' %></p>
                  <% if (!user.name) { %>
                    <p class="error-text">Erreur : Nom de l'utilisateur non défini</p>
                  <% } %>
                  <p style="margin: 0;"><strong>Chantier :</strong> <%= chantier.nom || 'Non défini' %></p>
                  <% if (!chantier.nom) { %>
                    <p class="error-text">Erreur : Chantier non défini</p>
                  <% } %>
                  <input type="hidden" name="responsable" value="<%= user.name || '' %>" />
                  <input type="hidden" name="chantier" value="<%= chantier.nom || '' %>" />
                  <div class="form-group" style="margin: 0;">
                    <% if (justifCaisse && justifCaisse.id) { %>
                      <select name="designation" id="mois" class="form-control" style="width: 200px; display: inline-block;" disabled>
                        
                        <% const year = new Date().getFullYear(); %>
                        <% const months = ['Janvier', 'Février', 'Mars', 'Avril', 'Mai', 'Juin', 'Juillet', 'Août', 'Septembre', 'Octobre', 'Novembre', 'Décembre']; %>
                        <% months.forEach((m, i) => { %>
                          <option value="<%= `${m}-${year}` %>" <%= justifCaisse && justifCaisse.designation && justifCaisse.designation.includes(m) ? 'selected' : '' %>>
                            <%= `${m}-${year}` %>
                          </option>
                        <% }); %>
                      </select>
                    <% } else { %>
                      <label for="mois" style="margin-right: 10px;"><strong>SITUATION DE CAISSE :</strong></label>

                      <select name="designation" id="mois" class="form-control" style="width: 200px; display: inline-block;">
                        
                        <% const year = new Date().getFullYear(); %>
                        <% const months = ['Janvier', 'Février', 'Mars', 'Avril', 'Mai', 'Juin', 'Juillet', 'Août', 'Septembre', 'Octobre', 'Novembre', 'Décembre']; %>
                        <% months.forEach((m, i) => { %>
                          <option value="<%= `${m}-${year}` %>" <%= justifCaisse && justifCaisse.designation && justifCaisse.designation.includes(m) ? 'selected' : '' %>>
                            <%= `${m}-${year}` %>
                          </option>
                        <% }); %>
                      </select>
                    <% } %>
                  </div>
                </div>
              </div>
            </div>
          </div>


          <!-- Toggle Buttons for Tables -->
          <div class="table-toggle-container">
            <button class="table-toggle-btn" id="showRecettesBtn" onclick="showTable('recettes')">
              <i class="fas fa-arrow-down"></i> Recettes
            </button>
            <button class="table-toggle-btn" id="showDepensesBtn" onclick="showTable('depenses')">
              <i class="fas fa-arrow-up"></i> Dépenses
            </button>
          </div>

          <!-- Recettes -->
         <!-- Recettes Table -->
<div id="recettes" class="card shadow mb-4 table-section">
  <div class="card-header d-flex justify-content-between align-items-center">
    <h2 class="card-title">Caisse Reçue</h2>
    <div>
      <button class="btn btn-primary btn-sm" onclick="addNewRecetteRow()">
        <i class="fas fa-plus"></i> Ajouter Recette
      </button>
      <button class="btn btn-success btn-sm" id="saveRecettesBtn" onclick="saveAllRecetteItems()">Enregistrer Recette</button>
    </div>
  </div>
  <div class="card-body">
    <table class="table table-hover" id="recetteTable">
      <thead>
        <tr>
          <th>Date</th>
          <th>Origine Caisse</th>
          <th>Montant</th>
        </tr>
      </thead>
      <tbody>
        <% if (user.recettes && user.recettes.length > 0) { %>
          <% user.recettes.forEach(d => { %>
            <tr data-id="<%= d._id || '' %>">
              <td>
                <%= d.dateRecette ? new Date(d.dateRecette).toISOString().split('T')[0] : '' %>
              </td>
              <td>
                <%= d.source || '' %>
              </td>
              <td>
                <%= d.montant ? d.montant.toFixed(2) : '0.00' %>
              </td>
              
            </tr>
          <% }) %>
        <% } else { %>
          <tr class="no-data">
            <td colspan="4" class="text-center">Aucune recette enregistrée.</td>
          </tr>
        <% } %>
      </tbody>
      
    </table>
  </div>
</div>


          <!-- Dépenses -->
          <div id="depenses" class="card shadow mb-4 table-section">
            <div class="card-header d-flex justify-content-between align-items-center">
              <h2 class="card-title">DÉPENSES 
              

              </h2>
              <span class="badge bg-primary ms-1 text-white d-flex justify-content-center" style="font-size: 15px;">
                Solde Précédent : <%= justifCaisse.soldePrecedent ? justifCaisse.soldePrecedent.toLocaleString('fr-FR', { minimumFractionDigits: 2, maximumFractionDigits: 2 }) : '0.00' %> DH
              </span>
              <div>
                <button class="btn btn-primary btn-sm" onclick="addNewDepenseRow()">
                  <i class="fas fa-plus"></i> Ajouter Dépense
                </button>
                <button class="btn btn-success btn-sm" id="saveDepensesBtn" onclick="saveAllDepenseItems()">Enregistrer Dépense</button>
              </div>
            </div>
            <div class="card-body">
              <table class="table table-hover" id="depenseTable">
                <thead>
                  <tr>
                    <th>Date</th>
                    <th>Numéro de Pièce</th>
                    <th>Imputation</th>
                    <th>Nature Dépense</th>
                    <th>Montant Justifié</th>
                    <th>Montant Non Justifié</th>
                   
                    <th>Validation</th>
                    <th>Verifié Par</th>
                    <th>Actions</th>
                  </tr>
                </thead>
                <tbody>
                  <% if (user.depenses && user.depenses.length > 0) { %>
                    <% user.depenses.forEach(d => { %>
                      <tr data-id="<%= d._id || '' %>">
                        <% if (d.validerPar === null) { %>
                          <!-- Editable version (not validated yet) -->
                          <td>
                            <input type="date" name="dateDepense" 
                                   value="<%= d.date ? new Date(d.date).toISOString().split('T')[0] : '' %>" 
                                   class="form-control" required />
                          </td>
                          <td><input type="text" name="numeroPiece" value="<%= d.numeroDuPiece || '' %>" class="form-control" /></td>
                          <td><input type="text" name="imputation" value="<%= d.imputation || '' %>" class="form-control" /></td>
                          <td><input type="text" name="natureDepense" value="<%= d.natureDepense || '' %>" class="form-control" required /></td>
                          <td><input type="number" name="montantJustifie" value="<%= d.justifier || 0 %>" step="0.01" class="form-control" required /></td>
                          <td><input type="number" name="montantNonJustifie" value="<%= d.nonJustifier || 0 %>" step="0.01" class="form-control" required /></td>
                        <% } else { %>
                          <!-- Read-only version (validated) -->
                          <td><%= d.date ? new Date(d.date).toLocaleDateString('fr-FR') : '' %></td>
                          <td><%= d.numeroDuPiece || '' %></td>
                          <td><%= d.imputation || '' %></td>
                          <td><%= d.natureDepense || '' %></td>
                          <td><%= d.justifier || 0 %></td>
                          <td><%= d.nonJustifier || 0 %></td>
                        <% } %>
                        
                
                        <td>
                          <% if (d.validation && d.validerPar !== null) { %>
                            <span class="badge bg-success text-white">Validé</span>
                          <% } else { %>
                            <span class="badge bg-danger text-white">Non validé</span>
                          <% } %>
                        </td>
                
                        <td><%= d.validerPar || 'Non défini' %></td>
                
                        <td>
                          <% if (d.validerPar === null) { %>
                            <div class="d-flex justify-content-end">
                             
                              <button class="btn btn-primary btn-sm me-2" onclick="addNewDepenseRow()">
                                <i class="fas fa-plus"></i>
                              </button>
                              <button class="btn btn-danger btn-sm" onclick="deleteDepenseItem(this)">
                                <i class="fas fa-trash"></i>
                              </button>
                            </div>
                          <% } else { %>
                            <span class="text-muted">Lecture seule</span>
                          <% } %>
                        </td>
                      </tr>
                    <% }) %>
                  <% } else { %>
                    <tr>
                     
                    </tr>
                  <% } %>
                </tbody>
                
                
              </table>
              
            </div>
           
          </div><button class="btn btn-success btn-md save-all-btn" id="saveAllBtn" onclick="saveAllData()" hidden>
         
        </button>
        </div>
        
        <div id="summary" class="card shadow mb-4">
          <!-- Simple Modern Summary -->
          <div class="row">
            <div class="col-lg-12">
              <div class="card shadow-sm border-0 rounded-4">
                <div class="card-header bg-primary text-white py-3">
                  <h4 class="mb-0">Résumé</h4>
                </div>
                <div class="card-body p-5">
                  <div class="row text-center text-md-start g-4">
                    <div class="col-md-3">
                      <div class="p-4 bg-light rounded-4">
                        <div class="text-muted mb-2" style="font-size: 1rem; font-weight: 500;">Soldé Précédent</div>
                        <div class="fw-bold text-success" style="font-size: 1.5rem; letter-spacing: 0.05rem;">
                          <%= justifCaisse.soldePrecedent ? justifCaisse.soldePrecedent.toFixed(2) : '0.00' %> DH
                        </div>
                      </div>
                    </div>
                    <div class="col-md-3">
                      <div class="p-4 bg-light rounded-4">
                        <div class="text-muted mb-2" style="font-size: 1rem; font-weight: 500;">Total Recettes</div>
                        <div class="fw-bold text-primary" style="font-size: 1.5rem; letter-spacing: 0.05rem;">
                          <%= justifCaisse.totalRecettes ? justifCaisse.totalRecettes.toFixed(2) : '0.00' %> DH
                        </div>
                      </div>
                    </div>
                    <div class="col-md-3">
                      <div class="p-4 bg-light rounded-4">
                        <div class="text-muted mb-2" style="font-size: 1rem; font-weight: 500;">Dépenses Justifiées</div>
                        <div class="fw-bold text-warning" style="font-size: 1.5rem; letter-spacing: 0.05rem;">
                          <%= justifCaisse.depenses ? justifCaisse.depenses.filter(d => d.validation).reduce((sum, d) => sum + (d.montantJustifie || 0), 0).toFixed(2) : '0.00' %> DH
  
                        </div>
                      </div>
                    </div>
                    <div class="col-md-3">
                      <div class="p-4 bg-light rounded-4">
                        <div class="text-muted mb-2" style="font-size: 1rem; font-weight: 500;">Dépenses Non Justifiées</div>
                        <div class="fw-bold text-danger" style="font-size: 1.5rem; letter-spacing: 0.05rem;">
                          <%= justifCaisse.depenses ? justifCaisse.depenses.filter(d => d.validation).reduce((sum, d) => sum + (d.montantNonJustifie || 0), 0).toFixed(2) : '0.00' %> DH
                        </div>
                      </div>
                    </div>
                  </div>
                  <hr class="my-5">
                  <div class="text-center">
                    <div class="text-muted mb-2" style="font-size: 1.1rem; font-weight: 500;">Soldé Final</div>
                    <div class="fw-bold text-info" style="font-size: 1.75rem; letter-spacing: 0.05rem;">
                      <%= justifCaisse.soldeFinal ? justifCaisse.soldeFinal.toFixed(2) : '0.00' %> DH
                    </div>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>


    <br><br>
    
    

    <script>
      // Toggle table visibility
      function hideTables() {
        const recettesSection = document.getElementById('recettes');
        const depensesSection = document.getElementById('depenses');
        const recettesBtn = document.getElementById('showRecettesBtn');
        const depensesBtn = document.getElementById('showDepensesBtn');

        recettesSection.classList.remove('visible');
        depensesSection.classList.remove('visible');
        recettesBtn.classList.remove('active');
        depensesBtn.classList.remove('active');
      }

      function showTable(tableName) {
        const recettesSection = document.getElementById('recettes');
        const depensesSection = document.getElementById('depenses');

        const target = tableName === 'recettes' ? recettesSection : depensesSection;
        const isAlreadyVisible = target.classList.contains('visible');

        // If you click the same active button again => hide both
        if (isAlreadyVisible) {
          hideTables();
          sessionStorage.removeItem('justifTable');
          return;
        }

        // Otherwise show the selected one
        hideTables();
        if (tableName === 'recettes') {
          recettesSection.classList.add('visible');
          document.getElementById('showRecettesBtn').classList.add('active');
        } else if (tableName === 'depenses') {
          depensesSection.classList.add('visible');
          document.getElementById('showDepensesBtn').classList.add('active');
        }

        // Store in sessionStorage to persist after save-triggered reload/redirect
        sessionStorage.setItem('justifTable', tableName);
      }

      // Restore only after a save-triggered reload/redirect
      document.addEventListener('DOMContentLoaded', function () {
        const shouldRestore = sessionStorage.getItem('restoreJustifTable') === '1';
        if (!shouldRestore) return;
        sessionStorage.removeItem('restoreJustifTable');

        const savedTable = sessionStorage.getItem('justifTable');
        if (savedTable) showTable(savedTable);
      });

      // Enable/disable save buttons based on month selection
      const moisSelect = document.querySelector('#mois');
      const saveAllBtn = document.querySelector('#saveAllBtn');
      const saveRecettesBtn = document.querySelector('#saveRecettesBtn');
    
      function updateSaveButtons() {
        const isMonthSelected = !!moisSelect.value;
        saveAllBtn.disabled = !isMonthSelected;
        saveRecettesBtn.disabled = !isMonthSelected;
        saveDepensesBtn.disabled = !isMonthSelected;
      }
    
      moisSelect.addEventListener('change', updateSaveButtons);
      updateSaveButtons(); // Initial check
    
      // Shared remove row for new rows (client-side only)
      function removeRow(button) {
        button.closest('tr').remove();
      }
    
      // Add new recette row
      // Add new recette row
// Add new editable row
function addNewRecetteRow() {
  const tbody = document.querySelector('#recetteTable tbody');
  if (!tbody) {
    console.error('Error: #recetteTable tbody not found in the DOM');
    alert('Erreur : Table des recettes non trouvée.');
    return;
  }

  console.log('Adding new recette row'); // Debug

  const placeholder = tbody.querySelector('.no-data');
  if (placeholder) {
    console.log('Removing no-data placeholder'); // Debug
    placeholder.remove();
  }

  const newRow = document.createElement('tr');
  newRow.innerHTML = `
    <td><input type="date" name="dateRecette" class="form-control" value="${new Date().toISOString().split('T')[0]}" required></td>
    <td><input type="text" name="source" class="form-control" placeholder="Origine" required></td>
    <td><input type="number" name="montant" step="0.01" min="0.01" class="form-control" placeholder="Montant" required></td>
    <td><button class="btn btn-danger btn-sm" onclick="deleteRecetteItem(this)">Supprimer</button></td>
  `;
  tbody.appendChild(newRow);
  console.log('New recette row added successfully'); // Debug
}
// Delete row

// Save all recettes
function saveAllRecetteItems() {
  const rows = document.querySelectorAll('#recetteTable tbody tr');
  const items = [];
  let valid = true;
  let errorMessages = [];

  // Collect recette items
  rows.forEach((row, index) => {
    const dateInput = row.querySelector('input[name="dateRecette"]')?.value;
    const sourceInput = row.querySelector('input[name="source"]')?.value?.trim();
    const montantInput = row.querySelector('input[name="montant"]')?.value?.trim();

    // Skip completely empty rows
    if (!dateInput && !sourceInput && !montantInput) return;

    // Validate inputs
    if (!dateInput) {
      errorMessages.push(`Ligne ${index + 1}: Date manquante`);
      valid = false;
      return;
    }
    if (!sourceInput) {
      errorMessages.push(`Ligne ${index + 1}: Source manquante`);
      valid = false;
      return;
    }
    const montant = parseFloat(montantInput);
    if (isNaN(montant) || montant <= 0) {
      errorMessages.push(`Ligne ${index + 1}: Montant invalide ou non positif`);
      valid = false;
      return;
    }

    // Add recette object
    items.push({
      _id: row.dataset.id || null, // null for new rows
      dateRecette: dateInput,
      source: sourceInput,
      montant,
      validation: 1,
    });
  });

  // Collect form metadata
  const responsable = document.querySelector('input[name="responsable"]')?.value?.trim();
  const userId = document.querySelector('input[name="userId"]')?.value?.trim(); // Added for debugging
  const chantier = document.querySelector('input[name="chantier"]')?.value?.trim();
  const designation = document.querySelector('#mois')?.value?.trim();

  // Validate metadata
  if (!responsable || !chantier || !designation) {
    const missingFields = [];
    if (!responsable) missingFields.push('responsable');
    if (!chantier) missingFields.push('chantier');
    if (!designation) missingFields.push('mois');
    errorMessages.push(`Champs manquants: ${missingFields.join(', ')}`);
    valid = false;
  }

  // Debug: Log the payload to inspect values
  console.log('Recettes payload:', { userId, responsable, chantier, designation, items });

  // Stop if validation fails
  if (!valid) {
    alert(`Erreurs détectées:\n${errorMessages.join('\n')}`);
    return;
  }

  // Stop if no valid items
  if (items.length === 0) {
    alert('Veuillez ajouter au moins une recette valide.');
    return;
  }

  // Determine the correct endpoint
  const urlParams = new URLSearchParams(window.location.search);
  const justifId = urlParams.get('id');
  const url = justifId && !isNaN(parseInt(justifId)) ? `/achats/caisse/justification/save-all` : `/achats/caisse/justification/recettes`;

  // Send request
  fetch(url, {
    method: 'POST',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify({ userId, responsable, chantier, designation, items }), // Include userId
  })
    .then(res => {
      if (!res.ok) {
        return res.json().then(data => {
          throw new Error(data.error || `Erreur HTTP ${res.status}`);
        });
      }
      return res.json();
    })
    .then(data => {
      if (data.success) {
        alert('Recettes enregistrées avec succès.');
        if (data.isNew && data.justifId) {
          setTimeout(() => {
            sessionStorage.setItem('restoreJustifTable', '1');
            window.location.href = `/achats/caisse/justifecaisse/${data.justifId}`;
          }, 1000);
        } else {
          sessionStorage.setItem('restoreJustifTable', '1');
          window.location.reload();
        }
      } else {
        alert(`Erreur: ${data.error || 'Erreur inconnue.'}`);
      }
    })
    .catch(err => {
      console.error('Fetch error:', err);
      alert(`Erreur: ${err.message}`);
    });
}
// Delete recette item
      function deleteRecetteItem(button) {
        if (confirm('Supprimer cette recette ?')) {
          const row = button.closest('tr');
          const id = row.dataset.id;
          if (id) {
            fetch(`/achats/caisse/justification/recettes/${id}`, {
              method: 'DELETE',
              headers: { 'Content-Type': 'application/json' }
            })
              .then(res => {
                if (!res.ok) {
                  return res.text().then(text => {
                    throw new Error(`HTTP error ${res.status}: ${text}`);
                  });
                }
                return res.json();
              })
              .then(data => {
                if (data.success) {
                  row.remove();
                  alert('Recette supprimée avec succès.');
                } else {
                  alert('Erreur lors de la suppression.');
                }
              })
              .catch(err => {
                console.error('Fetch error:', err);
                alert('Erreur réseau : ' + err.message);
              });
          } else {
            row.remove();
          }
        }
      }
    
      // Add new depense row
      function addNewDepenseRow() {
        const tableBody = document.querySelector('#depenseTable tbody');
        const newRow = document.createElement('tr');
        newRow.innerHTML = `
          <td><input type="date" name="dateDepense" value="${new Date().toISOString().split('T')[0]}" class="form-control" required /></td>
          <td><input type="text" name="numeroPiece" class="form-control" /></td>
          <td><input type="text" name="imputation" class="form-control" /></td>
          <td><input type="text" name="natureDepense" class="form-control" required /></td>
          <td><input type="number" name="montantJustifie" value="0" step="0.01" class="form-control" required /></td>
          <td><input type="number" name="montantNonJustifie" value="0" step="0.01" class="form-control" required /></td>
            <td>
                          <div class="d-flex justify-content-end">
                          
                            <button class="btn btn-primary btn-sm me-2" onclick="addNewDepenseRow()">
                              <i class="fas fa-plus"></i> 
                            </button>
                            <button class="btn btn-danger btn-sm" onclick="deleteDepenseItem(this)">
                              <i class="fas fa-trash"></i> 
                            </button>
                          </div>
                        </td>
        `;
        tableBody.appendChild(newRow);
      }
    
      // Save all depense items
      function saveAllDepenseItems() {
        const rows = document.querySelectorAll('#depenseTable tbody tr');
        const items = [];
    
        let valid = true;
        rows.forEach(row => {
          const inputs = row.querySelectorAll('input');
          if (inputs.length === 6) {
            const depense = {
              date: inputs[0].value,
              numeroPiece: inputs[1].value,
              imputation: inputs[2].value,
              natureDepense: inputs[3].value,
              montantJustifie: parseFloat(inputs[4].value) || 0,
              montantNonJustifie: parseFloat(inputs[5].value) || 0,
            };
            const id = row.dataset.id || null;
            if (id) depense._id = id;
    
            if (!depense.date || !depense.natureDepense || (depense.montantJustifie === 0 && depense.montantNonJustifie === 0)) {
              valid = false;
              return;
            }
    
            items.push(depense);
          }
        });
    
        const responsable = document.querySelector('input[name="responsable"]').value;
        const chantier = document.querySelector('input[name="chantier"]').value;
        const designation = document.querySelector('#mois').value;
    
        console.log("Saving dépenses:", { responsable, chantier, designation, items });
    
        if (!responsable || !chantier || !designation) {
          const missingFields = [];
          if (!responsable) missingFields.push("responsable");
          if (!chantier) missingFields.push("chantier");
          if (!designation) missingFields.push("mois");
          alert(`Erreur : Les champs suivants sont manquants : ${missingFields.join(", ")}.`);
          return;
        }
    
        if (!valid) {
          alert('Veuillez remplir correctement tous les champs des dépenses (date, nature, et au moins un montant).');
          return;
        }
    
        if (items.length === 0) {
          alert('Veuillez ajouter au moins une dépense valide.');
          return;
        }
    
        fetch('/achats/caisse/justification/depenses', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ responsable, chantier, designation, items })
        })
          .then(res => res.json())
          .then(data => {
            if (data.success) {
              alert('Dépenses enregistrées avec succès.');
              sessionStorage.setItem('restoreJustifTable', '1');
              window.location.reload();
            } else {
              alert('Erreur : ' + (data.error || 'Erreur inconnue.'));
            }
          })
          .catch(err => {
            console.error('Fetch error:', err);
            alert('Erreur réseau : ' + err.message);
          });
      }
    
      // Delete depense item
      function deleteDepenseItem(button) {
        if (confirm('Supprimer cette dépense ?')) {
          const row = button.closest('tr');
          const id = row.dataset.id;
          if (id) {
            fetch(`/achats/caisse/justification/depenses/${id}`, {
              method: 'DELETE',
              headers: { 'Content-Type': 'application/json' }
            })
              .then(res => res.json())
              .then(data => {
                if (data.success) {
                  row.remove();
                  alert('Dépense supprimée avec succès.');
                } else {
                  alert('Erreur lors de la suppression.');
                }
              })
              .catch(err => alert('Erreur réseau : ' + err.message));
          } else {
            row.remove();
          }
        }
      }
    
      // Save all data (recettes + dépenses)
      function saveAllData() {
        const recetteRows = document.querySelectorAll('#recetteTable tbody tr');
        const depenseRows = document.querySelectorAll('#depenseTable tbody tr');
        const recetteItems = [];
        const depenseItems = [];
    
        let valid = true;
    
        // Collect recettes
        recetteRows.forEach(row => {
          const dateRecetteInput = row.querySelector('input[name="dateRecette"]');
          const sourceInput = row.querySelector('input[name="source"]');
          const montantInput = row.querySelector('input[name="montant"]');
    
          if (dateRecetteInput && sourceInput && montantInput) {
            const dateRecette = dateRecetteInput.value;
            const source = sourceInput.value;
            const montant = parseFloat(montantInput.value);
            const id = row.dataset.id || null;
    
            if (!dateRecette || !source || isNaN(montant) || montant <= 0) {
              valid = false;
              return;
            }
    
            const item = { dateRecette, source, montant };
            if (id) item._id = id;
            recetteItems.push(item);
          }
        });
    
        // Collect dépenses
        depenseRows.forEach(row => {
          const inputs = row.querySelectorAll('input');
          if (inputs.length === 6) {
            const depense = {
              date: inputs[0].value,
              numeroPiece: inputs[1].value,
              imputation: inputs[2].value,
              natureDepense: inputs[3].value,
              montantJustifie: parseFloat(inputs[4].value) || 0,
              montantNonJustifie: parseFloat(inputs[5].value) || 0,
            };
            const id = row.dataset.id || null;
            if (id) depense._id = id;
    
            if (!depense.date || !depense.natureDepense || (depense.montantJustifie === 0 && depense.montantNonJustifie === 0)) {
              valid = false;
              return;
            }
    
            depenseItems.push(depense);
          }
        });
    
        const responsable = document.querySelector('input[name="responsable"]').value;
        const chantier = document.querySelector('input[name="chantier"]').value;
        const designation = document.querySelector('#mois').value;
    
        console.log("Saving all data:", { responsable, chantier, designation, recettes: recetteItems, depenses: depenseItems });
    
        if (!responsable || !chantier || !designation) {
          const missingFields = [];
          if (!responsable) missingFields.push("responsable");
          if (!chantier) missingFields.push("chantier");
          if (!designation) missingFields.push("mois");
          alert(`Erreur : Les champs suivants sont manquants : ${missingFields.join(", ")}.`);
          return;
        }
    
        if (!valid) {
          alert('Veuillez remplir correctement tous les champs des recettes et dépenses.');
          return;
        }
    
        if (recetteItems.length === 0 && depenseItems.length === 0) {
          alert('Veuillez ajouter au moins une recette ou une dépense.');
          return;
        }
    
        // Check if editing an existing justification
        const urlParams = new URLSearchParams(window.location.search);
        const justifId = urlParams.get('id');
        const url = justifId ? '/achats/caisse/justification/save-all' : '/achats/caisse/justification/save-all';
        const method = 'POST';
    
        fetch(url, {
          method,
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ responsable, chantier, designation, recettes: recetteItems, depenses: depenseItems })
        })
          .then(res => {
            if (!res.ok) {
              return res.text().then(text => {
                throw new Error(`HTTP error ${res.status}: ${text}`);
              });
            }
            return res.json();
          })
          .then(data => {
            if (data.success) {
              alert('Justification enregistrée avec succès.');
              if (data.isNew && data.justifId) {
                // Redirect to update page for the new justification
                setTimeout(() => {
                  window.location.href = `/achats/caisse/justifecaisse/${data.justifId}`;
                }, 1000);
              } else {
                window.location.reload();
              }
            } else {
              alert('Erreur : ' + (data.error || 'Erreur inconnue.'));
            }
          })
          .catch(err => {
            console.error('Fetch error:', err);
            alert('Erreur réseau : ' + err.message);
            // Log the response for debugging
            console.log('Raw response causing error:', err.message);
          });
      }
    </script>
