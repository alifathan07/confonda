<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8" />
  <meta http-equiv="X-UA-Compatible" content="IE=edge" />
  <meta name="viewport" content="width=device-width, initial-scale=1, shrink-to-fit=no" />
  <meta name="description" content="Justification Caisse Dashboard" />
  <title><%= user.name || 'Utilisateur' %> - Justification Caisse</title>

  <!-- Fonts & Icons -->
  <link href="/vendor/fontawesome-free/css/all.min.css" rel="stylesheet" />
  <link href="https://fonts.googleapis.com/css?family=Nunito:400,600,700,900" rel="stylesheet" />

  <!-- Theme CSS -->
  <link href="/css/sb-admin-2.min.css" rel="stylesheet" />

  <style>
    .card-header { font-weight: 600; font-size: 1.1rem; }
    .demande-info p { margin-bottom: 0.4rem; }
    .badge { font-size: 0.85rem; padding: 0.4em 0.7em; }
    .table th { background: #f8f9fc; }
    .page-title { font-weight: 700; color: #4e73df; }
    .summary-card { background: #f8f9fc; padding: 15px; border-radius: 5px; }
    .summary-card p { margin: 0.5rem 0; }
    .save-all-btn { margin-bottom: 20px; }
    .error-text { color: red; font-size: 0.9rem; }
    .table input { width: 100%; }
    .card-body { overflow-x: auto; }
    .readonly input, .readonly select { background-color: #e9ecef; cursor: not-allowed; }
    .edit-btn { margin-right: 10px; }
  </style>
</head>
<body id="page-top">
  <div id="wrapper">
    <!-- Sidebar -->
    <%- include('../../../../layouts/sidebar') %>

    <!-- Content Wrapper -->
    <div id="content-wrapper" class="d-flex flex-column">
      <div id="content">
        <!-- Topbar -->
        <%- include('../../../../layouts/topbar') %>

        <div class="container-fluid">
          <!-- Page Header -->
          <div class="d-flex justify-content-between align-items-center mb-4">
            <h1 class="h3 page-title"><i class="fas fa-cash-register"></i> Justification Caisse - <%= user.name || 'Utilisateur' %></h1>
            <div>
              <button class="btn btn-warning btn-sm edit-btn" id="editBtn" onclick="toggleEditMode()">Activer l'édition</button>
              <a href="/achats/caisse/justifecaisse" class="btn btn-primary btn-sm">
                <i class="fas fa-list"></i> Retour
              </a>
            </div>
          </div>

          <!-- Justification Info -->
          <div class="row">
            <div class="col-lg-12">
              <div class="card shadow mb-4">
                <div class="card-body demande-info" style="display: flex; align-items: center; gap: 20px; padding: 20px;">
                  <p style="margin: 0;"><strong>RESPONSABLE CAISSE :</strong> <%= user.name || 'Non défini' %></p>
                  <% if (!user.name) { %>
                    <p class="error-text">Erreur : Nom de l'utilisateur non défini</p>
                  <% } %>
                  <p style="margin: 0;"><strong>Chantier :</strong> <%= chantier.nom || 'Non défini' %></p>
                  <% if (!chantier.nom) { %>
                    <p class="error-text">Erreur : Chantier non défini</p>
                  <% } %>
                  <input type="hidden" name="responsable" value="<%= user.name || '' %>" />
                  <input type="hidden" name="chantier" value="<%= chantier.nom || '' %>" />
                  <input type="hidden" name="userId" value="<%= user.id || '' %>" />
                  <input type="hidden" name="justifId" value="<%= justifCaisse.id || '' %>" />
                  <div class="form-group" style="margin: 0;">
                    <label for="mois" style="margin-right: 10px;"><strong>SITUATION DE CAISSE :</strong></label>
                    <select name="designation" id="mois" class="form-control" style="width: 200px; display: inline-block;" disabled>
                      <% const year = new Date().getFullYear(); %>
                      <% const months = ['Janvier', 'Février', 'Mars', 'Avril', 'Mai', 'Juin', 'Juillet', 'Août', 'Septembre', 'Octobre', 'Novembre', 'Décembre']; %>
                      <% months.forEach((m, i) => { %>
                        <option value="<%= `${m}-${year}` %>" <%= justifCaisse && justifCaisse.designation === `${m}-${year}` ? 'selected' : '' %>>
                          <%= `${m}-${year}` %>
                        </option>
                      <% }); %>
                    </select>
                  </div>
                </div>
              </div>
            </div>
          </div>

          <!-- Recettes Table -->
          <div id="recettes" class="card shadow mb-4 readonly">
            <div class="card-header d-flex justify-content-between align-items-center">
              <h2 class="card-title">Caisse Reçue</h2>
              <div>
                <button class="btn btn-primary btn-sm" id="addRecetteBtn" onclick="addNewRecetteRow()" disabled>
                  <i class="fas fa-plus"></i> Ajouter Recette
                </button>
                <button class="btn btn-success btn-sm" id="saveRecettesBtn" onclick="saveAllRecetteItems()" >Enregistrer Recette</button>
              </div>
            </div>
            <div class="card-body">
              <table class="table table-hover" id="recetteTable">
                <thead>
                  <tr>
                    <th>Date</th>
                    <th>Origine Caisse</th>
                    <th>Montant</th>
                    <th>Actions</th>
                  </tr>
                </thead>
                <tbody>
                  <% if (user.recettes && user.recettes.length > 0) { %>
                    <% user.recettes.forEach(d => { %>
                      <input type="hidden" id="recetteId" value="<%= d._id || '' %>"></input>
                      <tr data-id="<%= d._id || '' %>">
                        <td>
                          <input type="date" name="dateRecette" class="form-control"
                                 value="<%= d.dateRecette ? new Date(d.dateRecette).toISOString().split('T')[0] : '' %>" readonly />
                        </td>
                        <td>
                          <input type="text" name="source" class="form-control"
                                 value="<%= d.source || '' %>" readonly />
                        </td>
                        <td>
                          <input type="number" name="montant" class="form-control" step="0.01" min="0.01"
                                 value="<%= d.montant ? d.montant.toFixed(2) : '0.00' %>" readonly />
                        </td>
                        <td>
                          <button class="btn btn-danger btn-sm" onclick="deleteRecetteItem(this)" disabled>Supprimer</button>
                        </td>
                      </tr>
                    <% }) %>
                  <% } else { %>
                    <tr class="no-data">
                      <td colspan="4" class="text-center">Aucune recette enregistrée.</td>
                    </tr>
                  <% } %>
                </tbody>
              </table>
            </div>
          </div>

          <!-- Dépenses Table -->
          <div id="depenses" class="card shadow mb-4 readonly">
            <div class="card-header d-flex justify-content-between align-items-center">
              <h2 class="card-title">DÉPENSES</h2>
              <span class="badge bg-primary ms-1 text-white d-flex justify-content-center" style="font-size: 15px;">
                Solde Précédent : <%= justifCaisse.soldePrecedent ? justifCaisse.soldePrecedent.toFixed(2) : '0.00' %> DH
              </span>
              <div>
                <button class="btn btn-primary btn-sm" id="addDepenseBtn" onclick="addNewDepenseRow()" disabled>
                  <i class="fas fa-plus"></i> Ajouter Dépense
                </button>
                <button class="btn btn-success btn-sm" id="saveDepensesBtn" onclick="saveAllDepenseItems()" disabled>Enregistrer Dépense</button>
              </div>
            </div>
            <div class="card-body">
              <table class="table table-hover" id="depenseTable">
                <thead>
                  <tr>
                    <th>Date</th>
                    <th>Numéro de Pièce</th>
                    <th>Imputation</th>
                    <th>Nature Dépense</th>
                    <th>Montant Justifié</th>
                    <th>Montant Non Justifié</th>
                    <th>Actions</th>
                  </tr>
                </thead>
                <tbody>
                  <% if (user.depenses && user.depenses.length > 0) { %>
                    <% user.depenses.forEach(d => { %>
                      <tr data-id="<%= d._id || '' %>">
                        <td><input type="date" name="dateDepense" value="<%= d.date ? new Date(d.date).toISOString().split('T')[0] : '' %>" class="form-control" readonly /></td>
                        <td><input type="text" name="numeroPiece" value="<%= d.numeroDuPiece || '' %>" class="form-control" readonly /></td>
                        <td><input type="text" name="imputation" value="<%= d.imputation || '' %>" class="form-control" readonly /></td>
                        <td><input type="text" name="natureDepense" value="<%= d.natureDepense || '' %>" class="form-control" readonly /></td>
                        <td><input type="number" name="montantJustifie" value="<%= d.justifier ? d.justifier.toFixed(2) : '0.00' %>" step="0.01" min="0" class="form-control" readonly /></td>
                        <td><input type="number" name="montantNonJustifie" value="<%= d.nonJustifier ? d.nonJustifier.toFixed(2) : '0.00' %>" step="0.01" min="0" class="form-control" readonly /></td>
                        <td>
                          <button class="btn btn-danger btn-sm" onclick="deleteDepenseItem(this)" disabled>
                            <i class="fas fa-trash"></i> Supprimer
                          </button>
                        </td>
                      </tr>
                    <% }) %>
                  <% } else { %>
                    <tr class="no-data">
                      <td colspan="7" class="text-center">Aucune dépense enregistrée.</td>
                    </tr>
                  <% } %>
                </tbody>
              </table>
            </div>
          </div>

          <!-- Save All Button -->
          <button class="btn btn-success btn-md save-all-btn" id="saveAllBtn" onclick="saveAllData()" disabled>
            <i class="fas fa-save"></i> Enregistrer Tout
          </button>

          <!-- Summary Section -->
          <div id="summary" class="card shadow mb-4">
            <div class="card shadow-sm border-0 rounded-4">
              <div class="card-header bg-primary text-white py-3">
                <h4 class="mb-0">Résumé</h4>
              </div>
              <div class="card-body p-5">
                <div class="row text-center text-md-start g-4">
                  <div class="col-md-3">
                    <div class="p-4 bg-light rounded-4">
                      <div class="text-muted mb-2" style="font-size: 1rem; font-weight: 500;">Solde Précédent</div>
                      <div class="fw-bold text-success" style="font-size: 1.5rem; letter-spacing: 0.05rem;">
                        <%= justifCaisse.soldePrecedent ? justifCaisse.soldePrecedent.toFixed(2) : '0.00' %> DH
                      </div>
                    </div>
                  </div>
                  <div class="col-md-3">
                    <div class="p-4 bg-light rounded-4">
                      <div class="text-muted mb-2" style="font-size: 1rem; font-weight: 500;">Total Recettes</div>
                      <div class="fw-bold text-primary" style="font-size: 1.5rem; letter-spacing: 0.05rem;">
                        <%= user.recettes ? user.recettes.reduce((sum, r) => sum + (r.montant || 0), 0).toFixed(2) : '0.00' %> DH
                      </div>
                    </div>
                  </div>
                  <div class="col-md-3">
                    <div class="p-4 bg-light rounded-4">
                      <div class="text-muted mb-2" style="font-size: 1rem; font-weight: 500;">Dépenses Justifiées</div>
                      <div class="fw-bold text-warning" style="font-size: 1.5rem; letter-spacing: 0.05rem;">
                        <%= user.depenses ? user.depenses.reduce((sum, d) => sum + (d.justifier || 0), 0).toFixed(2) : '0.00' %> DH
                      </div>
                    </div>
                  </div>
                  <div class="col-md-3">
                    <div class="p-4 bg-light rounded-4">
                      <div class="text-muted mb-2" style="font-size: 1rem; font-weight: 500;">Dépenses Non Justifiées</div>
                      <div class="fw-bold text-danger" style="font-size: 1.5rem; letter-spacing: 0.05rem;">
                        <%= user.depenses ? user.depenses.reduce((sum, d) => sum + (d.nonJustifier || 0), 0).toFixed(2) : '0.00' %> DH
                      </div>
                    </div>
                  </div>
                </div>
                <hr class="my-5">
                <div class="text-center">
                  <div class="text-muted mb-2" style="font-size: 1.1rem; font-weight: 500;">Solde Final</div>
                  <div class="fw-bold text-info" style="font-size: 1.75rem; letter-spacing: 0.05rem;">
                    <%= justifCaisse.soldeFinal ? justifCaisse.soldeFinal.toFixed(2) : '0.00' %> DH
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>

    <script>
      // Toggle edit mode
      function toggleEditMode() {
        const editBtn = document.querySelector('#editBtn');
        const isEditing = editBtn.textContent.includes('Activer');
        const inputs = document.querySelectorAll('#recettes input, #depenses input, #mois');
        const buttons = document.querySelectorAll('#addRecetteBtn, #saveRecettesBtn, #addDepenseBtn, #saveDepensesBtn, #saveAllBtn, #recettes button, #depenses button');

        if (isEditing) {
          inputs.forEach(input => input.removeAttribute('readonly'));
          inputs.forEach(input => input.classList.remove('readonly'));
          buttons.forEach(button => button.removeAttribute('disabled'));
          document.querySelector('#mois').removeAttribute('disabled');
          editBtn.textContent = 'Désactiver l\'édition';
          editBtn.classList.remove('btn-warning');
          editBtn.classList.add('btn-secondary');
        } else {
          inputs.forEach(input => input.setAttribute('readonly', 'readonly'));
          inputs.forEach(input => input.classList.add('readonly'));
          buttons.forEach(button => button.setAttribute('disabled', 'disabled'));
          document.querySelector('#mois').setAttribute('disabled', 'disabled');
          editBtn.textContent = 'Activer l\'édition';
          editBtn.classList.remove('btn-secondary');
          editBtn.classList.add('btn-warning');
        }
        updateSaveButtons();
      }

      // Enable/disable save buttons based on month selection and edit mode
      const moisSelect = document.querySelector('#mois');
      const saveAllBtn = document.querySelector('#saveAllBtn');
      const saveRecettesBtn = document.querySelector('#saveRecettesBtn');
      const saveDepensesBtn = document.querySelector('#saveDepensesBtn');

      function updateSaveButtons() {
        const isMonthSelected = !!moisSelect.value;
        const isEditing = !document.querySelector('#recettes').classList.contains('readonly');
        saveAllBtn.disabled = !isMonthSelected || !isEditing;
        saveDepensesBtn.disabled = !isMonthSelected || !isEditing;
      }

      moisSelect.addEventListener('change', updateSaveButtons);
      updateSaveButtons();

      // Add new recette row
      function addNewRecetteRow() {
  const tbody = document.querySelector('#recetteTable tbody');
  const placeholder = tbody.querySelector('.no-data');
  if (placeholder) placeholder.remove();

  const newRow = document.createElement('tr');
  newRow.innerHTML = `
    <td><input type="date" name="dateRecette" class="form-control" value="${new Date().toISOString().split('T')[0]}" required></td>
    <td><input type="text" name="source" class="form-control" required></td>
    <td><input type="number" name="montant" step="0.01" min="0.01" class="form-control" required></td>
    <td><button class="btn btn-danger btn-sm" onclick="deleteRecetteItem(this)">Supprimer</button></td>
  `;
  tbody.appendChild(newRow);
}

function saveAllRecetteItems() {
  const rows = document.querySelectorAll('#recetteTable tbody tr');
  const items = [];
  let valid = true;
  let errorMessages = [];

  rows.forEach((row, index) => {
    const dateInput = row.querySelector('input[name="dateRecette"]')?.value;
    const sourceInput = row.querySelector('input[name="source"]')?.value?.trim();
    const montantInput = row.querySelector('input[name="montant"]')?.value?.trim();

    if (!dateInput && !sourceInput && !montantInput) return;

    if (!dateInput) {
      errorMessages.push(`Ligne ${index + 1}: Date manquante`);
      valid = false;
      return;
    }
    if (!sourceInput) {
      errorMessages.push(`Ligne ${index + 1}: Source manquante`);
      valid = false;
      return;
    }
    const montant = parseFloat(montantInput);
    if (isNaN(montant) || montant <= 0) {
      errorMessages.push(`Ligne ${index + 1}: Montant invalide ou non positif`);
      valid = false;
      return;
    }

    items.push({
      _id: row.dataset.id || null,
      dateRecette: dateInput,
      source: sourceInput,
      montant,
    });
  });

  const responsable = document.querySelector('input[name="responsable"]')?.value?.trim();
  const userId = document.querySelector('input[name="userId"]')?.value?.trim();
  const chantier = document.querySelector('input[name="chantier"]')?.value?.trim();
  const designation = document.querySelector('#mois')?.value?.trim();
  const justifId = document.querySelector('input[name="justifId"]')?.value?.trim() || new URLSearchParams(window.location.search).get('id');

  if (!responsable || !userId || !chantier || !designation || !justifId) {
    const missingFields = [];
    if (!responsable) missingFields.push('responsable');
    if (!userId) missingFields.push('userId');
    if (!chantier) missingFields.push('chantier');
    if (!designation) missingFields.push('mois');
    if (!justifId) missingFields.push('justifId');
    errorMessages.push(`Champs manquants: ${missingFields.join(', ')}`);
    valid = false;
  }

  if (!valid) {
    console.error('Validation errors:', errorMessages);
    alert(`Erreurs détectées pour la justification de ${responsable || 'l\'utilisateur'}:\n${errorMessages.join('\n')}`);
    return;
  }

  if (items.length === 0) {
    alert('Veuillez ajouter au moins une recette valide.');
    return;
  }

  fetch(`/achats/caisse/admin/${userId}/${justifId}/recettes`, {
    method: 'POST',
    headers: { 
      'Content-Type': 'application/json',
      // Add CSRF token if required, e.g.:
      // 'X-CSRF-Token': document.querySelector('meta[name="csrf-token"]').content
    },
    body: JSON.stringify({ userId, responsable, chantier, designation, justifId, items }),
  })
    .then(res => {
      const contentType = res.headers.get('content-type');
      if (!contentType || !contentType.includes('application/json')) {
        return res.text().then(text => {
          console.error('Non-JSON response:', text);
          throw new Error('Réponse du serveur non-JSON, probablement une erreur ou une redirection.');
        });
      }
      if (!res.ok) {
        return res.json().then(data => {
          throw new Error(data.error || `Erreur HTTP ${res.status}`);
        });
      }
      return res.json();
    })
    .then(data => {
      if (data.success) {
        alert('Recettes enregistrées avec succès.');
        window.location.reload();
      } else {
        alert(`Erreur: ${data.error || 'Erreur inconnue.'}`);
      }
    })
    .catch(err => {
      console.error('Fetch error:', err);
      alert(`Erreur: ${err.message}`);
    });
}
// Delete recette item
      function deleteRecetteItem(button) {
        if (confirm('Supprimer cette recette ?')) {
          const row = button.closest('tr');
          const id = row.dataset.id;
          const urlParams = new URLSearchParams(window.location.search);
          const justifId = document.getElementById('recetteId').value;
          const userId = document.querySelector('input[name="userId"]')?.value?.trim();

          if (id && justifId && userId) {
            fetch(`/achats/caisse/admin/${userId}/${justifId}/recettes/${id}`, {
              method: 'DELETE',
              headers: { 'Content-Type': 'application/json' },
            })
              .then(res => {
                if (!res.ok) {
                  return res.json().then(data => {
                    throw new Error(data.error || `HTTP error ${res.status}`);
                  });
                }
                return res.json();
              })
              .then(data => {
                if (data.success) {
                  row.remove();
                  alert('Recette supprimée avec succès.');
                  if (!document.querySelector('#recetteTable tbody tr')) {
                    const tbody = document.querySelector('#recetteTable tbody');
                    tbody.innerHTML = '<tr class="no-data"><td colspan="4" class="text-center">Aucune recette enregistrée.</td></tr>';
                  }
                } else {
                  alert(`Erreur: ${data.error || 'Erreur lors de la suppression.'}`);
                }
              })
              .catch(err => {
                console.error('Fetch error:', err);
                alert(`Erreur réseau: ${err.message}`);
              });
          } else {
            row.remove();
            if (!document.querySelector('#recetteTable tbody tr')) {
              const tbody = document.querySelector('#recetteTable tbody');
              tbody.innerHTML = '<tr class="no-data"><td colspan="4" class="text-center">Aucune recette enregistrée.</td></tr>';
            }
          }
        }
      }

      // Add new depense row
      function addNewDepenseRow() {
        const tbody = document.querySelector('#depenseTable tbody');
        const placeholder = tbody.querySelector('.no-data');
        if (placeholder) placeholder.remove();

        const newRow = document.createElement('tr');
        newRow.innerHTML = `
          <td><input type="date" name="dateDepense" value="${new Date().toISOString().split('T')[0]}" class="form-control" required /></td>
          <td><input type="text" name="numeroPiece" class="form-control" /></td>
          <td><input type="text" name="imputation" class="form-control" /></td>
          <td><input type="text" name="natureDepense" class="form-control" required /></td>
          <td><input type="number" name="montantJustifie" value="0.00" step="0.01" min="0" class="form-control" required /></td>
          <td><input type="number" name="montantNonJustifie" value="0.00" step="0.01" min="0" class="form-control" required /></td>
          <td>
            <button class="btn btn-danger btn-sm" onclick="deleteDepenseItem(this)">
              <i class="fas fa-trash"></i> Supprimer
            </button>
          </td>
        `;
        tbody.appendChild(newRow);
      }

      // Save all depense items
      function saveAllDepenseItems() {
        const rows = document.querySelectorAll('#depenseTable tbody tr');
        const items = [];
        let valid = true;
        let errorMessages = [];

        rows.forEach((row, index) => {
          const inputs = row.querySelectorAll('input');
          if (inputs.length === 6) {
            const date = inputs[0].value;
            const numeroPiece = inputs[1].value?.trim();
            const imputation = inputs[2].value?.trim();
            const natureDepense = inputs[3].value?.trim();
            const montantJustifie = parseFloat(inputs[4].value) || 0;
            const montantNonJustifie = parseFloat(inputs[5].value) || 0;

            if (!date) {
              errorMessages.push(`Ligne ${index + 1}: Date manquante`);
              valid = false;
              return;
            }
            if (!natureDepense) {
              errorMessages.push(`Ligne ${index + 1}: Nature de dépense manquante`);
              valid = false;
              return;
            }
            if (montantJustifie === 0 && montantNonJustifie === 0) {
              errorMessages.push(`Ligne ${index + 1}: Au moins un montant (justifié ou non justifié) doit être supérieur à 0`);
              valid = false;
              return;
            }

            const depense = {
              _id: row.dataset.id || null,
              dateDepense: date,
              numeroPiece,
              imputation,
              natureDepense,
              montantJustifie,
              montantNonJustifie,
            };
            items.push(depense);
          }
        });

        const responsable = document.querySelector('input[name="responsable"]')?.value?.trim();
        const userId = document.querySelector('input[name="userId"]')?.value?.trim();
        const chantier = document.querySelector('input[name="chantier"]')?.value?.trim();
        const designation = document.querySelector('#mois')?.value?.trim();
        const urlParams = new URLSearchParams(window.location.search);
        const justifId = urlParams.get('id');

        if (!responsable || !userId || !chantier || !designation || !justifId) {
          const missingFields = [];
          if (!responsable) missingFields.push('responsable');
          if (!userId) missingFields.push('userId');
          if (!chantier) missingFields.push('chantier');
          if (!designation) missingFields.push('mois');
          if (!justifId) missingFields.push('justifId');
          errorMessages.push(`Champs manquants: ${missingFields.join(', ')}`);
          valid = false;
        }

        if (!valid) {
          alert(`Erreurs détectées pour la justification de ${responsable || 'l\'utilisateur'}:\n${errorMessages.join('\n')}`);
          return;
        }

        if (items.length === 0) {
          alert('Veuillez ajouter au moins une dépense valide.');
          return;
        }

        fetch(`/achats/caisse/admin/${userId}/${justifId}/depenses`, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ userId, responsable, chantier, designation, items }),
        })
          .then(res => {
            if (!res.ok) {
              return res.json().then(data => {
                throw new Error(data.error || `Erreur HTTP ${res.status}`);
              });
            }
            return res.json();
          })
          .then(data => {
            if (data.success) {
              alert('Dépenses enregistrées avec succès.');
              window.location.reload();
            } else {
              alert(`Erreur: ${data.error || 'Erreur inconnue.'}`);
            }
          })
          .catch(err => {
            console.error('Fetch error:', err);
            alert(`Erreur: ${err.message}`);
          });
      }

      // Delete depense item
      function deleteDepenseItem(button) {
        if (confirm('Supprimer cette dépense ?')) {
          const row = button.closest('tr');
          const id = row.dataset.id;
          const urlParams = new URLSearchParams(window.location.search);
          const justifId = urlParams.get('id');
          const userId = document.querySelector('input[name="userId"]')?.value?.trim();

          if (id && justifId && userId) {
            fetch(`/achats/caisse/admin/${userId}/${justifId}/depenses/${id}`, {
              method: 'DELETE',
              headers: { 'Content-Type': 'application/json' },
            })
              .then(res => {
                if (!res.ok) {
                  return res.json().then(data => {
                    throw new Error(data.error || `HTTP error ${res.status}`);
                  });
                }
                return res.json();
              })
              .then(data => {
                if (data.success) {
                  row.remove();
                  alert('Dépense supprimée avec succès.');
                  if (!document.querySelector('#depenseTable tbody tr')) {
                    const tbody = document.querySelector('#depenseTable tbody');
                    tbody.innerHTML = '<tr class="no-data"><td colspan="7" class="text-center">Aucune dépense enregistrée.</td></tr>';
                  }
                } else {
                  alert(`Erreur: ${data.error || 'Erreur lors de la suppression.'}`);
                }
              })
              .catch(err => {
                console.error('Fetch error:', err);
                alert(`Erreur réseau: ${err.message}`);
              });
          } else {
            row.remove();
            if (!document.querySelector('#depenseTable tbody tr')) {
              const tbody = document.querySelector('#depenseTable tbody');
              tbody.innerHTML = '<tr class="no-data"><td colspan="7" class="text-center">Aucune dépense enregistrée.</td></tr>';
            }
          }
        }
      }

      // Save all data (recettes + dépenses)
      function saveAllData() {
        const recetteRows = document.querySelectorAll('#recetteTable tbody tr');
        const depenseRows = document.querySelectorAll('#depenseTable tbody tr');
        const recetteItems = [];
        const depenseItems = [];
        let valid = true;
        let errorMessages = [];

        // Collect recettes
        recetteRows.forEach((row, index) => {
          const dateInput = row.querySelector('input[name="dateRecette"]')?.value;
          const sourceInput = row.querySelector('input[name="source"]')?.value?.trim();
          const montantInput = row.querySelector('input[name="montant"]')?.value?.trim();

          if (!dateInput && !sourceInput && !montantInput) return;

          if (!dateInput) {
            errorMessages.push(`Recette ligne ${index + 1}: Date manquante`);
            valid = false;
            return;
          }
          if (!sourceInput) {
            errorMessages.push(`Recette ligne ${index + 1}: Source manquante`);
            valid = false;
            return;
          }
          const montant = parseFloat(montantInput);
          if (isNaN(montant) || montant <= 0) {
            errorMessages.push(`Recette ligne ${index + 1}: Montant invalide ou non positif`);
            valid = false;
            return;
          }

          recetteItems.push({
            _id: row.dataset.id || null,
            dateRecette: dateInput,
            source: sourceInput,
            montant,
          });
        });

        // Collect dépenses
        depenseRows.forEach((row, index) => {
          const inputs = row.querySelectorAll('input');
          if (inputs.length === 6) {
            const date = inputs[0].value;
            const numeroPiece = inputs[1].value?.trim();
            const imputation = inputs[2].value?.trim();
            const natureDepense = inputs[3].value?.trim();
            const montantJustifie = parseFloat(inputs[4].value) || 0;
            const montantNonJustifie = parseFloat(inputs[5].value) || 0;

            if (!date) {
              errorMessages.push(`Dépense ligne ${index + 1}: Date manquante`);
              valid = false;
              return;
            }
            if (!natureDepense) {
              errorMessages.push(`Dépense ligne ${index + 1}: Nature de dépense manquante`);
              valid = false;
              return;
            }
            if (montantJustifie === 0 && montantNonJustifie === 0) {
              errorMessages.push(`Dépense ligne ${index + 1}: Au moins un montant (justifié ou non justifié) doit être supérieur à 0`);
              valid = false;
              return;
            }

            depenseItems.push({
              _id: row.dataset.id || null,
              dateDepense: date,
              numeroPiece,
              imputation,
              natureDepense,
              montantJustifie,
              montantNonJustifie,
            });
          }
        });

        const responsable = document.querySelector('input[name="responsable"]')?.value?.trim();
        const userId = document.querySelector('input[name="userId"]')?.value?.trim();
        const chantier = document.querySelector('input[name="chantier"]')?.value?.trim();
        const designation = document.querySelector('#mois')?.value?.trim();
        const urlParams = new URLSearchParams(window.location.search);
        const justifId = urlParams.get('id');

        if (!responsable || !userId || !chantier || !designation || !justifId) {
          const missingFields = [];
          if (!responsable) missingFields.push('responsable');
          if (!userId) missingFields.push('userId');
          if (!chantier) missingFields.push('chantier');
          if (!designation) missingFields.push('mois');
          if (!justifId) missingFields.push('justifId');
          errorMessages.push(`Champs manquants: ${missingFields.join(', ')}`);
          valid = false;
        }

        if (!valid) {
          alert(`Erreurs détectées pour la justification de ${responsable || 'l\'utilisateur'}:\n${errorMessages.join('\n')}`);
          return;
        }

        if (recetteItems.length === 0 && depenseItems.length === 0) {
          alert('Veuillez ajouter au moins une recette ou une dépense.');
          return;
        }

        fetch(`/achats/caisse/admin/${userId}/${justifId}/save-all`, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ userId, responsable, chantier, designation, recettes: recetteItems, depenses: depenseItems }),
        })
          .then(res => {
            if (!res.ok) {
              return res.json().then(data => {
                throw new Error(data.error || `Erreur HTTP ${res.status}`);
              });
            }
            return res.json();
          })
          .then(data => {
            if (data.success) {
              alert('Justification enregistrée avec succès.');
              window.location.reload();
            } else {
              alert(`Erreur: ${data.error || 'Erreur inconnue.'}`);
            }
          })
          .catch(err => {
            console.error('Fetch error:', err);
            alert(`Erreur: ${err.message}`);
          });
      }
    </script>
</body>
</html>