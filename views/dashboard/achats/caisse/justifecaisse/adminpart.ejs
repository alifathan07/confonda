<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8" />
  <meta http-equiv="X-UA-Compatible" content="IE=edge" />
  <meta name="viewport" content="width=device-width, initial-scale=1, shrink-to-fit=no" />
  <meta name="description" content="Justification Caisse Dashboard" />
  <title><%= user.name || 'Utilisateur' %> - Justification Caisse</title>

  <!-- Fonts & Icons -->
  <link href="/vendor/fontawesome-free/css/all.min.css" rel="stylesheet" />
  <link href="https://fonts.googleapis.com/css?family=Nunito:400,600,700,900" rel="stylesheet" />

  <!-- Theme CSS -->
  <link href="/css/sb-admin-2.min.css" rel="stylesheet" />

  <style>
    .card-header { font-weight: 600; font-size: 1.1rem; }
    .demande-info p { margin-bottom: 0.4rem; }
    .badge { font-size: 0.85rem; padding: 0.4em 0.7em; }
    .table th { background: #f8f9fc; }
    .page-title { font-weight: 700; color: #4e73df; }
    .summary-card { background: #f8f9fc; padding: 15px; border-radius: 5px; }
    .summary-card p { margin: 0.5rem 0; }
    .save-all-btn { margin-bottom: 20px; }
    .error-text { color: red; font-size: 0.9rem; }
    .table input { width: 100%; }
    .card-body { overflow-x: auto; }
    .readonly input, .readonly select { background-color: #e9ecef; cursor: not-allowed; }
    .edit-btn { margin-right: 10px; }
  </style>
</head>
<body id="page-top">
  <div id="wrapper">
    <!-- Sidebar -->
    <%- include('../../../../layouts/sidebar') %>

    <!-- Content Wrapper -->
    <div id="content-wrapper" class="d-flex flex-column">
      <div id="content">
        <!-- Topbar -->
        <%- include('../../../../layouts/topbar') %>

        <div class="container-fluid">
          <!-- Page Header -->
          <div class="d-flex justify-content-between align-items-center mb-4">
            <h1 class="h3 page-title"><i class="fas fa-cash-register"></i> Justification Caisse - <%= user.name || 'Utilisateur' %></h1>
            <div>
              <a href="/achats/caisse/admin" class="btn btn-primary btn-sm">
                <i class="fas fa-list"></i> Retour
              </a>
            </div>
          </div>

          <!-- Justification Info -->
          <div class="row">
            <div class="col-lg-12">
              <div class="card shadow mb-4">
                <div class="card-body demande-info" style="display: flex; align-items: center; gap: 20px; padding: 20px;">
                  <p style="margin: 0;"><strong>RESPONSABLE CAISSE :</strong> <%= user.name || 'Non défini' %></p>
                  <% if (!user.name) { %>
                    <p class="error-text">Erreur : Nom de l'utilisateur non défini</p>
                  <% } %>
                  <p style="margin: 0;"><strong>Chantier :</strong> <%= chantier.nom || 'Non défini' %></p>
                  <% if (!chantier.nom) { %>
                    <p class="error-text">Erreur : Chantier non défini</p>
                  <% } %>
                  <input type="hidden" name="responsable" value="<%= user.name || '' %>" />
                  <input type="hidden" name="chantier" value="<%= chantier.nom || '' %>" />
                  <input type="hidden" name="userId" value="<%= user.id || '' %>" />
                  <input type="hidden" name="justifId" value="<%= justifCaisse.id || '' %>" />
                  <div class="form-group" style="margin: 0;">
                    <% if (justifCaisse && justifCaisse.id) { %>
                      <p><strong>SITUATION DE CAISSE :</strong> <%= justifCaisse.designation || '' %></p>
                      <select name="designation" id="mois" class="form-control" style="width: 200px; display: inline-block;" hidden>
                        
                        <% const year = new Date().getFullYear(); %>
                        <% const months = ['Janvier', 'Février', 'Mars', 'Avril', 'Mai', 'Juin', 'Juillet', 'Août', 'Septembre', 'Octobre', 'Novembre', 'Décembre']; %>
                        <% months.forEach((m, i) => { %>
                          <option value="<%= `${m}-${year}` %>" <%= justifCaisse && justifCaisse.designation && justifCaisse.designation.includes(m) ? 'selected' : '' %>>
                            <%= `${m}-${year}` %>
                          </option>
                        <% }); %>
                      </select>
                    <% } else { %>
                      <label for="mois" style="margin-right: 10px;"><strong>SITUATION DE CAISSE :</strong></label>

                      <select name="designation" id="mois" class="form-control" style="width: 200px; display: inline-block;">
                        
                        <% const year = new Date().getFullYear(); %>
                        <% const months = ['Janvier', 'Février', 'Mars', 'Avril', 'Mai', 'Juin', 'Juillet', 'Août', 'Septembre', 'Octobre', 'Novembre', 'Décembre']; %>
                        <% months.forEach((m, i) => { %>
                          <option value="<%= `${m}-${year}` %>" <%= justifCaisse && justifCaisse.designation && justifCaisse.designation.includes(m) ? 'selected' : '' %>>
                            <%= `${m}-${year}` %>
                          </option>
                        <% }); %>
                      </select>
                    <% } %>
                  </div>
                </div>
              </div>
            </div>
          </div>

          <!-- Recettes Table -->
          <div id="recettes" class="card shadow mb-4">
            <div class="card-header d-flex justify-content-between align-items-center">
              <h2 class="card-title">Caisse Reçue</h2>
              <div class="d-flex justify-content-end mb-3">
                <% if (!justifCaisse.id) { %>
                  <label for="soldePrecedent" class="me-2">Solde Précédent</label>
                  <input type="number" id="soldePrecedent" name="soldePrecedent" class="form-control" step="0.01" min="0.01" value="0.00" />
                
                 
                <% } %>
              </div>
           
              <div>
                <button class="btn btn-primary btn-sm" id="addRecetteBtn" onclick="addNewRecetteRow()">
                  <i class="fas fa-plus"></i> Ajouter Recette
                </button>
                <button class="btn btn-success btn-sm" id="saveRecettesBtn" onclick="saveAllRecetteItems()">Enregistrer Recette</button>
              </div>
            </div>
            <div class="card-body">
              <table class="table table-hover" id="recetteTable">
                <thead>
                  <tr>
                    <th>Date</th>
                    <th>Origine Caisse</th>
                    <th>Montant</th>
                    <th>Actions</th>
                  </tr>
                </thead>
                <tbody>
                  <% if (user.recettes && user.recettes.length > 0) { %>
                    <% user.recettes.forEach(d => { %>
                      <tr data-id="<%= d._id || '' %>">
                        <td>
                          <input type="date" name="dateRecette" class="form-control"
                                 value="<%= d.dateRecette ? new Date(d.dateRecette).toISOString().split('T')[0] : '' %>" />
                        </td>
                        <td>
                          <input type="text" name="source" class="form-control"
                                 value="<%= d.source || '' %>" />
                        </td>
                        <td>
                          <input type="number" name="montant" class="form-control" step="0.01" min="0.01"
                                 value="<%= d.montant ? d.montant.toFixed(2) : '0.00' %>" />
                        </td>
                        <td>
                          <button class="btn btn-danger btn-sm" onclick="deleteRecetteItem(this)">Supprimer</button>
                        </td>
                      </tr>
                    <% }) %>
                  <% } else { %>
                    <tr class="no-data">
                      <td colspan="4" class="text-center">Aucune recette enregistrée.</td>
                    </tr>
                  <% } %>
                </tbody>
              </table>
            </div>
          </div>

          <div id="depenses" class="card shadow mb-4">
            <div class="card-header d-flex justify-content-between align-items-center">
              <h2 class="card-title">DÉPENSES</h2>
              <span class="badge bg-primary ms-1 text-white d-flex justify-content-center" style="font-size: 15px;">
                Solde Précédent : <%= justifCaisse.soldePrecedent ? justifCaisse.soldePrecedent.toFixed(2) : '0.00' %> DH
              </span>
              <div>
                <button class="btn btn-primary btn-sm" id="addDepenseBtn" style="display: none;">
                  <i class="fas fa-plus"></i> Ajouter Dépense
                </button>
                <button class="btn btn-success btn-sm" id="validBtn" onclick="validePar()">
                  <i class="fas fa-check-circle"></i> Validé
                </button>
              </div>
            </div>
            <div class="card-body">
              <!-- Add hidden input for justifId -->
              <input type="hidden" name="justifId" value="<%= justifCaisse._id %>">
              <table class="table table-hover" id="depenseTable">
                <thead>
                  <tr>
                    <th>Date</th>
                    <th>Numéro de Pièce</th>
                    <th>Imputation</th>
                    <th>Nature Dépense</th>
                    <th>Montant Justifié</th>
                    <th>Montant Non Justifié</th>
                    <th>Validation</th>
                    <th>Validé par</th>
                  </tr>
                </thead>
                <tbody>
                  <% if (user.depenses && user.depenses.length > 0) { %>
                    <% user.depenses.forEach(d => { %>
                      <tr data-id="<%= d._id %>">
                        <td><%= d.date ? new Date(d.date).toLocaleDateString('fr-FR') : '-' %></td>
                        <td><%= d.numeroDuPiece || '-' %></td>
                        <td><%= d.imputation || '-' %></td>
                        <td><%= d.natureDepense || '-' %></td>
                        <td><%= d.justifier ? d.justifier.toFixed(2) : '0.00' %> DH</td>
                        <td><%= d.nonJustifier ? d.nonJustifier.toFixed(2) : '0.00' %> DH</td>
                        <td>
                          <div class="form-check form-check-inline">
                            <input type="checkbox" class="form-check-input validation-checkbox"
                                   id="validation-<%= d._id %>"
                                   name="validation" data-id="<%= d._id %>"
                                   <%= d.validation === true  ? 'checked' : '' %>>
                            <label class="form-check-label" for="validation-<%= d._id %>"></label>
                          </div>
                        </td>
                        <td><%= d.validerPar || '-' %></td>
                      </tr>
                    <% }) %>
                  <% } else { %>
                    <tr class="no-data">
                      <td colspan="8" class="text-center">Aucune dépense enregistrée.</td>
                    </tr>
                  <% } %>
                </tbody>
              </table>
            </div>
          </div>
          
          <script>
          document.addEventListener('change', function (e) {
            if (e.target.classList.contains('validation-checkbox')) {
              const depenseId = e.target.dataset.id;
              const validation = e.target.checked;
              const previousState = validation; // Store for error handling
          
              // Show loading state
              e.target.disabled = true;
              e.target.nextElementSibling.style.opacity = '0.5'; // Dim label
          
              // Send validation and clear validerPar if unchecked
              fetch(`/achats/caisse/justification/depenses/${depenseId}`, {
                method: 'PATCH',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ 
                  validation,
                  validerPar: validation ? undefined : null // Clear validerPar if unchecked
                }),
              })
                .then(res => res.json())
                .then(data => {
                  if (data.success) {
                    alert(`Validation ${validation ? 'activée' : 'désactivée'} avec succès.`);
                    
                    
                    // Update the 'Validé par' column
                    const row = e.target.closest('tr');
                    const validerParCell = row.querySelector('td:last-child');
                    validerParCell.textContent = data.validerPar || '-';
                    window.location.reload();
                  } else {
                    alert('Erreur : ' + (data.error || 'Erreur inconnue.'));
                    e.target.checked = !previousState; // Revert checkbox on error
                  }
                })
                .catch(err => {
                  console.error('Fetch error:', err);
                  alert('Erreur réseau : ' + err.message);
                  e.target.checked = !previousState; // Revert checkbox on error
                })
                .finally(() => {
                  // Re-enable checkbox and restore label
                  e.target.disabled = false;
                  e.target.nextElementSibling.style.opacity = '1';
                });
            }
          });
          
          async function validePar() {
            // Extract justifId from input
            const justifIdInput = document.querySelector('input[name="justifId"]');
            const justifId = justifIdInput?.value.trim() || null;
            if (!justifId) {
              alert('Erreur : Identifiant de justification manquant.');
              return;
            }
          
            try {
              // Disable button during request
              const validBtn = document.getElementById('validBtn');
              validBtn.disabled = true;
              validBtn.style.opacity = '0.5';
          
              // Send PATCH request with justifId in the URL
              // /achats/caisse/justification/valider/:justifId
              const response = await fetch(`/achats/caisse/justification/valider/${justifId}`, {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({}), // Empty body since justifId is in the URL
              });
          
              // Check if response is JSON
              const contentType = response.headers.get('content-type');
              if (!contentType || !contentType.includes('application/json')) {
                const text = await response.text();
                console.error('Non-JSON response:', text);
                throw new Error(`Réponse non-JSON reçue (statut ${response.status}): ${text.slice(0, 100)}...`);
              }
          
              const data = await response.json();
              if (data.success) {
                // Update all rows in the table
               
                window.location.reload();
              } else {
                alert('Erreur : ' + (data.error || 'Erreur inconnue.'));
              }
            } catch (err) {
              console.error('Fetch error:', err);
              alert(`Erreur réseau : ${err.message}`);
            } finally {
              // Re-enable button
              validBtn.disabled = false;
              validBtn.style.opacity = '1';
            }
          }
          </script>
          
          <!-- Save All Button -->
          <button class="btn btn-success btn-md save-all-btn" id="saveAllBtn" onclick="saveAllData()" hidden>
          </button>

          <!-- Summary Section -->
          <div id="summary" class="card shadow mb-4">
            <div class="card shadow-sm border-0 rounded-4">
              <div class="card-header bg-primary text-white py-3">
                <h4 class="mb-0">Résumé</h4>
              </div>
              <div class="card-body p-5">
                <div class="row text-center text-md-start g-4">
                  <div class="col-md-3">
                    <div class="p-4 bg-light rounded-4">
                      <div class="text-muted mb-2" style="font-size: 1rem; font-weight: 500;">Solde Précédent</div>
                      <div class="fw-bold text-success" style="font-size: 1.5rem; letter-spacing: 0.05rem;">
                        <%= justifCaisse.soldePrecedent ? justifCaisse.soldePrecedent.toFixed(2) : '0.00' %> DH
                      </div>
                    </div>
                  </div>
                  <div class="col-md-3">
                    <div class="p-4 bg-light rounded-4">
                      <div class="text-muted mb-2" style="font-size: 1rem; font-weight: 500;">Total Recettes</div>
                      <div class="fw-bold text-primary" style="font-size: 1.5rem; letter-spacing: 0.05rem;">
                        <%= justifCaisse.totalRecettes ? justifCaisse.totalRecettes.toFixed(2) : '0.00' %> DH
                      </div>
                    </div>
                  </div>
                  <div class="col-md-3">
                    <div class="p-4 bg-light rounded-4">
                      <div class="text-muted mb-2" style="font-size: 1rem; font-weight: 500;">Dépenses Justifiées</div>
                      <div class="fw-bold text-warning" style="font-size: 1.5rem; letter-spacing: 0.05rem;">
                        <%= justifCaisse.depenses ? justifCaisse.depenses.filter(d => d.validation).reduce((sum, d) => sum + (d.montantJustifie || 0), 0).toFixed(2) : '0.00' %> DH

                      </div>
                    </div>
                  </div>
                  <div class="col-md-3">
                    <div class="p-4 bg-light rounded-4">
                      <div class="text-muted mb-2" style="font-size: 1rem; font-weight: 500;">Dépenses Non Justifiées</div>
                      <div class="fw-bold text-danger" style="font-size: 1.5rem; letter-spacing: 0.05rem;">
                        <%= justifCaisse.depenses ? justifCaisse.depenses.filter(d => d.validation).reduce((sum, d) => sum + (d.montantNonJustifie || 0), 0).toFixed(2) : '0.00' %> DH
                      </div>
                    </div>
                  </div>
                </div>
                <hr class="my-5">
                <div class="text-center">
                  <div class="text-muted mb-2" style="font-size: 1.1rem; font-weight: 500;">Solde Final</div>
                  <div class="fw-bold text-info" style="font-size: 1.75rem; letter-spacing: 0.05rem;">
                    <%= justifCaisse.soldeFinal ? justifCaisse.soldeFinal.toFixed(2) : '0.00' %> DH
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>

    <script>



      
        //   const response = await fetch(`/achats/caisse/justification/depenses/${id}`, {
        //     method: 'POST',
        //     headers: { 'Content-Type': 'application/json' },
        //   });
        //   if (!response.ok) {
        //     throw new Error(`HTTP error! status: ${response.status}`);
        //   }
        //   const data = await response.json();
        //   if (data.success) {
        //     alert('Validation de la dépense mise à jour avec succès.');
        //     window.location.reload();
        //   } else {
        //     alert(`Erreur: ${data.error || 'Erreur inconnue.'}`);
        //   }
        // }
      
      // Determine if it's a new justification
      const isNewJustification = !document.querySelector('input[name="justifId"]').value;

      // Enable save buttons based on month selection
      function updateSaveButtons() {
        const moisSelect = document.querySelector('#mois');
        const saveAllBtn = document.querySelector('#saveAllBtn');
        const saveRecettesBtn = document.querySelector('#saveRecettesBtn');
        const saveDepensesBtn = document.querySelector('#saveDepensesBtn');
        const isMonthSelected = !!moisSelect.value;
        saveAllBtn.disabled = !isMonthSelected;
        saveRecettesBtn.disabled = !isMonthSelected;
        saveDepensesBtn.disabled = !isMonthSelected;
      }

      document.querySelector('#mois').addEventListener('change', updateSaveButtons);
      updateSaveButtons();

      // Add new recette row
      function addNewRecetteRow() {
  const tbody = document.querySelector('#recetteTable tbody');
  const placeholder = tbody.querySelector('.no-data');
  if (placeholder) placeholder.remove();

  const newRow = document.createElement('tr');
  newRow.innerHTML = `
    <td><input type="date" name="dateRecette" class="form-control" value="${new Date().toISOString().split('T')[0]}" required></td>
    <td><input type="text" name="source" class="form-control" required></td>
    <td><input type="number" name="montant" step="0.01" min="0.01" class="form-control" required></td>
    <td><button class="btn btn-danger btn-sm" onclick="deleteRecetteItem(this)">Supprimer</button></td>
  `;
  tbody.appendChild(newRow);

  // Ensure soldePrecedent is editable if no justifCaisse exists
  const soldePrecedentInput = document.querySelector('#soldePrecedent');
  const justifId = document.querySelector('input[name="justifId"]')?.value?.trim();
  if (!justifId) {
    soldePrecedentInput.removeAttribute('readonly');
    soldePrecedentInput.classList.remove('readonly');
  }
}
      // Save all recette items
   
      function saveAllRecetteItems() {
  const rows = document.querySelectorAll('#recetteTable tbody tr');
  const items = [];
  let valid = true;
  let errorMessages = [];

  rows.forEach((row, index) => {
    const dateInput = row.querySelector('input[name="dateRecette"]')?.value;
    const sourceInput = row.querySelector('input[name="source"]')?.value?.trim();
    const montantInput = row.querySelector('input[name="montant"]')?.value?.trim();

    if (!dateInput && !sourceInput && !montantInput) return;

    if (!dateInput) {
      errorMessages.push(`Ligne ${index + 1}: Date manquante`);
      valid = false;
      return;
    }
    if (!sourceInput) {
      errorMessages.push(`Ligne ${index + 1}: Source manquante`);
      valid = false;
      return;
    }
    const montant = parseFloat(montantInput);
    if (isNaN(montant) || montant <= 0) {
      errorMessages.push(`Ligne ${index + 1}: Montant invalide ou non positif`);
      valid = false;
      return;
    }

    items.push({
      _id: row.dataset.id || null,
      dateRecette: dateInput,
      source: sourceInput,
      montant,
    });
  });

  const responsable = document.querySelector('input[name="responsable"]')?.value?.trim();
  const userId = document.querySelector('input[name="userId"]')?.value?.trim();
  const chantier = document.querySelector('input[name="chantier"]')?.value?.trim();
  const designation = document.querySelector('#mois')?.value?.trim();
  const justifId = document.querySelector('input[name="justifId"]')?.value?.trim() || null;
  const soldePrecedentInput = document.querySelector('#soldePrecedent')?.value?.trim();
  const soldePrecedent = soldePrecedentInput ? parseFloat(soldePrecedentInput) : null;

  if (!responsable || !userId || !chantier || !designation) {
    const missingFields = [];
    if (!responsable) missingFields.push('responsable');
    if (!userId) missingFields.push('userId');
    if (!chantier) missingFields.push('chantier');
    if (!designation) missingFields.push('mois');
    errorMessages.push(`Champs manquants: ${missingFields.join(', ')}`);
    valid = false;
  }

  if (!justifId && (soldePrecedent === null || isNaN(soldePrecedent) || soldePrecedent < 0)) {
    errorMessages.push('Solde Précédent manquant ou invalide pour la première justification');
    valid = false;
  }

  if (!valid) {
    alert(`Erreurs détectées pour la justification de ${responsable || 'l\'utilisateur'}:\n${errorMessages.join('\n')}`);
    return;
  }

  if (items.length === 0) {
    alert('Veuillez ajouter au moins une recette valide.');
    return;
  }

  const id = window.location.pathname.split('/').pop();
  const payload = { userId, responsable, chantier, designation, justifId, items };
  if (!justifId) {
    payload.soldePrecedent = soldePrecedent;
  }

  fetch(`/achats/caisse/admin/${userId}/${id}/recettes`, {
    method: 'POST',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify(payload),
  })
    .then(res => {
      if (!res.ok) {
        return res.json().then(data => {
          throw new Error(data.error || `Erreur HTTP ${res.status}`);
        });
      }
      return res.json();
    })
    .then(data => {
      if (data.success) {
        alert('Recettes enregistrées avec succès.');
        if (isNewJustification && data.justifId) {
          window.location.href = `/achats/caisse/admin/${userId}/${data.justifId}`;
        } else {
          window.location.reload();
        }
      } else {
        alert(`Erreur: ${data.error || 'Erreur inconnue.'}`);
      }
    })
    .catch(err => {
      console.error('Fetch error:', err);
      alert(`Erreur: ${err.message}`);
    });
}
      // Delete recette item
      function deleteRecetteItem(button) {
        if (confirm('Supprimer cette recette ?')) {
          const row = button.closest('tr');
          const id = row.dataset.id;
          const userId = document.querySelector('input[name="userId"]')?.value?.trim();
          const justifId = document.querySelector('input[name="justifId"]')?.value?.trim();

          if (id && justifId && userId) {
            fetch(`/achats/caisse/justification/recettes/${id}`, {
              method: 'DELETE',
              headers: { 'Content-Type': 'application/json' },
            })
              .then(res => {
                if (!res.ok) {
                  return res.json().then(data => {
                    throw new Error(data.error || `HTTP error ${res.status}`);
                  });
                }
                return res.json();
              })
              .then(data => {
                if (data.success) {
                  row.remove();
                  alert('Recette supprimée avec succès.');
                  if (!document.querySelector('#recetteTable tbody tr')) {
                    const tbody = document.querySelector('#recetteTable tbody');
                    tbody.innerHTML = '<tr class="no-data"><td colspan="4" class="text-center">Aucune recette enregistrée.</td></tr>';
                  }
                } else {
                  alert(`Erreur: ${data.error || 'Erreur lors de la suppression.'}`);
                }
              })
              .catch(err => {
                console.error('Fetch error:', err);
                alert(`Erreur réseau: ${err.message}`);
              });
          } else {
            row.remove();
            if (!document.querySelector('#recetteTable tbody tr')) {
              const tbody = document.querySelector('#recetteTable tbody');
              tbody.innerHTML = '<tr class="no-data"><td colspan="4" class="text-center">Aucune recette enregistrée.</td></tr>';
            }
          }
        }
      }

     
     

// Save all data (recettes + depenses)
      function saveAllData() {
        const recetteRows = document.querySelectorAll('#recetteTable tbody tr');
        const depenseRows = document.querySelectorAll('#depenseTable tbody tr');
        const recetteItems = [];
        const depenseItems = [];
        let valid = true;
        let errorMessages = [];

        // Collect recettes
        recetteRows.forEach((row, index) => {
          const dateInput = row.querySelector('input[name="dateRecette"]')?.value;
          const sourceInput = row.querySelector('input[name="source"]')?.value?.trim();
          const montantInput = row.querySelector('input[name="montant"]')?.value?.trim();

          if (!dateInput && !sourceInput && !montantInput) return;

          if (!dateInput) {
            errorMessages.push(`Recette ligne ${index + 1}: Date manquante`);
            valid = false;
            return;
          }
          if (!sourceInput) {
            errorMessages.push(`Recette ligne ${index + 1}: Source manquante`);
            valid = false;
            return;
          }
          const montant = parseFloat(montantInput);
          if (isNaN(montant) || montant <= 0) {
            errorMessages.push(`Recette ligne ${index + 1}: Montant invalide ou non positif`);
            valid = false;
            return;
          }

          recetteItems.push({
            _id: row.dataset.id || null,
            dateRecette: dateInput,
            source: sourceInput,
            montant,
          });
        });

        // Collect depenses
        depenseRows.forEach((row, index) => {
          const inputs = row.querySelectorAll('input');
          if (inputs.length === 6) {
            const date = inputs[0].value;
            const numeroPiece = inputs[1].value?.trim();
            const imputation = inputs[2].value?.trim();
            const natureDepense = inputs[3].value?.trim();
            const montantJustifie = parseFloat(inputs[4].value) || 0;
            const montantNonJustifie = parseFloat(inputs[5].value) || 0;

            if (!date) {
              errorMessages.push(`Dépense ligne ${index + 1}: Date manquante`);
              valid = false;
              return;
            }
            if (!natureDepense) {
              errorMessages.push(`Dépense ligne ${index + 1}: Nature de dépense manquante`);
              valid = false;
              return;
            }
            if (montantJustifie === 0 && montantNonJustifie === 0) {
              errorMessages.push(`Dépense ligne ${index + 1}: Au moins un montant (justifié ou non justifié) doit être supérieur à 0`);
              valid = false;
              return;
            }

            depenseItems.push({
              _id: row.dataset.id || null,
              dateDepense: date,
              numeroPiece,
              imputation,
              natureDepense,
              montantJustifie,
              montantNonJustifie,
            });
          }
        });

        const responsable = document.querySelector('input[name="responsable"]')?.value?.trim();
        const userId = document.querySelector('input[name="userId"]')?.value?.trim();
        const chantier = document.querySelector('input[name="chantier"]')?.value?.trim();
        const designation = document.querySelector('#mois')?.value?.trim();
        const justifId = document.querySelector('input[name="justifId"]')?.value?.trim() || null;

        if (!responsable || !userId || !chantier || !designation) {
          const missingFields = [];
          if (!responsable) missingFields.push('responsable');
          if (!userId) missingFields.push('userId');
          if (!chantier) missingFields.push('chantier');
          if (!designation) missingFields.push('mois');
          errorMessages.push(`Champs manquants: ${missingFields.join(', ')}`);
          valid = false;
        }

        if (!valid) {
          alert(`Erreurs détectées pour la justification de ${responsable || 'l\'utilisateur'}:\n${errorMessages.join('\n')}`);
          return;
        }

        if (recetteItems.length === 0 && depenseItems.length === 0) {
          alert('Veuillez ajouter au moins une recette ou une dépense.');
          return;
        }

        const id = window.location.pathname.split('/').pop();
        fetch(`/achats/caisse/admin/${userId}/${id}/save-all`, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ userId, responsable, chantier, designation, recettes: recetteItems, depenses: depenseItems }),
        })
          .then(res => {
            if (!res.ok) {
              return res.json().then(data => {
                throw new Error(data.error || `Erreur HTTP ${res.status}`);
              });
            }
            return res.json();
          })
          .then(data => {
            if (data.success) {
              alert('Justification enregistrée avec succès.');
              if (isNewJustification && data.justifId) {
                window.location.href = `/achats/caisse/admin/${userId}/${data.justifId}`;
              } else {
                window.location.reload();
              }
            } else {
              alert(`Erreur: ${data.error || 'Erreur inconnue.'}`);
            }
          })
          .catch(err => {
            console.error('Fetch error:', err);
            alert(`Erreur: ${err.message}`);
          });
      }
    
    </script>
</body>
</html>