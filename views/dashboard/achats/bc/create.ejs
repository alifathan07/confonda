  <!-- Scripts -->
  <script src="/vendor/jquery/jquery.min.js"></script>
  <script src="/vendor/bootstrap/js/bootstrap.bundle.min.js"></script>
  <script src="https://cdnjs.cloudflare.com/ajax/libs/jspdf/2.5.1/jspdf.umd.min.js"></script>
  <script src="https://cdnjs.cloudflare.com/ajax/libs/jspdf-autotable/3.8.3/jspdf.plugin.autotable.min.js"></script>
  <script src="https://cdnjs.cloudflare.com/ajax/libs/xlsx/0.18.5/xlsx.full.min.js"></script>
  <!-- Choices.js (tag-style multi-select for chantiers) -->
  <script src="https://cdn.jsdelivr.net/npm/choices.js/public/assets/scripts/choices.min.js"></script>
  <script>
    function openSupplierEmailManager() {
      const supplierId = document.getElementById('fournisseurSelectBc').value;
      if (!supplierId) {
        alert('Veuillez d\'abord sélectionner un fournisseur');
        return;
      }
      $('#manageSupplierId').val(supplierId);
      $('#newSupplierEmail').val('');
      
      // Load current emails from local data
      renderSupplierEmails(supplierId);
      $('#supplierEmailModal').modal('show');
    }

    function renderSupplierEmails(supplierId) {
      // In Create mode, we might need to fetch the latest from server to be sure
      fetch('/api/fournisseurs')
        .then(r => r.json())
        .then(data => {
          const supplier = (data.fournisseurs || data).find(f => String(f.id) === String(supplierId));
          const list = $('#supplierEmailsList');
          list.empty();
          
          if (supplier) {
            // Main email
            if (supplier.email) {
              list.append(`
                <div class="d-flex justify-content-between align-items-center mb-2 p-2 bg-light rounded border-left border-primary">
                  <span class="small font-weight-bold">${supplier.email} (Principal)</span>
                </div>
              `);
            }
            
            // Secondary emails
            if (supplier.emails && supplier.emails.length) {
              supplier.emails.forEach(e => {
                list.append(`
                  <div class="d-flex justify-content-between align-items-center mb-2 p-2 bg-light rounded border-left">
                    <span class="small">${e.email}</span>
                    <button class="btn btn-xs btn-link text-danger p-0" onclick="deleteSupplierEmail(${e.id}, ${supplierId})">
                      <i class="fas fa-trash-alt"></i>
                    </button>
                  </div>
                `);
              });
            }
          }
        });
    }

    function addNewSupplierEmail() {
      const supplierId = $('#manageSupplierId').val();
      const email = $('#newSupplierEmail').val().trim();
      if (!email || !email.includes('@')) {
        alert('Veuillez entrer un email valide');
        return;
      }

      $.post(`/achats/fournisseurs/${supplierId}/emails`, { email: email }, function(res) {
        renderSupplierEmails(supplierId);
        $('#newSupplierEmail').val('');
        // Also update the local display if possible, or just refresh
      });
    }

    function deleteSupplierEmail(emailId, supplierId) {
      if (confirm('Supprimer cet email ?')) {
        $.ajax({
          url: `/achats/fournisseurs/emails/${emailId}`,
          type: 'DELETE',
          success: function() {
            renderSupplierEmails(supplierId);
          }
        });
      }
    }

    async function updateSupplierDetails() {
      const id = document.getElementById('fournisseurSelectBc').value;
      if (!id) {
        alert('Sélectionnez un fournisseur !');
        return;
      }

      const nameVal = document.getElementById('fourNameBc').value;
      const emailVal = document.getElementById('fourEmailBc').value;
      const telVal = document.getElementById('fourTelBc').value;

      try {
        const res = await fetch(`/achat/bc/supplier/update`, {
          method: 'PATCH',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({
            supplierId: id,
            name: nameVal,
            email: emailVal,
            telFournisseur: telVal,
          })
        });
        if (res.ok) {
          // Update local data
          const f = fournisseursDataBc.find(x => x.id === id);
          if (f) {
            f.name = nameVal;
            f.email = emailVal;
            f.tel = telVal;
          }
          alert('Informations fournisseur mises à jour !');
        } else {
          throw new Error('Erreur lors de la mise à jour');
        }
      } catch (e) {
        alert(e.message);
      }
    }
    (function () {
      const sel = document.getElementById('chantierSelect');
      if (sel && typeof Choices !== 'undefined') {
        window.chantierChoices = new Choices(sel, {
          removeItemButton: true,
          searchResultLimit: 5,
          placeholderValue: 'Sélectionner des chantiers',
          searchPlaceholderValue: 'Rechercher...',
          shouldSort: false
        });
      }
    })();

    // Fournisseurs data for BC edit (UI only)
    const fournisseursDataBc = <%- JSON.stringify(fournisseurs.map(f => ({
      id: String(f.id),
      name: f.name || '',
      email: [f.email, ...(f.emails || []).map(e => e.email)].filter(Boolean).join(', '),
      tel: f.telFournisseur || ''
    }))) %>;

    console.log('📦 Fournisseurs data loaded:', fournisseursDataBc);

    const selectBc = document.getElementById('fournisseurSelectBc');
    if (selectBc) {
      // Initialize Choices.js for searchable supplier select
      const supplierChoices = new Choices(selectBc, {
        removeItemButton: false,
        searchResultLimit: 10,
        placeholderValue: '-- Choisir un fournisseur --',
        searchPlaceholderValue: 'Rechercher un fournisseur...',
        shouldSort: false,
        itemSelectText: '',
      });

      console.log('✅ Supplier select element found and Choices initialized');
      
      selectBc.addEventListener('change', function () {
        const selectedId = this.value;
        const f = fournisseursDataBc.find(x => x.id === selectedId);

        if (f) {
          const nameEl = document.getElementById('fourNameBc');
          const emailEl = document.getElementById('fourEmailBc');
          const telEl = document.getElementById('fourTelBc');

          if (nameEl) {
            nameEl.value = f.name ?? '';
          }
          if (emailEl) {
            emailEl.value = f.email ?? '';
          }
          if (telEl) {
            telEl.value = f.tel ?? '';
          }
        }
      });
    } else {
      console.error('❌ Supplier select element not found!');
    }

    (function () {
      const chantierSelectEl = document.getElementById('chantierSelect');
      const label = document.getElementById('selectedChantiersLabel');
      if (!chantierSelectEl || !label) return;

      const getSelectedChantiers = () => {
        const selected = [];
        if (chantierSelectEl && chantierSelectEl.selectedOptions) {
          Array.from(chantierSelectEl.selectedOptions).forEach(o => {
            if (o.value) {
              selected.push({ id: o.value, name: o.textContent });
            }
          });
        }
        return selected;
      };

      const autoDistributeAll = () => {
        const selectedChantiers = getSelectedChantiers();
        if (selectedChantiers.length !== 1) return;
        
        const ch = selectedChantiers[0];
        const rows = document.querySelectorAll('#bcBody .bc-row');
        
        rows.forEach(row => {
          const qtyInput = row.querySelector('input[data-field="quantite"]');
          const priceInput = row.querySelector('input[data-field="prixUnitaire"]');
          const remiseInput = row.querySelector('input[data-field="remise"]');
          
          if (!qtyInput) return;
          
          const qty = parseFloat(qtyInput.value) || 0;
          if (qty <= 0) return;
          
          const pu = parseFloat((priceInput?.value || '0').toString().replace(/\s/g, '').replace(',', '.')) || 0;
          const rem = parseFloat((remiseInput?.value || '0').toString().replace(/\s/g, '').replace(',', '.')) || 0;
          const qtyNet = pu > 0 ? qty - (rem / pu) : qty;
          
          const dist = [{chantierId: ch.id, qty: qty, montant: qtyNet * pu}];
          row.dataset.distribution = JSON.stringify(dist);
          
          let badge = row.querySelector('.distribution-badge');
          if (!badge) {
            badge = document.createElement('span');
            badge.className = 'distribution-badge badge badge-success ml-2';
            const btn = row.querySelector('button[onclick*="openDistributionModal"]');
            if (btn) btn.parentNode.insertBefore(badge, btn.nextSibling);
          }
          badge.textContent = ch.name + ': ' + qty;
          
          if (typeof updateRowTotal === 'function') updateRowTotal(row);
        });
        
        if (typeof window.__recalcBcTotals === 'function') window.__recalcBcTotals();
      };

      // Expose for addBcRow to call
      window.__autoDistributeIfSingleChantier = autoDistributeAll;

      const updateLabel = () => {
        const selected = Array.from(chantierSelectEl.selectedOptions || []).map(o => (o.textContent || '').trim()).filter(Boolean);
        label.textContent = selected.length ? selected.join(', ') : 'Non renseigné';
        // Delay auto-distribute to ensure rows exist
        setTimeout(autoDistributeAll, 100);
      };

      // Run updateLabel after page loads and rows are created
      window.addEventListener('DOMContentLoaded', () => {
        setTimeout(() => {
          updateLabel();
        }, 200);
      });
      
      chantierSelectEl.addEventListener('change', updateLabel);
    })();

    (function () {
      let fournitureData = [];
      let activeInput = null;
      let activeType = null;
      let activeItems = [];
      let activeIndex = -1;

      const list = document.createElement('ul');
      list.id = 'bc-global-autocomplete-list';
      list.setAttribute('role', 'listbox');
      document.body.appendChild(list);

      const normalize = (v) => (v == null ? '' : String(v)).trim();
      const lower = (v) => normalize(v).toLowerCase();

      const getDesignation = (item) => normalize(item?.designation || item?.Designation || '');
      const getReference = (item) => normalize(item?.reference || item?.lot || item?.ref || item?.Reference || '');
      const getUnite = (item) => normalize(item?.unite || item?.unité || item?.Unite || item?.Unité || '');
      const getPrixUnitaire = (item) => {
        const raw = item?.prixUnitaire ?? item?.prix_unitaire ?? item?.prix ?? item?.PrixUnitaire;
        const cleaned = normalize(raw).replace(/\s/g, '').replace(',', '.');
        const n = parseFloat(cleaned);
        return Number.isFinite(n) ? n : null;
      };

      const fmtMoney = (n) => {
        const v = Number(n);
        if (!Number.isFinite(v)) return '';
        try {
          return v.toLocaleString('fr-FR', { minimumFractionDigits: 2, maximumFractionDigits: 2 });
        } catch (e) {
          return String(v.toFixed(2)).replace('.', ',');
        }
      };

      const isVisible = () => list.style.display === 'block';
      const hide = () => {
        list.style.display = 'none';
        activeItems = [];
        activeIndex = -1;
        activeType = null;
      };

      const positionList = (inputEl) => {
        const rect = inputEl.getBoundingClientRect();
        const scrollTop = window.pageYOffset || document.documentElement.scrollTop || 0;
        const scrollLeft = window.pageXOffset || document.documentElement.scrollLeft || 0;
        list.style.top = `${rect.bottom + scrollTop + 6}px`;
        list.style.left = `${rect.left + scrollLeft}px`;
        list.style.width = `${Math.max(rect.width, 220)}px`;
        list.style.display = 'block';
      };

      const setActiveIndex = (idx) => {
        activeIndex = idx;
        const items = Array.from(list.querySelectorAll('li[data-idx]'));
        items.forEach((li) => li.classList.remove('is-active'));
        const activeLi = items.find(li => parseInt(li.dataset.idx, 10) === activeIndex);
        if (activeLi) {
          activeLi.classList.add('is-active');
          try { activeLi.scrollIntoView({ block: 'nearest' }); } catch (e) { }
        }
      };

      const renderDesignation = (matches, query) => {
        list.innerHTML = '';
        activeType = 'designation';
        activeItems = matches;
        activeIndex = -1;

        if (!matches.length) {
          const li = document.createElement('li');
          li.className = 'is-disabled';
          const main = document.createElement('div');
          main.className = 'bc-suggest-main';
          main.textContent = query ? 'Aucune suggestion' : '';
          li.appendChild(main);
          list.appendChild(li);
          return;
        }

        matches.forEach((m, i) => {
          const li = document.createElement('li');
          li.dataset.idx = String(i);
          const d = getDesignation(m);
          const countRefs = fournitureData.filter(x => lower(getDesignation(x)) === lower(d) && getReference(x)).length;

          const main = document.createElement('div');
          main.className = 'bc-suggest-main';
          main.textContent = d;

          const sub = document.createElement('div');
          sub.className = 'bc-suggest-sub';
          sub.textContent = countRefs ? `${countRefs} référence${countRefs > 1 ? 's' : ''}` : 'Sans référence';

          li.appendChild(main);
          li.appendChild(sub);
          list.appendChild(li);
        });
      };

      const renderReference = (matches, query) => {
        list.innerHTML = '';
        activeType = 'reference';
        activeItems = matches;
        activeIndex = -1;

        if (!matches.length) {
          const li = document.createElement('li');
          li.className = 'is-disabled';
          const main = document.createElement('div');
          main.className = 'bc-suggest-main';
          main.textContent = query ? 'Aucune suggestion' : '';
          li.appendChild(main);
          list.appendChild(li);
          return;
        }

        matches.slice(0, 30).forEach((m, i) => {
          const li = document.createElement('li');
          li.dataset.idx = String(i);
          const main = document.createElement('div');
          main.className = 'bc-suggest-main';
          main.textContent = getReference(m) || '(Sans référence)';
          const unite = getUnite(m);
          const pu = getPrixUnitaire(m);
          const sub = document.createElement('div');
          sub.className = 'bc-suggest-sub';
          if (unite && pu != null) sub.textContent = `Unité: ${unite} · PU: ${fmtMoney(pu)}`;
          else if (unite) sub.textContent = `Unité: ${unite}`;
          else if (pu != null) sub.textContent = `PU: ${fmtMoney(pu)}`;
          else sub.textContent = '';
          li.appendChild(main);
          if (sub.textContent) li.appendChild(sub);
          list.appendChild(li);
        });
      };

      const selectCurrent = (idx) => {
        if (!activeInput) return;
        if (!activeItems || !activeItems.length) return;
        if (idx < 0 || idx >= activeItems.length) return;

        const tr = activeInput.closest('tr');
        const selected = activeItems[idx];
        if (!tr) return;

        if (activeType === 'designation') {
          const des = getDesignation(selected);
          activeInput.value = des;
          const refEl = tr.querySelector('input[data-field="reference"]');
          const uniteEl = tr.querySelector('input[data-field="unite"]');
          const puEl = tr.querySelector('input[data-field="prixUnitaire"]');
          if (refEl) refEl.value = '';
          if (uniteEl) uniteEl.value = '';
          if (puEl) puEl.value = '0,00';
          tr.dataset.bcDesignation = des;
          if (typeof window.__recalcBcTotals === 'function') window.__recalcBcTotals();
        } else if (activeType === 'reference') {
          const ref = getReference(selected);
          activeInput.value = ref;
          const uniteEl = tr.querySelector('input[data-field="unite"]');
          const desEl = tr.querySelector('input[data-field="designation"]');
          const puEl = tr.querySelector('input[data-field="prixUnitaire"]');
          const des = tr.dataset.bcDesignation || (desEl ? desEl.value : '');
          if (desEl && des && !normalize(desEl.value)) {
            desEl.value = des;
          }
          if (uniteEl) uniteEl.value = getUnite(selected);
          const pu = getPrixUnitaire(selected);
          if (puEl && pu != null) puEl.value = fmtMoney(pu);
          if (typeof window.__recalcBcTotals === 'function') window.__recalcBcTotals();
        }

        hide();
        try { activeInput.blur(); activeInput.focus(); } catch (e) { }
      };

      const updateDesignationSuggestions = (inputEl) => {
        const val = lower(inputEl.value);
        list.innerHTML = '';
        if (!val) {
          hide();
          return;
        }

        const seen = new Set();
        const matches = [];
        for (const item of fournitureData) {
          const d = getDesignation(item);
          const dl = lower(d);
          if (!d) continue;
          if (dl.includes(val) && !seen.has(dl)) {
            seen.add(dl);
            matches.push(item);
          }
          if (matches.length >= 25) break;
        }

        renderDesignation(matches, val);
        positionList(inputEl);
      };

      const updateReferenceSuggestions = (inputEl) => {
        const tr = inputEl.closest('tr');
        if (!tr) {
          hide();
          return;
        }
        const desEl = tr.querySelector('input[data-field="designation"]');
        const designation = normalize(tr.dataset.bcDesignation || (desEl ? desEl.value : ''));
        if (!designation) {
          hide();
          return;
        }

        const val = lower(inputEl.value);
        const matches = fournitureData
          .filter(item => lower(getDesignation(item)) === lower(designation))
          .filter(item => lower(getReference(item)).includes(val));

        renderReference(matches, val);
        positionList(inputEl);
      };

      list.addEventListener('mousedown', (e) => {
        const t = e.target;
        const inList = t && (t === list || (t.closest && t.closest('#bc-global-autocomplete-list')));
        const inInput = t && (t.closest && t.closest('input[data-field="designation"], input[data-field="reference"]'));
        if (!inList && !inInput) {
          hide();
        }
      });

      list.addEventListener('click', (e) => {
        const li = e.target && e.target.closest ? e.target.closest('li[data-idx]') : null;
        if (!li) return;
        const idx = parseInt(li.dataset.idx, 10);
        if (Number.isNaN(idx)) return;
        selectCurrent(idx);
      });

      document.addEventListener('focusin', (e) => {
        const t = e.target;
        if (!(t instanceof HTMLElement)) return;
        if (t.matches && t.matches('input[data-field="designation"], input[data-field="reference"]')) {
          activeInput = t;
          if (t.getAttribute('data-field') === 'designation') {
            updateDesignationSuggestions(t);
          } else {
            updateReferenceSuggestions(t);
          }
        }
      });

      document.addEventListener('input', (e) => {
        const t = e.target;
        if (!(t instanceof HTMLElement)) return;
        if (t.matches && t.matches('input[data-field="designation"]')) {
          activeInput = t;
          const tr = t.closest('tr');
          if (tr) {
            tr.dataset.bcDesignation = '';
            const refEl = tr.querySelector('input[data-field="reference"]');
            const uniteEl = tr.querySelector('input[data-field="unite"]');
            const puEl = tr.querySelector('input[data-field="prixUnitaire"]');
            if (refEl && normalize(refEl.value)) refEl.value = '';
            if (uniteEl && normalize(uniteEl.value)) uniteEl.value = '';
            if (puEl && normalize(puEl.value) && normalize(puEl.value) !== '0,00') puEl.value = '0,00';
            if (typeof window.__recalcBcTotals === 'function') window.__recalcBcTotals();
          }
          updateDesignationSuggestions(t);
        }
        if (t.matches && t.matches('input[data-field="reference"]')) {
          activeInput = t;
          updateReferenceSuggestions(t);
        }
      });

      document.addEventListener('keydown', (e) => {
        if (!activeInput) return;
        if (!isVisible()) return;
        if (!activeItems || !activeItems.length) return;

        if (e.key === 'ArrowDown') {
          e.preventDefault();
          const next = Math.min(activeItems.length - 1, activeIndex + 1);
          setActiveIndex(next);
          return;
        }
        if (e.key === 'ArrowUp') {
          e.preventDefault();
          const prev = Math.max(0, activeIndex - 1);
          setActiveIndex(prev);
          return;
        }
        if (e.key === 'Enter') {
          if (activeIndex >= 0) {
            e.preventDefault();
            selectCurrent(activeIndex);
          }
          return;
        }
        if (e.key === 'Escape') {
          e.preventDefault();
          hide();
          return;
        }
      });

      document.addEventListener('mousedown', (e) => {
        const t = e.target;
        const inList = t && (t === list || (t.closest && t.closest('#bc-global-autocomplete-list')));
        const inInput = t && (t.closest && t.closest('input[data-field="designation"], input[data-field="reference"]'));
        if (!inList && !inInput) {
