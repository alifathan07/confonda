    function updateMontantEnLettres(totalTtc) {
      const displayEl = document.getElementById('montantLettresValue');
      const inputEl = document.getElementById('montantLettresInp');

      // Si un des éléments manque ou total invalide → on vide tout
      if (!displayEl || !inputEl || totalTtc == null || isNaN(totalTtc)) {
        displayEl.textContent = '—';
        inputEl.value = '';
        return;
      }

      // Arrondi propre à 2 décimales
      const rounded = Math.round((totalTtc + Number.EPSILON) * 100) / 100;
      const dirhams = Math.floor(rounded);
      const centimes = Math.round((rounded - dirhams) * 100);

      const dirhamsText = bcNumberToFrenchWords(dirhams).toUpperCase();
      const centimesText = bcNumberToFrenchWords(centimes).toUpperCase();

      let result = `${dirhamsText} DIRHAM${dirhams !== 1 ? 'S' : ''}`;

      if (centimes > 0) {
        result += ` ET ${centimesText} CENTIME${centimes !== 1 ? 'S' : ''}`;
      } else {
        result += ' ET ZÉRO CENTIMES';
      }

      // Mise à jour affichage + champ caché
      displayEl.textContent = result;
      inputEl.value = result; // ← Là, ton input name="montantLettres" est bien rempli !
    }

    (function () {
      const totalHtEl = document.getElementById('totalHtValue');
      if (!totalHtEl) return;

      const tvaInput = document.getElementById('tvaInput');
      const totalTtcEl = document.getElementById('totalTtcValue');

      const montantTvaEl = document.getElementById('montantTvaValue');


      const formatNumber = (value) => {
        return value.toLocaleString('fr-FR', {
          minimumFractionDigits: 2,
          maximumFractionDigits: 2,
        });
      };

      const recalc = () => {
        // 1) Recalculate line totals (base), line remise (amount per line) and Total HT from inputs in the table
        let rawTotalHt = 0;
        let totalRemise = 0;
        const rows = document.querySelectorAll('.bc-row');

        rows.forEach((tr) => {
          const cells = tr.cells;
          const qtyInput = tr.querySelector('input[data-field="quantite"]');
          const priceInput = tr.querySelector('input[data-field="prixUnitaire"]');
          const priceAfterRemiseInput = tr.querySelector('input[data-field="prixUnitaireRemise"]');
          const remiseInputRow = tr.querySelector('input[data-field="remise"]');
          const totalEl = tr.querySelector('[data-field="totalHt"]');

          if (!qtyInput || !priceInput || !totalEl) return;

          const qtyText = (qtyInput.value || '')
            .trim()
            .replace(/[^0-9.,-]/g, '')
            .replace(/\s/g, '')
            .replace(',', '.');

          const priceText = (priceInput.value || '')
            .trim()
            .replace(/[^0-9.,-]/g, '')
            .replace(/\s/g, '')
            .replace(',', '.');

          const q = parseFloat(qtyText || '0') || 0;
          const p = parseFloat(priceText || '0') || 0;
          const lineBase = q * p;

          let remisePctRow = 0;
          if (remiseInputRow) {
            remisePctRow = parseFloat((remiseInputRow.value || '').toString().replace(',', '.')) || 0;
            if (isNaN(remisePctRow) || remisePctRow < 0) remisePctRow = 0;
          }
          const lineRemise = lineBase * remisePctRow / 100;
          const lineNet = lineBase - lineRemise;

          const puRemise = p * (1 - (remisePctRow / 100));
          if (priceAfterRemiseInput) {
            priceAfterRemiseInput.value = formatNumber(puRemise);
          }

          // Keep saved distribution montants in sync with current PU/remise (qty stays the same)
          if (tr.dataset.distribution) {
            try {
              const dist = JSON.parse(tr.dataset.distribution);
              if (Array.isArray(dist)) {
                const updated = dist.map(d => {
                  const qtyDist = parseFloat((d && d.qty != null ? d.qty : 0).toString()) || 0;
                  return {
                    chantierId: d.chantierId,
                    qty: qtyDist,
                    montant: qtyDist * puRemise
                  };
                });
                tr.dataset.distribution = JSON.stringify(updated);
              }
            } catch (e) { }
          }

          rawTotalHt += lineBase;
          totalRemise += lineRemise;

          const netText = formatNumber(lineNet);
          totalEl.textContent = netText;

          // store for distribution calculations
          tr.dataset.lineBase = String(lineBase);
          tr.dataset.lineRemise = String(lineRemise);
          tr.dataset.lineNet = String(lineNet);
        });

        // Update Total HT display element (sum of per-line nets)
        const totalNetHt = rawTotalHt - totalRemise; // rawTotalHt was sum of base (we can compute from dataset)
        totalHtEl.setAttribute('data-total-ht', totalNetHt);
        totalHtEl.textContent = formatNumber(totalNetHt);

        // 2) Recalculate TVA / TTC from per-line net values
        let tva = parseFloat((tvaInput.value || '').replace(',', '.'));
        if (isNaN(tva) || tva < 0) tva = 0;

        const montantTva = totalNetHt * tva / 100;
        const totalTtc = totalNetHt + montantTva;

        if (montantTvaEl) {
          montantTvaEl.textContent = formatNumber(montantTva);
        }
        if (totalTtcEl) {
          totalTtcEl.textContent = formatNumber(totalTtc);
        }

        // 3) Mettre à jour le montant en lettres basé sur le TTC
        updateMontantEnLettres(totalTtc);
      };

      // Recompute when TVA changes
      if (tvaInput) tvaInput.addEventListener('input', recalc);

      // Recompute when quantity, price or per-row remise inputs change
      const editableCells = document.querySelectorAll('input[data-field="quantite"], input[data-field="prixUnitaire"], input[data-field="remise"]');
      editableCells.forEach((el) => {
        el.addEventListener('input', recalc);
      });

      // Expose recalc globally so addBcRow can reuse it for new lines
      window.__recalcBcTotals = recalc;

      // Initial line + calculation to sync with current values
      addBcRow();
      recalc();
    })();
    function openDistributionModal(button) {
      const row = button.closest('tr');
      if (typeof window.__recalcBcTotals === 'function') window.__recalcBcTotals();
      // Resolve total quantity with multiple fallbacks (input, data-field cell, or text)
      let totalQty = 0;
      const totalQtyInput = row.querySelector('input[data-field="quantite"].item-total-qty') || row.querySelector('input[data-field="quantite"]') || row.querySelector('.item-total-qty');
      if (totalQtyInput) {
        const raw = (totalQtyInput.value || '').toString().trim();
        const cleaned = raw.replace(/\s/g, '').replace(/,/g, '.');
        totalQty = parseFloat(cleaned) || 0;
      } else {
        const qtyCell = row.querySelector('[data-field="quantite"]');
        if (qtyCell) {
          const raw = (qtyCell.textContent || '').toString().trim();
          const cleaned = raw.replace(/\s/g, '').replace(/,/g, '.');
          totalQty = parseFloat(cleaned) || 0;
        }
      }

      // Get discounted Unit Price from the row (prixUnitaireRemise) if available.
      // Fallback: compute it from prixUnitaire and taux de remise.
      const priceAfterRemiseInput = row.querySelector('input[data-field="prixUnitaireRemise"]');
      const rawPriceAfterRemise = (priceAfterRemiseInput && priceAfterRemiseInput.value ? priceAfterRemiseInput.value : '').toString().trim().replace(/[^0-9.,-]/g, '').replace(/\s/g, '').replace(',', '.');
      let unitPriceRemise = parseFloat(rawPriceAfterRemise || '0') || 0;
      if (!unitPriceRemise) {
        const priceInput = row.querySelector('input[data-field="prixUnitaire"]');
        const remiseInputRow = row.querySelector('input[data-field="remise"]');
        const rawPrice = (priceInput && priceInput.value ? priceInput.value : '').toString().trim().replace(/[^0-9.,-]/g, '').replace(/\s/g, '').replace(',', '.');
        const unitPrice = parseFloat(rawPrice || '0') || 0;
        const remisePctRow = parseFloat((remiseInputRow?.value || '0').toString().replace(',', '.')) || 0;
        unitPriceRemise = unitPrice * (1 - (Math.max(0, remisePctRow) / 100));
      }
      if (totalQty <= 0) {
        alert('Veuillez d\'abord entrer une quantité totale pour cet article.');
        return;
      }

      // Get selected chantiers (support Choices.js, native select, or fallback to checkboxes)
      const selectedChantiers = [];
      const chantierSelectEl = document.getElementById('chantierSelect');
      if (typeof window.chantierChoices !== 'undefined' && chantierSelectEl) {
        const vals = window.chantierChoices.getValue(true);
        vals.forEach(v => {
          const opt = chantierSelectEl.querySelector(`option[value="${v}"]`);
          selectedChantiers.push({ id: v, name: opt ? opt.textContent : String(v) });
        });
      } else if (chantierSelectEl) {
        Array.from(chantierSelectEl.selectedOptions).forEach(o => {
          selectedChantiers.push({ id: o.value, name: o.textContent });
        });
      } else {
        document.querySelectorAll('.chantier-checkbox:checked').forEach(cb => {
          selectedChantiers.push({ id: cb.value, name: cb.dataset.chantierName });
        });
      }
      if (selectedChantiers.length === 0) {
        alert('Veuillez sélectionner au moins un chantier.');
        return;
      }

      // Auto-fill if only ONE chantier selected
      if (selectedChantiers.length === 1) {
        const ch = selectedChantiers[0];
        const pu = parseFloat((row.querySelector('.price-input')?.value || '0').toString().replace(/\s/g, '').replace(',', '.')) || 0;
        const qty = parseFloat(row.querySelector('.qty-input')?.value) || 0;
        const rem = parseFloat((row.querySelector('.remise-input')?.value || '0').toString().replace(/\s/g, '').replace(',', '.')) || 0;
        const qtyNet = pu > 0 ? qty - (rem / pu) : qty;
        
        const dist = [{chantierId: ch.id, qty: qty, montant: qtyNet * pu}];
        row.dataset.distribution = JSON.stringify(dist);
        updateRowTotal(row);
        
        let badge = row.querySelector('.distribution-badge');
        if (!badge) {
          badge = document.createElement('span');
          badge.className = 'distribution-badge badge badge-success ml-2';
          row.querySelector('.affect-btn').appendChild(badge);
        }
        badge.textContent = ch.name + ': ' + qty;
        return;
      }

      // [NEW] Load existing distribution data if available
      let existingData = [];
      try {
        if (row.dataset.distribution) {
          existingData = JSON.parse(row.dataset.distribution);
        }
      } catch (e) { console.error("Error parsing distribution data", e); }
      // Build modal content
      let modalHTML = `
    <div class="modal fade" id="distributionModal" tabindex="-1">
      <div class="modal-dialog modal-lg">
        <div class="modal-content">
          <div class="modal-header">
            <h5 class="modal-title">Distribution des quantités</h5>
            <button type="button" class="close" data-dismiss="modal">&times;</button>
