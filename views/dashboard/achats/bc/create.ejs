                <tr>
                  <th>Chantier</th>
                  <th>Quantité</th>
                  <th>Montant</th>
                </tr>
              </thead>
              <tbody id="distributionTableBody">
  `;
      let totalAllocatedInit = 0;
      selectedChantiers.forEach(ch => {
        // [NEW] Find existing values for this chantier
        const saved = existingData.find(d => d.chantierId === ch.id);
        const qtyVal = saved ? saved.qty : 0;
        const montantVal = saved ? saved.montant : 0;

        totalAllocatedInit += parseFloat(qtyVal) || 0;
        modalHTML += `
