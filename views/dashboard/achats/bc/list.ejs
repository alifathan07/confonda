<!DOCTYPE html>
<html lang="fr">

<head>
  <meta charset="UTF-8">
  <title>Liste des Bon de Commande</title>
  <link href="/vendor/bootstrap/css/bootstrap.min.css" rel="stylesheet">
  <link href="/vendor/fontawesome-free/css/all.min.css" rel="stylesheet">
  <link href="/css/sb-admin-2.min.css" rel="stylesheet">


  <style>
    /* Tableau compact et propre */
    #dpTable {
      font-size: 0.9rem;
    }

    #dpTable th,
    #dpTable td {
      padding: 0.5rem 0.75rem !important;
      vertical-align: middle;
    }

    #dpTable th {
      background-color: #f8f9fa;
      font-weight: 600;
      text-align: center;
    }

    /* Largeurs fixes pour chaque colonne */
    #dpTable th:nth-child(1),
    #dpTable td:nth-child(1) {
      width: 80px;
      text-align: center;
    }

    /* Numéro */
    #dpTable th:nth-child(2),
    #dpTable td:nth-child(2) {
      width: 110px;
      text-align: center;
    }

    /* Date */
    #dpTable th:nth-child(3),
    #dpTable td:nth-child(3) {
      width: 220px;
    }

    /* Fournisseur */
    #dpTable th:nth-child(4),
    #dpTable td:nth-child(4) {
      width: 90px;
      text-align: center;
    }

    /* Articles */
    #dpTable th:nth-child(5),
    #dpTable td:nth-child(5) {
      width: 260px;
      text-align: center;
    }

    /* Actions */

    /* Boutons plus petits et alignés */
    .btn-group .btn {
      font-size: 0.8rem;
      padding: 0.25rem 0.5rem;
    }

    /* Icônes seules sur petits boutons pour gagner de la place */
    @media (max-width: 768px) {
      .btn-group .btn .fas {
        margin-right: 0 !important;
      }

      .btn-group .btn span.d-none.d-md-inline {
        display: none !important;
      }
    }

    /* Sticky header propre */
    #dpTable thead th {
      position: sticky;
      top: 0;
      z-index: 10;
      background: #f8f9fa !important;
    }

    /* Chantier list: keep badges on one line, truncate long names */
    .chantier-list {
      display: flex;
      gap: .4rem;
      align-items: center;
      flex-wrap: nowrap;
      overflow: hidden;
    }

    .chantier-list .badge {
      flex: 0 0 auto;
      white-space: nowrap;
      overflow: hidden;
      text-overflow: ellipsis;
      max-width: 160px;
      display: inline-block;
    }

    .chantier-list .chantier-name {
      display: inline-block;
      vertical-align: middle;
      max-width: 120px;
      overflow: hidden;
      text-overflow: ellipsis;
      white-space: nowrap;
    }

    .chantier-more {
      margin-left: .25rem;
      color: #6b7280;
    }
  </style>
</head>

<body id="page-top">
  <div id="wrapper">
    <%- include('../../../layouts/sidebar') %>
      <div id="content-wrapper" class="d-flex flex-column">
        <div id="content">
          <%- include('../../../layouts/topbar') %>
            <div class="container-fluid">

              <div class="card shadow mb-4">
                <div class="card-header py-3 d-flex align-items-center justify-content-between">
                  <h6 class="m-0 font-weight-bold text-primary">Liste des Bon de Commandes</h6>
                  <div class="d-flex" style="gap:10px;">
                    <button id="downloadPdfBtn" class="btn btn-success btn-sm">
                      <i class="fas fa-file-pdf"></i> <span class="d-none d-md-inline">PDF</span>
                    </button>
                    <button id="downloadExcelBtn" class="btn btn-outline-success btn-sm">
                      <i class="fas fa-file-excel"></i> <span class="d-none d-md-inline">Excel</span>
                    </button>
                    <form action="/achat/bc/import" method="POST" enctype="multipart/form-data" class="d-flex"
                      style="gap:8px; align-items:center;">
                      <input type="file" name="excelFile" accept=".xlsx,.xls" class="form-control form-control-sm"
                        style="max-width: 220px;" required>
                      <button type="submit" class="btn btn-info btn-sm">
                        <i class="fas fa-upload"></i> <span class="d-none d-md-inline">Importer Excel</span>
                      </button>
                    </form>
                    <a href="/achat/bc/create" class="btn btn-modern btn-primary">Créer un bon de commande</a>
                  </div>
                </div>

                <div class="card-body">

                  <div class="table-responsive">
                    <table id="dpTable" class="table table-bordered table-sm table-hover">
                      <thead class="thead-light">
                        <tr>
                          <th>Numéro</th>
                          <th>Date</th>
                          <th>Fournisseur</th>
                          <th>Chantiers</th>
                          <th>Articles</th>
                          <th>Actions</th>
                        </tr>
                      </thead>
                      <tbody>
                        <% if (!bc || bc.length===0) { %>
                          <tr>
                            <td colspan="6" class="text-center text-muted">Aucun Bon de commande disponible.</td>
                          </tr>
                          <% } else { %>
                            <% bc.forEach(dp=> { %>
                              <tr data-id="<%= dp.id %>">
                                <td class="font-weight-bold" data-order="<%= dp.id %>">
                                  <%= dp.numero %>
                                </td>
                                <td>
                                  <%= new Date(dp.date).toLocaleDateString('fr-FR', { day: '2-digit' , month: '2-digit'
                                    , year: 'numeric' }) %>
                                </td>
                                <td>
                                  <div><strong>
                                      <%= dp.fournisseur?.name || '—' %>
                                    </strong></div>
                                  <% if (dp.fournisseur && dp.fournisseur.ville) { %>
                                    <small class="text-muted">
                                      <%= dp.fournisseur.ville %>
                                    </small>
                                    <% } %>
                                </td>
                                <td>
                                  <% // Collect unique chantier names from commandesItems -> BondeCommandeChantierItem
                                    const chantierSet = new Set();
                                    (dp.commandesItems || []).forEach(item => {
                                    (item.BondeCommandeChantierItem || []).forEach(bcci => {
                                    if (bcci && bcci.chantier && bcci.chantier.nom) chantierSet.add(bcci.chantier.nom);
                                    });
                                    });
                                    const chantierList = Array.from(chantierSet).slice(0,3);
                                    const fullChantiers = Array.from(chantierSet).join(', ');
                                    %>
                                    <div class="chantier-list" title="<%= fullChantiers %>">
                                      <% if (chantierList.length===0) { %>
                                        <span class="text-muted">—</span>
                                        <% } else { %>
                                          <% chantierList.forEach(function(cn){ %>
                                            <span class="badge badge-light border"><i class="fas fa-hard-hat"></i> <span
                                                class="chantier-name">
                                                <%= cn %>
                                              </span></span>
                                            <% }); %>
                                              <% if (chantierSet.size> 3) { %>
                                                <small class="chantier-more">+<%= chantierSet.size - 3 %> autres</small>
                                                <% } %>
                                                  <% } %>
                                    </div>
                                </td>
                                <td class="text-center"><span class="badge badge-info">
                                    <%= Array.isArray(dp.commandesItems) ? dp.commandesItems.length : 0 %>
                                  </span></td>
                                <td>
                                  <div class="btn-group btn-group-sm" role="group">

                                    <a href="/achat/bc/<%= dp.id %>/edit" class="btn btn-warning" title="Éditer">
                                      <i class="fas fa-edit"></i>
                                    </a>
                                    <button class="btn btn-danger" title="PDF" onclick="downloadPDF(<%= dp.id %>)">
                                      <i class="fas fa-file-pdf"></i>
                                    </button>
                                    <button class="btn btn-outline-danger" title="Supprimer"
                                      onclick="deletebc(<%= dp.id %>, this)">
                                      <i class="fas fa-trash"></i>
                                    </button>
                                  </div>
                                </td>
                              </tr>
                              <% }) %>
                                <% } %>
                      </tbody>
                    </table>
                  </div>
                </div>
              </div>
            </div>
        </div>

        <!-- Scripts (inchangés sauf petite amélioration Excel) -->
        <script src="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/5.15.4/js/all.min.js"></script>
        <script src="https://cdnjs.cloudflare.com/ajax/libs/jspdf/2.5.1/jspdf.umd.min.js"></script>
        <script
          src="https://cdnjs.cloudflare.com/ajax/libs/jspdf-autotable/3.8.3/jspdf.plugin.autotable.min.js"></script>
        <script src="https://cdnjs.cloudflare.com/ajax/libs/xlsx/0.18.5/xlsx.full.min.js"></script>

        <script>
          // Ensure jsPDF + autotable are available; load from CDN if needed
          function loadPdfLibs() {
            return new Promise((resolve, reject) => {
              if (window.jspdf && window.jspdf.jsPDF && window.jspdf?.autoTable) return resolve();
              const add = (src, onload) => { const s = document.createElement('script'); s.src = src; s.defer = true; s.onload = onload; s.onerror = reject; document.head.appendChild(s); };
              const afterJsPdf = () => add('https://cdnjs.cloudflare.com/ajax/libs/jspdf-autotable/3.8.3/jspdf.plugin.autotable.min.js', () => resolve());
              if (!(window.jspdf && window.jspdf.jsPDF)) add('https://cdnjs.cloudflare.com/ajax/libs/jspdf/2.5.1/jspdf.umd.min.js', afterJsPdf); else afterJsPdf();
            });
          }



          async function deletebc(id, btn) {
            if (!confirm('Confirmer la suppression du bon de commande #' + id + ' ?')) return;
            const original = btn.innerHTML;
            btn.disabled = true; btn.innerHTML = '<i class="fas fa-spinner fa-spin"></i>';
            try {
              const res = await fetch(`/achat/bc/${id}`, { method: 'DELETE' });
              const json = await res.json().catch(() => ({}));
              if (!res.ok || !json.success) { throw new Error(json.error || 'Suppression échouée'); }
              const tr = btn.closest('tr');
              if (tr) { tr.remove(); }
            } catch (e) {
              alert(e.message || 'Erreur serveur');
              btn.disabled = false; btn.innerHTML = original;
            }
          }




          async function downloadPDF(id) {
            try {
              const res = await fetch(`/achat/bc/${id}/pdf`);
              if (!res.ok) throw new Error('Erreur lors du téléchargement');
              const blob = await res.blob();
              const url = URL.createObjectURL(blob);
              const link = document.createElement('a');
              link.href = url;
              link.download = `bondeCommande_${id}.pdf`;
              document.body.appendChild(link);
              link.click();
              link.remove();
              URL.revokeObjectURL(url);
            } catch (err) {
              console.error(err);
              alert('Erreur lors du téléchargement du PDF');
            }
          }




        </script>


        <script src="/vendor/jquery/jquery.min.js"></script>
        <script src="/vendor/bootstrap/js/bootstrap.bundle.min.js"></script>
        <script src="/vendor/jquery-easing/jquery.easing.min.js"></script>

        <script src="/js/sb-admin-2.min.js"></script>

        <script>
          // Data snapshot for robust exports (fallback if DOM/DataTables retrieval fails)
          window.__DP_ROWS__ = (<% - JSON.stringify((bc || []).map(dp => ({
            id: `#${dp.id}`,
            date: new Date(dp.date).toLocaleDateString('fr-FR', { day: '2-digit', month: '2-digit', year: 'numeric' }),
            fournisseur: (dp.fournisseur && dp.fournisseur.name) ? dp.fournisseur.name : '—',
            articles: Array.isArray(dp.articles) ? String(dp.articles.length) : '0'
          })), null, 2) %>);

          // No DataTables: simple table, exports work over DOM rows
        </script>
      </div>
  </div>
</body>

</html>