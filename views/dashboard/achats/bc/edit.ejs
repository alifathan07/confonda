    }

    .table-doc thead th {
      background: var(--blue);
      color: white;
      padding: 0.9rem 0.8rem;
      text-align: left;
      font-weight: 600;
      font-size: 0.78rem;
      text-transform: uppercase;
      letter-spacing: 0.8px;
      border: 1px solid #dee2e6;
    }

    .table-doc tbody td {
      padding: 1rem 0.8rem;
      border-bottom: 1px solid #eef1f5;
      vertical-align: middle;
    }

    .table-doc tbody tr:nth-child(even) {
      background: #f9fafb;
    }

    .table-doc tbody tr:hover {
      background: var(--blue-light);
    }

    .num-circle {
      background: var(--blue);
      color: white;
      width: 32px;
      height: 32px;
      border-radius: 50%;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      font-weight: 700;
      font-size: 0.95rem;
    }

    .qty-pill {
      background: #e2e8f0;
      color: #1e293b;
      padding: 0.4rem 0.9rem;
      border-radius: 50px;
      font-weight: 700;
      font-size: 0.9rem;
    }

    .observation {
      font-size: 0.82rem;
      color: #64748b;
      font-style: italic;
      margin-top: 5px;
    }

    .montant-lettres-box {
      background: #f8fbff;
      border-radius: 12px;
      border: 1px solid #dbeafe;
      padding: 1rem 1.25rem;
      display: flex;
      align-items: flex-start;
      gap: 8px;
      font-size: 0.9rem;
    }

    .montant-lettres-label {
      font-weight: 600;
      color: #1e3a8a;
      white-space: nowrap;
    }

    .montant-lettres-value {
      font-style: italic;
      color: #111827;
    }

    /* Signature */
    .signature-area {
      padding: 2.5rem 2rem;
      background: #f8fbff;
      border-top: 1px solid #dee2e6;
    }

    .signature-grid {
      display: grid;
      grid-template-columns: 1fr;
      gap: 2rem;
      margin-top: 1.5rem;
    }

    @media (min-width: 640px) {
      .signature-grid {
        grid-template-columns: 1fr 1fr;
      }
    }

    .sig-box {
      text-align: center;
      padding: 1.8rem;
      border: 2px dashed #c3d4e9;
      border-radius: 16px;
      background: white;
    }

    .sig-box h6 {
      color: var(--gray-600);
      font-weight: 600;
      text-transform: uppercase;
      letter-spacing: 1px;
      font-size: 0.82rem;
      margin-bottom: 1.5rem;
    }

    .sig-line {
      height: 80px;
      border-bottom: 3px solid #e2e8f0;
      margin: 1.2rem 0;
    }

    /* Mobile adjustments */
    @media (max-width: 576px) {
      .action-bar {
        padding: 1rem;
      }

      .action-bar h1 {
        font-size: 1.2rem;
      }

      .btn-modern {
        padding: 0.6rem 1rem;
        font-size: 0.8rem;
      }

      .doc-header {
        padding: 2rem 1.5rem;
      }

      .logo-title h1 {
        font-size: 1.7rem;
      }

      .table-section {
        padding: 1.5rem;
      }

      .fournisseur-box {
        padding: 1.2rem;
      }

      .info-line {
        font-size: 0.88rem;
      }
    }

    /* NEW: Additional info section for User & Chantier */
    .additional-info {
      padding: 1.5rem 2rem;
      background: #f8fbff;
      border-bottom: 1px solid #dee2e6;
    }

    .additional-info-grid {
      display: grid;
      grid-template-columns: 1fr;
      gap: 1.5rem;
    }

    @media (min-width: 768px) {
      .additional-info-grid {
        grid-template-columns: 1fr 1fr;
      }
    }

    .info-box {
      background: white;
      border: 2px solid #e2e8f0;
      border-radius: 12px;
      padding: 1.2rem;
    }

    .info-box h6 {
      color: var(--blue);
      font-weight: 700;
      font-size: 0.95rem;
      margin-bottom: 0.8rem;
      display: flex;
      align-items: center;
      gap: 8px;
    }

    .bc-extra-grid {
      display: flex;
      flex-direction: column;
      gap: 14px;
    }

    @media (min-width: 992px) {
      .bc-extra-grid {
        flex-direction: row;
        align-items: stretch;
      }
    }

    .bc-extra-field {
      flex: 0 0 320px;
      min-width: 260px;
      background: var(--blue-light);
      border: 1px solid #dbeafe;
      border-radius: 12px;
      padding: 0.9rem;
    }

    .bc-extra-label {
      font-weight: 800;
      color: #1e3a8a;
      font-size: 0.85rem;
      margin-bottom: 0.45rem;
      text-transform: uppercase;
      letter-spacing: 0.6px;
    }

    .bc-extra-input {
      border-radius: 10px !important;
      border: 1px solid #cfd6df;
      box-shadow: none !important;
    }
  </style>
</head>

<body>

  <div id="wrapper">
    <%- include('../../../layouts/sidebar') %>
      <div id="content-wrapper" class="d-flex flex-column">
        <div id="content">
          <%- include('../../../layouts/topbar') %>
            <div class="container-fluid px-3 px-md-4">

              <!-- Action Bar -->
              <div class="action-bar no-print">
                <div
                  class="d-flex flex-column flex-md-row justify-content-between align-items-start align-items-md-center gap-2">
                  <h1 style="font-size: 1.2rem;">
                    <i class="fas fa-file-invoice-dollar"></i> Bon de Commande
                    <span class="badge">#<%= bc.numero || bc.id %></span>
                  </h1>
                  <div class="d-flex flex-wrap gap-1">
                    <button onclick="sendEmail()" class="btn btn-sm btn-modern btn-send d-flex align-items-center gap-1"
                      id="btnSend">
                      <i class="fas fa-paper-plane"></i> <span>Envoyer</span>
                    </button>
                    <button class="btn btn-sm btn-modern btn-outline d-flex align-items-center gap-1" title="PDF"
                      onclick="downloadPDF(<%= bc.id %>)">
                      <i class="fas fa-file-pdf"></i> <span>PDF</span>
                    </button>
                    <button id="btnSaveBc" class="btn btn-sm btn-modern btn-save d-flex align-items-center gap-1"
                      title="Sauvegarder les modifications">
                      <i class="fas fa-save"></i> <span>Sauvegarder</span>
                    </button>
                  </div>
                </div>
              </div> <!-- Close action-bar div -->
              <!-- Document -->
              <div class="doc-card">

                <div class="doc-header">
                  <div class="topline">
                    <div class="brand-title">
                      <img src="/img/logo-4.png" alt="Logo" class="logo-img" />
                      <div class="brand-sep"></div>
                      <div>
                        <div class="brand-name">Construction et Fondation</div>
                        <div class="brand-sub">Pour des constructions bien fondées
</div>
                      </div>
                    </div>
                    <div style="font-weight:800; color:#b45309; font-size: 1.05rem;"></div>
                  </div>

                  <div class="header-grid">
                    <div class="fournisseur-box">
                      <input type="date" name="date" value="<%= new Date(bc.date).toISOString().slice(0,10) %>" hidden>
                      <div class="meta-grid">
                        <div class="meta-item"><strong>BC N° :</strong><%= bc.numero || bc.id %></div>
                        <br>
                        <div class="meta-item"><strong>Date :</strong> <%= new Date(bc.date).toLocaleDateString('fr-FR', { day: '2-digit', month: '2-digit', year: 'numeric' }) %></div>
                      </div>
                    </div>

                    <div class="qr-box">
                      <div style="text-align:center;">
                        <img
                          src="https://api.qrserver.com/v1/create-qr-code/?size=180x180&data=<%= encodeURIComponent(publicBcUrl || '') %>"
                          alt="QR Code"
                        />
                      </div>
                    </div>

                    <div class="fournisseur-box">
                      <h5 class="mb-3"><i class="fas fa-building"></i> Fournisseur</h5>
                      <select id="fournisseurSelectBc" class="form-control mb-3" name="supplier">
                        <option value="">-- Choisir un fournisseur --</option>
                        <% fournisseurs.forEach(f=> { %>
                          <option value="<%= f.id %>" <%=f.id===bc.fournisseur.id ? 'selected' : '' %>><%= f.name %>
                              <%= f.ville ? '- ' + f.ville : '' %>
                          </option>
                          <% }) %>
                      </select>
                      <div class="small">
                        <div class="info-line"><i class="fas fa-user-tie"></i> <strong id="fourNameBc">
                            <%= bc.fournisseur.name %>
                          </strong></div>
                        <div class="info-line"><i class="fas fa-envelope"></i> <span id="fourEmailBc">
                            <%= bc.fournisseur.email %>
                          </span></div>
                        <div class="info-line"><i class="fas fa-phone"></i> <span id="fourTelBc">
                            <%= bc.fournisseur.telFournisseur || 'Non renseigné' %>
                          </span></div>
                      </div>
                    </div>
                  </div>
                </div>

                <div class="row mt-3">
                  <div class="col-12 col-lg-6 mb-3 mb-lg-0">
                    <div class="fournisseur-box">
                      <h5 class="mb-3"><i class="fas fa-wallet"></i> Règlement</h5>
                      <div class="bc-extra-grid">
                        <div class="bc-extra-field" style="flex: 1 1 320px;">
                          <div class="bc-extra-label">Mode de règlement</div>
                          <select id="modeReglement" name="modeReg" class="form-control bc-extra-input">
                            <option value="">-- Choisir --</option>
                            <option value="virement" <%= bc.modeReg === 'virement' ? 'selected' : '' %>>Virement</option>
                            <option value="cheque" <%= bc.modeReg === 'cheque' ? 'selected' : '' %>>Chèque</option>
                            <option value="effets" <%= bc.modeReg === 'effets' ? 'selected' : '' %>>Effets</option>
                          </select>
                        </div>

                        <div class="bc-extra-field" style="flex: 1 1 320px;">
                          <div class="bc-extra-label">Délais de règlement</div>
                          <select id="delaisReglement" name="delaiReg" class="form-control bc-extra-input">
                            <option value="">-- Choisir --</option>
                            <option value="a_vue" <%= bc.delaiReg === 'a_vue' ? 'selected' : '' %>>À vue</option>
                            <option value="30_jours" <%= bc.delaiReg === '30_jours' ? 'selected' : '' %>>30 jours</option>
                            <option value="60_jours" <%= bc.delaiReg === '60_jours' ? 'selected' : '' %>>60 jours</option>
                            <option value="90_jours" <%= bc.delaiReg === '90_jours' ? 'selected' : '' %>>90 jours</option>
                            <option value="120_jours" <%= bc.delaiReg === '120_jours' ? 'selected' : '' %>>120 jours</option>
                          </select>
                        </div>
                      </div>
                    </div>
                  </div>

                  <div class="col-12 col-lg-6">
                    <div class="fournisseur-box">
                      <h5 class="mb-3"><i class="fas fa-hard-hat"></i> Chantiers</h5>
                      <div class="bc-extra-grid">
                        <div id="chantierCheckboxes" style="flex: 1 1 520px; min-width: 260px;">
                          <!-- Multi-select + tags for chantiers -->
                          <select id="chantierSelect" class="form-control" multiple size="6" style="min-height:120px;">
                            <% chantiers.forEach(ch=> {
                                const isUsed = bc.commandesItems.some(item => (item.BondeCommandeChantierItem || []).some(bcci => bcci.chantierId === ch.id));
                              %>
                              <option value="<%= ch.id %>" data-chantier-name="<%= ch.nom %>" <%= isUsed ? 'selected' : '' %>><%= ch.nom %></option>
                            <% }) %>
                          </select>
                        </div>

                        <div class="bc-extra-field">
                          <div class="bc-extra-label">Date de livraison</div>
                          <input id="dateLivraison" type="date" class="form-control bc-extra-input" value="<%= bc.dateLivraison ? new Date(bc.dateLivraison).toISOString().slice(0,10) : '' %>" />
                        </div>

                        <div class="bc-extra-field">
                          <div class="bc-extra-label">Lieu de livraison</div>
                          <input id="lieuLivraison" type="text" class="form-control bc-extra-input" placeholder="Ex: Dépôt / Chantier / Adresse" value="<%= bc.lieuLivraison || '' %>" />
                        </div>
                      </div>
                    </div>
                  </div>
                </div>

                <div class="table-section">
                  <div class="table-container">
                    <table class="table-doc">
                      <thead>
                        <tr>
                          <th style="width:6%; text-align:center; border: 1px solid #dee2e6;">N°</th>
                          <th style="width:34%; border: 1px solid #dee2e6;">Désignation</th>
                          <th style="width:12%; text-align:center; border: 1px solid #dee2e6;">Unité</th>
                          <th style="width:16%; text-align:center; border: 1px solid #dee2e6;">Reference</th>

                          <th style="width:8%; text-align:center; border: 1px solid #dee2e6;">Quantité</th>
                          <th style="width:8%; text-align:center; border: 1px solid #dee2e6;">Imputation</th>
                          <th style="width:14%; text-align:center; border: 1px solid #dee2e6;">Prix unitaire HT</th>
                          <th style="width:10%; text-align:center; border: 1px solid #dee2e6;">Remise (%)</th>
                          <th style="width:12%; text-align:center; border: 1px solid #dee2e6;">Total HT</th>
                          <th style="width:20%; text-align:center; border: 1px solid #dee2e6;">Affectation</th>
                          <th style="width:6%; text-align:center; border: 1px solid #dee2e6;">Action</th>
                        </tr>
                      </thead>
                      <tbody id="bcBody">
                        <% (bc.commandesItems || []).forEach((item, i)=> {
                          const distributionData = (item.BondeCommandeChantierItem || []).map(d => ({
                          chantierId: String(d.chantierId),
                          qty: d.qty,
                          montant: d.montant
                          }));
                          const distributionJson = JSON.stringify(distributionData);
                          %>
                          <tr class="bc-row" data-id="<%= item.id %>" data-distribution='<%= distributionJson %>'
