        // Initialize Choices.js for chantierSelect to provide professional tag UI
        (function initChantierChoices() {
          const sel = document.getElementById('chantierSelect');
          if (!sel || typeof Choices === 'undefined') return;
          window.chantierChoices = new Choices(sel, {
            removeItemButton: true,
