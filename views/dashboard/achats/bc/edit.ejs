            <label class="small font-weight-bold">Ajouter un email</label>
            <div class="input-group">
              <input type="email" id="newSupplierEmail" class="form-control form-control-sm" placeholder="exemple@domaine.com">
              <div class="input-group-append">
                <button class="btn btn-sm btn-success" type="button" onclick="addNewSupplierEmail()">
                  <i class="fas fa-plus"></i>
                </button>
              </div>
