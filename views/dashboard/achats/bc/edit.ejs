      <script src="https://cdnjs.cloudflare.com/ajax/libs/jspdf-autotable/3.8.3/jspdf.plugin.autotable.min.js"></script>
      <script src="https://cdnjs.cloudflare.com/ajax/libs/xlsx/0.18.5/xlsx.full.min.js"></script>
        <script src="https://cdn.jsdelivr.net/npm/choices.js/public/assets/scripts/choices.min.js"></script>

      <script>
        function sendEmail() {
          const btn = $('#btnSend');
          btn.html('<i class="fas fa-spinner fa-spin"></i> Envoi...').prop('disabled', true);

          $.post('/api/bc/<%= bc.id %>/send-email', {
            email: '<%= bc.fournisseur.email %>'
          })
            .done(() => {
              alert('Email envoyé avec succès !');
            })
            .fail(() => {
              alert('Échec de l\'envoi !');
            })
            .always(() => {
              btn.html('<i class="fas fa-paper-plane"></i> <span>Envoyer</span>').prop('disabled', false);
            });
        }

        function downloadPDF(id) {
          if (!id) return;
          window.location.href = `/achat/bc/${id}/pdf`;
        }

        // Fournisseurs data for BC edit (UI only)
        const fournisseursDataBc = <%- JSON.stringify(fournisseurs.map(f => ({
          id: String(f.id),
          name: f.name || '',
          email: f.email || '',
          tel: f.telFournisseur || ''
        }))) %>;

        const selectBc = document.getElementById('fournisseurSelectBc');
        if (selectBc) {
          selectBc.addEventListener('change', function () {
            const f = fournisseursDataBc.find(x => x.id === this.value);
            if (f) {
              const nameEl = document.getElementById('fourNameBc');
              const emailEl = document.getElementById('fourEmailBc');
              const telEl = document.getElementById('fourTelBc');
              if (nameEl) nameEl.textContent = f.name;
              if (emailEl) emailEl.textContent = f.email;
              if (telEl) telEl.textContent = f.tel || 'Non renseigné';
            }

            // (No-op) chantier UI is initialized globally with Choices.js
          });
        }

        // Initialize Choices.js for chantierSelect to provide professional tag UI
        (function initChantierChoices(){
          const sel = document.getElementById('chantierSelect');
          if (!sel || typeof Choices === 'undefined') return;
          window.chantierChoices = new Choices(sel, {
            removeItemButton: true,
            placeholderValue: 'Sélectionner des chantiers',
            shouldSort: false,
            searchPlaceholderValue: 'Rechercher...'
          });
        })();

        // Gestion de la sauvegarde du bon de commande
        const btnSaveBc = document.getElementById('btnSaveBc');
        if (btnSaveBc) {
          btnSaveBc.addEventListener('click', function () {
            const btn = this;
            btn.innerHTML = '<i class="fas fa-spinner fa-spin"></i> Sauvegarde...';
            btn.disabled = true;

            const data = collectPayload();

            // Validation basique côté client
            if (!data.supplier || Number.isNaN(data.supplier)) {
              alert('Sélectionnez un fournisseur.');
              btn.innerHTML = 'SAUVEGARDER LES MODIFICATIONS';
              btn.disabled = false;
              return;
            }
            const d = new Date(data.date);
            if (!(d instanceof Date) || isNaN(d.getTime())) {
              alert('La date est invalide.');
              btn.innerHTML = 'SAUVEGARDER LES MODIFICATIONS';
              btn.disabled = false;
              return;
            }

            try { console.log('Payload bon de commande', data); } catch (e) { }

            fetch('/achat/bc/<%= bc.id %>', {
              method: 'PUT',
              headers: { 'Content-Type': 'application/json' },
              body: JSON.stringify(data)
            })
              .then(r => r.json())
              .then(res => {
                btn.innerHTML = '<i class="fas fa-check"></i> Sauvegardé !';
                btn.style.background = '#10b981';
                setTimeout(() => location.reload(), 1500);
              })
              .catch(() => {
                btn.innerHTML = '<i class="fas fa-times"></i> Erreur';
                btn.style.background = '#ef4444';
                setTimeout(() => {
                  btn.innerHTML = 'SAUVEGARDER LES MODIFICATIONS';
                  btn.disabled = false;
                  btn.style.background = '';
                }, 2000);
              });
          });
        }

        // --- Conversion nombre -> texte FR (inspiré du chèque BMCI) ---
        function bcNumberToFrenchWords(number) {
          if (!Number.isInteger(number)) {
            number = Math.trunc(number);
          }

          if (number < 0) {
            return "moins " + bcNumberToFrenchWords(Math.abs(number));
          }

          const units = ["", "un", "deux", "trois", "quatre", "cinq", "six", "sept", "huit", "neuf"];
          const teens = ["dix", "onze", "douze", "treize", "quatorze", "quinze", "seize", "dix-sept", "dix-huit", "dix-neuf"];
          const tens = ["", "", "vingt", "trente", "quarante", "cinquante", "soixante", "", "quatre-vingt", ""];
          const thousands = ["", "mille", "million", "milliard"];

          function convertLessThanThousand(n) {
            if (n === 0) return "";
            let result = "";

            if (n >= 100) {
              const hundreds = Math.floor(n / 100);
              if (hundreds === 1) {
                result += "cent";
              } else {
                result += units[hundreds] + " cent";
              }
              if (n % 100 === 0 && hundreds > 1) {
                result += "s";
              }
              if (n % 100 > 0) {
                result += " ";
              }
              n %= 100;
            }

            if (n > 0) {
              if (n >= 20) {
                const tenIndex = Math.floor(n / 10);
                const unit = n % 10;
                if (tenIndex === 7 || tenIndex === 9) {
                  const base = tenIndex === 7 ? "soixante" : "quatre-vingt";
                  if (unit === 0) {
                    result += base + "-" + teens[0];
                  } else {
                    result += base + "-" + teens[unit];
                  }
                } else {
                  result += tens[tenIndex];
                  if (unit === 1 && tenIndex !== 8) {
                    result += "-et-" + units[unit];
                  } else if (unit > 0) {
                    result += "-" + units[unit];
                  } else if (tenIndex === 8 && unit === 0) {
                    result += "s"; // quatre-vingts
                  }
                }
              } else if (n >= 10) {
                result += teens[n - 10];
              } else {
                result += units[n];
              }
            }

            return result.trim();

          }

          function numberToWords(n) {
            if (n === 0) return "zéro";

            let parts = [];
            let index = 0;

            while (n > 0) {
              let chunk = n % 1000;
              if (chunk > 0) {
                let chunkText = convertLessThanThousand(chunk);
                if (index === 1) {
                  if (chunk === 1) {
                    chunkText = "mille";
                  } else {
                    chunkText += " mille";
                  }
                } else if (index > 1) {
                  chunkText += " " + thousands[index];
                  if (chunk > 1) {
                    chunkText += "s";
                  }
                }
                parts.unshift(chunkText);
              }
              n = Math.floor(n / 1000);
              index++;
            }

            return parts.join(" ").trim();
          }

          return numberToWords(number);
        }

        // --- NEW: Distribution Logic (Fixed & Robust) ---
        window.openDistributionModal = function (button) {
          console.log("Opening distribution modal...");

          if (typeof $ === 'undefined') {
            alert("Erreur: jQuery n'est pas chargé.");
            return;
          }

          const row = button.closest('tr');
          // Always read fresh totalQty from input at modal open time (NOT stale)
          const totalQtyInput = row.querySelector('input[data-field="quantite"].item-total-qty') || row.querySelector('input[data-field="quantite"]') || row.querySelector('.item-total-qty');
          let totalQty = 0;
          if (totalQtyInput) {
            const raw = (totalQtyInput.value || '').toString().trim();
            const cleaned = raw.replace(/\s/g, '').replace(/,/g, '.');
            totalQty = parseFloat(cleaned) || 0;
          }

          // Unit Price from the row
          const priceInput = row.querySelector('input[data-field="prixUnitaire"]');
          const rawPrice = (priceInput && priceInput.value ? priceInput.value : '').toString().trim().replace(/[^0-9.,-]/g, '').replace(/\s/g, '').replace(',', '.');
          const unitPrice = parseFloat(rawPrice || '0') || 0;

          // Discount (taux de remise) from the row and discounted unit price for distribution
          const remiseInput = row.querySelector('input[data-field="remise"]');
          const rawRemise = (remiseInput && remiseInput.value ? remiseInput.value : '').toString().trim().replace(',', '.');
          const tauxRemise = Math.max(0, parseFloat(rawRemise || '0') || 0);
          const unitPriceRemise = unitPrice * (1 - (tauxRemise / 100));

          if (totalQty <= 0) {
            alert('Veuillez d\'abord entrer une quantité totale pour cet article.');
            return;
          }

          // Get selected chantiers (Choices.js if available)
          const selectedChantiers = [];
          const chantierSelect = document.getElementById('chantierSelect');
          if (chantierSelect) {
            if (window.chantierChoices && typeof window.chantierChoices.getValue === 'function') {
              const vals = window.chantierChoices.getValue(true) || [];
              vals.forEach(v => {
                const opt = chantierSelect.querySelector(`option[value="${v}"]`);
                selectedChantiers.push({ id: v, name: opt ? (opt.dataset.chantierName || opt.textContent) : v });
              });
            } else {
              Array.from(chantierSelect.selectedOptions).forEach(opt => {
                selectedChantiers.push({ id: opt.value, name: opt.dataset.chantierName || opt.text });
              });
            }
          }

          if (selectedChantiers.length === 0) {
            alert('Veuillez sélectionner au moins un chantier dans la liste en haut.');
            return;
          }

          // Load existing distribution data
          let existingData = [];
          try {
            if (row.dataset.distribution) {
              // Handle potential single-quote issues if they exist
              const rawJson = row.dataset.distribution;
              existingData = JSON.parse(rawJson);
            }
          } catch (e) {
            console.error("Error parsing distribution data", e);
            existingData = [];
          }

          // Build modal content
          let modalHTML = `
            <div class="modal fade" id="distributionModal" tabindex="-1" role="dialog" aria-hidden="true">
              <div class="modal-dialog modal-lg" role="document">
                <div class="modal-content">
                  <div class="modal-header">
                    <h5 class="modal-title">Distribution des quantités</h5>
                    <button type="button" class="close" data-dismiss="modal" aria-label="Close">
                      <span aria-hidden="true">&times;</span>
                    </button>
                  </div>
                  <div class="modal-body">
                    <p><strong>Quantité totale:</strong> <span id="modalTotalQty">${totalQty}</span></p>
                    <p><strong>Restant à distribuer:</strong> <span id="modalRemainingQty">${totalQty}</span></p>
                    <table class="table table-bordered">
                      <thead>
                        <tr>
                          <th>Chantier</th>
                          <th>Quantité</th>
                          <th>Montant</th>
                        </tr>
                      </thead>
                      <tbody id="distributionTableBody">
          `;

          let totalAllocatedInit = 0;
          selectedChantiers.forEach(ch => {
            // Find existing data for this chantier
            // Note: existingData chantierId might be string or number, force string comparison
            const saved = existingData.find(d => String(d.chantierId) === String(ch.id));
            const qtyVal = saved ? saved.qty : 0;
            const montantVal = saved ? saved.montant : 0;

            totalAllocatedInit += parseFloat(qtyVal) || 0;
            modalHTML += `
              <tr data-chantier-id="${ch.id}">
                <td>${ch.name}</td>
                <td>
                  <input 
                    type="number" 
                    class="form-control chantier-qty-input" 
                    min="0" 
                    step="1" 
                    value="${qtyVal}" 
                    data-chantier-id="${ch.id}"
                  />
                </td>
                <td>
                  <input 
                    type="number" 
                    class="form-control chantier-montant-input" 
                    min="0" 
                    step="0.01" 
                    value="${montantVal}" 
                    data-chantier-id="${ch.id}"
                  />
                </td>
              </tr>
            `;
          });

          modalHTML += `
                      </tbody>
                    </table>
                  </div>
                  <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-dismiss="modal">Annuler</button>
                    <button type="button" class="btn btn-primary" onclick="window.saveDistribution()">Sauvegarder</button>
                    
                  </div>
                </div>
              </div>
            </div>
          `;

          // Remove existing modal if any
          const existingModal = document.getElementById('distributionModal');
          if (existingModal) {
            existingModal.remove();
            $('.modal-backdrop').remove(); // Cleanup backdrops just in case
          }

          // Append and show
          document.body.insertAdjacentHTML('beforeend', modalHTML);

          try {
            $('#distributionModal').modal('show');
          } catch (e) {
            console.error("Bootstrap modal error:", e);
            alert("Erreur lors de l'ouverture du modal (Bootstrap).");
          }

          window.currentDistributionRow = row;

          // Initial remaining qty display
          const remainingInit = totalQty - totalAllocatedInit;
          const remEl = document.getElementById('modalRemainingQty');
          if (remEl) {
            remEl.textContent = remainingInit;
            remEl.style.color = remainingInit < 0 ? 'red' : 'green';
          }

          // Use discounted unit price for distribution montant
          setupDistributionListeners(totalQty, unitPriceRemise);

          // Attach listener to quantity input to refresh modal if qty is changed while modal is open
          if (totalQtyInput) {
            const handleQtyChange = function () {
              // Close modal and reopen with fresh quantity
              const backdrop = document.querySelector('.modal-backdrop');
              if (backdrop) {
                $('#distributionModal').modal('hide');
                setTimeout(() => {
                  window.openDistributionModal(button);
                }, 400);
              }
            };
            // Clean up old listeners and add fresh one
            totalQtyInput.removeEventListener('input', totalQtyInput._distModalListener);
            totalQtyInput._distModalListener = handleQtyChange;
            totalQtyInput.addEventListener('input', handleQtyChange);
          }
        };

        window.setupDistributionListeners = function (totalQty, unitPriceRemise) {
          const qtyInputs = document.querySelectorAll('.chantier-qty-input');
          qtyInputs.forEach(input => {
            input.addEventListener('input', function () {
              // 1. Update Remaining Qty
              let totalAllocated = 0;
              qtyInputs.forEach(inp => {
                totalAllocated += parseFloat(inp.value) || 0;
              });
              const remaining = totalQty - totalAllocated;
              const remEl = document.getElementById('modalRemainingQty');
              remEl.textContent = remaining;

              if (remaining < 0) {
                remEl.style.color = 'red';
              } else {
                remEl.style.color = 'green';
              }

              // Auto-calculate Montant using discounted unit price
              const currentQty = parseFloat(this.value) || 0;
              const newMontant = currentQty * (unitPriceRemise || 0);
              const row = this.closest('tr');
              const montantInput = row.querySelector('.chantier-montant-input');
              if (montantInput) {
                montantInput.value = newMontant.toFixed(2);
              }
            });
          });
        };

        window.saveDistribution = function () {
          const row = window.currentDistributionRow;
          if (!row) return;

          // Step 1: First, update the item's basic data (qty, price, etc.) on the server
          const itemId = row.getAttribute('data-id');
          
          // Extract current item data from the row
          const designationInput = row.querySelector('input[data-field="designation"]');
          const uniteInput = row.querySelector('input[data-field="unite"]');
          const quantiteInput = row.querySelector('input[data-field="quantite"]');
          const prixUnitaireInput = row.querySelector('input[data-field="prixUnitaire"]');
          
          const designation = (designationInput && designationInput.value) || '';
          const unite = (uniteInput && uniteInput.value) || '';
          const quantiteRaw = (quantiteInput && quantiteInput.value) || '0';
          const quantiteStr = quantiteRaw.toString().trim().replace(/\s/g, '').replace(/,/g, '.');
          const quantite = parseFloat(quantiteStr) || 0;
          const prixRaw = (prixUnitaireInput && prixUnitaireInput.value) || '0';
          const prixStr = prixRaw.toString().trim().replace(/[^0-9.,-]/g, '').replace(/\s/g, '').replace(',', '.');
          const prixUnitaire = parseFloat(prixStr) || 0;

          // Prepare distribution data
          const distributionData = [];
          document.querySelectorAll('#distributionTableBody tr').forEach(tr => {
            const chantierId = tr.dataset.chantierId;
            const qty = parseFloat(tr.querySelector('.chantier-qty-input').value) || 0;
            const montant = parseFloat(tr.querySelector('.chantier-montant-input').value) || 0;

            if (qty > 0 || montant > 0) {
              distributionData.push({ chantierId, qty, montant });
            }
          });

          // If this row has a server-side item ID, update the single item then its distribution.
          const updateItemPayload = {
            designation,
            unite,
            quantite,
            prixUnitaire,
            tauxRemise: parseFloat((row.querySelector('input[data-field="remise"]')?.value || '0').toString().replace(',', '.')) || 0
          };

          if (itemId) {
            fetch(`/achat/bc/item/${itemId}`, {
              method: 'PUT',
              headers: { 'Content-Type': 'application/json' },
              body: JSON.stringify(updateItemPayload)
            })
              .then(r => r.json())
              .then(resp1 => {
                if (resp1 && resp1.success) {
                  // Step 3: Now save distribution for this item
                  return fetch(`/achat/bc/item/${itemId}/distribution`, {
                    method: 'PATCH',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ distribution: distributionData })
                  });
                } else {
                  throw new Error('Échec de la sauvegarde des données de l\'article.');
                }
              })
              .then(r => r.json())
              .then(resp => {
                if (resp && resp.success) {
                  // store in dataset for UI sync
                  row.dataset.distribution = JSON.stringify(distributionData);

                  // Update button UI
                  const button = row.querySelector('button[onclick*="openDistributionModal"]');
                  if (button) {
                    if (distributionData.length > 0) {
                      button.innerHTML = '<i class="fas fa-check"></i> Distribué (' + distributionData.length + ')';
                      button.classList.remove('btn-primary');
                      button.classList.add('btn-success');
                    } else {
                      button.innerHTML = '<i class="fas fa-share-alt"></i> Distribuer';
                      button.classList.remove('btn-success');
                      button.classList.add('btn-primary');
                    }
                  }

                  $('#distributionModal').modal('hide');
                  window.location.reload();
                } else {
                  alert('Échec de la sauvegarde de la distribution.');
                }
              })
              .catch(err => {
                console.error('Erreur sauvegarde:', err);
                alert('Erreur lors de la sauvegarde: ' + err.message);
              });
          } else {
            // No itemId: this is a new UI-only row. We must send the full BC payload so the server can create the item and persist its distribution.
            try {
              const payload = collectPayload();
              // Find index of current row among table rows
              const rows = Array.from(document.querySelectorAll('#bcBody tr'));
              const rowIndex = rows.indexOf(row);
              if (rowIndex === -1) throw new Error('Impossible de localiser la ligne dans le tableau');

              // Ensure commandesItems exists and has same order as rows
              if (!Array.isArray(payload.commandesItems) || payload.commandesItems.length !== rows.length) {
                // Rebuild commandesItems to match rows
                payload.commandesItems = rows.map(r => {
                  const referenceVal = (r.querySelector('input[data-field="reference"]')?.value || '').toString();
                  const rawQty = (r.querySelector('input[data-field="quantite"]')?.value || '').toString();
                  const rawPu = (r.querySelector('input[data-field="prixUnitaire"]')?.value || '').toString();
                  const rawRemiseValRow = (r.querySelector('input[data-field="remise"]')?.value || '').toString();
                  const qtyVal = rawQty.trim().replace(/[^0-9.,-]/g, '').replace(/\s/g, '').replace(',', '.');
                  const prixVal = rawPu.trim().replace(/[^0-9.,-]/g, '').replace(/\s/g, '').replace(',', '.');
                  const quantiteLocal = parseFloat(qtyVal || '0') || 0;
                  const prixUnitaireLocal = parseFloat(prixVal || '0') || 0;
                  const tauxRemiseRow = parseFloat(rawRemiseValRow.trim().replace(',', '.')) || 0;
                  const montantRemiseRow = quantiteLocal * prixUnitaireLocal * tauxRemiseRow / 100;
                  return {
                    id: parseInt(r.getAttribute('data-id')) || null,
                    designation: (r.querySelector('input[data-field="designation"]')?.value || '').trim(),
                    unite: (r.querySelector('input[data-field="unite"]')?.value || '').trim(),
                    reference: referenceVal.trim(),
                    quantite: quantiteLocal,
                    prixUnitaire: prixUnitaireLocal,
                    totalHt: quantiteLocal * prixUnitaireLocal - montantRemiseRow,
                    tauxRemise: tauxRemiseRow,
                    montantRemise: montantRemiseRow,
                    chantierDistribution: r.dataset.distribution ? JSON.parse(r.dataset.distribution) : []
                  };
                });
              }

              // Overwrite the current row's chantierDistribution with the freshly edited distribution
              payload.commandesItems[rowIndex].chantierDistribution = distributionData;

              // Call update BC endpoint to persist new item + its distribution
              fetch(`/achat/bc/<%= bc.id %>`, {
                method: 'PUT',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify(payload)
              })
                .then(r => r.json())
                .then(res => {
                  if (res && res.success) {
                    $('#distributionModal').modal('hide');
                    window.location.reload();
                  } else {
                    throw new Error(res && res.error ? res.error : 'Échec sauvegarde BC');
                  }
                })
                .catch(err => {
                  console.error('Erreur création ligne + distribution:', err);
                  alert('Erreur lors de la sauvegarde: ' + (err.message || err));
                });
            } catch (e) {
              console.error('Erreur préparation payload:', e);
              alert('Erreur lors de la préparation des données: ' + e.message);
            }
          }
        };

        // Ajouter une nouvelle ligne de BC (inspiré de Demande de prix)
        function addBcRow() {
          const tbody = document.getElementById('bcBody');
          if (!tbody) return;

          const index = tbody.querySelectorAll('tr.bc-row').length + 1;
          const tr = document.createElement('tr');
          tr.className = 'bc-row';
          tr.setAttribute('data-distribution', '[]');
          tr.style.backgroundColor = index % 2 === 1 ? '#ffffff' : '#f9fafb';
          tr.style.border = '1px solid #dee2e6';

          tr.innerHTML = `
      <td style="text-align:center; border: 1px solid #dee2e6;">
        <div class="num-circle">${index}</div>
      </td>
      <td style="border: 1px solid #dee2e6;">
        <input
          type="text"
          class="form-control form-control-sm"
          style="font-weight:600; color:#1e293b; border-radius: 10px;"
          value=""
          data-field="designation"
        />
      </td>
      <td style="text-align:center; border: 1px solid #dee2e6;">
        <input
          type="text"
          class="form-control form-control-sm text-center"
          style="font-weight:600; border-radius: 999px; max-width: 110px; margin: 0 auto;"
          value=""
          data-field="unite"
        />
      </td>
      <td style="text-align:center; border: 1px solid #dee2e6;">
        <input
          type="text"
          class="form-control form-control-sm text-center"
          style="font-weight:600; border-radius: 999px; max-width: 110px; margin: 0 auto;"
          value=""
          data-field="reference"
        />
      </td>
      <td style="text-align:center; border: 1px solid #dee2e6;">
          <input
            type="number"
            min="0"
            step="1"
            class="qty-pill item-total-qty"
            style="border:none; outline:none;"
            value="0"
            data-field="quantite"
          />
      </td>
      <td style="text-align:center; border: 1px solid #dee2e6;">
        <input
          type="text"
          class="form-control form-control-sm text-center"
          style="font-weight:600; border-radius: 999px; max-width: 110px; margin: 0 auto;"
          value=""
          data-field="imputation"
        />
      </td>

      <td style="text-align:right; border: 1px solid #dee2e6;">
        <input
          type="text"
          class="form-control form-control-sm text-right"
          style="border-radius: 10px; max-width: 140px; margin-left: auto;"
          value="0,00"
          data-field="prixUnitaire"
        />
      </td>
      <td style="text-align:center; border: 1px solid #dee2e6;">
        <input type="number" min="0" step="0.01" class="form-control form-control-sm text-center"
          style="border-radius: 10px; max-width: 100px; margin: 0 auto;"
          value="0" data-field="remise" />
      </td>
      <td style="text-align:right; border: 1px solid #dee2e6;" data-field="totalHt">
        0,00
      </td>
      <td style="border: 1px solid #dee2e6;">
        <button type="button" class="btn btn-sm btn-primary" onclick="openDistributionModal(this)">
          <i class="fas fa-share-alt"></i> Distribuer
        </button>
        <div class="distribution-container" style="display:none;"></div>
      </td>
      <td style="text-align:center; border: 1px solid #dee2e6;">
        <button type="button" onclick="deleteBcRow(this)" class="btn btn-sm btn-modern btn-danger">
          <i class="fas fa-trash"></i>
        </button>
      </td>
    `;

          tbody.appendChild(tr);

          // Raccorder les nouveaux inputs à la logique de recalcul
          const qtyInput = tr.querySelector('input[data-field="quantite"]');
          const priceInput = tr.querySelector('input[data-field="prixUnitaire"]');
          const remiseInputRow = tr.querySelector('input[data-field="remise"]');
          const recalcFn = window.__recalcBcTotals;
          if (qtyInput && recalcFn) qtyInput.addEventListener('input', () => recalcFn());
          if (priceInput && recalcFn) priceInput.addEventListener('input', () => recalcFn());
          if (remiseInputRow && recalcFn) remiseInputRow.addEventListener('input', () => recalcFn());

          // Recalcule après ajout
          if (recalcFn) recalcFn();
        }

        function updateMontantEnLettres(totalTtc) {
          const el = document.getElementById('montantLettresValue');
          if (!el || isNaN(totalTtc)) return;

          const rounded = Math.round((totalTtc + Number.EPSILON) * 100) / 100;
          let dirhams = Math.floor(rounded);
          let centimes = Math.round((rounded - dirhams) * 100);

          if (dirhams < 0) dirhams = 0;
          if (centimes < 0) centimes = 0;

          const dirhamsText = bcNumberToFrenchWords(dirhams).toUpperCase();
          const centimesText = bcNumberToFrenchWords(centimes).toUpperCase();

          let result = `${dirhamsText} DIRHAM${dirhams !== 1 ? 'S' : ''}`;
          if (centimes > 0) {
            result += ` ET ${centimesText} CENTIME${centimes !== 1 ? 'S' : ''}`;
          } else {
            result += ' ET ZÉRO CENTIMES';
          }

          el.textContent = result;
          document.getElementById('montantLettresInp').value = result;
        }

        (function () {
          const totalHtEl = document.getElementById('totalHtValue');
          if (!totalHtEl) return;

          const tvaInput = document.getElementById('tvaInput');
          const totalTtcEl = document.getElementById('totalTtcValue');

          // Prevent mouse wheel / trackpad scroll from changing focused number inputs (e.g. remise 10 -> 9.99)
          document.addEventListener('wheel', function (e) {
            const el = document.activeElement;
            if (el && el.tagName === 'INPUT' && el.type === 'number') {
              e.preventDefault();
            }
          }, { passive: false });

          const montantTvaEl = document.getElementById('montantTvaValue');
          const formatNumber = (value) => {
            return value.toLocaleString('fr-FR', {
              minimumFractionDigits: 2,
              maximumFractionDigits: 2,
            });

          };

          const recalc = () => {
            // 1) Recalculate per-line NET totals (after remise) and Total HT
            let rawTotalHt = 0;
            let totalRemise = 0;
            const rows = document.querySelectorAll('.bc-row');
            rows.forEach((tr) => {
              const cells = tr.cells;
              const qtyInput = tr.querySelector('input[data-field="quantite"]');
              const priceInput = tr.querySelector('input[data-field="prixUnitaire"]');
              const remiseInputRow = tr.querySelector('input[data-field="remise"]');
              const totalEl = tr.querySelector('[data-field="totalHt"]');

              if (!qtyInput || !priceInput || !totalEl) return;
              const qtyText = (qtyInput.value || '')
                .trim()
                .replace(/[^0-9.,-]/g, '')
                .replace(/\s/g, '')
                .replace(',', '.');

              const priceText = (priceInput.value || '')
                .trim()
                .replace(/[^0-9.,-]/g, '')
                .replace(/\s/g, '')
                .replace(',', '.');

              const q = parseFloat(qtyText || '0') || 0;
              const p = parseFloat(priceText || '0') || 0;
              const lineBase = q * p;

              let remisePctRow = 0;
              if (remiseInputRow) {
                remisePctRow = parseFloat((remiseInputRow.value || '').toString().replace(',', '.')) || 0;
                if (isNaN(remisePctRow) || remisePctRow < 0) remisePctRow = 0;
              }

              const lineRemise = lineBase * remisePctRow / 100;
              const lineNet = lineBase - lineRemise;

              // Keep saved distribution montants in sync with current PU/remise (qty stays the same)
              const puRemise = p * (1 - (remisePctRow / 100));
              if (tr.dataset.distribution) {
                try {
                  const dist = JSON.parse(tr.dataset.distribution);
                  if (Array.isArray(dist)) {
                    const updated = dist.map(d => {
                      const qtyDist = parseFloat((d && d.qty != null ? d.qty : 0).toString()) || 0;
                      return {
                        chantierId: d.chantierId,
                        qty: qtyDist,
                        montant: qtyDist * puRemise
                      };
                    });
                    tr.dataset.distribution = JSON.stringify(updated);
                  }
                } catch (e) { }
              }

              rawTotalHt += lineBase;
              totalRemise += lineRemise;
              totalEl.textContent = formatNumber(lineNet);

              tr.dataset.lineBase = String(lineBase);
              tr.dataset.lineRemise = String(lineRemise);
              tr.dataset.lineNet = String(lineNet);
            });

            // Update Total HT display element (sum of per-line nets)
            const totalNetHt = rawTotalHt - totalRemise;
            totalHtEl.setAttribute('data-total-ht', totalNetHt);
            totalHtEl.textContent = formatNumber(totalNetHt);

            let tva = parseFloat((tvaInput.value || '').replace(',', '.'));
            if (isNaN(tva) || tva < 0) tva = 0;

            const montantTva = totalNetHt * tva / 100;
            const totalTtc = totalNetHt + montantTva;
            if (montantTvaEl) {
              montantTvaEl.textContent = formatNumber(montantTva);
            }
            if (totalTtcEl) {
              totalTtcEl.textContent = formatNumber(totalTtc);
            }
            updateMontantEnLettres(totalTtc);
          };

          // Recompute when TVA changes
          if (tvaInput) tvaInput.addEventListener('input', recalc);

          // Recompute when quantity, price, or per-row remise inputs change
          const editableCells = document.querySelectorAll('input[data-field="quantite"], input[data-field="prixUnitaire"], input[data-field="remise"]');
          editableCells.forEach((el) => {
            el.addEventListener('input', recalc);
          });
          recalc();
          window.__recalcBcTotals = recalc;
        })();

        function collectPayload() {
          const commandesItems = [];
          const tvaInputEl = document.getElementById('tvaInput');
          const tauxTva = tvaInputEl ? parseFloat((tvaInputEl.value || '').toString().replace(',', '.')) || 0 : 0;
          const montantLettresInp = document.getElementById('montantLettresInp');
          const dateLivraison = document.getElementById('dateLivraison')?.value || null;
          const lieuLivraison = (document.getElementById('lieuLivraison')?.value || '').toString().trim();
          const modeReg = (document.getElementById('modeReglement')?.value || '').toString().trim() || null;
          const delaiReg = (document.getElementById('delaisReglement')?.value || '').toString().trim() || null;
          document.querySelectorAll('#bcBody tr').forEach(tr => {
            const referenceVal = (tr.querySelector('input[data-field="reference"]')?.value || '').toString();
            const rawQty = (tr.querySelector('input[data-field="quantite"]')?.value || '').toString();
            const rawPu = (tr.querySelector('input[data-field="prixUnitaire"]')?.value || '').toString();

            const rawRemiseValRow = (tr.querySelector('input[data-field="remise"]')?.value || '').toString();
            const qtyVal = rawQty.trim().replace(/[^0-9.,-]/g, '').replace(/\s/g, '').replace(',', '.');
            const prixVal = rawPu.trim().replace(/[^0-9.,-]/g, '').replace(/\s/g, '').replace(',', '.');
            const quantite = parseFloat(qtyVal || '0') || 0;
            const imputationVal = (tr.querySelector('input[data-field="imputation"]')?.value || '').toString();
            const prixUnitaire = parseFloat(prixVal || '0') || 0;
            const tauxRemiseRow = parseFloat(rawRemiseValRow.trim().replace(',', '.')) || 0;
            const montantRemiseRow = quantite * prixUnitaire * tauxRemiseRow / 100;

            // Recompute distribution montants using current discounted unit price
            const prixUnitaireRemise = prixUnitaire * (1 - (Math.max(0, tauxRemiseRow) / 100));
            let distributionData = [];
            if (tr.dataset.distribution) {
              try {
                const dist = JSON.parse(tr.dataset.distribution);
                if (Array.isArray(dist)) {
                  distributionData = dist.map(d => {
                    const qtyDist = parseFloat((d && d.qty != null ? d.qty : 0).toString()) || 0;
                    return {
                      chantierId: d.chantierId,
                      qty: qtyDist,
                      montant: qtyDist * prixUnitaireRemise
                    };
                  });
                }
              } catch (e) { distributionData = []; }
            }

            // Keep dataset in sync too
            tr.dataset.distribution = JSON.stringify(distributionData);
            commandesItems.push({
              id: parseInt(tr.getAttribute('data-id')) || null,
              designation: (tr.querySelector('input[data-field="designation"]')?.value || '').trim(),
              unite: (tr.querySelector('input[data-field="unite"]')?.value || '').trim(),
              reference: referenceVal.trim(),
              quantite,
              imputation : imputationVal.trim(),
              prixUnitaire,
              totalHt: quantite * prixUnitaire - montantRemiseRow,
              tauxRemise: tauxRemiseRow,
              montantRemise: montantRemiseRow,
              tauxTva,
              chantierDistribution: distributionData
            });
          });

          const supplierSelect = document.getElementById('fournisseurSelectBc');
          const supplierVal = supplierSelect ? supplierSelect.value : '';
          const dateInput = document.querySelector('input[name="date"]');
          const dateVal = dateInput ? dateInput.value : null;
          return {
            supplier: supplierVal ? parseInt(supplierVal) : null,
            date: dateVal || null,
            dateLivraison,
            lieuLivraison,
            modeReg,
            delaiReg,
            tauxTva,
            montantLettres: montantLettresInp ? montantLettresInp.value : '',
            commandesItems
          };
        }

        async function deleteBcRow(button) {
          const row = button.closest('tr');
          if (!row) return;
          const id = parseInt(row.getAttribute('data-id'));
          if (id) {
            if (!confirm('Confirmer la suppression de cette ligne ?')) return;
            try {
              const res = await fetch(`/achat/bc/article/${id}`, { method: 'DELETE' });
              if (!res.ok) { throw new Error(`Suppression échouée (${res.status})`); }
            } catch (e) {
              alert(e.message);
              return;
            }
          }

          const tbody = row.parentElement;
          row.remove();

          // Renumber N° column
          if (tbody) {
            const rows = tbody.querySelectorAll('tr.bc-row');
            rows.forEach((tr, index) => {
              const numDiv = tr.querySelector('.num-circle');
              if (numDiv) numDiv.textContent = index + 1;
            });
          }

          // Recalculate totals using the shared function
          if (window.__recalcBcTotals) {
            window.__recalcBcTotals();
          }
        }




      </script>

