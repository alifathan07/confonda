  <!-- Scripts -->
  <script src="/vendor/jquery/jquery.min.js"></script>
  <script src="/vendor/bootstrap/js/bootstrap.bundle.min.js"></script>
  <script src="https://cdnjs.cloudflare.com/ajax/libs/jspdf/2.5.1/jspdf.umd.min.js"></script>
  <script src="https://cdnjs.cloudflare.com/ajax/libs/jspdf-autotable/3.8.3/jspdf.plugin.autotable.min.js"></script>
  <script src="https://cdnjs.cloudflare.com/ajax/libs/xlsx/0.18.5/xlsx.full.min.js"></script>
  <script src="https://cdn.jsdelivr.net/npm/choices.js/public/assets/scripts/choices.min.js"></script>

  <script>
    function openSupplierEmailManager() {
      const supplierId = document.getElementById('fournisseurSelectBc').value;
      if (!supplierId) {
        alert('Veuillez d\'abord sélectionner un fournisseur');
        return;
      }
      $('#manageSupplierId').val(supplierId);
      $('#newSupplierEmail').val('');
      
      renderSupplierEmails(supplierId);
      $('#supplierEmailModal').modal('show');
    }

    function renderSupplierEmails(supplierId) {
      fetch('/api/fournisseurs')
        .then(r => r.json())
        .then(data => {
          const supplier = (data.fournisseurs || data).find(f => String(f.id) === String(supplierId));
          const list = $('#supplierEmailsList');
          list.empty();
          
          if (supplier) {
            if (supplier.email) {
              list.append(`
                <div class="d-flex justify-content-between align-items-center mb-2 p-2 bg-light rounded border-left border-primary">
                  <span class="small font-weight-bold">${supplier.email} (Principal)</span>
                </div>
              `);
            }
            if (supplier.emails && supplier.emails.length) {
              supplier.emails.forEach(e => {
                list.append(`
                  <div class="d-flex justify-content-between align-items-center mb-2 p-2 bg-light rounded border-left">
                    <span class="small">${e.email}</span>
                    <button class="btn btn-xs btn-link text-danger p-0" onclick="deleteSupplierEmail(${e.id}, ${supplierId})">
                      <i class="fas fa-trash-alt"></i>
                    </button>
                  </div>
                `);
              });
            }
          }
        });
    }

    function addNewSupplierEmail() {
      const supplierId = $('#manageSupplierId').val();
      const email = $('#newSupplierEmail').val().trim();
      if (!email || !email.includes('@')) {
        alert('Veuillez entrer un email valide');
        return;
      }

      $.post(`/achats/fournisseurs/${supplierId}/emails`, { email: email }, function(res) {
        renderSupplierEmails(supplierId);
        $('#newSupplierEmail').val('');
      });
    }

    function deleteSupplierEmail(emailId, supplierId) {
      if (confirm('Supprimer cet email ?')) {
        $.ajax({
          url: `/achats/fournisseurs/emails/${emailId}`,
          type: 'DELETE',
          success: function() {
            renderSupplierEmails(supplierId);
          }
        });
      }
    }

    async function updateSupplierDetails() {
      const id = document.getElementById('fournisseurSelectBc').value;
      if (!id) {
        alert('Sélectionnez un fournisseur !');
        return;
      }

      const nameVal = document.getElementById('fourNameBc').value;
      const emailVal = document.getElementById('fourEmailBc').value;
      const telVal = document.getElementById('fourTelBc').value;

      try {
        const res = await fetch(`/achat/bc/supplier/update`, {
          method: 'PATCH',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({
            supplierId: id,
            name: nameVal,
            email: emailVal,
            telFournisseur: telVal,
          })
        });
        if (res.ok) {
          alert('Informations fournisseur mises à jour !');
        } else {
          throw new Error('Erreur lors de la mise à jour');
        }
      } catch (e) {
        alert(e.message);
      }
    }
        // BL Creation Modal Functions
        function openBLCreationModal(bcId, fourName, fourId, bcNumero) {
          document.getElementById('blActionModal').style.display = 'flex';
          document.getElementById('blActionSubtitle').textContent = 'BC n° ' + bcNumero;
          window.currentBCEditionId = bcId;
          window.currentBCFournisseurId = fourId;
          window.currentBCNumero = bcNumero;
        }

        function closeBLActionModal() {
          document.getElementById('blActionModal').style.display = 'none';
          window.currentBCEditionId = null;
        }

        // ==================== BL MODAL FUNCTIONS ====================
        let currentArticles = [];
        let removedArticleIds = new Set();
        let selectedBLId = null;
        let unlinkedBLs = [];
        let existingBLArticles = [];
        let remainingBCArticles = [];
        let removedRemainingArticleIds = new Set();
        let currentAffectationBcId = null;

        let extraArticles = [];

        async function openCreateBLModal(bcId) {
          currentArticles = [];
          extraArticles = [];
          removedArticleIds.clear();
          window.currentBCEditionId = bcId; // Store before closing other modal
          document.getElementById('createBL_bcId').value = bcId;
          document.getElementById('createBLSubtitle').textContent = 'BC n° ' + (window.currentBCNumero || bcId);
          document.getElementById('createBLForm').reset();
          document.getElementById('dateReception').valueAsDate = new Date();
          try {
            const response = await fetch('/api/bons-commande/' + bcId + '/articles-remaining');
            if (!response.ok) throw new Error('Erreur de chargement des articles');
            currentArticles = await response.json();
            renderArticles();
            document.getElementById('createBLModal').style.display = 'flex';
          } catch (error) {
            showToast('Erreur: ' + error.message, 'error');
          }
        }

        function closeCreateBLModal() {
          document.getElementById('createBLModal').style.display = 'none';
          currentArticles = [];
          extraArticles = [];
          removedArticleIds.clear();
        }

        function addExtraArticleToBL() {
          const newArt = {
            id: 'extra-' + Date.now(),
            isExtra: true,
            designation: '',
            reference: '',
            unite: '',
            prixUnitaire: 0,
            qte_commandee: 0,
            qte_deja_recue: 0
          };
          extraArticles.push(newArt);
          renderArticles();
        }

        function removeExtraArticle(id) {
          extraArticles = extraArticles.filter(a => a.id !== id);
          renderArticles();
        }

        function renderArticles() {
          const container = document.getElementById('articlesContainer');
          if (currentArticles.length === 0 && extraArticles.length === 0) {
            container.innerHTML = '<div class="text-center text-muted py-4">Aucun article à livrer</div>';
            return;
          }
          
          let html = '<div style="display:grid; grid-template-columns: 2fr 100px 100px 100px 40px; gap:10px; padding:10px; background:#f8f9fc; font-weight:bold; font-size:0.85rem; color:#4e73df;"><div>Article</div><div class="text-center">Cmd/Reçu</div><div class="text-center">Qty Livrer</div><div class="text-center">Prix Unit.</div><div></div></div>';
          
          // BC Articles
          currentArticles.forEach(article => {
            if (removedArticleIds.has(article.id)) return;
            const qteRestante = article.qte_commandee - article.qte_deja_recue;
            if (article.qte_deja_recue >= article.qte_commandee) {
              html += '<div class="article-row disabled" style="display:grid; grid-template-columns:2fr 100px 100px 100px; gap:10px; padding:12px 10px; border-bottom:1px solid #e3e6f0; align-items:center; background:#f8f9fa; opacity:0.6;"><div><strong>' + article.designation + '</strong><div style="font-size:0.8rem; color:#6c757d;">Réf: ' + (article.reference || '---') + '</div></div><div class="text-center"><span class="badge badge-success">Complet</span></div><div class="text-center"><input type="number" class="form-control form-control-sm" value="' + article.qte_commandee + '" disabled></div><div class="text-center">' + (article.prixUnitaire || '') + '</div></div>';
            } else {
              const badge = article.qte_deja_recue > 0 ? '<span class="badge badge-warning">' + article.qte_deja_recue + '/' + article.qte_commandee + '</span>' : '<span class="badge badge-info">0/' + article.qte_commandee + '</span>';
              html += '<div class="article-row" data-id="' + article.id + '" data-qte-commandee="' + article.qte_commandee + '" data-qte-recue="' + article.qte_deja_recue + '" style="display:grid; grid-template-columns:2fr 100px 100px 100px 40px; gap:10px; padding:12px 10px; border-bottom:1px solid #e3e6f0; align-items:center;"><div><strong>' + article.designation + '</strong><div style="font-size:0.8rem; color:#6c757d;">Réf: ' + (article.reference || '---') + '</div></div><div class="text-center">' + badge + '</div><div class="text-center"><input type="number" class="form-control form-control-sm qte-input" data-id="' + article.id + '" value="' + qteRestante + '" min="0" max="' + qteRestante + '"></div><div class="text-center"><input type="number" class="form-control form-control-sm prix-input" data-id="' + article.id + '" value="' + (article.prixUnitaire || '') + '" step="0.01"></div></div>';
            }
          });

          // Extra Articles
          extraArticles.forEach(article => {
            html += `
              <div class="article-row extra-row" data-id="${article.id}" style="display:grid; grid-template-columns:2fr 100px 100px 100px 40px; gap:10px; padding:12px 10px; border-bottom:1px solid #e3e6f0; align-items:center; background:#fffdf0;">
                <div>
                  <input type="text" class="form-control form-control-sm extra-designation mb-1" placeholder="Désignation" value="${article.designation}" data-field="designation" autocomplete="off">
                  <input type="text" class="form-control form-control-xs extra-reference" placeholder="Référence" value="${article.reference}" data-field="reference" style="font-size:0.75rem;" autocomplete="off">
                </div>
                <div class="text-center"><span class="badge badge-secondary">Hors BC</span></div>
                <div class="text-center"><input type="number" class="form-control form-control-sm extra-qte" value="1" min="0" step="0.01"></div>
                <div class="text-center"><input type="number" class="form-control form-control-sm extra-prix" value="${article.prixUnitaire || 0}" step="0.01" data-field="prixUnitaire"></div>
                <div class="text-center"><button type="button" class="btn btn-xs btn-danger" onclick="removeExtraArticle('${article.id}')"><i class="fas fa-trash"></i></button></div>
              </div>
            `;
          });

          container.innerHTML = html;

          // Re-attach autocomplete to extra rows
          document.querySelectorAll('.extra-row').forEach(row => {
            const desInp = row.querySelector('.extra-designation');
            const refInp = row.querySelector('.extra-reference');
            if (desInp) desInp.setAttribute('data-field', 'designation');
            if (refInp) refInp.setAttribute('data-field', 'reference');
          });
        }

        async function submitCreateBL() {
          const bcId = document.getElementById('createBL_bcId').value;
          const numeroBL = document.getElementById('numeroBL').value.trim();
          const dateReception = document.getElementById('dateReception').value;
          if (!bcId) { showToast('Erreur: BC non identifié', 'error'); return; }
          if (!numeroBL) { showToast('Le N° BL est requis', 'error'); return; }
          if (!dateReception) { showToast('La date de réception est requise', 'error'); return; }
          
          const activeArticles = [];
          // Regular BC articles
          document.querySelectorAll('.article-row:not(.disabled):not(.extra-row)').forEach(row => {
            const id = parseInt(row.dataset.id);
            const input = row.querySelector('.qte-input');
            const qte = parseFloat(input?.value || 0);
            const prixInput = row.querySelector('.prix-input');
            const prixUnitaire = prixInput?.value ? parseFloat(prixInput.value) : null;
            if (qte > 0) activeArticles.push({ id, qte, prixUnitaire });
          });

          // Extra articles
          document.querySelectorAll('.extra-row').forEach(row => {
            const designation = row.querySelector('.extra-designation').value.trim();
            const reference = row.querySelector('.extra-reference').value.trim();
            const qte = parseFloat(row.querySelector('.extra-qte').value) || 0;
            const prixUnitaire = parseFloat(row.querySelector('.extra-prix').value) || 0;
            if (designation && qte > 0) {
              activeArticles.push({ designation, reference, qte, prixUnitaire, isExtra: true });
            }
          });

          if (activeArticles.length === 0) { showToast('Au moins un article actif est requis', 'error'); return; }
          
          const btn = document.getElementById('btnSaveBL');
          btn.disabled = true;
          btn.innerHTML = '<i class="fas fa-spinner fa-spin"></i> Enregistrement...';
          try {
            const response = await fetch('/api/bons-livraison', {
              method: 'POST',
              headers: { 'Content-Type': 'application/json' },
              body: JSON.stringify({ bcId: bcId, numeroBL, dateReception, articles: activeArticles })
            });
            const data = await response.json();
            if (response.ok && data.success) {
              showToast('Bon de livraison créé avec succès', 'success');
              closeCreateBLModal();
              window.location.reload();
            } else {
              throw new Error(data.error || 'Erreur lors de la création');
            }
          } catch (error) {
            showToast('Erreur: ' + error.message, 'error');
          } finally {
            btn.disabled = false;
            btn.innerHTML = '<i class="fas fa-save"></i> Enregistrer le BL';
          }
        }

        async function openAffecterBLModal(bcId) {
          currentAffectationBcId = bcId;
          selectedBLId = null;
          unlinkedBLs = [];
          document.getElementById('affecterBLSubtitle').textContent = 'BC n° ' + (window.currentBCNumero || '');
          document.getElementById('searchBLInput').value = '';
          document.getElementById('btnAffecterBLNext').disabled = true;
          document.getElementById('affecterBLModal').style.display = 'flex';
          await loadUnlinkedBLs();
        }

        function closeAffecterBLModal(preserveContext = false) {
          document.getElementById('affecterBLModal').style.display = 'none';
          if (!preserveContext) {
            selectedBLId = null;
            unlinkedBLs = [];
            document.getElementById('btnAffecterBLNext').disabled = true;
          }
        }

        async function loadUnlinkedBLs(query = '') {
          const container = document.getElementById('blListContainer');
          container.innerHTML = '<div class="text-center py-4"><i class="fas fa-spinner fa-spin"></i><p>Chargement...</p></div>';
          try {
            const fournisseurId = window.currentBCFournisseurId;
            console.log('loadUnlinkedBLs - fournisseurId:', fournisseurId, 'type:', typeof fournisseurId);
            if (!fournisseurId || fournisseurId === 'null' || fournisseurId === 'undefined') {
              container.innerHTML = '<div class="bl-list-empty"><p>Fournisseur non défini pour ce BC.</p></div>';
              return;
            }
            const url = '/api/bons-livraison/search?fournisseur_id=' + fournisseurId + '&q=' + encodeURIComponent(query);
            console.log('Loading BLs from:', url);
            const response = await fetch(url);
            const data = await response.json();
            console.log('BL search response:', response.status, data);
            if (!response.ok) throw new Error('Erreur de chargement: ' + (data.error || response.statusText));
            unlinkedBLs = data;
            renderBLList(unlinkedBLs);
          } catch (error) {
            console.error('loadUnlinkedBLs error:', error);
            container.innerHTML = '<div class="bl-list-empty"><p>Erreur: ' + error.message + '</p></div>';
          }
        }

        function renderBLList(bls) {
          const container = document.getElementById('blListContainer');
          console.log('renderBLList called with:', bls.length, 'items');
          if (bls.length === 0) {
            container.innerHTML = '<div class="bl-list-empty"><p>Aucun BL disponible à affecter</p></div>';
            return;
          }
          let rows = bls.map(bl => {
            const dateStr = bl.dateReception ? new Date(bl.dateReception).toLocaleDateString('fr-FR') : '---';
            return '<div class="bl-list-item ' + (bl.id === selectedBLId ? 'selected' : '') + '" data-id="' + bl.id + '" onclick="selectBL(' + bl.id + ')"><div><strong>BL n° ' + (bl.numero || '---') + '</strong></div><div class="text-muted small">' + dateStr + '</div><div class="text-muted small">' + (bl.fournisseur_name || '---') + '</div><div><span class="badge badge-info">' + (bl.nb_articles || 0) + '</span></div></div>';
          }).join('');
          console.log('Generated HTML:', rows.substring(0, 200));
          container.innerHTML = rows;
          console.log('Container innerHTML length:', container.innerHTML.length);
        }

        function selectBL(blId) {
          selectedBLId = blId;
          document.getElementById('btnAffecterBLNext').disabled = false;
          document.querySelectorAll('.bl-list-item').forEach(item => {
            item.classList.toggle('selected', parseInt(item.dataset.id) === blId);
          });
        }

        function filterBLList() {
          loadUnlinkedBLs(document.getElementById('searchBLInput').value);
        }

        async function goToAffecterBLStep2() {
          if (!selectedBLId || !currentAffectationBcId) {
            showToast('Veuillez sélectionner un BL et un BC valides', 'error');
            return;
          }
          const selectedBL = unlinkedBLs.find(b => b.id === selectedBLId);
          if (!selectedBL) return;
          document.getElementById('affecterBLDetailsTitle').innerHTML = '<i class="fas fa-link"></i> Affecter BL n° ' + selectedBL.numero + ' - BC n° ' + (window.currentBCNumero || '');
          document.getElementById('affecterBLDetailsSubtitle').textContent = (selectedBL.fournisseur_name || '---');
          closeAffecterBLModal(true);
          document.getElementById('affecterBLDetailsModal').style.display = 'flex';
          removedRemainingArticleIds.clear();
          existingBLArticles = [];
          remainingBCArticles = [];
          document.getElementById('existingBLArticlesContainer').innerHTML = '<div class="text-center py-4"><i class="fas fa-spinner fa-spin"></i></div>';
          document.getElementById('remainingBCArticlesContainer').innerHTML = '<div class="text-center py-4"><i class="fas fa-spinner fa-spin"></i></div>';
          document.getElementById('btnConfirmAffectation').disabled = true;
          try {
            const resExisting = await fetch('/api/bons-livraison/' + selectedBLId + '/articles');
            if (resExisting.ok) { existingBLArticles = await resExisting.json(); renderExistingBLArticles(); }
            const resRemaining = await fetch('/api/bons-commande/' + currentAffectationBcId + '/articles-remaining');
            if (resRemaining.ok) { remainingBCArticles = await resRemaining.json(); renderRemainingBCArticles(); }
            checkConfirmButtonState();
          } catch (e) { showToast('Erreur lors du chargement des détails', 'error'); }
        }

        function closeAffecterBLDetailsModal() {
          document.getElementById('affecterBLDetailsModal').style.display = 'none';
        }

        function renderExistingBLArticles() {
          const container = document.getElementById('existingBLArticlesContainer');
          if (existingBLArticles.length === 0) {
            container.innerHTML = '<div class="text-muted small">Aucun article enregistré dans ce BL.</div>';
            return;
          }
          let html = '';
          existingBLArticles.forEach(article => {
            html += '<div style="padding:10px; border-bottom:1px solid #e3e6f0; background:#f8f9fa; opacity:0.6;"><strong>' + (article.designation || '---') + '</strong><div class="text-muted small">Qté: ' + (article.qte_recue || 0) + '</div></div>';
          });
          container.innerHTML = html;
        }

        function renderRemainingBCArticles() {
          const container = document.getElementById('remainingBCArticlesContainer');
          if (remainingBCArticles.length === 0) {
            container.innerHTML = '<div class="text-muted small">Tous les articles de ce BC ont déjà été reçus.</div>';
            return;
          }
          let activeCount = 0;
          let html = '';
          remainingBCArticles.forEach(article => {
            if (removedRemainingArticleIds.has(article.id)) return;
            const qteRestante = article.qte_commandee - article.qte_deja_recue;
            if (qteRestante <= 0) return;
            activeCount++;
            html += '<div class="article-row remaining-article-row" data-id="' + article.id + '" data-qte-commandee="' + article.qte_commandee + '" data-qte-recue="' + article.qte_deja_recue + '" style="display:grid; grid-template-columns:2fr 100px 100px 100px 40px; gap:10px; padding:12px 10px; border-bottom:1px solid #e3e6f0; align-items:center;"><div><strong>' + (article.designation || '---') + '</strong><div style="font-size:0.8rem; color:#6c757d;">Réf: ' + (article.reference || '---') + '</div></div><div class="text-center"><span class="badge badge-info">' + article.qte_deja_recue + '/' + article.qte_commandee + '</span></div><div class="text-center"><input type="number" class="form-control form-control-sm affect-qte-input" data-id="' + article.id + '" value="' + qteRestante + '" min="0" max="' + qteRestante + '"></div><div class="text-center"><input type="number" class="form-control form-control-sm affect-prix-input" data-id="' + article.id + '" value="' + (article.prixUnitaire || '') + '" step="0.01"></div><div><button type="button" class="btn-remove-article" onclick="removeRemainingArticle(' + article.id + ')">×</button></div></div>';
          });
          if (activeCount === 0) {
            container.innerHTML = '<div class="alert alert-info">Tous les articles de ce BC ont déjà été reçus.</div>';
          } else {
            container.innerHTML = html;
          }
          checkConfirmButtonState();
        }

        function removeRemainingArticle(articleId) {
          removedRemainingArticleIds.add(articleId);
          renderRemainingBCArticles();
        }

        function checkConfirmButtonState() {
          const btn = document.getElementById('btnConfirmAffectation');
          if (!btn) return;
          let hasValidArticle = false;
          document.querySelectorAll('.remaining-article-row').forEach(row => {
            const input = row.querySelector('.affect-qte-input');
            if (input && parseInt(input.value) > 0) hasValidArticle = true;
          });
          btn.disabled = !hasValidArticle;
        }

        async function submitAffectationFinale() {
          const bcId = currentAffectationBcId;
          const blId = selectedBLId;
          if (!blId || !bcId) return;
          const articlesToAffect = [];
          document.querySelectorAll('.remaining-article-row').forEach(row => {
            const id = parseInt(row.dataset.id);
            const input = row.querySelector('.affect-qte-input');
            const qte = parseFloat(input?.value || 0);
            const prixInput = row.querySelector('.affect-prix-input');
            const prixUnitaire = prixInput?.value ? parseFloat(prixInput.value) : null;
            if (qte > 0) articlesToAffect.push({ bc_article_id: id, qte_recue: qte, prixUnitaire: prixUnitaire });
          });
          if (articlesToAffect.length === 0) { showToast('Au moins un article valide est requis', 'error'); return; }
          const btn = document.getElementById('btnConfirmAffectation');
          btn.disabled = true;
          btn.innerHTML = '<i class="fas fa-spinner fa-spin"></i> Affectation...';
          try {
            const response = await fetch('/api/bons-livraison/' + blId + '/affecter-bc', {
              method: 'POST',
              headers: { 'Content-Type': 'application/json' },
              body: JSON.stringify({ bc_id: bcId, articles: articlesToAffect })
            });
            const data = await response.json();
            if (response.ok && data.success) {
              showToast('BL affecté avec succès', 'success');
              closeAffecterBLDetailsModal();
              window.location.reload();
            } else {
              throw new Error(data.error || 'Erreur lors de l\'affectation');
            }
          } catch (error) {
            showToast('Erreur: ' + error.message, 'error');
          } finally {
            btn.disabled = false;
            btn.innerHTML = '<i class="fas fa-check"></i> Confirmer l\'affectation';
          }
        }

