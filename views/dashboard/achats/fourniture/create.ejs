<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta http-equiv="X-UA-Compatible" content="IE=edge" />
  <meta name="viewport" content="width=device-width, initial-scale=1, shrink-to-fit=no" />
  <meta name="description" content="Fournisseurs" />
  <meta name="author" content="Confonda" />
  <title>Fournisseurs</title>

  <link href="/vendor/fontawesome-free/css/all.min.css" rel="stylesheet" type="text/css" />
  <link href="https://fonts.googleapis.com/css?family=Nunito:200,300,400,600,700,800,900" rel="stylesheet" />
  <link href="/css/sb-admin-2.min.css" rel="stylesheet" />
 
  
</head>
<body id="page-top">
  <div id="wrapper">
    <%- include('../../../layouts/sidebar') %>

    <!-- Page Wrapper -->
    <div id="content-wrapper" class="d-flex flex-column">
      <!-- Main Content -->
      <div id="content">
        <!-- Topbar -->    
         <%- include('../../../layouts/topbar') %>

        <!-- End of Topbar -->

        <!-- Begin Page Content -->
        <!-- Begin Page Content -->
<div class="container-fluid">

    <!-- Page Heading -->
    <h1 class="h3 mb-4 text-gray-800">Créer une Demande de Fournitures</h1>
  
    <!-- Form Card -->
    <div class="card shadow mb-4">
      <div class="card-body">
        <form id="demandeForm" action="/achats/fourniture/create" method="POST">
          <div class="form-row">
            <!-- Code de la demande -->
            <div class="form-group col-md-6">
              <label for="codeDemande">Code de la demande</label>
              <input type="text" class="form-control" id="codeDemande" name="codeDemande" 
                     value="1" readonly>
            </div>
  
            <!-- Nom Chantier -->
            <div class="form-group col-md-6">
                <input type="number" class="form-control" id="chantierId" name="chantierId" 
                value="<%= user.chantierId %>" hidden>
         
              </div>
  
          <div class="form-row">
            <!-- Date d’établissement -->
            <div class="form-group col-md-6">
              <label for="dateEtablissement">Date d’établissement</label>
              <input type="date" class="form-control" id="dateEtablissement" name="dateEtablissement" 
                     value="<%= new Date().toISOString().split('T')[0] %>" readonly>
            </div>
  
            <!-- Demandeur -->
            <div class="form-group col-md-6">
              <label for="demandeur">Demandeur</label>
              <input type="text" class="form-control" id="demandeur" name="demandeur" 
                     value="<%= user.name %>" readonly>
            </div>
            
          </div>
  
          <!-- Observations -->
          
        </form>
      </div>
    </div>
  
    <!-- Products Table -->
    <!-- Products Table -->
<div class="card shadow mb-4">
    <div class="card-header py-3">
      <h6 class="m-0 font-weight-bold text-primary">Demande Fournitures </h6>
    </div>
    <div class="card-body">
      <div class="table-responsive">
        <table class="table table-bordered text-center align-middle" id="productsTable" width="100%" cellspacing="0">
          <thead class="thead-light">
            <tr>
              <th rowspan="2">Code article</th>
              <th rowspan="2">Désignations</th>
              <th rowspan="2">Unité</th>
              <th colspan="2">Quantités</th>
              <th colspan="2">Date de livraison</th>
              <th colspan="2">Quantités</th>
              <th rowspan="2">LOT</th>
              <th rowspan="2">Recommandations et Observations</th>
              <th rowspan="2"></th>
            </tr>
            <tr>
              <th>Demandées</th>
              <th>Stockées</th>
              <th>Au plus tôt</th>
              <th>Au plus tard</th>
              <th>Prévu</th>
              <th>Reçue</th>
            </tr>
          </thead>
          <tbody>
            <tr>
              <td><input type="text" name="codeArticle[]" class="form-control" value=""></td>
              <td><input type="text" name="designation[]" class="form-control" value=""></td>
              <td><input type="text" name="unite[]" class="form-control" value=""></td>
              <td><input type="number" name="qteDemandee[]" class="form-control" value=""></td>
              <td><input type="number" name="qteStockee[]" class="form-control"></td>
              <td><input type="date" name="dateTôt[]" class="form-control"></td>
              <td><input type="date" name="dateTard[]" class="form-control"></td>
              <td><input type="number" name="qtePrevue[]" class="form-control"></td>
              <td><input type="number" name="qteRecue[]" class="form-control"></td>
              <td><input type="text" name="lot[]" class="form-control"></td>
              <td><input type="text" name="observation[]" class="form-control"></td>
              <td>
                <button type="button" class="btn btn-sm btn-danger deleteRow">
                  <i class="fas fa-trash"></i>
                </button>
              </td>
            </tr>
          </tbody>
        </table>
      </div>
  
      <button type="button" id="addRow" class="btn btn-success btn-sm mt-2">
        <i class="fas fa-plus"></i> Ajouter une Fourniture
      </button>
    </div>
  </div>
  
  <script>
    $(document).ready(function() {
      const tableBody = $("#productsTable tbody");
  
      // Add Row
      $("#addRow").on("click", function() {
        const row = `
          <tr>
            <td><input type="text" name="codeArticle[]" class="form-control"></td>
            <td><input type="text" name="designation[]" class="form-control"></td>
            <td><input type="text" name="unite[]" class="form-control"></td>
            <td><input type="number" name="qteDemandee[]" class="form-control"></td>
            <td><input type="number" name="qteStockee[]" class="form-control"></td>
            <td><input type="date" name="dateTôt[]" class="form-control"></td>
            <td><input type="date" name="dateTard[]" class="form-control"></td>
            <td><input type="number" name="qtePrevue[]" class="form-control"></td>
            <td><input type="number" name="qteRecue[]" class="form-control"></td>
            <td><input type="text" name="lot[]" class="form-control"></td>
            <td><input type="text" name="observation[]" class="form-control"></td>
            <td>
              <button type="button" class="btn btn-sm btn-danger deleteRow">
                <i class="fas fa-trash"></i>
              </button>
            </td>
          </tr>`;
        tableBody.append(row);
      });
  
      // Delete Row
      $(document).on("click", ".deleteRow", function() {
        $(this).closest("tr").remove();
      });
    });
  </script>
  
  
    <!-- Action Buttons -->
    <div class="mb-4 text-right">
     
      <button type="submit" form="demandeForm" name="action" value="submit" class="btn btn-primary">
        Enregistrer la Demande
      </button>
      <a href="/demande-fourniture" class="btn btn-danger">Annuler</a>
    </div>
  </div>
  <!-- /.container-fluid -->
  
  
  
        <!-- /.container-fluid -->
      </div>
      <!-- End of Main Content -->

      <!-- Footer -->
      <footer class="sticky-footer bg-white">
        <div class="container my-auto">
          <div class="copyright text-center my-auto">
            <span>Copyright &copy; Your Website 2020</span>
          </div>
        </div>
      </footer>
      <!-- End of Footer -->
    </div>
    <!-- End of Content Wrapper -->
  </div>
  <!-- End of Page Wrapper -->

  <!-- Scroll to Top Button-->
  <a class="scroll-to-top rounded" href="#page-top">
    <i class="fas fa-angle-up"></i>
  </a>

  <!-- Logout Modal-->
  <div
    class="modal fade"
    id="logoutModal"
    tabindex="-1"
    role="dialog"
    aria-labelledby="exampleModalLabel"
    aria-hidden="true"
  >
    <div class="modal-dialog" role="document">
      <div class="modal-content">
        <div class="modal-header">
          <h5 class="modal-title" id="exampleModalLabel">Ready to Leave?</h5>
          <button
            class="close"
            type="button"
            data-dismiss="modal"
            aria-label="Close"
          >
            <span aria-hidden="true">×</span>
          </button>
        </div>
        <div class="modal-body">
          Select "Logout" below if you are ready to end your current session.
        </div>
        <div class="modal-footer">
          <button class="btn btn-secondary" type="button" data-dismiss="modal">
            Cancel
          </button>
          <a class="btn btn-primary" href="/login">Logout</a>
        </div>
      </div>
    </div>
  </div>

  <!-- Bootstrap core JavaScript-->
  <script src="/vendor/jquery/jquery.min.js"></script>
  <script src="/vendor/bootstrap/js/bootstrap.bundle.min.js"></script>

  <!-- Core plugin JavaScript-->
  <script src="/vendor/jquery-easing/jquery.easing.min.js"></script>

  <!-- Custom scripts for all pages-->
  <script src="/js/sb-admin-2.min.js"></script>

  <!-- Page level plugins -->
  <script src="/vendor/datatables/jquery.dataTables.min.js"></script>
  <script src="/vendor/datatables/dataTables.bootstrap4.min.js"></script>

  <!-- Page level custom scripts -->
  <script src="/js/demo/datatables-demo.js"></script>
</body>
</html>
