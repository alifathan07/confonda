<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta http-equiv="X-UA-Compatible" content="IE=edge" />
  <meta name="viewport" content="width=device-width, initial-scale=1, shrink-to-fit=no" />
  <meta name="description" content="Fournisseurs" />
  <meta name="author" content="Confonda" />
  <title>Fournisseurs</title>

  <link href="/vendor/fontawesome-free/css/all.min.css" rel="stylesheet" type="text/css" />
  <link href="https://fonts.googleapis.com/css?family=Nunito:200,300,400,600,700,800,900" rel="stylesheet" />
  <link href="/css/sb-admin-2.min.css" rel="stylesheet" />
 
  
</head>
<body id="page-top">
  <div id="wrapper">
    <%- include('../../../layouts/sidebar') %>

    <!-- Page Wrapper -->
    <div id="content-wrapper" class="d-flex flex-column">
      <!-- Main Content -->
      <div id="content">
        <!-- Topbar -->    
         <%- include('../../../layouts/topbar') %>

        <!-- End of Topbar -->

        <!-- Begin Page Content -->
        <!-- Begin Page Content -->
<div class="container-fluid">

    <!-- Page Heading -->
    <h1 class="h3 mb-4 text-gray-800">Créer une Demande de Fournitures</h1>
  
    <!-- Form Card -->
    <!-- <div class="card shadow mb-4">
      <div class="card-body">
        <form id="demandeForm" action="/achats/fourniture/create" method="POST">
          
          
        </form>
      </div>
    </div> -->
  
    <!-- Products Table -->
    <!-- Products Table -->
<div class="card shadow mb-4">
    <div class="card-header py-3">
      <h6 class="m-0 font-weight-bold text-primary">Demande Fournitures </h6>
      <br>
          <form 
            id="demandeForm"
            action="/achats/demande/fourniture"
            method="POST"
          >
        <div class="d-flex justify-content-between">
      
            <div class="form-group">
              <label for="date">Date</label>

              <input type="date" class="form-control" id="date" name="date" value="<%= today %>" readonly>
            </div>
            <div class="form-group">
              <label for="numero">Numéro</label>
              <input type="number" class="form-control" id="numero" name="numero" value="<%= numero %>" readonly>
            </div>
            <div class="form-group">
              <label for="user">User</label>
              <input type="text" class="form-control" id="user" name="user" value="<%= user.name %>" readonly>
            </div>

            <div class="form-group">
              <label for="chantierId">Chantier</label>
              <select class="form-control" id="chantierId" name="chantierId" required>
                <option value="">Sélectionner un chantier</option>
                <% if (typeof chantiers !== 'undefined' && chantiers.length > 0) { %>
                  <% chantiers.forEach(c => { %>
                    <option value="<%= c.id %>"><%= c.nom %></option>
                  <% }) %>
                <% } %>
              </select>
            </div>
        
        </div>


        
    </div>
    <div class="card-body">
      <div class="table-responsive">
        <table class="table table-bordered text-center align-middle" id="productsTable" width="100%" cellspacing="0">
          <thead class="thead-light">
            <tr>
              <th rowspan="2">Code article</th>
              <th rowspan="2">Désignations</th>
              <th rowspan="2">Unité</th>
              <th rowspan="2">Quantité</th>
              <th rowspan="2">Imputation</th>
              <th colspan="2">Date de livraison</th>
              <th rowspan="2">Reference</th>
              <th rowspan="2">Recommandations et Observations</th>
              <th rowspan="2"></th>
            </tr>
            <tr>
              
              <th>Au plus tôt</th>
              <th>Au plus tard</th>
              
            </tr>
          </thead>
          <tbody>
            <tr>
  <td><input type="text" name="codeArticle[]" class="form-control" value=""></td>
  <td><input type="text" name="designation[]" class="form-control" value=""></td>
  <td><input type="text" name="unite[]" class="form-control" value=""></td>
  <td><input type="number" name="qteDemandee[]" class="form-control" value=""></td>
  <td><input type="text" name="imputation[]" class="form-control" value=""></td>
  <td><input type="date" name="dateTôt[]" class="form-control"></td>
  <td><input type="date" name="dateTard[]" class="form-control"></td>
  <td><input type="text" name="lot[]" class="form-control"></td>
  <td><input type="text" name="observation[]" class="form-control" value=""></td>
  <td>
    <div class="d-flex justify-content-end">
      <button type="button" class="btn btn-md btn-danger deleteRow">
        <i class="fas fa-trash"></i>
      </button>
      <button type="button" class="btn btn-md btn-primary addRow">
        <i class="fas fa-plus"></i> 
      </button>
    </div>
  </td>
</tr>
          </tbody>
        </table>
      </div>
  
      
    </div>

      </form>
  </div>
  <div class="mb-4 text-right">
     
      <button type="submit" form="demandeForm" name="action" value="submit" class="btn btn-primary" onclick="saveDemande(event)">
        Enregistrer la Demande
      </button>
      <a href="/demande-fourniture" class="btn btn-danger">Annuler</a>
    </div>
  </div>
  <script>
    $(document).ready(function() {
      const tableBody = $("#productsTable tbody");

      let lastChantierAlertAt = 0;
      const showChantierModal = () => {
        if (typeof $ === 'function' && $('#chantierRequiredModal').length && typeof $('#chantierRequiredModal').modal === 'function') {
          $('#chantierRequiredModal').modal('show');
        } else {
          alert('Veuillez sélectionner un chantier avant de continuer.');
        }
      };
      const ensureChantierSelected = () => {
        const chantierId = $('#chantierId').val();
        if (chantierId) return true;

        const now = Date.now();
        if (now - lastChantierAlertAt > 800) {
          lastChantierAlertAt = now;
          showChantierModal();
        }
        $('#chantierId').focus();
        return false;
      };

      $(document).on('focus mousedown keydown click', '#productsTable input, .addRow, .deleteRow', function(e) {
        if (!ensureChantierSelected()) {
          e.preventDefault();
          e.stopImmediatePropagation();
          try { $(this).blur(); } catch (err) {}
          return false;
        }
      });

      // Add Row
      $(document).on("click", ".addRow", function() {
        if (!ensureChantierSelected()) return;
        const rowCount = $("#productsTable tbody tr").length;
        const row = `
          <tr>
            <td><input type="text" name="codeArticle[]" class="form-control" value=""></td>
            <td><input type="text" name="designation[]" class="form-control" value=""></td>
            <td><input type="text" name="unite[]" class="form-control" value=""></td>
            <td><input type="number" name="qteDemandee[]" class="form-control" value=""></td>
            <td><input type="text" name="imputation[]" class="form-control" value=""></td>
            <td><input type="date" name="dateTôt[]" class="form-control"></td>
            <td><input type="date" name="dateTard[]" class="form-control"></td>
            <td><input type="text" name="lot[]" class="form-control"></td>
            <td><input type="text" name="observation[]" class="form-control" value=""></td>
            <td>
              <div class="d-flex justify-content-end">
                <button type="button" class="btn btn-md btn-danger deleteRow">
                  <i class="fas fa-trash"></i>
                </button>
                <button type="button" class="btn btn-md btn-primary addRow">
                  <i class="fas fa-plus"></i> 
                </button>
              </div>
            </td>
          </tr>`;
        tableBody.append(row);
      });

      // Delete Row
      $(document).on("click", ".deleteRow", function() {
        if (!ensureChantierSelected()) return;
        $(this).closest("tr").remove();
      });
    });
    const saveDemande = (e) => {
      if (e) e.preventDefault(); // Prevent default form submission if event is passed

      const chantierId = $('#chantierId').val();
      if (!chantierId) {
        if (typeof $ === 'function' && $('#chantierRequiredModal').length && typeof $('#chantierRequiredModal').modal === 'function') {
          $('#chantierRequiredModal').modal('show');
        } else {
          alert('Veuillez sélectionner un chantier avant de continuer.');
        }
        $('#chantierId').focus();
        return;
      }
      
      // Convert parallel arrays to items array format
      const items = [];
      const codeArticles = $('input[name="codeArticle[]"]').map(function() { return $(this).val(); }).get();
      const designations = $('input[name="designation[]"]').map(function() { return $(this).val(); }).get();
      const unites = $('input[name="unite[]"]').map(function() { return $(this).val(); }).get();
      const qteDemandees = $('input[name="qteDemandee[]"]').map(function() { return $(this).val(); }).get();
      const imputations = $('input[name="imputation[]"]').map(function() { return $(this).val(); }).get();
      const dateTots = $('input[name="dateTôt[]"]').map(function() { return $(this).val(); }).get();
      const dateTards = $('input[name="dateTard[]"]').map(function() { return $(this).val(); }).get();
      const lots = $('input[name="lot[]"]').map(function() { return $(this).val(); }).get();
      const observations = $('input[name="observation[]"]').map(function() { return $(this).val(); }).get();
      
      // Debug logging
      console.log('Collected data:', {
        codeArticles,
        designations,
        unites,
        qteDemandees,
        imputations,
        dateTots,
        dateTards,
        lots,
        observations
      });
      
      for (let i = 0; i < designations.length; i++) {
        if (designations[i] || qteDemandees[i]) {
          items.push({
            code: codeArticles[i] || '',
            designation: designations[i] || '',
            unité: unites[i] || '',
            quantité: qteDemandees[i] || '0',
            imputation: imputations[i] || '',
            auPlutot: dateTots[i] || '',
            auPlutart: dateTards[i] || '',
            lot: lots[i] || '',
            observation: observations[i] || ''
          });
        }
      }
      
      // Debug logging
      console.log('Items array:', items);
      
      // Get form data
      const formData = {
        date: $('#date').val(),
        numero: $('#numero').val(),
        chantierId: chantierId,
        items: items
      };
      
      console.log('Form data to submit:', formData);
      
      // Submit via AJAX
      $.ajax({
        url: '/achats/demande/fourniture',
        method: 'POST',
        contentType: 'application/json',
        data: JSON.stringify(formData),
        success: function(response) {
          console.log('Success:', response);
          if (response.success) {
            window.location.href = response.redirect || '/achats/fourniture';
          } else {
            alert('Erreur: ' + (response.error || response.message || 'Erreur inconnue'));
          }
        },
        error: function(xhr, status, error) {
          console.error('Error:', xhr.responseText);
          alert('Erreur serveur: ' + (xhr.responseJSON?.error || xhr.responseText || error));
        }
      });
    }
  </script>
  
  
    <!-- Action Buttons -->
    
  <!-- /.container-fluid -->
  
  
  
        <!-- /.container-fluid -->
      </div>
      <!-- End of Main Content -->

      <!-- Footer -->
      <footer class="sticky-footer bg-white">
        <div class="container my-auto">
          <div class="copyright text-center my-auto">
            <span>Copyright &copy; Your Website 2020</span>
          </div>
        </div>
      </footer>
      <!-- End of Footer -->
    </div>
    <!-- End of Content Wrapper -->
  </div>
  <!-- End of Page Wrapper -->

  <!-- Scroll to Top Button-->
  <a class="scroll-to-top rounded" href="#page-top">
    <i class="fas fa-angle-up"></i>
  </a>

  <!-- Logout Modal-->
  <div
    class="modal fade"
    id="logoutModal"
    tabindex="-1"
    role="dialog"
    aria-labelledby="exampleModalLabel"
    aria-hidden="true"
  >
    <div class="modal-dialog" role="document">
      <div class="modal-content">
        <div class="modal-header">
          <h5 class="modal-title" id="exampleModalLabel">Ready to Leave?</h5>
          <button
            class="close"
            type="button"
            data-dismiss="modal"
            aria-label="Close"
          >
            <span aria-hidden="true">×</span>
          </button>
        </div>
        <div class="modal-body">
          Select "Logout" below if you are ready to end your current session.
        </div>
        <div class="modal-footer">
          <button class="btn btn-secondary" type="button" data-dismiss="modal">
            Cancel
          </button>
          <a class="btn btn-primary" href="/login">Logout</a>
        </div>
      </div>
    </div>
  </div>

  <div
    class="modal fade"
    id="chantierRequiredModal"
    tabindex="-1"
    role="dialog"
    aria-labelledby="chantierRequiredModalLabel"
    aria-hidden="true"
  >
    <div class="modal-dialog" role="document">
      <div class="modal-content">
        <div class="modal-header">
          <h5 class="modal-title" id="chantierRequiredModalLabel">Chantier requis</h5>
          <button
            class="close"
            type="button"
            data-dismiss="modal"
            aria-label="Close"
          >
            <span aria-hidden="true">×</span>
          </button>
        </div>
        <div class="modal-body">
          Veuillez sélectionner un chantier avant de continuer.
        </div>
        <div class="modal-footer">
          <button class="btn btn-primary" type="button" data-dismiss="modal">
            OK
          </button>
        </div>
      </div>
    </div>
  </div>

  <!-- Bootstrap core JavaScript-->
  <script src="/vendor/jquery/jquery.min.js"></script>
  <script src="/vendor/bootstrap/js/bootstrap.bundle.min.js"></script>

  <!-- Core plugin JavaScript-->
  <script src="/vendor/jquery-easing/jquery.easing.min.js"></script>

  <!-- Custom scripts for all pages-->
  <script src="/js/sb-admin-2.min.js"></script>

  <!-- Page level plugins -->
  <script src="/vendor/datatables/jquery.dataTables.min.js"></script>
  <script src="/vendor/datatables/dataTables.bootstrap4.min.js"></script>

  <!-- Page level custom scripts -->
  <script src="/js/demo/datatables-demo.js"></script>
</body>
</html>
