            <script>
              $(function () {
                const $tbody = $('#productsTable tbody');
                let rowIndex = $tbody.find('tr').length;
                let isUploading = false;

                /* ---------- ADD ROW ---------- */
                $('#btnAddRow').on('click', function () {
                  const html = `
      <tr data-index="${rowIndex}" data-new="true">
        <td class="cell-code"><input type="text" class="form-control code" value=""></td>
        <td class="cell-designation"><input type="text" class="form-control designation designation-input" value="" autocomplete="off"></td>
        <td class="cell-lot"><input type="text" class="form-control lot lot-input" value="" autocomplete="off"></td>
        <td class="cell-unite"><input type="text" class="form-control unite" value=""></td>
        <td class="cell-quantite"><input type="number" class="form-control quantite" min="1" value=""></td>
        <td><input type="date" class="form-control auPlutot" value=""></td>
        <td><input type="date" class="form-control auPlutart" value=""></td>
        <td><input type="text" class="form-control imputation" value=""></td>
        <td class="cell-observation"><input type="text" class="form-control observation" value=""></td>
        <td class="validation-cell"><span class="badge badge-secondary">En attente</span></td>
        <td class="validerPar-cell">-</td>
        <td class="text-center">
           <div class="d-flex justify-content-center mt-2">
              <img class="img-thumbnail ml-2 previewImg d-none" style="max-height:32px;cursor:pointer;">
            </div>
        </td>
       
       
        <td>
          <div class="d-flex align-items-center gap-2">
            <a href="#" class="btn btn-sm btn-secondary downloadBtn d-none" target="_blank">
              <i class="fas fa-download"></i>
            </a>
            <button type="button" class="btn btn-sm btn-primary uploadBtn">
              <i class="fas fa-upload"></i>
            </button>
            <input type="file" class="d-none uploadInput" accept="image/*">
            <input type="hidden" class="tempImage">
            <button type="button" class="btn btn-sm btn-danger deleteRow">
              <i class="fas fa-trash"></i>
            </button>
          </div>
        </td>
      </tr>`;
                  $tbody.append(html);
                  rowIndex++;
                });

                /* ---------- DELETE ROW ---------- */
                let $pendingDeleteRow = null;

                function openDeleteWarning($row) {
                  $pendingDeleteRow = $row;
                  $('#deleteWarningPopup').addClass('is-visible').attr('aria-hidden', 'false');
                }

                function closeDeleteWarning() {
                  $('#deleteWarningPopup').removeClass('is-visible').attr('aria-hidden', 'true');
                }

                $tbody.on('click', '.deleteRow', function () {
                  const $row = $(this).closest('tr');
                  const itemId = $row.data('item-id');

                  if (itemId) {
                    openDeleteWarning($row);
                    return;
                  }

                  $row.remove();
                });

                $('#confirmDeleteWarning').on('click', function () {
                  if (!$pendingDeleteRow) return;
                  $pendingDeleteRow.remove();
                  $pendingDeleteRow = null;
                  closeDeleteWarning();
                  $('#demandeForm').trigger('submit');
                });

                $('#cancelDeleteWarning').on('click', function () {
                  $pendingDeleteRow = null;
                  closeDeleteWarning();
                });

                /* ---------- UPLOAD IMAGE ---------- */
                let $pendingUploadRow = null;

                function openUploadPicker($row) {
                  const $input = $row.find('.uploadInput');
                  $input.val('');
                  setTimeout(() => $input.trigger('click'), 0);
                }

                $tbody.on('click', '.uploadBtn', function (e) {
                  e.preventDefault();
                  if (isUploading) return;
                  const $row = $(this).closest('tr');
                  const isNew = $row.data('new') === true;
                  const hasUnsavedRows = $tbody.find('tr[data-new="true"]').length > 0;

                  if (!isNew && hasUnsavedRows) {
                    $pendingUploadRow = $row;
                    $('#uploadWarningPopup').addClass('is-visible').attr('aria-hidden', 'false');
                    return;
                  }

                  openUploadPicker($row);
                });

                function closeUploadWarning() {
                  $('#uploadWarningPopup').removeClass('is-visible').attr('aria-hidden', 'true');
                }

                $('#confirmUploadWarning').on('click', function () {
                  if ($pendingUploadRow) {
                    const $row = $pendingUploadRow;
                    $pendingUploadRow = null;
                    closeUploadWarning();
                    openUploadPicker($row);
                  }
                });

                $('#cancelUploadWarning').on('click', function () {
                  $pendingUploadRow = null;
                  closeUploadWarning();
                });

                $tbody.on('change', '.uploadInput', function () {
                  const input = this;
                  const file = input.files[0];
                  if (!file) return;

                  const $row = $(input).closest('tr');
                  const $btn = $row.find('.uploadBtn');
                  const $preview = $row.find('.previewImg');
                  const $download = $row.find('.downloadBtn');
                  const $tempHidden = $row.find('.tempImage');

                  const itemId = $row.data('item-id');
                  const isNew = $row.data('new') === true;

                  if (isUploading) return;
                  isUploading = true;
                  $btn.prop('disabled', true);

                  const fd = new FormData();
                  fd.append('image', file);

                  const url = isNew
                    ? '/achat/fourniture/upload-temp-image'
                    : `/achat/fourniture/${itemId}/upload-image`;

                  $.ajax({
                    url,
                    method: 'POST',
                    data: fd,
                    processData: false,
                    contentType: false,
                    success: function (res) {
                      if (!res.success) {
                        alert(res.error || 'Erreur');
                        return;
                      }

                      const imgUrl = res.data.image;
                      $preview.attr('src', imgUrl).removeClass('d-none')
                        .off('click').on('click', () => window.open(imgUrl, '_blank'));

                      if (!isNew) {
                        $download.attr('href', `/achat/fourniture/${itemId}/download-image`)
                          .removeClass('d-none').addClass('btn-info');
                      }

                      if (isNew) $tempHidden.val(imgUrl);

                      if (!isNew) {
                        window.location.reload();
                      }
                    },
                    error: () => alert("Erreur d'upload"),
                    complete: () => {
                      isUploading = false;
                      $btn.prop('disabled', false);
                      input.value = '';
                    }
                  });
                });

                /* ---------- FORM SUBMIT ---------- */
                $('#demandeForm').on('submit', function (e) {
                  e.preventDefault();

                  const items = [];
                  $tbody.find('tr').each(function () {
                    const $tr = $(this);
                    const item = {
                      id: $tr.find('.itemId').val() || null,
                      code: $tr.find('.cell-code').find('input').val(),
                      designation: $tr.find('.cell-designation').find('input').val(),
                      unite: $tr.find('.cell-unite').find('input').val(),
                      quantite: $tr.find('.cell-quantite').find('input').val(),
                      imputation: $tr.find('.imputation').val(),
                      auPlutot: $tr.find('.auPlutot').val(),
                      auPlutart: $tr.find('.auPlutart').val(),
                      lot: $tr.find('.cell-lot').find('input').val(),
                      observation: $tr.find('.cell-observation').find('input').val(),
                      prixU: $tr.find('.prixU').val(),
                      delaisPaiement: $tr.find('.delaisPaiement').val(),
                      tempImage: $tr.find('.tempImage').first().val() || null,
                    };


                    items.push(item);
                  });

                  const fd = new FormData();
                  fd.append('items', JSON.stringify(items));
                  fd.append('date', $('#date').val());
                  fd.append('numero', $('#numero').val());

                  let fileIndex = 0;
                  $tbody.find('tr[data-new="true"]').each(function () {
                    const $input = $(this).find('.uploadInput')[0];
                    if ($input && $input.files[0]) {
                      fd.append(`newImage_${fileIndex}`, $input.files[0]);
                      fileIndex++;
                    }
                  });
                  fd.append('newImageCount', fileIndex);

                  $.ajax({
                    url: '/achats/fourniture/<%= demandeFourniture.id %>',
                    method: 'PUT',
                    data: fd,
                    processData: false,
                    contentType: false,
                    success: () => location.reload(),
                    error: xhr => alert("Erreur: " + (xhr.responseJSON?.error || 'Inconnue'))
                  });
                });

                /* ---------- VALIDATE ALL (Admin) ---------- */
                $('#btnValiderAll').on('click', function () {
                  fetch(`/achat/fourniture/validate-all/<%= demandeFourniture.id %>`, {
                    method: 'PATCH',
                    headers: { 'Content-Type': 'application/json' }
                  }).then(r => r.json()).then(d => {
                    if (d.success) location.reload();
                    else alert(d.error);
                  });
                });

                /* ---------- INDIVIDUAL VALIDATION (Admin) ---------- */
                $tbody.on('change', '.validation-dropdown', function () {
                  const $dropdown = $(this);
                  const itemId = $dropdown.data('id');
                  const status = $dropdown.val(); // "1", "0", or "null"

                  $dropdown.prop('disabled', true);

                  fetch(`/achat/fourniture/${itemId}/validate`, {
                    method: 'PATCH',
                    headers: { 'Content-Type': 'application/json' },
                    credentials: 'same-origin',
                    body: JSON.stringify({ validation: status })
                  })
                    .then(r => {
                      if (!r.ok) return r.json().then(err => { throw new Error(err.error || 'Erreur serveur'); });
                      return r.json();
                    })
                    .then(data => {
                      if (!data.success) throw new Error(data.error);
                      window.location.reload();

                      const $row = $dropdown.closest('tr');
                      const $badgeCell = $row.find('.validation-cell');
                      const $validerPar = $row.find('.validerPar-cell');

                      // Update badge based on status
                      let badgeHtml = '';
                      switch (status) {
                        case '1':
                          badgeHtml = '<span class="badge badge-success">Validée</span>';
                          break;
                        case '0':
                          badgeHtml = '<span class="badge badge-danger">Refusée</span>';
                          break;
                        case 'null':
                        default:
                          badgeHtml = '<span class="badge badge-secondary">En attente</span>';
                          break;
                      }

                      $badgeCell.find('.badge').remove();
                      $badgeCell.prepend(badgeHtml);
                      $validerPar.text(data.data.validepar || '-');
                    })
                    .catch(err => {
                      alert(err.message);
                      // Revert dropdown to previous value
                      const $row = $dropdown.closest('tr');
                      const currentValidation = $row.find('.validation-cell .badge').hasClass('badge-success') ? '1' :
                        $row.find('.validation-cell .badge').hasClass('badge-danger') ? '0' : 'null';
                      $dropdown.val(currentValidation);
                    })
                    .finally(() => $dropdown.prop('disabled', false));
                });

                // ==========================
                //  AUTOCOMPLETE LOGIC (GLOBAL)
                // ==========================
                let fournitureData = [];
                let activeInput = null;

                // Create global suggestion list
                const $globalList = $('<ul id="global-autocomplete-list"></ul>').appendTo('body');

                const positionList = (input) => {
                  const rect = input[0].getBoundingClientRect();
                  const scrollTop = $(window).scrollTop();
                  const scrollLeft = $(window).scrollLeft();

                  $globalList.css({
                    top: rect.bottom + scrollTop + 'px',
                    left: rect.left + scrollLeft + 'px',
                    width: rect.width + 'px',
                    display: 'block'
                  });
                };

                $(window).on('scroll resize', function () { $globalList.hide(); });
                $('.table-responsive').on('scroll', function () { $globalList.hide(); });

                // 1. Fetch data
                fetch('/achats/listfourniture')
                  .then(res => res.json())
                  .then(data => {
                    if (data && data.listfourniture) fournitureData = data.listfourniture;
                    else if (Array.isArray(data)) fournitureData = data;
                  })
                  .catch(err => console.error("Error/Autocompletion:", err));

                // 2. Designation Input
                $(document).on('input focus', '.designation-input', function () {
                  const input = $(this);
                  activeInput = input;
                  const val = input.val().toLowerCase();

                  $globalList.empty().hide();
                  if (!val) return;

                  const uniqueDesignations = new Set();
                  const matches = [];
                  for (const item of fournitureData) {
                    const d = (item.designation || "").trim();
                    if (d.toLowerCase().includes(val)) {
                      if (!uniqueDesignations.has(d)) {
                        uniqueDesignations.add(d);
                        matches.push(item);
                      }
                    }
                    if (matches.length >= 20) break;
                  }

                  if (matches.length > 0) {
                    matches.forEach(m => {
                      const li = $('<li>').text(m.designation);
                      li.data('type', 'designation');
                      li.data('value', m.designation);
                      $globalList.append(li);
                    });
                    positionList(input);
                  }
                });

                // 3. Lot Input
                $(document).on('input focus', '.lot-input', function () {
                  const input = $(this);
                  activeInput = input;
                  const tr = input.closest('tr');
                  const designation = tr.find('.designation-input').val();

                  $globalList.empty().hide();
                  if (!designation) return;

                  const val = input.val().toLowerCase();
                  const matches = fournitureData
                    .filter(item => (item.designation || "").trim() === designation.trim())
                    .filter(item => (item.reference || "").toLowerCase().includes(val));

                  if (matches.length > 0) {
                    matches.forEach(m => {
                      const refText = m.reference || "(Pas de référence)";
                      const li = $('<li>').text(refText);
                      li.data('type', 'lot');
                      li.data('item', m);
                      $globalList.append(li);
                    });
                    positionList(input);
                  }
                });

                // 4. Selection
                $globalList.on('click', 'li', function () {
                  const li = $(this);
                  const type = li.data('type');
                  if (!activeInput) return;

                  const tr = activeInput.closest('tr');

                  if (type === 'designation') {
                    activeInput.val(li.data('value'));
                    tr.find('.lot-input').val('');
                    tr.find('.unite').val('');
                  } else if (type === 'lot') {
                    const item = li.data('item');
                    activeInput.val(item.reference || "");
                    if (item.unite) tr.find('.unite').val(item.unite);
                  }
                  $globalList.hide();
                  activeInput = null;
                });

                $(document).on('click', function (e) {
                  if (!$(e.target).closest('.designation-input, .lot-input, #global-autocomplete-list').length) {
                    $globalList.hide();
                  }
                });

              }); // <-- Fermeture du $(function()

              /* ---------- PDF DOWNLOAD ---------- */
              async function generatepdf(id, numero) {
                try {
                  const res = await fetch(`/achats/demandefourniture/${id}/pdf`);
                  if (!res.ok) throw new Error('Erreur lors du téléchargement');
                  const blob = await res.blob();
                  const url = URL.createObjectURL(blob);
                  const link = document.createElement('a');
                  link.href = url;
                  const date = new Date().getFullYear();
                  link.download = `demandeFourniture_${numero}_${date}.pdf`;
                  document.body.appendChild(link);
                  link.click();
                  link.remove();
                  URL.revokeObjectURL(url);
                } catch (err) {
                  console.error(err);
                  alert('Erreur lors du téléchargement du PDF');
                }
              }



            </script>

</body>

</html>