                            <!-- ====== JS: CONFONDA Modal Logic ====== -->
                            <script>
                              let fournisseurs = [];
                              let selectedItems = [];
                              let convertMode = 'devis'; // 'devis' | 'bc'

                              // Filter Logic
                              $('#filterDelaisPaiement').on('change', function () {
                                const selectedVal = $(this).val();
                                $('#confondaTable tbody tr').each(function () {
                                  // Skip details rows
                                  if ($(this).hasClass('details-row')) return;

                                  const rowVal = $(this).find('.delaisPaiement').val();
                                  // Check if we show or hide
                                  // If filter is empty, show all. If filter matches row, show.
                                  if (selectedVal === '' || rowVal === selectedVal) {
                                    $(this).removeClass('d-none');
                                  } else {
                                    $(this).addClass('d-none');
                                    // Also hide details row if it exists
                                    const next = $(this).next();
                                    if (next.hasClass('details-row')) {
                                      next.addClass('d-none');
                                    }
                                  }
                                });
                                calculateTotals();
                              });

                              // Auto-calculation for CONFONDA table
                              $(document).on('input', '.prixU, .cell-quantite', function () {
                                const $tr = $(this).closest('tr');
                                const qty = parseFloat($tr.find('.cell-quantite').text().replace(',', '.') || 0);
                                const pu = parseFloat($tr.find('.prixU').val().replace(',', '.') || 0);
                                const total = qty * pu;
                                $tr.find('.itemTotalHt').text(total.toLocaleString('fr-FR', { minimumFractionDigits: 2, maximumFractionDigits: 2 }));
                              });

                              // Ouvrir modal en mode DEMANDE DE PRIX
                              $(document).on('click', '#convertToDevisBtn', function (e) {
                                e.preventDefault();
                                convertMode = 'devis';
                                selectedItems = [];
                                $('#itemsList').empty();
                                $('#loadingFournisseurs').removeClass('d-none');

                                $('#convertDevisModalLabel').text('Convertir en Devis');

                                $.get('/api/fournisseurs')
                                  .done(data => {
                                    fournisseurs = data;
                                    renderItemsForConversion();
                                  })
                                  .fail(() => alert('Erreur lors du chargement des fournisseurs'))
                                  .always(() => $('#loadingFournisseurs').addClass('d-none'));

                                $('#convertDevisModal').modal('show');
                              });

                              // Ouvrir modal en mode BON DE COMMANDE (même contenu, autre action)
                              $(document).on('click', '#convertToBonCommandeBtn', function (e) {
                                e.preventDefault();
                                convertMode = 'bc';
                                selectedItems = [];
                                $('#itemsList').empty();
                                $('#loadingFournisseurs').removeClass('d-none');

                                $('#convertDevisModalLabel').text('Convertir en Bon de commande');

                                $.get('/api/fournisseurs')
                                  .done(data => {
                                    fournisseurs = data;
                                    renderItemsForConversion();
                                  })
                                  .fail(() => alert('Erreur lors du chargement des fournisseurs'))
                                  .always(() => $('#loadingFournisseurs').addClass('d-none'));

                                $('#convertDevisModal').modal('show');
                              });

                              function renderItemsForConversion() {
                                const $list = $('#itemsList');
                                $list.empty();

                                $('#confondaTable tbody tr').each(function () {
                                  const $tr = $(this);
                                  if ($tr.hasClass('d-none')) return;

                                  const itemId = $tr.data('item-id');
                                  if (!itemId) return;

                                  const designation = $tr.find('.cell-designation').text().trim();
                                  const quantite = $tr.find('.cell-quantite').text().trim();
                                  const unite = $tr.find('.cell-unite').text().trim();

                                  if (!designation) return;

                                  const itemHtml = `
        <div class="border rounded p-3 mb-2 article-item">
          <div class="custom-control custom-checkbox">
            <input type="checkbox" class="custom-control-input item-checkbox" id="item-${itemId}" value="${itemId}">
            <label class="custom-control-label font-weight-bold" for="item-${itemId}">
              ${designation} (${quantite} ${unite})
            </label>
          </div>
          <div class="form-group mt-2 ml-4">
            <label class="small">Fournisseur</label>
            <select class="form-control form-control-sm fournisseur-select" data-item-id="${itemId}" disabled>
              <option value="">-- Choisir --</option>
              ${fournisseurs.map(f => `<option value="${f.id}">${f.name} (${f.email})</option>`).join('')}
            </select>
          </div>
        </div>`;
                                  $list.append(itemHtml);
                                });

                                $list.off('change', '.item-checkbox').on('change', '.item-checkbox', function () {
                                  const $select = $(this).closest('.article-item').find('.fournisseur-select');
                                  $select.prop('disabled', !this.checked);
                                  if (!this.checked) $select.val('');
                                });
                              }

                              $(document).on('click', '#btnCreateDevis', function () {
                                selectedItems = [];
                                let hasValidSelection = false;

                                $('#itemsList .item-checkbox:checked').each(function () {
                                  const itemId = $(this).val();
                                  const fournisseurId = $(this).closest('.article-item').find('.fournisseur-select').val();
                                  if (fournisseurId) {
                                    selectedItems.push({ itemId, fournisseurId });
                                    hasValidSelection = true;
                                  }
                                });

                                if (!hasValidSelection) {
                                  alert('Veuillez sélectionner au moins un article avec un fournisseur.');
                                  return;
                                }

                                const $btn = $(this).prop('disabled', true).html('<span class="spinner-border spinner-border-sm"></span> Création...');

                                const url = convertMode === 'bc'
                                  ? '/achats/bon-commande/create-from-demande'
                                  : '/achats/demande/prix';

                                $.ajax({
                                  url,
                                  method: 'POST',
                                  contentType: 'application/json',
                                  data: JSON.stringify({
                                    demandeId: <%= demandeFourniture.id %>,
                                    items: selectedItems,
                                  }),
                                  success: (res) => {
                                    if (res.success) {
                                      const count = res.count || 1;
                                      const primaryId = res.primaryId || (res.demandePrixIds && res.demandePrixIds[0]);

                                      const basePath = convertMode === 'bc'
                                        ? '/achat/bc'
                                        : '/achat/demande-prix';

                                      if (primaryId) {
                                        if (count === 1) {
                                          window.location.href = `${basePath}/${primaryId}/edit`;
                                        } else {
                                          const message = convertMode === 'bc'
                                            ? `${count} bon(s) de commande créés.\nVoulez-vous voir le premier ?`
                                            : `${count} demandes de prix créées.\nVoulez-vous voir la première ?`;

                                          if (confirm(message)) {
                                            window.location.href = `${basePath}/${primaryId}/edit`;
                                          } else {
                                            $('#convertDevisModal').modal('hide');
                                            alert(convertMode === 'bc'
                                              ? `${count} bon(s) de commande créés avec succès !`
                                              : `${count} demandes de prix créées avec succès !`);
                                          }
                                        }
                                      } else {
                                        alert('Création effectuée mais ID introuvable.');
                                      }
                                    } else {
                                      alert(res.error || 'Erreur lors de la création');
                                    }
                                  },
                                  error: () => alert('Erreur réseau'),
                                  complete: () => {
                                    $btn.prop('disabled', false).html('Convertir');
                                    $('#convertDevisModal').modal('hide');
                                  },
                                });
                              });

                              // Save Pricing for CONFONDA
                              $(document).on('click', '#btnSavePricing', function () {
                                const items = [];
                                $('#confondaTable tbody tr').each(function () {
                                  const $tr = $(this);
                                  const itemId = $tr.data('item-id');
                                  if (!itemId) return;
                                  const prixU = parseFloat($tr.find('.prixU').val().replace(',', '.') || 0);
                                  const delaisPaiement = $tr.find('.delaisPaiement').val();
                                  items.push({ id: itemId, prixU, delaisPaiement });
                                });

                                const tauxTva = parseFloat($('#tauxTvaConfonda').val().replace(',', '.') || 0);
                                const demandeId = <%= demandeFourniture.id %>;
                                const url = `/achats/fourniture/update/pricing/${demandeId}`;

                                console.log('Saving pricing:', { items, tauxTva, url });

                                const $btn = $(this).prop('disabled', true).html('<span class="spinner-border spinner-border-sm"></span> Saving...');

                                $.ajax({
                                  url,
                                  method: 'PUT',
                                  contentType: 'application/json',
                                  data: JSON.stringify({ items, tauxTva }),
                                  success: (res) => {
                                    console.log('Pricing save response:', res);
                                    if (res.success) {
                                      alert('Pricing mis à jour avec succès');
                                      window.location.reload();
                                    } else {
                                      alert(res.error || 'Erreur lors de la mise à jour');
                                    }
                                  },
                                  error: (xhr) => {
                                    console.error('Pricing save error:', xhr);
                                    // Fallback: try POST if PUT fails (some servers don’t support PUT)
                                    if (xhr.status === 404 || xhr.status === 405) {
                                      $.ajax({
                                        url,
                                        method: 'POST',
                                        contentType: 'application/json',
                                        data: JSON.stringify({ items, tauxTva }),
                                        success: (res) => {
                                          console.log('Pricing save response (POST):', res);
                                          if (res.success) {
                                            alert('Pricing mis à jour avec succès');
                                            window.location.reload();
                                          } else {
                                            alert(res.error || 'Erreur lors de la mise à jour');
                                          }
                                        },
                                        error: (xhr2) => {
                                          console.error('Pricing save error (POST):', xhr2);
                                          alert('Erreur réseau (POST fallback failed)');
                                        },
                                        complete: () => {
                                          $btn.prop('disabled', false).html('Save Pricing');
                                        },
                                      });
                                    } else {
                                      alert('Erreur réseau');
                                    }
                                  },
                                  complete: () => {
                                    $btn.prop('disabled', false).html('Save Pricing');
                                  },
                                });
                              });

                            </script>
                            <% } %>
                              <!-- Upload warning popup -->
                              <div class="upload-warning-overlay" id="uploadWarningPopup" aria-hidden="true">
                                <div class="upload-warning-card" role="dialog" aria-labelledby="uploadWarningTitle"
                                  aria-modal="true">
                                  <div class="upload-warning-header">
