                            <div class="row mt-3 justify-content-end">
                              <div class="col-md-3">
                                <div class="card shadow-sm">
                                  <div class="card-body p-3">
                                    <div class="d-flex justify-content-between align-items-center mb-2">
                                      <span class="font-weight-bold">Total HT :</span>
                                      <div class="text-right">
                                        <span id="globalTotalHt" class="h5 mb-0">0,00</span>
                                        <input type="hidden" id="hiddenGlobalTotalHt">
                                      </div>
                                    </div>

                                    <div class="d-flex justify-content-between align-items-center mb-2">
                                      <span class="font-weight-bold">TVA (%) :</span>
                                      <div class="text-right">
                                        <% let initialTvaRate=20; if (demandeFourniture.totalHt> 0 &&
                                          demandeFourniture.Tva >= 0) {
                                          initialTvaRate = (demandeFourniture.Tva / demandeFourniture.totalHt) *
                                          100;
                                          }
                                          %>
                                          <input type="number" id="tauxTvaConfonda"
                                            class="form-control form-control-sm text-right ml-auto" style="width: 80px;"
                                            value="<%= Number(initialTvaRate).toFixed(2) %>" step="0.01" min="0"
                                            max="100">
                                      </div>
                                    </div>

                                    <div class="d-flex justify-content-between align-items-center mb-2">
                                      <span class="font-weight-bold">Montant TVA :</span>
                                      <span id="globalMontantTva">0,00</span>
                                    </div>

                                    <hr class="my-2">

                                    <div class="d-flex justify-content-between align-items-center">
                                      <span class="font-weight-bold text-primary">Total TTC :</span>
                                      <span id="globalTotalTtc"
                                        class="h5 mb-0 font-weight-bold text-primary">0,00</span>
                                    </div>
                                  </div>
                                </div>
                              </div>
                            </div>
                            <script>
                              function calculateTotals() {
                                let totalHt = 0;
                                // Sum up all item totals
                                document.querySelectorAll('#confondaTable .itemTotalHt').forEach(el => {
                                  // Skip invisible rows
                                  if (el.closest('tr').classList.contains('d-none')) return;

                                  // Extract number from string like "1 250,50" -> 1250.50
                                  let valStr = el.innerText.replace(/\s/g, '').replace(',', '.');
                                  let val = parseFloat(valStr);
                                  if (!isNaN(val)) totalHt += val;
                                });

                                // Get TVA rate
                                let tvaRate = parseFloat(document.getElementById('tauxTvaConfonda').value.replace(',', '.')) || 0;
                                let montantTva = totalHt * (tvaRate / 100);
                                let totalTtc = totalHt + montantTva;

                                // Update UI
                                const fmt = (n) => n.toLocaleString('fr-FR', { minimumFractionDigits: 2, maximumFractionDigits: 2 });

                                document.getElementById('globalTotalHt').innerText = fmt(totalHt);
                                document.getElementById('hiddenGlobalTotalHt').value = totalHt;
                                document.getElementById('globalMontantTva').innerText = fmt(montantTva);
                                document.getElementById('globalTotalTtc').innerText = fmt(totalTtc);
                              }

                              // Initial calculation
                              document.addEventListener('DOMContentLoaded', calculateTotals);

                              // Recalculate on any change
                              $(document).on('input', '.prixU, .cell-quantite', function () {
                                // Let the row calculation finish first (event bubbling order)
                                // Wait a macrotask or just call it after the current stack if needed
                                // But since the other handler is also 'input', order depends on registration.
                                // The other handler updates .itemTotalHt text. We need that to be done.
                                // The other handler is registered at line ~715. This one is injected after table.
                                // So this one might run AFTER.

                                // Wait 50ms to ensure row update is done
                                setTimeout(calculateTotals, 50);
                              });

                              document.getElementById('tauxTvaConfonda').addEventListener('input', calculateTotals);
                            </script>
                            <script>
                              document.addEventListener('click', function (e) {
                                if (!e.target.classList.contains('toggle-details')) return;

                                e.preventDefault();
                                e.stopPropagation(); // 🔥 THIS IS THE KEY

                                const mainRow = e.target.closest('tr');
                                const detailsRow = mainRow.nextElementSibling;

                                if (detailsRow && detailsRow.classList.contains('details-row')) {
                                  detailsRow.classList.toggle('d-none');
                                }
                              });

                            </script>



                            <!-- ///////////////////////////////////////////// MODAL Bon de commande (non utilisé par le JS, IDs renommés pour éviter les conflits) /////////////////////////////////////////////  -->
