<!DOCTYPE html>
<html lang="fr">

<head>
  <meta charset="UTF-8">
  <meta http-equiv="X-UA-Compatible" content="IE=edge">
  <meta name="viewport" content="width=device-width, initial-scale=1, shrink-to-fit=no">
  <title>Modifier la Demande de Fournitures</title>

  <link href="/vendor/fontawesome-free/css/all.min.css" rel="stylesheet">
  <link href="https://fonts.googleapis.com/css?family=Nunito:200,300,400,600,700,800,900" rel="stylesheet">
  <link href="/css/sb-admin-2.min.css" rel="stylesheet">

  <style>
    .upload-warning-overlay {
      position: fixed;
      inset: 0;
      background: rgba(15, 23, 42, 0.55);
      display: flex;
      align-items: center;
      justify-content: center;
      opacity: 0;
      visibility: hidden;
      transition: opacity 0.2s ease, visibility 0.2s ease;
      z-index: 1055;
    }

    .upload-warning-overlay.is-visible {
      opacity: 1;
      visibility: visible;
    }

    .upload-warning-card {
      background: #ffffff;
      border-radius: 16px;
      width: min(92vw, 420px);
      box-shadow: 0 20px 50px rgba(15, 23, 42, 0.3);
      overflow: hidden;
      transform: translateY(10px);
      transition: transform 0.2s ease;
    }

    .upload-warning-overlay.is-visible .upload-warning-card {
      transform: translateY(0);
    }

    .upload-warning-header {
      background: linear-gradient(135deg, #f59e0b, #f97316);
      color: #111827;
      padding: 18px 20px;
      display: flex;
      align-items: center;
      gap: 10px;
      font-weight: 700;
      font-size: 16px;
    }

    .upload-warning-body {
      padding: 18px 20px 8px;
      color: #374151;
      font-size: 14px;
      line-height: 1.5;
    }

    .upload-warning-body .muted {
      color: #6b7280;
      margin-top: 6px;
      font-size: 13px;
    }

    .upload-warning-actions {
      padding: 14px 20px 18px;
      display: flex;
      justify-content: flex-end;
      gap: 10px;
    }

    .upload-warning-btn {
      border: none;
      border-radius: 10px;
      padding: 8px 14px;
      font-weight: 600;
      cursor: pointer;
    }

    .upload-warning-btn.cancel {
      background: #f3f4f6;
      color: #374151;
    }

    .upload-warning-btn.confirm {
      background: #f59e0b;
      color: #111827;
    }

    .delete-warning-overlay {
      position: fixed;
      inset: 0;
      background: rgba(15, 23, 42, 0.55);
      display: flex;
      align-items: center;
      justify-content: center;
      opacity: 0;
      visibility: hidden;
      transition: opacity 0.2s ease, visibility 0.2s ease;
      z-index: 1056;
    }

    .delete-warning-overlay.is-visible {
      opacity: 1;
      visibility: visible;
    }

    .delete-warning-card {
      background: #ffffff;
      border-radius: 16px;
      width: min(92vw, 440px);
      box-shadow: 0 24px 60px rgba(15, 23, 42, 0.25);
      overflow: hidden;
      transform: translateY(10px);
      transition: transform 0.2s ease;
    }

    .delete-warning-overlay.is-visible .delete-warning-card {
      transform: translateY(0);
    }

    .delete-warning-header {
      display: flex;
      align-items: center;
      gap: 10px;
      padding: 16px 20px;
      font-weight: 700;
      background: #fee2e2;
      color: #991b1b;
    }

    .delete-warning-header i {
      font-size: 18px;
    }

    .delete-warning-body {
      padding: 18px 20px 8px;
      color: #374151;
      font-size: 14px;
      line-height: 1.5;
    }

    .delete-warning-body .muted {
      margin-top: 6px;
      color: #6b7280;
      font-size: 13px;
    }

    .delete-warning-actions {
      padding: 14px 20px 18px;
      display: flex;
      justify-content: flex-end;
      gap: 10px;
    }

    .delete-warning-btn {
      border: none;
      border-radius: 10px;
      padding: 8px 14px;
      font-weight: 600;
      cursor: pointer;
    }

    .delete-warning-btn.cancel {
      background: #e2e8f0;
      color: #0f172a;
    }

    .delete-warning-btn.confirm {
      background: #ef4444;
      color: #ffffff;
    }

    .cell-designation {
      min-width: 280px;
      max-width: 520px;
    }

    #productsTable {
      table-layout: auto;
      min-width: 1550px;
    }

    #productsTable th,
    #productsTable td {
      vertical-align: middle;
    }

    #productsTable input.form-control {
      min-width: 90px;
    }

    #productsTable .cell-code {
      min-width: 140px;
    }

    #productsTable .cell-lot {
      min-width: 160px;
    }

    #productsTable .cell-unite {
      min-width: 120px;
    }

    #productsTable .cell-quantite {
      min-width: 120px;
    }

    #productsTable .validation-cell {
      min-width: 140px;
    }

    #productsTable .validerPar-cell {
      min-width: 150px;
    }

    #productsTable .cell-observation {
      min-width: 320px;
      white-space: normal;
    }

    #productsTable .cell-designation {
      white-space: normal;
    }

    /* Autocomplete Styles - Global Container */
    #global-autocomplete-list {
      position: absolute;
      z-index: 9999;
      background-color: #fff;
      border: 1px solid #ccc;
      max-height: 200px;
      overflow-y: auto;
      padding: 0;
      margin: 0;
      list-style: none;
      box-shadow: 0 4px 6px rgba(0, 0, 0, 0.1);
      border-radius: 4px;
      display: none;
      /* Hidden by default */
      min-width: 200px;
    }

    #global-autocomplete-list li {
      padding: 8px 12px;
      cursor: pointer;
      border-bottom: 1px solid #eee;
    }

    #global-autocomplete-list li:last-child {
      border-bottom: none;
    }

    #global-autocomplete-list li:hover {
      background-color: #f1f3f9;
    }
  </style>
</head>

<body id="page-top">
  <div id="wrapper">
    <%- include('../../../layouts/sidebar') %>

      <div id="content-wrapper" class="d-flex flex-column">
        <div id="content">
          <%- include('../../../layouts/topbar') %>

            <div class="container-fluid">
              <h1 class="h3 mb-4 text-gray-800">Modifier la Demande de Fournitures</h1>
              <div class="d-flex justify-content-between align-items-center mb-3">
                <div></div>

                <button type="button" class="btn btn-danger btn-sm"
                  onclick="generatepdf(<%= demandeFourniture.id %> , <%= demandeFourniture.numero %>)"><i
                    class="fas fa-file-pdf"></i> PDF</button>

              </div>

              <form id="demandeForm">
                <!-- Hidden JSON field for items -->
                <input type="hidden" name="items" id="itemsJson">

                <div class="card shadow mb-4">
                  <div class="card-header py-3">
                    <h6 class="m-0 font-weight-bold text-primary">Demande Fournitures</h6>
                    <br>
                    <div class="d-flex justify-content-between">
                      <div class="form-group">
                        <label for="date">Date</label>
                        <input type="text" class="form-control" id="date" value="<%= demandeFourniture.dateDemande
                    ? (function(){
                        const d = new Date(demandeFourniture.dateDemande);
                        const day   = String(d.getDate()).padStart(2,'0');
                        const month = String(d.getMonth()+1).padStart(2,'0');
                        const year  = d.getFullYear();
                        return `${day}/${month}/${year}`;
                      })()
                    : '' %>" readonly>
                      </div>

                      <div class="form-group">
                        <label for="numero">Numéro</label>
                        <input type="number" class="form-control" id="numero" value="<%= demandeFourniture.numero %>"
                          readonly>
                      </div>

                      <div class="form-group">
                        <label for="user">User</label>
                        <input type="text" class="form-control" id="user" value="<%= demandeFourniture.user.name %>"
                          readonly>
                      </div>

                    </div>
                  </div>

                  <div class="card-body">
                    <div class="table-responsive">
                      <% if (user.role==="user" ) { %>


                        <table class="table table-bordered text-center align-middle" id="productsTable">
                          <thead class="thead-light">
                            <tr>
                              <th rowspan="2">Code article</th>
                              <th rowspan="2">Désignations</th>
                              <th rowspan="2">Reference</th>
                              <th rowspan="2">Unité</th>
                              <th rowspan="2">Quantité</th>
                              <th colspan="2">Date de livraison</th>
                              <th rowspan="2">Imputation</th>
                              <th rowspan="2">Recommandations et Observations</th>
                              <th rowspan="2">Validation</th>
                              <th rowspan="2">Validé Par</th>
                              <th rowspan="2">Image</th>
                              <th rowspan="2">Actions</th>
                            </tr>
                            <tr>
                              <th>Au plus tôt</th>
                              <th>Au plus tard</th>
                            </tr>
                          </thead>
                          <tbody>
                            <% demandeFourniture.items.forEach((item, idx)=> { %>
                              <tr data-index="<%= idx %>" data-item-id="<%= item.id %>">
                                <!-- Inputs WITHOUT name -->

                                <td class="cell-code"><input type="text" class="form-control code"
                                    value="<%= item.code ?? '' %>"></td>
                                <td class="cell-designation"><input type="text"
                                    class="form-control designation designation-input"
                                    value="<%= item.designation ?? '' %>" autocomplete="off"></td>
                                <td class="cell-lot"><input type="text" class="form-control lot lot-input"
                                    value="<%= item.lot ?? '' %>" autocomplete="off"></td>
                                <td class="cell-unite"><input type="text" class="form-control unite"
                                    value="<%= item.unité ?? '' %>"></td>
                                <td class="cell-quantite"><input type="number" class="form-control quantite"
                                    value="<%= item.quantité ?? '' %>" min="1"></td>
                                <td><input type="date" class="form-control auPlutot"
                                    value="<%= item.auPlutot ? new Date(item.auPlutot).toISOString().split('T')[0] : '' %>">
                                </td>
                                <td><input type="date" class="form-control auPlutart"
                                    value="<%= item.auPlutart ? new Date(item.auPlutart).toISOString().split('T')[0] : '' %>">
                                </td>
                                <td><input type="text" class="form-control imputation"
                                    value="<%= item.imputation ?? '' %>"></td>

                                <td class="cell-observation"><input type="text" class="form-control observation"
                                    value="<%= item.observation ?? '' %>"></td>

                                <!-- Hidden fields -->
                                <input type="hidden" class="itemId" value="<%= item.id %>">
                                <input type="hidden" class="tempImage" value="<%= item.image || '' %>">

                                <!-- Validation -->
                                <td class="validation-cell">
                                  <% if (item.validation===true && item.validepar) { %>
                                    <span class="badge badge-success">Validée</span>
                                    <% } else if (item.validation===false && item.validepar) { %>
                                      <span class="badge badge-danger">Refusée</span>
                                      <% } else { %>
                                        <span class="badge badge-secondary">En attente</span>
                                        <% } %>
                                </td>

                                <td class="validerPar-cell">
                                  <%= item.validepar || '-' %>
                                </td>

                                <!-- Image Column -->
                                <td class="text-center">
                                  <% if (item.image) { %>
                                    <img src="<%= item.image %>" style="max-height:32px;cursor:pointer;"
                                      class="img-thumbnail ml-2" onclick="window.open('<%= item.image %>', '_blank')">
                                    <% } else { %>
                                      <span class="text-muted">Aucune image</span>
                                      <% } %>

                                        <div class="d-flex justify-content-center mt-2">
                                          <img class="img-thumbnail ml-2 previewImg d-none"
                                            style="max-height:32px;cursor:pointer;">
                                        </div>
                                </td>

                                <!-- Actions -->
                                <td>
                                  <div class="d-flex align-items-center gap-2">
                                    <% if (item.image) { %>
                                      <a href="/achat/fourniture/<%= item.id %>/download-image"
                                        class="btn btn-sm btn-info downloadBtn" data-item-id="<%= item.id %>"
                                        target="_blank">
                                        <i class="fas fa-download"></i>
                                      </a>
                                      <% } else { %>
                                        <a href="#" class="btn btn-sm btn-secondary downloadBtn d-none"
                                          data-item-id="<%= item.id %>" target="_blank">
                                          <i class="fas fa-download"></i>
                                        </a>
                                        <% } %>
                                          <button type="button" class="btn btn-sm btn-primary uploadBtn"
                                            data-item-id="<%= item.id %>">
                                            <i class="fas fa-upload"></i>
                                          </button>
                                          <input type="file" class="d-none uploadInput" accept="image/*">
                                          <input type="hidden" class="tempImage" value="<%= item.image || '' %>">
                                          <button type="button" class="btn btn-sm btn-danger deleteRow">
                                            <i class="fas fa-trash"></i>
                                          </button>
                                  </div>
                                </td>
                              </tr>
                              <% }) %>
                          </tbody>
                        </table>

                        <% } else if ((user.role==="grandadmin" || user.role==="admin" ) && user.name !=="CONFONDA" ) {
                          %>
                          <!-- Admin validation view -->
                          <input type="hidden" name="demandeFournitureId" value="<%= demandeFourniture.id %>">

                          <div class="d-flex justify-content-end mb-2">
                            <button type="button" id="btnValiderAll" class="btn btn-success">Valider Tout</button>
                          </div>

                          <table class="table table-bordered text-center align-middle" id="productsTable">
                            <thead class="thead-light">
                              <tr>
                                <th rowspan="2">Code article</th>
                                <th rowspan="2">Désignations</th>
                                <th rowspan="2">Reference</th>
                                <th rowspan="2">Unité</th>
                                <th rowspan="2">Quantité</th>
                                <th colspan="2">Date de livraison</th>
                                <th rowspan="2">Imputation</th>
                                <th rowspan="2">Recommandations et Observations</th>
                                <th rowspan="2">Validation</th>
                                <th rowspan="2">Validé Par</th>
                                <th rowspan="2"> Image</th>
                                <th rowspan="2">Prix Ht</th>
                                <th rowspan="2">Total Ht</th>
                                <th rowspan="2">Action </th>
                              </tr>
                              <tr>
                                <th>Au plus tôt</th>
                                <th>Au plus tard</th>
                              </tr>
                            </thead>

                            <tbody>
                              <% demandeFourniture.items.forEach((item, idx)=> { %>
                                <tr data-item-id="<%= item.id %>">
                                  <td class="cell-code"><input type="hidden" value="<%= item.id %>">
                                    <input type="text" class="form-control" value="<%= item.code ?? '' %>">
                                  </td>

                                  <td class="cell-designation"><input type="text" class="form-control designation-input"
                                      value="<%= item.designation ?? '' %>" autocomplete="off"></td>
                                  <td class="cell-lot"><input type="text" class="form-control lot-input"
                                      value="<%= item.lot ?? '' %>" autocomplete="off"></td>
                                  <td class="cell-unite"><input type="text" class="form-control"
                                      value="<%= item.unité ?? '' %>"></td>
                                  <td class="cell-quantite"><input type="number" class="form-control"
                                      value="<%= item.quantité ?? '' %>" min="1"></td>
                                  <td><input type="date" class="form-control"
                                      value="<%= item.auPlutot ? new Date(item.auPlutot).toISOString().split('T')[0] : '' %>">
                                  </td>
                                  <td><input type="date" class="form-control"
                                      value="<%= item.auPlutart ? new Date(item.auPlutart).toISOString().split('T')[0] : '' %>">
                                  </td>
                                  <td><input type="text" class="form-control" value="<%= item.imputation ?? '' %>"></td>
                                  <td class="cell-observation"><input type="text" class="form-control"
                                      value="<%= item.observation ?? '' %>"></td>

                                  <td class="validation-cell text-center align-middle">
                                    <div class="d-flex flex-column align-items-center gap-1">
                                      <!-- Badge -->
                                      <% if (item.validation===true && item.validepar) { %>
                                        <span class="badge badge-success">Validée</span>
                                        <% } else if (item.validation===false && item.validepar) { %>
                                          <span class="badge badge-danger">Refusée</span>
                                          <% } else { %>
                                            <span class="badge badge-secondary">En attente</span>
                                            <% } %>
                                              <br>

                                              <!-- Dropdown for validation -->
                                              <div class="d-flex align-items-center gap-2 mt-1">
                                                <select class="form-control form-control-sm validation-dropdown"
                                                  id="validation-<%= item.id %>" data-id="<%= item.id %>"
                                                  style="width: 120px;">
                                                  <option value="null" <%=item.validation===null ||
                                                    item.validation===undefined ? 'selected' : '' %>>En attente</option>
                                                  <option value="1" <%=item.validation===true ? 'selected' : '' %>
                                                    >Validé</option>
                                                  <option value="0" <%=item.validation===false ? 'selected' : '' %>
                                                    >Refusé</option>
                                                </select>
                                              </div>
                                    </div>
                                  </td>

                                  <td class="validerPar-cell">
                                    <%= item.validepar || '-' %>
                                  </td>
                                  <td class="text-center">
                                    <% if (item.image) { %>
                                      <img src="<%= item.image %>" style="max-height:32px;cursor:pointer;"
                                        class="img-thumbnail ml-2" onclick="window.open('<%= item.image %>', '_blank')">
                                      <% } else { %>
                                        <span class="text-muted">Aucune image</span>
                                        <% } %>

                                          <div class="d-flex justify-content-center mt-2">
                                            <img class="img-thumbnail ml-2 previewImg d-none"
                                              style="max-height:32px;cursor:pointer;">
                                          </div>
                                  </td>
                                  <td class="cell-prixu text-right">
                                    <%= (Number(item.prixU ?? 0)).toLocaleString('fr-FR', { minimumFractionDigits: 2,
                                      maximumFractionDigits: 2 }) %>
                                  </td>
                                  <td class="cell-totalht text-right">
                                    <%= (Number(item.totalHt ?? 0)).toLocaleString('fr-FR', { minimumFractionDigits: 2,
                                      maximumFractionDigits: 2 }) %>
                                  </td>
                                  <td>
                                    <div class="d-flex align-items-center gap-2">
                                      <% if (item.image) { %>
                                        <a href="/achat/fourniture/<%= item.id %>/download-image"
                                          class="btn btn-sm btn-info downloadBtn" target="_blank">
                                          <i class="fas fa-download"></i>
                                        </a>
                                        <% } else { %>
                                          <a href="#" class="btn btn-sm btn-secondary downloadBtn d-none"
                                            target="_blank">
                                            <i class="fas fa-download"></i>
                                          </a>
                                          <% } %>
                                            <button type="button" class="btn btn-sm btn-primary uploadBtn"
                                              data-item-id="<%= item.id %>">
                                              <i class="fas fa-upload"></i>
                                            </button>
                                            <input type="file" class="d-none uploadInput" accept="image/*">
                                            <input type="hidden" class="tempImage" value="<%= item.image || '' %>">
                                            <button type="button" class="btn btn-sm btn-danger deleteRow">
                                              <i class="fas fa-trash"></i>
                                            </button>
                                    </div>
                                  </td>
                                </tr>
                                <% }) %>
                            </tbody>
                          </table>

                          <% } else if (user.role==="grandadmin" && user.name==="CONFONDA" ) { %>
                            <!-- ====== CONFONDA: Convertir en Devis / Bon de Commande ====== -->
                            <div class="d-flex justify-content-end align-items-center gap-2 mb-3 mt-3">
                              <!-- Filter Delais Paiement -->
                              <select class="form-control delaisPaiement" style="width: auto; max-width: 200px;"
                                id="filterDelaisPaiement">
                                <option value="">Tous les délais</option>
                                <option value="à vue">À vue</option>
                                <option value="30 jours">30 jours</option>
                                <option value="60 jours">60 jours</option>
                                <option value="90 jours">90 jours</option>
                                <option value="120 jours">120 jours</option>
                              </select>

                              <button type="button" id="btnSavePricing" class="btn btn-success">Sauvgarder</button>

                              <div class="dropdown">

                                <button class="btn btn-primary dropdown-toggle" type="button" id="convertirDropdown"
                                  data-toggle="dropdown" aria-haspopup="true" aria-expanded="false">
                                  Convertir
                                </button>
                                <div class="dropdown-menu dropdown-menu-right" aria-labelledby="convertirDropdown">
                                  <a class="dropdown-item" href="#" id="convertToDevisBtn">Convertir en devis</a>
                                  <a class="dropdown-item" id="convertToBonCommandeBtn" href="#">Convertir en bon de
                                    commande</a>
                                </div>
                              </div>
                            </div>

                            <!-- Tableau CONFONDA (lecture seule) -->
                            <style>
                              .table-wrapper {
                                max-height: 70vh;
                                overflow: auto;
                              }

                              #productsTable {
                                min-width: 1100px;
                              }

                              #productsTable thead th {
                                position: sticky;
                                top: 0;
                                background: #fff;
                                z-index: 3;
                              }

                              #productsTable th,
                              #productsTable td {
                                padding: 6px 8px;
                                font-size: 13px;
                                vertical-align: middle;
                              }

                              .cell-designation {
                                min-width: 280px;
                                white-space: normal;
                              }

                              .details-row td {
                                padding: 12px;
                              }

                              .details-grid {
                                display: grid;
                                grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
                                gap: 12px;
                              }

                              .detail-image {
                                max-height: 90px;
                                cursor: pointer;
                                border-radius: 8px;
                                object-fit: cover;
                              }
                            </style>
                            <div class="table-wrapper">
                              <table class="table table-bordered align-middle text-center" id="confondaTable">
                                <thead>
                                  <tr>
                                    <th>Code</th>
                                    <th>Désignation</th>
                                    <th>Unité</th>
                                    <th>Qté</th>
                                    <th>Prix HT</th>
                                    <th>Total HT</th>
                                    <th>Au plus tôt</th>
                                    <th>Au plus tard</th>
                                    <th>Délais Paiement</th>
                                    <th>Statut</th>
                                    <th></th>
                                  </tr>
                                </thead>

                                <tbody>
                                  <% demandeFourniture.items.forEach((item)=> { %>

                                    <!-- MAIN ROW -->
                                    <tr data-item-id="<%= item.id %>">
                                      <td>
                                        <%= item.code ?? '-' %>
                                      </td>
                                      <td class="text-start cell-designation">
                                        <%= item.designation ?? '-' %>
                                      </td>
                                      <td>
                                        <%= item.unité ?? '-' %>
                                      </td>
                                      <td class="cell-quantite">
                                        <%= item.quantité ?? 0 %>
                                      </td>

                                      <td>
                                        <input type="number" class="form-control form-control-sm prixU" step="0.01"
                                          min="0" value="<%= item.prixU ?? '' %>">
                                      </td>

                                      <td class="text-end">
                                        <span class="itemTotalHt">
                                          <%= Number(item.totalHt ?? 0).toLocaleString('fr-FR', { minimumFractionDigits:
                                            2 }) %>
                                        </span>
                                      </td>

                                      <td class="text-center">
                                        <small>
                                          <%= item.auPlutot ? new Date(item.auPlutot).toLocaleDateString('fr-FR') : '-'
                                            %>
                                        </small>
                                      </td>
                                      <td class="text-center">
                                        <small>
                                          <%= item.auPlutart ? new Date(item.auPlutart).toLocaleDateString('fr-FR')
                                            : '-' %>
                                        </small>
