<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8" />
  <meta http-equiv="X-UA-Compatible" content="IE=edge" />
  <meta name="viewport" content="width=device-width, initial-scale=1, shrink-to-fit=no" />
  <meta name="description" content="Fournisseurs" />
  <meta name="author" content="Confonda" />
  <title>Fournisseurs</title>

  <link href="/vendor/fontawesome-free/css/all.min.css" rel="stylesheet" type="text/css" />
  <link href="https://fonts.googleapis.com/css?family=Nunito:200,300,400,600,700,800,900" rel="stylesheet" />
  <link href="/css/sb-admin-2.min.css" rel="stylesheet" />
</head>

<body id="page-top">
<div id="wrapper">
  <%- include('../../../layouts/sidebar') %>

  <div id="content-wrapper" class="d-flex flex-column">
    <div id="content">
      <%- include('../../../layouts/topbar') %>

      <div class="container-fluid">

        <h1 class="h3 mb-4 text-gray-800">Modifier la Demande de Fournitures</h1>

        <!-- ==== FORM ==== -->
        <form id="demandeForm">
          <div class="card shadow mb-4">
            <div class="card-header py-3">
              <h6 class="m-0 font-weight-bold text-primary">Demande Fournitures</h6>
              <br>
              <div class="d-flex justify-content-between">
                <div class="form-group">
                  <label for="date">Date</label>
                  <input type="text" class="form-control" id="date" name="date"
                         value="<%= demandeFourniture.dateDemande 
                           ? (function(){
                               const d = new Date(demandeFourniture.dateDemande);
                               const day   = String(d.getDate()).padStart(2,'0');
                               const month = String(d.getMonth()+1).padStart(2,'0');
                               const year  = d.getFullYear();
                               return `${day}/${month}/${year}`;
                             })()
                           : '' %>" readonly>
                </div>

                <div class="form-group">
                  <label for="numero">Numéro</label>
                  <input type="number" class="form-control" id="numero" name="numero"
                         value="<%= demandeFourniture.numero %>" readonly>
                </div>

                <div class="form-group">
                  <label for="user">User</label>
                  <input type="text" class="form-control" id="user" name="user"
                         value="<%= demandeFourniture.user.name %>" readonly>
                </div>
              </div>
            </div>

            <div class="card-body">
              <div class="table-responsive">
                <table class="table table-bordered text-center align-middle"
                       id="productsTable" width="100%" cellspacing="0">
                  <thead class="thead-light">
                    <tr>
                      <th rowspan="2">Code article</th>
                      <th rowspan="2">Désignations</th>
                      <th rowspan="2">Unité</th>
                      <th rowspan="2">Quantité</th>
                      <th colspan="2">Date de livraison</th>
                      <th rowspan="2">LOT</th>
                      <th rowspan="2">Recommandations et Observations</th>
                      <th rowspan="2">Actions</th>
                    </tr>
                    <tr>
                      <th>Au plus tôt</th>
                      <th>Au plus tard</th>
                    </tr>
                  </thead>
                  <tbody>
                    <!-- ==== DYNAMIC ROWS FOR EVERY ITEM ==== -->
                    <% demandeFourniture.items.forEach((item, idx) => { %>
                      <tr data-index="<%= idx %>">
                        <td><input type="text"   name="items[<%= idx %>][code]"        class="form-control" value="<%= item.code ?? '' %>"></td>
                        <td><input type="text"   name="items[<%= idx %>][designation]" class="form-control" value="<%= item.designation %>"></td>
                        <td><input type="text"   name="items[<%= idx %>][unité]"       class="form-control" value="<%= item.unité ?? '' %>"></td>
                        <td><input type="number" name="items[<%= idx %>][quantité]"    class="form-control" value="<%= item.quantité %>"></td>
                        <td><input type="date"   name="items[<%= idx %>][auPlutot]"    class="form-control"
                                   value="<%= item.auPlutot ? new Date(item.auPlutot).toISOString().split('T')[0] : '' %>"></td>
                        <td><input type="date"   name="items[<%= idx %>][auPlutart]"   class="form-control"
                                   value="<%= item.auPlutart ? new Date(item.auPlutart).toISOString().split('T')[0] : '' %>"></td>
                        <td><input type="text"   name="items[<%= idx %>][lot]"         class="form-control" value="<%= item.lot ?? '' %>"></td>
                        <td><input type="text"   name="items[<%= idx %>][observation]" class="form-control" value="<%= item.observation ?? '' %>"></td>
                        <td>
                            <div class="d-flex justify-content-center align-items-center">
                                <button type="button" class="btn btn-sm btn-danger deleteRow" id="deleteData">
                                    <i class="fas fa-trash"></i>
                                </button>
                                <button type="button" id="btnAddRow" class="btn btn-success btn-sm ml-2">
                                    <i class="fas fa-plus"></i>
                                </button>
                            </div>
                        </td>
                        </td>
                      </tr>
                    <% }) %>
                  </tbody>
                </table>

                <!-- ==== GLOBAL ADD BUTTON ==== -->
                
              </div>
            </div>
          </div>

          <div class="mb-4 text-right">
            <button type="submit" class="btn btn-primary">Enregistrer la Demande</button>
            <a href="/demande-fourniture" class="btn btn-danger">Annuler</a>
          </div>
        </form>
      </div>
    </div>

    <footer class="sticky-footer bg-white">
      <div class="container my-auto">
        <div class="copyright text-center my-auto">
          <span>Copyright &copy; Your Website 2020</span>
        </div>
      </div>
    </footer>
  </div>
</div>

<a class="scroll-to-top rounded" href="#page-top"><i class="fas fa-angle-up"></i></a>

<script src="/vendor/jquery/jquery.min.js"></script>
<script src="/vendor/bootstrap/js/bootstrap.bundle.min.js"></script>
<script src="/vendor/jquery-easing/jquery.easing.min.js"></script>
<script src="/js/sb-admin-2.min.js"></script>

<script>
  $(function () {
    const $tbody = $('#productsTable tbody');
    let rowIndex = $tbody.find('tr').length;   // start after existing rows

    // ---------- ADD ROW ----------
    $('#btnAddRow').on('click', function () {
      const html = `
        <tr data-index="${rowIndex}">
          <td><input type="text"   name="items[${rowIndex}][code]"        class="form-control"></td>
          <td><input type="text"   name="items[${rowIndex}][designation]" class="form-control"></td>
          <td><input type="text"   name="items[${rowIndex}][unité]"       class="form-control"></td>
          <td><input type="number" name="items[${rowIndex}][quantité]"    class="form-control"></td>
          <td><input type="date"   name="items[${rowIndex}][auPlutot]"    class="form-control"></td>
          <td><input type="date"   name="items[${rowIndex}][auPlutart]"   class="form-control"></td>
          <td><input type="text"   name="items[${rowIndex}][lot]"         class="form-control"></td>
          <td><input type="text"   name="items[${rowIndex}][observation]" class="form-control"></td>
          <td>
            <button type="button" class="btn btn-sm btn-danger deleteRow">
              <i class="fas fa-trash"></i>
            </button>
          </td>
        </tr>`;
      $tbody.append(html);
      rowIndex++;
    });

    // ---------- DELETE ROW ----------
    $tbody.on('click', '.deleteRow', function () {
      $(this).closest('tr').remove();
      reindexRows();
    });

    // ---------- RE-INDEX ----------
    function reindexRows() {
      $tbody.find('tr').each(function (i) {
        $(this).attr('data-index', i);
        $(this).find('input').each(function () {
          const name = $(this).attr('name');
          if (name) {
            const newName = name.replace(/\[\d+\]/, '[' + i + ']');
            $(this).attr('name', newName);
          }
        });
      });
      rowIndex = $tbody.find('tr').length;
    }

    // ---------- FORM SUBMISSION ----------
    $('#demandeForm').on('submit', function (e) {
      e.preventDefault();

      const formData = $(this).serialize();

      $.ajax({
        url: '/achats/fourniture/<%= demandeFourniture.id %>',   // fixed: .id not ._id
        method: 'PUT',
        data: formData,
        success: function () {
          alert('Demande mise à jour avec succès !');
          window.location.href = '/achats/fourniture/' + demandeFourniture.id;   // back to list
        },
        error: function (xhr) {
          const msg = xhr.responseJSON?.error || xhr.statusText;
          alert('Erreur : ' + msg);
        }
      });
    });
    $('#deleteData').on('click', function(){
    if (!confirm('Confirmer la suppression de cette demande ?')) return;

    const $btn = $(this);
    $btn.prop('disabled', true);

    $.ajax({
        url: '/achats/fourniture/<%= demandeFourniture.id %>',
        method: 'DELETE',
        success() {
            alert('Demande supprimée avec succès.');
            window.location.href = '/achats/fourniture/' + demandeFourniture.id;
        },
        error(xhr) {
            const msg = xhr.responseJSON?.error || xhr.statusText || 'Erreur inconnue';
            alert('Erreur : ' + msg);
            $btn.prop('disabled', false);
        }
    });
    });
  });
</script>
</body>
</html>