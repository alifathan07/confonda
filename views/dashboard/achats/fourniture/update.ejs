                          <td>
                      <div class="form-check d-flex justify-content-center">
                        <input 
                          type="checkbox" 
                          class="form-check-input validation-checkbox"
                          id="validation-<%= item.id %>" 
                          data-id="<%= item.id %>"
                          <%= item.validation ? 'checked' : '' %>>
                        <label class="form-check-label" for="validation-<%= item.id %>"></label>
                      </div>
                    </td>

                    <script>
                      document.addEventListener('change', async function (e) {
                        if (e.target.classList.contains('validation-checkbox')) {
                          const itemId = e.target.dataset.id;
                          const validation = e.target.checked;
                          const previousState = !validation;

                          e.target.disabled = true;
                          e.target.nextElementSibling.style.opacity = '0.5';

                          try {
                            const res = await fetch(`/achat/fourniture/${itemId}/validation`, {
                              method: 'PATCH',
                              headers: { 'Content-Type': 'application/json' },
                              body: JSON.stringify({ validation }),
                            });

                            const data = await res.json();

                            if (data.success) {
                              window.location.reload();
                              // Optionally update inline cell (no need reload)
                              const row = e.target.closest('tr');
                              const validerParCell = row.querySelector('.valide-par');
                              if (validerParCell) validerParCell.textContent = data.data.validePar || '-';

                              // Reload page for full refresh (optional)
                              window.location.reload();
                            } else {
                              alert('Erreur : ' + (data.error || 'Erreur inconnue.'));
                              e.target.checked = previousState;
                            }
                          } catch (err) {
                            console.error('Fetch error:', err);
                            alert('Erreur réseau : ' + err.message);
                            e.target.checked = previousState;
                          } finally {
                            e.target.disabled = false;
                            e.target.nextElementSibling.style.opacity = '1';
                          }
                        }
                      });
                      function valideAll() {
                        const demandeId = "<%= demandeFourniture.id %>";
                        fetch(`/achat/fourniture/validate-all/${demandeId}`, {
                          method: 'PATCH',
                          headers: { 'Content-Type': 'application/json' },
