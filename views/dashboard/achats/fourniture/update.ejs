<script>
  $(function () {
    let isUploading = false;

    // 1. Open file dialog
    $(document).on('click', '.uploadBtn', function (e) {
      e.preventDefault();
      e.stopPropagation();

      if (isUploading) return;

      const id = $(this).data('item-id');
      const $input = $(`.uploadInput[data-item-id="${id}"]`);

      if ($input.length) {
        $input.val(''); // allow same file
        setTimeout(() => $input.trigger('click'), 0);
      }
    });

    // 2. Handle file selection + upload
    $(document).on('change', '.uploadInput', function () {
      const input = this;
      const file = input.files[0];
      if (!file) return;

      const id = $(input).data('item-id');
      if (!id) {
        alert('ID manquant.');
        return;
      }

      if (isUploading) return;
      isUploading = true;

      const $btn = $(`.uploadBtn[data-item-id="${id}"]`);
      const $label = $(`.uploaded-filename[data-item-id="${id}"]`);
      $btn.prop('disabled', true);

      const fd = new FormData();
      fd.append('image', file);

      $.ajax({
        url: `/achat/fourniture/${id}/upload-image`,
        method: 'POST',
        data: fd,
        processData: false,
        contentType: false,
        cache: false,
        timeout: 30000,

        success: function (res) {
          if (res.success) {
            const filename = res.data?.image?.split('/').pop() || file.name;
            const imageUrl = res.data?.image;

            // 1. Update filename
            $label.text(filename).attr('title', filename);

            // 2. Show/enable download button
            let $downloadBtn = $(`.downloadBtn[data-item-id="${id}"]`);
            if ($downloadBtn.length === 0) {
              $downloadBtn = $(`
                <a href="/achat/fourniture/${id}/download-image"
                   class="btn btn-sm btn-info ml-2 downloadBtn"
                   data-item-id="${id}"
                   download
                   title="Télécharger l'image">
                  <i class="fas fa-download"></i>
                </a>
              `);
              $btn.after($downloadBtn);
            } else {
              $downloadBtn
                .removeClass('d-none btn-secondary')
                .addClass('btn-info')
                .prop('disabled', false)
                .attr('href', `/achat/fourniture/${id}/download-image`);
            }

            // 3. Show image preview
            let $preview = $(`.previewImg[data-item-id="${id}"]`);
            if ($preview.length === 0) {
              $preview = $(`
                <img class="img-thumbnail ml-2 previewImg d-none"
                     style="max-height:32px; cursor:pointer;"
                     data-item-id="${id}"
                     title="Cliquez pour télécharger">
              `);
              $label.after($preview);
            }
            $preview
              .attr('src', imageUrl)
              .removeClass('d-none')
              .off('click')
              .on('click', () => {
                window.location.href = `/achat/fourniture/${id}/download-image`;
              });

          } else {
            alert('Erreur : ' + (res.error || 'Upload échoué'));
          }
        },

        error: function (xhr) {
          const msg = xhr.responseJSON?.error || 'Erreur upload';
          alert('Erreur : ' + msg);
          console.error('Upload error:', xhr);
        },

        complete: function () {
          isUploading = false;
          $btn.prop('disabled', false);
          input.value = '';
        }
      });
    });
  });
</script>

