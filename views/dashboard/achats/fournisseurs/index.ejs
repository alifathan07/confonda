<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8" />
  <meta http-equiv="X-UA-Compatible" content="IE=edge" />
  <meta name="viewport" content="width=device-width, initial-scale=1, shrink-to-fit=no" />
  <title>Gestion des Fournisseurs | Confonda</title>

  <link href="/vendor/fontawesome-free/css/all.min.css" rel="stylesheet" type="text/css" />
  <link href="https://fonts.googleapis.com/css?family=Nunito:200,300,400,600,700,800,900" rel="stylesheet" />
  <link href="/css/sb-admin-2.min.css" rel="stylesheet" />
  <link href="/vendor/datatables/dataTables.bootstrap4.min.css" rel="stylesheet">
  
  <style>
    :root {
      --primary-color: #4e73df;
      --secondary-color: #858796;
      --success-color: #1cc88a;
      --info-color: #36b9cc;
      --warning-color: #f6c23e;
      --danger-color: #e74a3b;
    }

    .card-header {
      background-color: #f8f9fc;
      border-bottom: 1px solid #e3e6f0;
    }

    .table thead th {
      background-color: #f8f9fc;
      color: #4e73df;
      text-transform: uppercase;
      font-size: 0.8rem;
      letter-spacing: 0.05em;
      border-top: none;
    }

    .supplier-card {
      transition: all 0.2s ease;
      border-left: 4px solid transparent;
    }

    .supplier-card:hover {
      background-color: #f8f9fc;
      border-left: 4px solid var(--primary-color);
    }

    .action-btn {
      width: 32px;
      height: 32px;
      padding: 0;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      border-radius: 6px;
      transition: all 0.2s;
    }

    .email-badge {
      display: inline-block;
      padding: 2px 8px;
      border-radius: 12px;
      background-color: #eaecf4;
      color: #4e73df;
      font-size: 0.75rem;
      margin-right: 4px;
      margin-bottom: 4px;
    }

    .modal-header {
      background: var(--primary-color);
      color: white;
    }

    .modal-header .close {
      color: white;
    }

    .form-section-title {
      font-weight: 700;
      color: var(--primary-color);
      margin-bottom: 15px;
      padding-bottom: 5px;
      border-bottom: 2px solid #eaecf4;
      font-size: 0.9rem;
      text-transform: uppercase;
    }

    .email-list-item {
      display: flex;
      justify-content: space-between;
      align-items: center;
      padding: 8px 12px;
      background: #f8f9fc;
      border-radius: 8px;
      margin-bottom: 8px;
    }
  </style>
</head>

<body id="page-top">
  <div id="wrapper">
    <%- include('../../../layouts/sidebar') %>

    <div id="content-wrapper" class="d-flex flex-column">
      <div id="content">
        <%- include('../../../layouts/topbar') %>

        <div class="container-fluid">
          <div class="d-sm-flex align-items-center justify-content-between mb-4">
            <h1 class="h3 mb-0 text-gray-800">Gestion des Fournisseurs</h1>
            <div class="d-flex gap-2">
              <label for="excelFile" class="btn btn-sm btn-success shadow-sm mr-2 mb-0" style="cursor: pointer;">
                <i class="fas fa-file-excel fa-sm text-white-50"></i> Importer Excel
                <form id="excelUploadForm" enctype="multipart/form-data" style="display:none;">
                  <input type="file" id="excelFile" name="excelFile" accept=".xlsx,.xls">
                </form>
              </label>
              <button onclick="openCreateModal()" class="btn btn-sm btn-primary shadow-sm">
                <i class="fas fa-plus fa-sm text-white-50"></i> Nouveau Fournisseur
              </button>
            </div>
          </div>

          <div class="card shadow mb-4">
            <div class="card-body">
              <div class="table-responsive">
                <table class="table table-hover" id="supplierTable" width="100%" cellspacing="0">
                  <thead>
                    <tr>
                      <th>Fournisseur</th>
                      <th>Contact Principal</th>
                      <th>ICE / IF</th>
                      <th>Emails</th>
                      <th class="text-right">Actions</th>
                    </tr>
                  </thead>
                  <tbody>
                    <% if (typeof suppliers !== 'undefined') { %>
                      <% suppliers.forEach(s => { %>
                        <tr class="supplier-card">
                          <td>
                            <div class="font-weight-bold text-primary"><%= s.name %></div>
                            <div class="small text-gray-600"><%= s.address || 'Pas d\'adresse' %></div>
                          </td>
                          <td>
                            <div class="small"><i class="fas fa-user fa-fw mr-1"></i> <%= s.contact || '—' %></div>
                            <div class="small"><i class="fas fa-phone fa-fw mr-1"></i> <%= s.telFournisseur || '—' %></div>
                          </td>
                          <td>
                            <div class="small"><strong>ICE:</strong> <%= s.ice || '—' %></div>
                            <div class="small"><strong>IF:</strong> <%= s.identifFiscal || '—' %></div>
                          </td>
                          <td>
                            <% if (s.email) { %>
                              <span class="email-badge"><%= s.email %></span>
                            <% } %>
                            <% if (s.emails && s.emails.length) { %>
                              <% s.emails.forEach(e => { %>
                                <span class="email-badge"><%= e.email %></span>
                              <% }) %>
                            <% } %>
                          </td>
                          <td class="text-right">
                            <button onclick="openEditModal(<%= JSON.stringify(s) %>)" class="btn btn-info action-btn" title="Modifier">
                              <i class="fas fa-edit fa-sm"></i>
                            </button>
                            <button onclick="deleteSupplier(<%= s.id %>)" class="btn btn-danger action-btn" title="Supprimer">
                              <i class="fas fa-trash fa-sm"></i>
                            </button>
                          </td>
                        </tr>
                      <% }) %>
                    <% } %>
                  </tbody>
                </table>
              </div>
            </div>
          </div>
        </div>
      </div>

      <footer class="sticky-footer bg-white">
        <div class="container my-auto">
          <div class="copyright text-center my-auto">
            <span>Copyright &copy; Confonda 2024</span>
          </div>
        </div>
      </footer>
    </div>
  </div>

  <!-- Supplier Modal -->
  <div class="modal fade" id="supplierModal" tabindex="-1" role="dialog">
    <div class="modal-dialog modal-lg" role="document">
      <div class="modal-content border-0 shadow">
        <div class="modal-header">
          <h5 class="modal-title" id="modalTitle">Nouveau Fournisseur</h5>
          <button type="button" class="close" data-dismiss="modal"><span>&times;</span></button>
        </div>
        <form id="supplierForm">
          <input type="hidden" id="supplierId">
          <div class="modal-body">
            <div class="row">
              <div class="col-md-6">
                <div class="form-section-title">Informations Générales</div>
                <div class="form-group">
                  <label class="small font-weight-bold">Nom du Fournisseur *</label>
                  <input type="text" class="form-control form-control-sm" id="name" required>
                </div>
                <div class="form-group">
                  <label class="small font-weight-bold">Adresse</label>
                  <textarea class="form-control form-control-sm" id="address" rows="2"></textarea>
                </div>
                <div class="row">
                  <div class="col-6">
                    <div class="form-group">
                      <label class="small font-weight-bold">ICE</label>
                      <input type="text" class="form-control form-control-sm" id="ice">
                    </div>
                  </div>
                  <div class="col-6">
                    <div class="form-group">
                      <label class="small font-weight-bold">Identifiant Fiscal</label>
                      <input type="text" class="form-control form-control-sm" id="idF">
                    </div>
                  </div>
                </div>
              </div>
              <div class="col-md-6">
                <div class="form-section-title">Coordonnées & Banque</div>
                <div class="row">
                  <div class="col-6">
                    <div class="form-group">
                      <label class="small font-weight-bold">Téléphone</label>
                      <input type="text" class="form-control form-control-sm" id="phone">
                    </div>
                  </div>
                  <div class="col-6">
                    <div class="form-group">
                      <label class="small font-weight-bold">Contact</label>
                      <input type="text" class="form-control form-control-sm" id="contact">
                    </div>
                  </div>
                </div>
                <div class="form-group">
                  <label class="small font-weight-bold">RIB</label>
                  <input type="text" class="form-control form-control-sm" id="rib">
                </div>
                <div class="row">
                  <div class="col-6">
                    <div class="form-group">
                      <label class="small font-weight-bold">Banque</label>
                      <input type="text" class="form-control form-control-sm" id="banque">
                    </div>
                  </div>
                  <div class="col-6">
                    <div class="form-group">
                      <label class="small font-weight-bold">Agence</label>
                      <input type="text" class="form-control form-control-sm" id="agence">
                    </div>
                  </div>
                </div>
              </div>
            </div>

            <div class="row mt-3">
              <div class="col-12">
                <div class="form-section-title d-flex justify-content-between align-items-center">
                  Gestion des Emails
                  <button type="button" onclick="addEmailField()" class="btn btn-xs btn-success py-0 px-2" style="font-size: 0.7rem;">
                    <i class="fas fa-plus"></i> Ajouter Email
                  </button>
                </div>
                <div class="form-group">
                  <label class="small font-weight-bold">Email Principal</label>
                  <input type="email" class="form-control form-control-sm" id="email" placeholder="exemple@domaine.com">
                </div>
                <div id="additionalEmailsContainer">
                  <!-- Secondary emails will be loaded here -->
                </div>
              </div>
            </div>
          </div>
          <div class="modal-footer bg-light">
            <button type="button" class="btn btn-secondary btn-sm" data-dismiss="modal">Annuler</button>
            <button type="submit" class="btn btn-primary btn-sm px-4">Enregistrer</button>
          </div>
        </form>
      </div>
    </div>
  </div>

  <script src="/vendor/jquery/jquery.min.js"></script>
  <script src="/vendor/bootstrap/js/bootstrap.bundle.min.js"></script>
  <script src="/vendor/datatables/jquery.dataTables.min.js"></script>
  <script src="/vendor/datatables/dataTables.bootstrap4.min.js"></script>

  <script>
    $(document).ready(function() {
      $('#supplierTable').DataTable({
        language: {
          url: '//cdn.datatables.net/plug-ins/1.10.24/i18n/French.json'
        },
        order: [[0, 'asc']]
      });

      $('#excelFile').on('change', function() {
        const formData = new FormData($('#excelUploadForm')[0]);
        $.ajax({
          url: '/achats/fournisseurs/import',
          type: 'POST',
          data: formData,
          processData: false,
          contentType: false,
          success: function(res) {
            alert('Importation réussie');
            location.reload();
          },
          error: function() { alert('Erreur lors de l\'importation'); }
        });
      });

      $('#supplierForm').on('submit', function(e) {
        e.preventDefault();
        const id = $('#supplierId').val();
        const data = {
          name: $('#name').val(),
          email: $('#email').val(),
          address: $('#address').val(),
          phone: $('#phone').val(),
          contact: $('#contact').val(),
          contactphone: $('#contactphone').val(), // Note: add this field if needed
          ice: $('#ice').val(),
          idF: $('#idF').val(),
          rib: $('#rib').val(),
          banque: $('#banque').val(),
          agence: $('#agence').val()
        };

        const method = id ? 'PATCH' : 'POST';
        const url = id ? `/achats/fournisseurs/${id}` : '/achats/fournisseurs/create';

        $.ajax({
          url: url,
          type: method,
          contentType: 'application/json',
          data: JSON.stringify(data),
          success: async function(res) {
            // If it's a new supplier, we need the ID to save additional emails
            const supplierId = id || res.id;
            
            // Save additional emails (simplified logic: we handle it here or in a separate call)
            // For now, let's just reload to keep it simple, but we could add email sync logic here
            alert('Enregistré avec succès');
            location.reload();
          },
          error: function() { alert('Erreur lors de l\'enregistrement'); }
        });
      });
    });

    function openCreateModal() {
      $('#modalTitle').text('Nouveau Fournisseur');
      $('#supplierId').val('');
      $('#supplierForm')[0].reset();
      $('#additionalEmailsContainer').empty();
      $('#supplierModal').modal('show');
    }

    function openEditModal(s) {
      $('#modalTitle').text('Modifier ' + s.name);
      $('#supplierId').val(s.id);
      $('#name').val(s.name);
      $('#email').val(s.email);
      $('#address').val(s.address);
      $('#phone').val(s.telFournisseur);
      $('#contact').val(s.contact);
      $('#ice').val(s.ice);
      $('#idF').val(s.identifFiscal);
      $('#rib').val(s.rib);
      $('#banque').val(s.banque);
      $('#agence').val(s.agence);

      // Load additional emails
      $('#additionalEmailsContainer').empty();
      if (s.emails && s.emails.length) {
        s.emails.forEach(e => {
          renderEmailItem(e);
        });
      }
      $('#supplierModal').modal('show');
    }

    function renderEmailItem(e) {
      const html = `
        <div class="email-list-item" id="email-row-${e.id}">
          <span class="small font-weight-bold">${e.email}</span>
          <button type="button" onclick="deleteEmail(${e.id})" class="btn btn-link text-danger p-0">
            <i class="fas fa-trash-alt fa-sm"></i>
          </button>
        </div>
      `;
      $('#additionalEmailsContainer').append(html);
    }

    async function addEmailField() {
      const supplierId = $('#supplierId').val();
      if (!supplierId) {
        alert('Veuillez d\'abord enregistrer le fournisseur');
        return;
      }
      const email = prompt('Entrez la nouvelle adresse email :');
      if (email && email.includes('@')) {
        $.post(`/achats/fournisseurs/${supplierId}/emails`, { email: email }, function(res) {
          location.reload(); // Simple reload to refresh data
        });
      }
    }

    async function deleteEmail(emailId) {
      if (confirm('Supprimer cet email ?')) {
        $.ajax({
          url: `/achats/fournisseurs/emails/${emailId}`,
          type: 'DELETE',
          success: function() {
            $(`#email-row-${emailId}`).remove();
          }
        });
      }
    }

    function deleteSupplier(id) {
      if (confirm('Voulez-vous vraiment supprimer ce fournisseur ?')) {
        $.ajax({
          url: `/achats/fournisseurs/${id}`,
          type: 'DELETE',
          success: function() { location.reload(); },
          error: function() { alert('Erreur lors de la suppression'); }
        });
      }
    }
  </script>
</body>
</html>
