<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta http-equiv="X-UA-Compatible" content="IE=edge" />
  <meta name="viewport" content="width=device-width, initial-scale=1, shrink-to-fit=no" />
  <meta name="description" content="Clients" />
  <meta name="author" content="Confonda" />
  <title>Clients</title>
  <link href="/vendor/fontawesome-free/css/all.min.css" rel="stylesheet" type="text/css" />
  <link href="https://fonts.googleapis.com/css?family=Nunito:200,300,400,600,700,800,900" rel="stylesheet" />
  <link href="/css/sb-admin-2.min.css" rel="stylesheet" />
  <style>
    /* Your custom styles */
    .custom-btn {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      font-weight: 600;
      font-size: 14px;
      padding: 6px 12px;
      border-radius: 6px;
      border: none;
      transition: all 0.2s ease-in-out;
    }
    .custom-btn i { font-size: 13px; }
    .btn-primary.custom-btn { background-color: #007bff; color: white; }
    .btn-secondary.custom-btn { background-color: #6c757d; color: white; }
    .excel-delete-btn { background: transparent; color: #dc3545; border: none; cursor: pointer; }
    .excel-delete-btn:hover { color: #bd2130; }
    .excel-table { width: 100%; border-collapse: collapse; }
    .excel-table th, .excel-table td {
      border: 1px solid #dee2e6;
      padding: 8px;
      text-align: center;
    }
    .excel-table thead th {
      background-color: #f8f9fa;
      font-weight: bold;
    }
    .excel-table tbody tr:nth-child(even) { background-color: #f2f2f2; }
    .excel-table tbody tr:hover { background-color: #e9ecef; }
  </style>
</head>
<body id="page-top">
  <div id="wrapper">
    <%- include('../../../layouts/sidebar') %>
    <div id="content-wrapper" class="d-flex flex-column">
      <div id="content">
        <%- include('../../../layouts/topbar') %>

        <div class="container-fluid">

          <!-- Page Heading -->
          <div class="d-flex justify-content-between align-items-center mb-4">
            <h1 class="h3 mb-0 text-gray-800">Clients</h1>
            <a href="/ventes/clients/new" class="btn btn-success custom-btn">
              <i class="fas fa-plus"></i> Nouveau Client
            </a>
          </div>

          <!-- Clients Table -->
          <div class="card shadow mb-4">
            <div class="card-body">
              <div class="table-responsive">
                <table class="excel-table">
                  <thead>
                    <tr>
                      <th>Nom</th>
                      <th>ICE</th>
                      <th>Contact</th>
                      <th>Téléphone</th>
                      <th>Actions</th>
                    </tr>
                  </thead>
                  <tbody>
                   <% clients.forEach(client => { %>
                      <tr>
                          <td><%= client.name %></td>
                          <td><%= client.ice %></td>
                          <td><%= client.contact %></td>
                          <td><%= client.telClient ? client.telClient : (client.telContact ? client.telContact : "Non renseigné") %></td>
                          <td style="display: flex; gap: 5px; align-items: center;">
                            <a href="/ventes/clients/<%= client.id %>" class="btn btn-primary btn-sm custom-btn">
                              <i class="fas fa-eye"></i> Voir
                            </a>
                            <a href="/ventes/clients/<%= client.id %>/edit" class="btn btn-secondary btn-sm custom-btn">
                              <i class="fas fa-edit"></i> Modifier
                            </a>
                            <form id="deleteForm_<%= client.id %>" 
                              action="/ventes/clients/<%= client.id %>/?_method=DELETE" 
                              method="post" 
                              style="margin: 0;">
                          <button type="button" 
                                  class="excel-delete-btn" 
                                  onclick="confirm('Voulez-vous vraiment supprimer ce client ?') 
                                    ? fetch(this.parentNode.action, { method: 'DELETE' })
                                        .then(res => { window.location.reload(); }) 
                                    : null">
                            <i class="fas fa-trash"></i>
                          </button>
                        </form>
                        
                          </td>
                      </tr>
                   <% }) %>
                  
             
                    
                  </tbody>
                </table>
              </div>
            </div>
          </div>

        </div>
      </div>
    </div>
  </div>
</body>
</html>
