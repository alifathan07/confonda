<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Users</title>
  <!-- Enhanced Styling -->
  <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" rel="stylesheet">
  <link href="https://cdnjs.cloudflare.com/ajax/libs/bootstrap/5.3.0/css/bootstrap.min.css" rel="stylesheet">
 
</head>

<body>
  <div id="wrapper" class="d-flex">
    <%- include('../../layouts/sidebar') %>
      <div id="content-wrapper" class="d-flex flex-column bg-light min-vh-100 w-100">

        <div class="container-fluid py-4">
          <div class="d-flex align-items-center justify-content-between mb-4">
            <div>
              <h3 class="mb-1 fw-bold">Settings</h3>
              <div class="text-muted">Gestion des notifications WhatsApp</div>
            </div>
            <div class="d-flex gap-2">
              <a class="btn btn-outline-dark" href="/dashboard">
                <i class="fa-solid fa-arrow-left"></i>
                Dashboard
              </a>
            </div>
          </div>

          <div class="row g-4">
            <div class="col-12 col-lg-4">
              <div class="card shadow-sm border-0">
                <div class="card-body p-4">
                  <div class="d-flex align-items-center gap-3 mb-3">
                    <div class="rounded-circle d-flex align-items-center justify-content-center" style="width: 44px; height: 44px; background: rgba(13,110,253,.12); color: #0d6efd;">
                      <i class="fa-brands fa-whatsapp"></i>
                    </div>
                    <div>
                      <div class="fw-bold">Ajouter un destinataire</div>
                      <div class="text-muted" style="font-size: 0.9rem;">Numéro + types de notifications</div>
                    </div>
                  </div>

                  <form method="POST" action="/settings/whatsapp-recipients" class="mt-3">
                    <div class="mb-3">
                      <label for="phone" class="form-label fw-semibold">Numéro</label>
                      <input id="phone" name="phone" class="form-control" placeholder="+2126..." required>
                      <div class="form-text">Tu peux coller avec +, espaces, etc. (le serveur normalise).</div>
                    </div>

                    <div class="mb-3">
                      <div class="fw-semibold mb-2">Notifications</div>
                      <div class="form-check">
                        <input class="form-check-input" type="checkbox" id="notifyCaisse" name="notifyCaisse" checked>
                        <label class="form-check-label" for="notifyCaisse">Demande Caisse</label>
                      </div>
                      <div class="form-check">
                        <input class="form-check-input" type="checkbox" id="notifyJustiffecaisse" name="notifyJustiffecaisse" checked>
                        <label class="form-check-label" for="notifyJustiffecaisse">Justif Caisse</label>
                      </div>
                      <div class="form-check">
                        <input class="form-check-input" type="checkbox" id="notifyFourniture" name="notifyFourniture" checked>
                        <label class="form-check-label" for="notifyFourniture">Demande Fourniture</label>
                      </div>
                      <div class="form-check">
                        <input class="form-check-input" type="checkbox" id="active" name="active" checked>
                        <label class="form-check-label" for="active">Actif</label>
                      </div>
                    </div>

                    <button type="submit" class="btn btn-primary w-100">
                      <i class="fa-solid fa-plus"></i>
                      Ajouter
                    </button>
                  </form>
                </div>
              </div>

              <div class="card shadow-sm border-0 mt-4">
                <div class="card-body p-4">
                  <div class="fw-bold mb-2">Règles</div>
                  <div class="text-muted" style="font-size: 0.95rem; line-height: 1.5;">
                    - Un destinataire peut recevoir:
                    <div class="mt-2">
                      <span class="badge text-bg-primary">Caisse</span>
                      <span class="badge text-bg-dark">Fourniture</span>
                      <span class="badge text-bg-success">Actif</span>
                    </div>
                    <div class="mt-3">
                      Les demandes enverront automatiquement le PDF + message vers les numéros actifs.
                    </div>
                  </div>
                </div>
              </div>
            </div>

            <div class="col-12 col-lg-8">
              <div class="card shadow-sm border-0">
                <div class="card-body p-0">
                  <div class="p-4 border-bottom d-flex align-items-center justify-content-between">
                    <div>
                      <div class="fw-bold">Destinataires</div>
                      <div class="text-muted" style="font-size: 0.9rem;">Active / Caisse / Fourniture</div>
                    </div>
                    <div class="text-muted" style="font-size: 0.9rem;">
                      Total: <span class="fw-semibold"><%= (recipients || []).length %></span>
                    </div>
                  </div>

                  <div class="table-responsive">
                    <table class="table align-middle mb-0">
                      <thead class="table-light">
                        <tr>
                          <th class="px-4">Numéro</th>
                          <th class="text-center">Caisse</th>
                          <th class="text-center">Justif Caisse</th>
                          <th class="text-center">Fourniture</th>
                          <th class="text-center">Actif</th>
                          <th class="text-end px-4">Actions</th>
                        </tr>
                      </thead>
                      <tbody>
                        <% if (!recipients || recipients.length === 0) { %>
                          <tr>
                            <td colspan="6" class="text-center text-muted py-5">
                              Aucun numéro configuré.
                            </td>
                          </tr>
                        <% } %>

                        <% (recipients || []).forEach((r) => { %>
                          <tr>
                            <td class="px-4">
                              <div class="d-flex align-items-center gap-3">
                                <div class="rounded-circle d-flex align-items-center justify-content-center" style="width: 38px; height: 38px; background: rgba(37,211,102,.12); color: #25D366;">
                                  <i class="fa-brands fa-whatsapp"></i>
                                </div>
                                <div>
                                  <div class="fw-semibold"><%= r.phone %></div>
                                  <div class="text-muted" style="font-size: 0.85rem;">ID: <%= r.id %></div>
                                </div>
                              </div>
                            </td>

                            <td class="text-center">
                              <form method="POST" action="/settings/whatsapp-recipients/<%= r.id %>">
                                <input type="hidden" name="notifyJustiffecaisse" value="<%= r.notifyJustiffecaisse ? 'on' : '' %>">
                                <input type="hidden" name="notifyFourniture" value="<%= r.notifyFourniture ? 'on' : '' %>">
                                <input type="hidden" name="active" value="<%= r.active ? 'on' : '' %>">
                                <div class="form-check form-switch d-inline-flex align-items-center">
                                  <input class="form-check-input" type="checkbox" role="switch" id="caisse_<%= r.id %>" name="notifyCaisse" <%= r.notifyCaisse ? 'checked' : '' %> onchange="this.form.submit()">
                                </div>
                              </form>
                            </td>

                            <td class="text-center">
                              <form method="POST" action="/settings/whatsapp-recipients/<%= r.id %>">
                                <input type="hidden" name="notifyCaisse" value="<%= r.notifyCaisse ? 'on' : '' %>">
                                <input type="hidden" name="notifyFourniture" value="<%= r.notifyFourniture ? 'on' : '' %>">
                                <input type="hidden" name="active" value="<%= r.active ? 'on' : '' %>">
                                <div class="form-check form-switch d-inline-flex align-items-center">
                                  <input class="form-check-input" type="checkbox" role="switch" id="justifcaisse_<%= r.id %>" name="notifyJustiffecaisse" <%= r.notifyJustiffecaisse ? 'checked' : '' %> onchange="this.form.submit()">
                                </div>
                              </form>
                            </td>

                            <td class="text-center">
                              <form method="POST" action="/settings/whatsapp-recipients/<%= r.id %>">
                                <input type="hidden" name="notifyCaisse" value="<%= r.notifyCaisse ? 'on' : '' %>">
                                <input type="hidden" name="notifyJustiffecaisse" value="<%= r.notifyJustiffecaisse ? 'on' : '' %>">
                                <input type="hidden" name="active" value="<%= r.active ? 'on' : '' %>">
                                <div class="form-check form-switch d-inline-flex align-items-center">
                                  <input class="form-check-input" type="checkbox" role="switch" id="fourniture_<%= r.id %>" name="notifyFourniture" <%= r.notifyFourniture ? 'checked' : '' %> onchange="this.form.submit()">
                                </div>
                              </form>
                            </td>

                            <td class="text-center">
                              <form method="POST" action="/settings/whatsapp-recipients/<%= r.id %>">
                                <input type="hidden" name="notifyCaisse" value="<%= r.notifyCaisse ? 'on' : '' %>">
                                <input type="hidden" name="notifyJustiffecaisse" value="<%= r.notifyJustiffecaisse ? 'on' : '' %>">
                                <input type="hidden" name="notifyFourniture" value="<%= r.notifyFourniture ? 'on' : '' %>">
                                <div class="form-check form-switch d-inline-flex align-items-center">
                                  <input class="form-check-input" type="checkbox" role="switch" id="active_<%= r.id %>" name="active" <%= r.active ? 'checked' : '' %> onchange="this.form.submit()">
                                </div>
                              </form>
                            </td>

                            <td class="text-end px-4">
                              <form method="POST" action="/settings/whatsapp-recipients/<%= r.id %>/delete" onsubmit="return confirm('Supprimer ce numéro ?')" class="d-inline">
                                <button type="submit" class="btn btn-sm btn-outline-danger">
                                  <i class="fa-solid fa-trash"></i>
                                </button>
                              </form>
                            </td>
                          </tr>
                        <% }) %>
                      </tbody>
                    </table>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
  </div>

  <!-- Scripts -->
  <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
  <script src="https://cdnjs.cloudflare.com/ajax/libs/bootstrap/5.3.0/js/bootstrap.bundle.min.js"></script>
  <script src="https://cdn.jsdelivr.net/npm/axios/dist/axios.min.js"></script>
 
</body>

</html>