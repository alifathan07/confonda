// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id       Int    @id @default(autoincrement())
  email    String @unique
  password String
  name     String @unique

  JustifCaisse JustifCaisse[]

  demandeCaisse     DemandeCaisse[]
  demandeFourniture DemandeFourniture[]
  bugReports        BugReport[]
  createdPopups     Popup[]             // Popups created by this user
  role              String              @default("grandadmin") // user, admin, grandadmin, developer
  popupEnabled      Boolean             @default(true) // For user-specific popup control
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt
}

model DemandeCaisse {
  id           Int       @id @default(autoincrement())
  designation  String? /// e.g. "Caisse Mois ..."
  numero       Int?
  montantTotal Float?
  dateDemande  DateTime?
  demandeur    String?
  color        String?
  // Relations
  userId       Int
  user         User      @relation(fields: [userId], references: [id])

  chantierId Int?
  chantier   Chantier? @relation(fields: [chantierId], references: [id])
  status     String    @default("En Attente") // Versée , Annulée , En Attente

  items ItemCaisse[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // ✅ numero unique per user
  @@unique([userId, numero])
}

model ItemCaisse {
  id              Int            @id @default(autoincrement())
  dateCaisse      DateTime?
  designation     String?
  montant         Float?
  imputation      String?
  validation      String         @default("En cours") // En cours , Refusée , Validée
  responsable     String?
  demandeCaisseId Int?
  validepar       String?
  demandeCaisse   DemandeCaisse? @relation(fields: [demandeCaisseId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model DemandeFourniture {
  id          Int       @id @default(autoincrement())
  numero      Int?
  dateDemande DateTime?
  demandeur   String?
  color       String?

  // Relations
  userId Int
  user   User @relation(fields: [userId], references: [id])

  chantierId Int?
  chantier   Chantier?        @relation(fields: [chantierId], references: [id])
  status     String           @default("En Attente") // En Attente // Commandé // Livré // Annulé
  etat       String?
  items      ItemFourniture[]
  totalHt    Float?
  Tva        Float?
  totalTTC   Float?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // ✅ numero unique per user
  @@unique([userId, numero])
}

model ItemFourniture {
  id          Int     @id @default(autoincrement())
  code        String?
  designation String
  unité      String?

  imputation     String?
  quantité      String?
  auPlutart      String?
  auPlutot       String?
  lot            String?
  observation    String?
  validation     Boolean?
  image          String? // <-- ✅ image file path
  // En cours , Refusée , Validée
  validepar      String?
  prixU          Float?
  totalHt        Float?
  delaisPaiement String?

  demandeFournitureId Int?
  demandeFourniture   DemandeFourniture? @relation(fields: [demandeFournitureId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model JustifCaisse {
  id             Int     @id @default(autoincrement())
  mois           Int // 1-12
  annee          Int
  designation    String? // e.g. "Justification Caisse Mars 2025"
  soldePrecedent Float?  @default(0)
  totalRecettes  Float?  @default(0)
  totalDepenses  Float?  @default(0)
  soldeFinal     Float?  @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  userId Int
  user   User @relation(fields: [userId], references: [id])

  // Relations
  chantierId Int?
  chantier   Chantier? @relation(fields: [chantierId], references: [id])

  // Demandes de caisse versées du mois précédent

  recettes RecetteCaisse[]
  depenses DepenseCaisse[]

  @@index([userId, annee(sort: Desc), mois(sort: Desc)])
}

model RecetteCaisse {
  id             Int          @id @default(autoincrement())
  source         String? // Ex: "Demande Caisse #12 - Mars"
  montant        Float?
  dateRecette    DateTime?    @default(now())
  userId         Int
  justifCaisseId Int
  justifCaisse   JustifCaisse @relation(fields: [justifCaisseId], references: [id])
}

model DepenseCaisse {
  id                 Int       @id @default(autoincrement())
  natureDepense      String?
  montantJustifie    Float?
  montantNonJustifie Float?
  observation        String?
  dateDepense        DateTime? @default(now())
  numeroPiece        String?
  imputation         String?

  justifCaisseId Int
  justifCaisse   JustifCaisse @relation(fields: [justifCaisseId], references: [id])
  validation     Boolean?     @default(true)
  validerPar     String?
}

model Attestation {
  id             Int         @id @default(autoincrement())
  fournisseur    Fournisseur @relation(fields: [fournisseurId], references: [id])
  fournisseurId  Int
  date           DateTime
  dateValidite   DateTime
  status         String // e.g. "pending", "valid", "invalid"
  demandeEnvoyee Boolean     @default(false)
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt
}

model Affectation {
  id       Int    @id @default(autoincrement())
  chantier String
  montant  Float
}

model Fournisseur {
  id                    Int                     @id @default(autoincrement())
  name                  String
  email                 String?
  ice                   String
  rib                   String
  agence                String?
  banque                String?
  objet                 String?
  identifFiscal         String
  telFournisseur        String
  contact               String
  telContact            String
  address               String?
  attestations          Attestation[] // One-to-many: a supplier can have many attestations
  demandeandfournisseur demandeandfournisseur[]

  prelevements           Prelevement[]
  cheques                Cheque[]
  commandes              BondeCommande[]
  effets                 Effet[]
  telepaimentPrelevement TelepaimentPrelevement[]

  payavenir Payavenir[]
  virements Virement[]

  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  bondeLivraisons BondeLivraison[]
  factures Facture[]
  facturesAvoir FactureAvoir[]

}

model Cheque {
  id                Int       @id @default(autoincrement())
  montant           Float?
  dateEtablissement DateTime?
  dateEcheance      DateTime?
  statut            String

  dateReglement DateTime?
  fournisseur   Fournisseur @relation(fields: [fournisseurId], references: [id])
  fournisseurId Int
  beneficiaire  String
  validation    Boolean?    @default(false)
  banque        Banque      @relation("BanqueCheques", fields: [banqueId], references: [id])
  banqueId      Int
  chantier      Chantier?   @relation("ChequesChantier", fields: [chantierId], references: [id])
  chantierId    Int?

  numero String // remove the @unique here ❌

  obs            String?
  montantLettres String?
  ville          String?
  allocations    ChequeAllocation[]
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt

  @@unique([banqueId, numero]) // ✅ compound unique constraint
}

// Add this new model
model ChequeAllocation {
  id         Int      @id @default(autoincrement())
  cheque     Cheque   @relation(fields: [chequeId], references: [id], onDelete: Cascade)
  chequeId   Int
  chantier   Chantier @relation(fields: [chantierId], references: [id])
  chantierId Int
  montant    Float

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Effet {
  id                Int         @id @default(autoincrement())
  montant           Float?
  dateEtablissement DateTime?
  dateEcheance      DateTime?
  statut            String // en circulation, payé, impayé, annulé
  // dateReglement is the date when the cheque was actually paid. NULL if it has not been paid yet.
  dateReglement     DateTime?
  fournisseur       Fournisseur @relation(fields: [fournisseurId], references: [id])
  fournisseurId     Int
  beneficiaire      String // beneficiaire
  validation        Boolean?    @default(false)

  banque         Banque            @relation("BanqueEffets", fields: [banqueId], references: [id])
  banqueId       Int
  chantier       Chantier?         @relation("EffetsChantier", fields: [chantierId], references: [id])
  chantierId     Int?
  numero         String // ✅ Add this line if it's not already
  obs            String?
  dateaujou      DateTime?
  montantLettres String?
  ville          String?
  allocations    EffetAllocation[]
  // facture             Facture? @relation(fields: [factureId], references: [id])
  // factureId           Int?
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt

  @@unique([banqueId, numero]) // ✅ compound unique constraint
}

model EffetAllocation {
  id         Int      @id @default(autoincrement())
  effet      Effet    @relation(fields: [effetId], references: [id], onDelete: Cascade)
  effetId    Int
  chantier   Chantier @relation(fields: [chantierId], references: [id])
  chantierId Int
  montant    Float

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Prelevement {
  id              Int         @id @default(autoincrement())
  fournisseur     Fournisseur @relation(fields: [fournisseurId], references: [id])
  fournisseurId   Int
  dateEcheance    DateTime
  montant         Float
  dateFinEcheance DateTime?
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
}

model Payavenir {
  id            Int       @id @default(autoincrement())
  designation   String?
  beneficiaire  String? // beneficiaire
  montant       Float?
  dateEcheance  DateTime?
  statut        String?
  dateReglement DateTime?
  obs           String?
  validation    Boolean?  @default(false)

  fournisseur   Fournisseur @relation(fields: [fournisseurId], references: [id])
  fournisseurId Int

  banque       Banque    @relation("BanquePayavenir", fields: [banqueId], references: [id])
  banqueId     Int
  chantier     Chantier? @relation("PayavenirChantier", fields: [chantierId], references: [id])
  chantierId   Int?
  chantierText String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
}

model Recavenir {
  id            Int       @id @default(autoincrement())
  designation   String?
  beneficiaire  String? // beneficiaire
  montant       Float?
  dateEcheance  DateTime?
  statut        String?
  dateReglement DateTime?
  obs           String?
  client        Client    @relation(fields: [clientId], references: [id])
  clientId      Int
  chantier      Chantier? @relation("RecavenirChantier", fields: [chantierId], references: [id])
  chantierId    Int?
  banque        Banque    @relation("BanqueRecavenir", fields: [banqueId], references: [id])
  banqueId      Int
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model Virement {
  id             Int                  @id @default(autoincrement())
  designation    String?
  beneficiaire   String? // beneficiaire
  montant        Float?
  date           DateTime?
  dateReglement  DateTime?
  obs            String?
  objet          String?
  cause          String?
  rtgs           Boolean              @default(false)
  srbm           Boolean              @default(false)
  instantane     Boolean              @default(false)
  rib            Int?
  montantLettres String?
  fournisseur    Fournisseur?         @relation(fields: [fournisseurId], references: [id])
  fournisseurId  Int?
  banque         Banque               @relation("BanqueVirements", fields: [banqueId], references: [id])
  banqueId       Int
  chantier       Chantier?            @relation("VirementsChantier", fields: [chantierId], references: [id])
  chantierId     Int?
  allocations    VirementAllocation[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// Add this new model
model VirementAllocation {
  id         Int      @id @default(autoincrement())
  virement   Virement @relation(fields: [virementId], references: [id], onDelete: Cascade)
  virementId Int
  chantier   Chantier @relation(fields: [chantierId], references: [id])
  chantierId Int
  montant    Float

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Miseadis {
  id             Int                          @id @default(autoincrement())
  beneficiaire   String? // beneficiaire
  montant        Float?
  date           DateTime?
  dateReglement  DateTime?
  obs            String?
  cin            String?
  objet          String?
  cause          String?
  montantLettres String?
  banque         Banque                       @relation("BanqueMiseadis", fields: [banqueId], references: [id])
  banqueId       Int
  chantier       Chantier?                    @relation("MiseadisChantier", fields: [chantierId], references: [id])
  chantierId     Int?
  allocations    MiseADispositionAllocation[]
  createdAt      DateTime                     @default(now())
  updatedAt      DateTime                     @updatedAt
}

model MiseADispositionAllocation {
  id         Int      @id @default(autoincrement())
  miseadis   Miseadis @relation(fields: [miseadisId], references: [id], onDelete: Cascade)
  miseadisId Int
  chantier   Chantier @relation(fields: [chantierId], references: [id])
  chantierId Int
  montant    Float

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Banque {
  id                     Int                      @id @default(autoincrement())
  name                   String
  rib                    String
  agence                 String
  solde                  Float
  dateSolde              DateTime
  positive               Float                    @default(0.0)
  negative               Float                    @default(0.0)
  dmlt                   Float                    @default(0.0)
  cheques                Cheque[]                 @relation("BanqueCheques")
  effets                 Effet[]                  @relation("BanqueEffets")
  payavenir              Payavenir[]              @relation("BanquePayavenir")
  recavenir              Recavenir[]              @relation("BanqueRecavenir")
  virements              Virement[]               @relation("BanqueVirements")
  miseadis               Miseadis[]               @relation("BanqueMiseadis")
  encaissementRecu       EncaissementRecu[]       @relation("BanqueEncaissementRecu")
  telepaimentPrelevement TelepaimentPrelevement[] @relation("BanqueTelepaimentPrelevement")
  createdAt              DateTime                 @default(now())
  updatedAt              DateTime                 @updatedAt
}

model Client {
  id               Int                @id @default(autoincrement())
  name             String
  email            String?
  ice              String             @unique
  identifFiscal    String
  telClient        String
  contact          String
  telContact       String
  address          String?
  recavenir        Recavenir[]
  chantier         Chantier[]         @relation("ClientChantier")
  encaissementRecu EncaissementRecu[]
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt
}

model Caisse {
  id          Int      @id @default(autoincrement())
  // Mois représenté sous forme "2025-09-01" (on prend le 1er jour du mois pour simplifier)
  month       DateTime
  ancienSolde Decimal  @default(0)
  allocation  Decimal  @default(0)
  // Calcul du disponible se fait au backend, pas stocké (ou tu peux le stocker en cache si tu veux)

  // Relation
  chantier   Chantier @relation(fields: [chantierId], references: [id])
  chantierId Int

  // Dépenses liées à ce mois

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([chantierId, month]) // Un seul enregistrement par chantier + mois
}

model ChantierItem {
  id            Int     @id @default(autoincrement())
  natureTravaux String
  numPrix       String?
  designation   String
  unite         String?
  qte           Float
  prixUnitaire  Float
  totalHt       Float

  chantierId Int
  chantier   Chantier @relation(fields: [chantierId], references: [id])
}

// Demande Fourniture : 

model DemandeProduit {
  id          Int       @id @default(autoincrement())
  designation String
  quantite    Int
  unite       String?
  dateTot     DateTime?
  dateTard    DateTime?
  qteDemandee Int?
  qteStockee  Int?
  qtePrevue   Int?
  qteRecue    Int?
  lot         String?
  observation String?
  codeArticle String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model TelepaimentPrelevement {
  id                Int         @id @default(autoincrement())
  dateEtablissement DateTime
  banque            Banque      @relation("BanqueTelepaimentPrelevement", fields: [banqueId], references: [id])
  banqueId          Int
  montant           Float
  chantier          Chantier?   @relation("TelepaimentPrelevementChantier", fields: [chantierId], references: [id])
  chantierId        Int?
  observation       String?
  fournisseur       Fournisseur @relation(fields: [fournisseurId], references: [id])
  fournisseurId     Int
  type              String?
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt
}

model EncaissementRecu {
  id                Int       @id @default(autoincrement())
  dateEtablissement DateTime
  banque            Banque    @relation("BanqueEncaissementRecu", fields: [banqueId], references: [id])
  banqueId          Int
  montant           Float
  chantier          Chantier? @relation("EncaissementRecuChantier", fields: [chantierId], references: [id])
  chantierId        Int?
  client            Client    @relation(fields: [clientId], references: [id])
  clientId          Int
  nDeFactureRG      String?
  RG                String?
  Ras_TVA           String?
  Autres            String?
  ResteAPayer       String?
  observation       String?
  type              String?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
}

// 

model DemandeDePrix {
  id                    Int                     @id @default(autoincrement())
  date                  DateTime                @default(now())
  articles              Article[]
  devisPath             String? // PDF path
  sentByEmail           Boolean                 @default(false)
  demandeandfournisseur demandeandfournisseur[]
  createdAt             DateTime                @default(now())
  updatedAt             DateTime                @updatedAt
}

model demandeandfournisseur {
  id              Int           @id @default(autoincrement())
  demandeDePrixId Int
  demandeDePrix   DemandeDePrix @relation(fields: [demandeDePrixId], references: [id])
  fournisseurId   Int
  fournisseur     Fournisseur   @relation(fields: [fournisseurId], references: [id])
  emailSentAt     DateTime?
  status          String? // envoyer , en attent 
  etat            String? // en cours , accepter , refuser

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Article {
  id              Int            @id @default(autoincrement())
  designation     String
  reference       String?
  unite           String
  quantite        Int
  prixUnitaire    Float?
  totalHt         Float?
  delaiLivraison  String?
  observation     String?
  demandeDePrix   DemandeDePrix? @relation(fields: [demandeDePrixId], references: [id])
  demandeDePrixId Int?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
}

model Chantier {
  id                        Int                         @id @default(autoincrement())
  nom                       String                      @unique
  objet                     String?
  montantContratHt          Float?
  natureContrat             String?
  numContrat                String?
  recavenir                 Recavenir[]                 @relation("RecavenirChantier")
  encaissementRecu          EncaissementRecu[]          @relation("EncaissementRecuChantier")
  telepaimentPrelevement    TelepaimentPrelevement[]    @relation("TelepaimentPrelevementChantier")
  BondeCommandeChantierItem BondeCommandeChantierItem[]

  clientId Int?
  client   Client? @relation("ClientChantier", fields: [clientId], references: [id])

  // Relations

  demandeCaisse DemandeCaisse[]
  bondeCommande BondeCommande[]

  demandes            DemandeFourniture[]
  JustifCaisse        JustifCaisse[]
  items               ChantierItem[] // 🔥 chantier has many invoice-like items
  chequeAllocations   ChequeAllocation[] // Add this line
  virementAllocations VirementAllocation[] // Add this line
  effetAllocations    EffetAllocation[]
  miseadisAllocations MiseADispositionAllocation[]

  cheques   Cheque[]    @relation("ChequesChantier")
  effets    Effet[]     @relation("EffetsChantier")
  payavenir Payavenir[] @relation("PayavenirChantier")
  virements Virement[]  @relation("VirementsChantier")
  miseadis  Miseadis[]  @relation("MiseadisChantier")
  caisse    Caisse[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model BondeCommandeChantierItem {
  id              Int            @id @default(autoincrement())
  bondeCommande   BondeCommande  @relation(fields: [bondeCommandeId], references: [id], onDelete: Cascade)
  bondeCommandeId Int
  chantier        Chantier       @relation(fields: [chantierId], references: [id])
  chantierId      Int
  item            commandesItems @relation(fields: [itemId], references: [id])
  itemId          Int
  montant         Float?
  qty             Float?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

  model BondeCommande {
    id                        Int                         @id @default(autoincrement())
    date                      DateTime                    @default(now())
    fournisseur               Fournisseur                 @relation(fields: [fournisseurId], references: [id])
    fournisseurId             Int
    BondeCommandeChantierItem BondeCommandeChantierItem[]
    chantier                  Chantier?                   @relation(fields: [chantierId], references: [id])
    chantierId                Int?
    demandeur                 String?
    commandesItems            commandesItems[]
    totalHt                   Float?
    tauxTva                   Float?
    totalTtc                  Float?
    dateLivraison             String?
    lieuLivraison             String?
    modeReg                   String?
    delaiReg                  String?
    numero                    String?
    montantLettre             String?
    statut                    String   @default("en_attente_bl") // en_attente_bl, partiel, livre, annule
    createdAt                 DateTime                    @default(now())
    updatedAt                 DateTime                    @updatedAt
    bondeLivraisonLinks       BondeLivraisonBondeCommande[]
    factureLinks              FactureBondecommande[]
  }

model commandesItems {
  id                        Int                         @id @default(autoincrement())
  designation               String
  unite                     String
  quantite                  Float
  quantiteRecue             Float @default(0)
  imputation                String?
  prixUnitaire              Float?
  tauxRemise                Float?
  remise                    Float?  
  totalHt                   Float?
  reference                 String?
  bondeCommande             BondeCommande?              @relation(fields: [bondeCommandeId], references: [id], onDelete: Cascade)
  bondeCommandeId           Int?
  BondeCommandeChantierItem BondeCommandeChantierItem[]

  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  bondeLivraisonItems BondeLivraisonItem[]
}

model Fourniture_list {
  id           Int      @id @default(autoincrement())
  designation  String?
  reference    String?
  prixUnitaire Decimal?

  @@unique([designation, reference])
}
model WhatsAppNotificationRecipient {
  id                   Int     @id @default(autoincrement())
  phone                String  @unique
  notifyCaisse         Boolean @default(true)
  notifyJustiffecaisse Boolean @default(true)
  notifyFourniture     Boolean @default(true)

  active Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}



model BondeLivraison {
  id                    Int                           @id @default(autoincrement())
  numero                String
  date                  DateTime                      @default(now())
  dateReception         DateTime?
  fournisseur           Fournisseur                   @relation(fields: [fournisseurId], references: [id])
  fournisseurId         Int
  items                 BondeLivraisonItem[]
  bondeCommandeLinks    BondeLivraisonBondeCommande[]
  factureLinks          FactureBondeLivraison[]       // ✅ moved here from Item
  avoirs                FactureAvoir[]                // ✅ moved here from Item
  status                String                        @default("Actif")
  obs                   String?
  fichier               String?
  createdAt             DateTime                      @default(now())
  updatedAt             DateTime                      @updatedAt
}

model BondeLivraisonBondeCommande {
  id                Int             @id @default(autoincrement())
  bondeLivraison    BondeLivraison  @relation(fields: [bondeLivraisonId], references: [id], onDelete: Cascade)
  bondeLivraisonId  Int
  bondeCommande     BondeCommande   @relation(fields: [bondeCommandeId], references: [id], onDelete: Cascade)
  bondeCommandeId   Int
  createdAt         DateTime        @default(now())

  @@unique([bondeLivraisonId, bondeCommandeId])
}

model BondeLivraisonItem {
  id               Int              @id @default(autoincrement())
  designation      String
  unite            String?
  reference        String?
  quantite         Float
  prixUnitaire     Float?
  obs              String?
  qtyRetourne      Float            @default(0)

  // ✅ only item-level back-relations stay here
  factureItems      FactureItem[]
  factureAvoirItems FactureAvoirItem[]

  commandesItems   commandesItems?  @relation(fields: [commandesItemsId], references: [id])
  commandesItemsId Int?
  bondeLivraison   BondeLivraison   @relation(fields: [bondeLivraisonId], references: [id], onDelete: Cascade)
  bondeLivraisonId Int
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
}

model Facture {
  id            Int      @id @default(autoincrement())
  numero        String
  date          DateTime
  totalHt       Float
  tauxTva       Float
  totalTtc      Float    // totalHt + (totalHt * tauxTva / 100)
  statut        String   @default("en_attente") // en_attente | payee | partielle

  fournisseurId Int
  fournisseur   Fournisseur @relation(fields: [fournisseurId], references: [id])
  fichier               String?
  items               FactureItem[]
  bondeLivraisonLinks FactureBondeLivraison[]
  bondeCommandeLinks  FactureBondecommande[]
  avoirs              FactureAvoir[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model FactureBondeLivraison {
  id               Int            @id @default(autoincrement())
  factureId        Int
  facture          Facture        @relation(fields: [factureId], references: [id], onDelete: Cascade)
  bondeLivraisonId Int
  bondeLivraison   BondeLivraison @relation(fields: [bondeLivraisonId], references: [id], onDelete: Cascade)
  createdAt        DateTime       @default(now())

  @@unique([factureId, bondeLivraisonId])
}

model FactureBondecommande {
  id                 Int            @id @default(autoincrement())
  factureId          Int
  facture            Facture        @relation(fields: [factureId], references: [id], onDelete: Cascade)
  bondeCommandeId    Int
  bondeCommande      BondeCommande  @relation(fields: [bondeCommandeId], references: [id], onDelete: Cascade)
  createdAt          DateTime       @default(now())

  @@unique([factureId, bondeCommandeId])
}

model FactureItem {
  id           Int     @id @default(autoincrement())
  designation  String
  unite        String?
  reference    String?
  quantite     Float
  prixUnitaire Float
  totalHt      Float   // quantite * prixUnitaire

  factureId            Int
  facture              Facture             @relation(fields: [factureId], references: [id], onDelete: Cascade)
  bondeLivraisonItemId Int?
  bondeLivraisonItem   BondeLivraisonItem? @relation(fields: [bondeLivraisonItemId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model FactureAvoir {
  id       Int      @id @default(autoincrement())
  numero   String
  date     DateTime
  type     String   // "retour" | "remise"
  totalHt  Float
  tauxTva  Float
  totalTtc Float    // totalHt + (totalHt * tauxTva / 100)
  raison   String?  // Reason for the avoir

  fournisseurId Int
  fournisseur   Fournisseur       @relation(fields: [fournisseurId], references: [id])
  factureId     Int
  facture       Facture           @relation(fields: [factureId], references: [id])
  bondeLivraisonId Int?
  bondeLivraison   BondeLivraison? @relation(fields: [bondeLivraisonId], references: [id])

  items     FactureAvoirItem[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model FactureAvoirItem {
  id           Int     @id @default(autoincrement())
  designation  String
  unite        String?
  reference    String?
  quantite     Float
  prixUnitaire Float
  totalHt      Float   // quantite * prixUnitaire

  factureAvoirId       Int
  factureAvoir         FactureAvoir        @relation(fields: [factureAvoirId], references: [id], onDelete: Cascade)
  bondeLivraisonItemId Int?
  bondeLivraisonItem   BondeLivraisonItem? @relation(fields: [bondeLivraisonItemId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model BugReport {
  id          Int      @id @default(autoincrement())
  title       String?
  description String?   @db.Text
  status      String?   @default("nouveau") // nouveau, en_cours, resolu, ferme
  priority    String?   @default("moyenne") // basse, moyenne, haute, critique
  category    String?   @default("autre") // ui, fonctionnalite, performance, securite, autre
  userId      Int?
  user        User?    @relation(fields: [userId], references: [id])
  userName    String?
  userEmail   String?
  screenshot  String?  // Path to uploaded screenshot
  url         String?  // Page URL where bug occurred
  resolution  String?  @db.Text // Solution/response from admin
  resolvedAt  DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Popup {
  id          Int       @id @default(autoincrement())
  title       String  
  message     String    @db.Text
  type        String    @default("info") // info, warning, success, error
  status      String    @default("active") // active, done, cancelled
  targetUsers String?   // Comma-separated user IDs (null = all users)
  targetRoles String?   // Comma-separated roles (null = all roles)
  createdBy   Int
  creator     User      @relation(fields: [createdBy], references: [id])
  displayMode String    @default("after_login") // after_login, always, once_only, after_every_action
  showOnce    Boolean   @default(true) // Legacy: Show once per session
  startDate   DateTime  @default(now())
  endDate     DateTime?
  dismissedBy String?   // Comma-separated user IDs who dismissed it
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}